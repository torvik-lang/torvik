            // print raw pointer bits and segfault). i128/u128 results are box ptrs
            // (passed through, typed); narrow/bool results are reinterpreted scalars
            // that echo_stringify recovers via coerce_i64 (ev_ty != "i64"); a plain
            // i64 must be ptrtoint'd here because echo_stringify skips coercion when
            // ev_ty == "i64".
            fixed crt: str = lookup_var_type(nm, var_names, var_types);
            check starts(crt, "fnret:") {
                fixed crtt: str = substr(crt, 6, len(crt));
                check crtt == "void" {
                    echo!(fmt("torvc: codegen error: '{}' returns nothing (void); its result can't be used as a value.", nm));
                    exit(1);

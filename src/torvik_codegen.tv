            check nm == "table_get" && len(args) >= 2 { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_table_get(ptr "), args[0]), str_concat(", ptr ", str_concat(args[1], ")")))); set _tvt: str = "ptr"; check len(first_arg_name) > 0 { fixed _vt: str = table_val_type(lookup_var_type(first_arg_name, var_names, var_types)); check len(_vt) > 0 { _tvt = _vt; } } check int_width(_tvt) > 0 && line_eq(_tvt, "i128") == 0 && line_eq(_tvt, "u128") == 0 { fixed _tiv: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", _tiv), " = ptrtoint ptr "), str_concat(tmp, " to i64"))); fixed _tgn: i64 = tok_peek(tokens, p); check suppress_chain == 0 && (chain_tier6(_tgn) > 0 || is_cmp_op(_tgn) == 1) { set _tgu: i64 = 0; check line_eq(_tvt, "u64") == 1 { _tgu = 1; } chain_tail(tokens, strings, allnames, _tiv, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, _tgu); return; } push(out_val, _tiv); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; } check line_eq(_tvt, "str") == 1 { finish_str_result(tokens, strings, allnames, tmp, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, _tvt); return; }
            check nm == "table_has" && len(args) >= 2 { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call i32 @torvik_table_has(ptr "), args[0]), str_concat(", ptr ", str_concat(args[1], ")")))); fixed thb: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", thb), " = icmp ne i32 "), str_concat(tmp, ", 0"))); push(out_val, thb); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return; }

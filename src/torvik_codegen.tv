apply torvik_lexer;
apply torvik_parser;

df split_words(s: str) -> list<str> {
    set result: list<str> = list_new();
    fixed slen: i64 = len(s);
    set i: i64 = 0;
    set word_start: i64 = 0;
    set in_word: i64 = 0;
    whilst i < slen {
        fixed c: i64 = byte_at(s, i);
        check c == 32 {
            check in_word == 1 {
                push(result, substr(s, word_start, i));
                in_word = 0;
            }
        }
        check c != 32 { check in_word == 0 { word_start = i; in_word = 1; } }
        i += 1;
    }
    check in_word == 1 { push(result, substr(s, word_start, slen)); }
    return result;
}

// torvik_codegen.tv — Full Torvik Codegen written in Torvik
// Stage 5: Parses and compiles real .tv programs


// ─── Helpers ──────────────────────────────────────────────────────────────────

df make_tmp(counter: list<i64>) -> str {
    fixed n: i64 = counter[0];
    counter[0] = n + 1;
    return str_concat("%t", int_to_str(n));
}

df make_label(counter: list<i64>, prefix: str) -> str {
    fixed n: i64 = counter[0];
    counter[0] = n + 1;
    return str_concat(prefix, int_to_str(n));
}

df emit(ir: list<str>, line: str) -> void {
    push(ir, line);
}

// Convert any value to i64
// Uses ptrtoint for ptr values, or add i64 0 for already-i64 values
// In our system, all stored vars are ptr (via inttoptr), so ptrtoint is standard
// Does the temp `val` already hold an i64? Inspect its defining instruction
// in the current function IR. Compensates for partial type tracking so we
// never emit an invalid 'ptrtoint ptr %tN to i64' on a value already i64.
df defines_i64(val: str, ir: list<str>) -> i64 {
    fixed marker: str = str_concat(str_concat("  ", val), " = ");
    set i: i64 = 0;
    whilst i < len(ir) {
        fixed line: str = ir[i];
        check str_contains(line, marker) {
            check str_contains(line, "= add i64 ")  { return 1; }
            check str_contains(line, "= sub i64 ")  { return 1; }
            check str_contains(line, "= mul i64 ")  { return 1; }
            check str_contains(line, "= sdiv i64 ") { return 1; }
            check str_contains(line, "= srem i64 ") { return 1; }
            check str_contains(line, "= ptrtoint ") { return 1; }
            check str_contains(line, "= zext ")     { return 1; }
            check str_contains(line, "= sext ")     { return 1; }
            check str_contains(line, "= call i64 ") { return 1; }
            return 0;
        }
        i += 1;
    }
    return 0;
}

df coerce_i64(val: str, ir: list<str>, ctr: list<i64>) -> str {
    // Already an i64 literal
    check val == "0" || val == "1" { return val; }
    // Check if val is a multi-digit integer literal (no % prefix)
    check len(val) > 0 {
        fixed fc: i64 = byte_at(val, 0);
        check fc >= 48 && fc <= 57 { return val; }  // digit → already i64
    }
    // Already an i64-producing temp → don't re-coerce
    check defines_i64(val, ir) == 1 { return val; }
    fixed tmp: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = ptrtoint ptr "), str_concat(val, " to i64")));
    return tmp;
}

// ─── Sized integer types (i8/i16/i32/u8/u16/u32, plus full-width i64) ──────────
// Width-typed values are stored as a canonical i64: the narrow value sign- or
// zero-extended. add/sub/mul are modular, so canonicalizing the RESULT equals
// canonicalizing each step; and for the <=32-bit widths the canonical rep stays
// inside i63 range, so comparison/division/printing reuse the i64 machinery as-is.
df int_width(ty: str) -> i64 {
    check line_eq(ty, "i8")  == 1 { return 8; }
    check line_eq(ty, "u8")  == 1 { return 8; }
    check line_eq(ty, "i16") == 1 { return 16; }
    check line_eq(ty, "u16") == 1 { return 16; }
    check line_eq(ty, "i32") == 1 { return 32; }
    check line_eq(ty, "u32") == 1 { return 32; }
    check line_eq(ty, "i64") == 1 { return 64; }
    check line_eq(ty, "u64") == 1 { return 64; }
    check line_eq(ty, "i128") == 1 { return 128; }
    check line_eq(ty, "u128") == 1 { return 128; }
    return 0;
}
df int_signed(ty: str) -> i64 {
    check line_eq(ty, "i8")  == 1 { return 1; }
    check line_eq(ty, "i16") == 1 { return 1; }
    check line_eq(ty, "i32") == 1 { return 1; }
    check line_eq(ty, "i64") == 1 { return 1; }
    check line_eq(ty, "i128") == 1 { return 1; }
    return 0;
}
// Re-canonicalize an i64 value to the storage form for type `ty`. A no-op for
// non-sized types and for i64 (already full-width). Narrow widths trunc to iN
// then re-extend (sext for signed, zext for unsigned) — this is the wraparound.
df canonicalize_int(val: str, ty: str, ir: list<str>, ctr: list<i64>) -> str {
    fixed w: i64 = int_width(ty);
    check w == 0 || w >= 64 { return val; }
    fixed iN: str = str_concat("i", int_to_str(w));
    fixed tr: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", tr), " = trunc i64 "), val), " to "), iN));
    fixed ex: str = make_tmp(ctr);
    check int_signed(ty) == 1 {
        emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", ex), " = sext "), iN), str_concat(" ", tr)), " to i64"));
    }
    check int_signed(ty) == 0 {
        emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", ex), " = zext "), iN), str_concat(" ", tr)), " to i64"));
    }
    return ex;
}
// All sized integer types (i8..u64, i128, u128) are now supported. This guard is
// retained as an extension point but currently reserves nothing.
// Range of a sized integer type as [lo, hi] for literal bounds checking. Returns
// 1 and fills lo/hi for a recognized narrow type; returns 0 otherwise. (i64/u64
// span or exceed the i64 range, so they are not bounds-checked here.)
df int_range(ty: str, out_lo: list<i64>, out_hi: list<i64>) -> i64 {
    check line_eq(ty, "i8")  == 1 { push(out_lo, 0 - 128); push(out_hi, 127); return 1; }
    check line_eq(ty, "u8")  == 1 { push(out_lo, 0); push(out_hi, 255); return 1; }
    check line_eq(ty, "i16") == 1 { push(out_lo, 0 - 32768); push(out_hi, 32767); return 1; }
    check line_eq(ty, "u16") == 1 { push(out_lo, 0); push(out_hi, 65535); return 1; }
    check line_eq(ty, "i32") == 1 { push(out_lo, 0 - 2147483648); push(out_hi, 2147483647); return 1; }
    check line_eq(ty, "u32") == 1 { push(out_lo, 0); push(out_hi, 4294967295); return 1; }
    return 0;
}

// u64's max (2^64-1) overflows i64, so its literal bound is checked by comparing
// digit strings rather than toint. Returns 1 if the (non-negative) decimal digit
// string `lit` is <= 18446744073709551615, else 0. Leading zeros are ignored.
df u64_in_range(lit: str) -> i64 {
    return digits_le(lit, "18446744073709551615");
}

// 1 if the decimal digit string `lit` (non-negative, leading zeros ignored) is
// <= `mx`. Used for bounds that overflow i64 (u64, i128, u128).
df digits_le(lit: str, mx: str) -> i64 {
    set i: i64 = 0;
    whilst i < len(lit) - 1 && byte_at(lit, i) == 48 { i += 1; }
    fixed d: str = substr(lit, i, len(lit));
    check len(d) > len(mx) { return 0; }
    check len(d) < len(mx) { return 1; }
    set j: i64 = 0;
    whilst j < len(d) {
        fixed cd: i64 = byte_at(d, j);
        fixed cm: i64 = byte_at(mx, j);
        check cd < cm { return 1; }
        check cd > cm { return 0; }
        j += 1;
    }
    return 1;
}

// i128 literal max (positive; negatives are expressions): 2^127 - 1.
df i128_in_range(lit: str) -> i64 {
    return digits_le(lit, "170141183460469231731687303715884105727");
}
// u128 literal max: 2^128 - 1.
df u128_in_range(lit: str) -> i64 {
    return digits_le(lit, "340282366920938463463374607431768211455");
}

// Convert any value to a printable string ptr for echo / interpolation.
//   val    — the SSA value
//   ev_ty  — the type compile_expr produced ("i64"/"f64"/"i1"/"ptr"/"str"/"list..")
//   eff_ty — the *effective* type used for the formatting decision. For a bare
//            variable this is the declared type, which disambiguates a boxed
//            scalar (printed numerically) from a string (both surface as "ptr").
// Returns a string ptr; non-stringifiable types fall through and print as-is.
df echo_stringify(val: str, ev_ty: str, eff_ty: str, ir: list<str>, ctr: list<i64>) -> str {
    check eff_ty == "i128" || eff_ty == "u128" {
        fixed lv: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", lv), " = call i128 @torvik_i128_load(ptr "), str_concat(val, ")")));
        set fn128: str = "torvik_i128_to_str";
        check eff_ty == "u128" { fn128 = "torvik_u128_to_str"; }
        fixed t128: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat(str_concat("  ", t128), " = call ptr @"), fn128), str_concat("(i128 ", str_concat(lv, ")"))));
        return t128;
    }
    check int_width(eff_ty) > 0 {
        set iv: str = val;
        check ev_ty != "i64" { iv = coerce_i64(val, ir, ctr); }
        fixed t1: str = make_tmp(ctr);
        set fn: str = "torvik_int_to_str";
        check eff_ty == "u64" { fn = "torvik_uint_to_str"; }
        emit(ir, str_concat(str_concat(str_concat(str_concat("  ", t1), " = call ptr @"), fn), str_concat("(i64 ", str_concat(iv, ")"))));
        return t1;
    }
    check eff_ty == "f64" {
        set fv: str = val;
        check ev_ty != "f64" {
            fixed pbits: str = coerce_i64(val, ir, ctr);
            fixed db: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", db), " = bitcast i64 "), str_concat(pbits, " to double")));
            fv = db;
        }
        fixed t2: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", t2), " = call ptr @torvik_float_to_str(double "), str_concat(fv, ")")));
        return t2;
    }
    check eff_ty == "bool" || eff_ty == "i1" {
        set bi: str = val;
        check ev_ty == "i1" { fixed z: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", z), " = zext i1 "), str_concat(val, " to i64"))); bi = z; }
        check ev_ty != "i1" { bi = coerce_i64(val, ir, ctr); }
        fixed t3: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", t3), " = call ptr @torvik_bool_to_str(i64 "), str_concat(bi, ")")));
        return t3;
    }
    check starts(eff_ty, "list") {
        fixed t4: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", t4), " = call ptr @torvik_list_to_str(ptr "), str_concat(val, ")")));
        return t4;
    }
    return val;
}

df join_ir(ir: list<str>) -> str {
    set result: str = "";
    set i: i64 = 0;
    fixed n: i64 = len(ir);
    whilst i < n {
        result = str_concat(result, str_concat(ir[i], "\n"));
        i += 1;
    }
    return result;
}

// ─── String interning ─────────────────────────────────────────────────────────

df intern_str(s: str, gvals: list<str>, gnames: list<str>) -> str {
    set i: i64 = 0;
    whilst i < len(gvals) {
        check line_eq(gvals[i], s) == 1 { return gnames[i]; }
        i += 1;
    }
    fixed n: str = str_concat("@.s", int_to_str(len(gvals)));
    push(gvals, s);
    push(gnames, n);
    return n;
}

// Memory Stage B2: interned string constants carry the same 16-byte refcount
// header as heap strings — [magic "HRTSVROT"][refcount "LATROMMI" = immortal]
// — embedded directly in the constant's bytes. Content is padded to >= 8 bytes
// so torvik_len's 8-byte dispatch read is in-bounds (mirrors torvik_str_alloc).
// All consumers address the BYTES at offset 16; retain/release see IMMORTAL
// and no-op, so literals live in rodata forever: never written, never freed.
// The three sites below (emit_str_ref GEP, global ptr GEPs, constant emission)
// MUST agree on this layout — these helpers are the single source of truth.
df str_const_content(vlen: i64) -> i64 {
    set c: i64 = vlen + 1;
    check c < 8 { c = 8; }
    return c;
}

df str_const_size(vlen: i64) -> i64 {
    // NOTE: a call is not yet a valid chain operand (roadmap: chaining stage 2),
    // so `return str_const_content(vlen) + 16;` silently DROPS the `+ 16` —
    // the old compiler compiled it without complaint and the +16 tokens were
    // skipped. Bind the call result first; var + int is fully supported.
    fixed c: i64 = str_const_content(vlen);
    return c + 16;
}

df str_const_pad(vlen: i64) -> str {
    set p: str = "";
    set k: i64 = vlen + 1;
    whilst k < 8 { p = str_concat(p, "\\00"); k += 1; }
    return p;
}

df emit_str_ref(gname: str, s: str, ir: list<str>, ctr: list<i64>) -> str {
    fixed slen: i64 = str_const_size(len(s));
    fixed tmp: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat(str_concat("  ", tmp), " = getelementptr ["), int_to_str(slen)), " x i8], ptr "), gname), ", i32 0, i32 16"));
    return tmp;
}

// Char-by-char line equality — independent of str== type inference, so it
// works correctly under the self-hosted codegen's partial type tracking.
df line_eq(a: str, b: str) -> i64 {
    fixed la: i64 = len(a);
    check la != len(b) { return 0; }
    set i: i64 = 0;
    whilst i < la {
        check byte_at(a, i) != byte_at(b, i) { return 0; }
        i += 1;
    }
    return 1;
}

// Returns 1 if the IR's last real instruction is a terminator (ret/br/unreachable),
// skipping trailing blank lines and "  ;" comment markers. Used to decide whether a
// basic block needs a synthesized terminator.
df block_terminated(ir: list<str>) -> i64 {
    set i: i64 = len(ir) - 1;
    set last: str = "";
    set found: i64 = 0;
    whilst i >= 0 && found == 0 {
        fixed l: str = ir[i];
        check len(l) > 0 {
            check starts(l, "  ;") { } fallback { last = l; found = 1; }
        }
        i -= 1;
    }
    set term: i64 = 0;
    check starts(last, "  ret ") { term = 1; }
    check starts(last, "  br ") { term = 1; }
    check starts(last, "  unreachable") { term = 1; }
    return term;
}


// Scan a function's IR for "  ; tv.undeffn:NAME:POS" markers (emitted at call sites
// to functions that don't exist) and turn each new NAME into a located error.
// undef_seen dedups across the whole program so a function called many times yields
// one error. POS is a token index; the caller renders it via offsets[POS].
df collect_undef_fns(fn_ir: list<str>, undef_seen: list<str>, e_pos: list<i64>, e_msg: list<str>) -> void {
    set i: i64 = 0;
    whilst i < len(fn_ir) {
        fixed line: str = fn_ir[i];
        check starts(line, "  ; tv.undeffn:") {
            fixed rest: str = substr(line, 15, len(line));
            set ci: i64 = 0;
            set found_c: i64 = 0;
            whilst ci < len(rest) && found_c == 0 {
                check byte_at(rest, ci) == 58 { found_c = 1; } fallback { ci += 1; }
            }
            fixed uname: str = substr(rest, 0, ci);
            fixed upos: i64 = toint(substr(rest, ci + 1, len(rest)));
            set seen: i64 = 0;
            set sj: i64 = 0;
            whilst sj < len(undef_seen) {
                check line_eq(undef_seen[sj], uname) == 1 { seen = 1; }
                sj += 1;
            }
            check seen == 0 {
                push(undef_seen, uname);
                push(e_pos, upos);
                push(e_msg, str_concat(str_concat("call to undefined function '", uname), "' — no function with this name is defined"));
            }
        }
        i += 1;
    }
}

// Scan a function's IR for "  ; tv.undefvar:NAME:POS" markers (reads of variables
// with no slot in this function) and turn each new NAME into a located error.
df collect_undef_vars(fn_ir: list<str>, fn_names: list<str>, undef_seen: list<str>, e_pos: list<i64>, e_msg: list<str>) -> void {
    set i: i64 = 0;
    whilst i < len(fn_ir) {
        fixed line: str = fn_ir[i];
        check starts(line, "  ; tv.unclosedinterp:") {
            fixed ipos: i64 = toint(substr(line, 22, len(line)));
            push(e_pos, ipos);
            push(e_msg, "unclosed interpolation in a string — every '{{' needs a matching '}}' (use '{{{{' to print a literal brace)");
        }
        check starts(line, "  ; tv.undefvar:") {
            fixed rest: str = substr(line, 16, len(line));
            set ci: i64 = 0;
            set found_c: i64 = 0;
            whilst ci < len(rest) && found_c == 0 {
                check byte_at(rest, ci) == 58 { found_c = 1; } fallback { ci += 1; }
            }
            fixed uname: str = substr(rest, 0, ci);
            fixed upos: i64 = toint(substr(rest, ci + 1, len(rest)));
            set seen: i64 = 0;
            set sj: i64 = 0;
            whilst sj < len(undef_seen) {
                check line_eq(undef_seen[sj], uname) == 1 { seen = 1; }
                sj += 1;
            }
            check seen == 0 {
                push(undef_seen, uname);
                push(e_pos, upos);
                // If the name is actually a function, the user likely forgot the call
                // parentheses — give a more useful message than "undefined variable".
                set is_fn: i64 = 0;
                set fj: i64 = 0;
                whilst fj < len(fn_names) {
                    check line_eq(fn_names[fj], uname) == 1 { is_fn = 1; }
                    fj += 1;
                }
                // A name with non-identifier characters only arises from an
                // interpolation like "{x + 1}" (the lexer never produces such an
                // identifier), so report it as an unsupported interpolated expression.
                set uname_bad: i64 = 0;
                set ubi: i64 = 0;
                whilst ubi < len(uname) {
                    fixed ubc: i64 = byte_at(uname, ubi);
                    check (ubc >= 65 && ubc <= 90) || (ubc >= 97 && ubc <= 122) || (ubc >= 48 && ubc <= 57) || ubc == 95 { } fallback { uname_bad = 1; }
                    ubi += 1;
                }
                check uname_bad == 1 {
                    push(e_msg, str_concat(str_concat("can't interpolate '", uname), "' — string interpolation takes a plain variable name, not an expression. Compute it into a variable first, then interpolate that."));
                }
                check uname_bad == 0 && is_fn == 1 {
                    push(e_msg, str_concat(str_concat("'", uname), "' is a function, not a variable — call it with parentheses, e.g. 'name(...)'"));
                }
                check uname_bad == 0 && is_fn == 0 {
                    push(e_msg, str_concat(str_concat("undefined variable '", uname), "' — no variable with this name is in scope"));
                }
            }
        }
        i += 1;
    }
}


df slot_exists(ir: list<str>, slot_line: str) -> i64 {
    set i: i64 = 0;
    whilst i < len(ir) {
        check line_eq(ir[i], slot_line) == 1 { return 1; }
        i += 1;
    }
    return 0;
}

// True if a slot "  %<nm>_slot = ..." is defined anywhere in this function's IR so
// far — i.e. nm is an accessible param, global, or already-declared local. Used to
// detect reads of variables that don't exist in the current function's scope.
df slot_defined(ir: list<str>, nm: str) -> i64 {
    fixed pfx: str = str_concat(str_concat("  %", nm), "_slot = ");
    set i: i64 = 0;
    whilst i < len(ir) {
        check starts(ir[i], pfx) { return 1; }
        i += 1;
    }
    return 0;
}

// ─── Expression compiler ──────────────────────────────────────────────────────

// ── Expression chaining, increment 1: exactly `var OP {int|var}` ───────────
// Minimal wedge in front of the old single-op path. Emits ; CHAIN comments
// (inert to LLVM) so miscompiles are observable via grep. No lists, no tiers.
df chain_tier6(op: i64) -> i64 {
    check op == OP_STAR || op == OP_SLASH || op == OP_PERCENT { return 6; }
    check op == OP_PLUS || op == OP_MINUS { return 5; }
    check op == OP_SHL || op == OP_SHR { return 4; }
    check op == OP_AMP { return 3; }
    check op == OP_CARET { return 2; }
    check op == OP_PIPE { return 1; }
    return 0;
}

df chain_emit_binop1(op: i64, lhs: str, rhs: str, ir: list<str>, ctr: list<i64>, uns: i64) -> str {
    fixed res: str = make_tmp(ctr);
    fixed pre: str = str_concat(str_concat("  ", res), " = ");
    fixed tail: str = str_concat(lhs, str_concat(", ", rhs));
    fixed divf: str = "torvik_div"; fixed modf: str = "torvik_mod"; fixed shrop: str = "ashr i64 ";
    set df2: str = divf; set mf2: str = modf; set sh2: str = shrop;
    check uns == 1 { df2 = "torvik_udiv"; mf2 = "torvik_umod"; sh2 = "lshr i64 "; }
    check op == OP_PLUS    { emit(ir, str_concat(pre, str_concat("add i64 ", tail))); }
    check op == OP_MINUS   { emit(ir, str_concat(pre, str_concat("sub i64 ", tail))); }
    check op == OP_STAR    { emit(ir, str_concat(pre, str_concat("mul i64 ", tail))); }
    check op == OP_SLASH   { emit(ir, str_concat(pre, str_concat(str_concat(str_concat("call i64 @", df2), str_concat("(i64 ", lhs)), str_concat(", i64 ", str_concat(rhs, ")"))))); }
    check op == OP_PERCENT { emit(ir, str_concat(pre, str_concat(str_concat(str_concat("call i64 @", mf2), str_concat("(i64 ", lhs)), str_concat(", i64 ", str_concat(rhs, ")"))))); }
    check op == OP_SHL     { emit(ir, str_concat(pre, str_concat("shl i64 ", tail))); }
    check op == OP_SHR     { emit(ir, str_concat(pre, str_concat(sh2, tail))); }
    check op == OP_AMP     { emit(ir, str_concat(pre, str_concat("and i64 ", tail))); }
    check op == OP_CARET   { emit(ir, str_concat(pre, str_concat("xor i64 ", tail))); }
    check op == OP_PIPE    { emit(ir, str_concat(pre, str_concat("or i64 ", tail))); }
    return res;
}

df lookup_var_type(name: str, var_names: list<str>, var_types: list<str>) -> str {
    // Return the LAST match, not the first. Entries accumulate in declaration
    // order across functions; the current function's params/locals are pushed
    // most recently, so the last match for a name is its innermost (correct)
    // binding. This scopes lookups per-function without truncating the map.
    //
    // Scanning backward and stopping at the first hit finds that innermost binding
    // directly: the current function's locals sit at the tail, so a typical lookup
    // touches only a handful of entries instead of the whole program-wide list
    // (which turned per-reference lookups into an O(N^2) hot path on large inputs).
    set i: i64 = len(var_names) - 1;
    whilst i >= 0 {
        check line_eq(var_names[i], name) == 1 { return var_types[i]; }
        i -= 1;
    }
    return "";
}

// Coarse type "kind" for assignment-compatibility checks: "num" (any integer
// width, f64, or bool), "str", "list", or "other" (bag/table/result, or the
// ambiguous uniform "ptr" — never flagged, to avoid false positives).
df ty_kind(t: str) -> str {
    check line_eq(t, "i64") == 1 { return "num"; }
    check line_eq(t, "u64") == 1 { return "num"; }
    check line_eq(t, "i128") == 1 { return "num"; }
    check line_eq(t, "u128") == 1 { return "num"; }
    check line_eq(t, "f64") == 1 { return "float"; }
    check line_eq(t, "bool") == 1 { return "num"; }
    check line_eq(t, "i1") == 1 { return "num"; }
    check line_eq(t, "i8") == 1 { return "num"; }
    check line_eq(t, "u8") == 1 { return "num"; }
    check line_eq(t, "i16") == 1 { return "num"; }
    check line_eq(t, "u16") == 1 { return "num"; }
    check line_eq(t, "i32") == 1 { return "num"; }
    check line_eq(t, "u32") == 1 { return "num"; }
    check line_eq(t, "str") == 1 { return "str"; }
    check starts(t, "list") { return "list"; }
    return "other";
}

// True if `t` names a valid Torvik value type (any type usable for a variable,
// parameter, or non-void return). `void` is intentionally excluded — it is only
// valid as a return type, handled separately at the return-type validator.
df is_value_type(t: str) -> i64 {
    check line_eq(t, "i64") == 1 { return 1; }
    check line_eq(t, "f64") == 1 { return 1; }
    check line_eq(t, "str") == 1 { return 1; }
    check line_eq(t, "bool") == 1 { return 1; }
    check line_eq(t, "i8") == 1 { return 1; }
    check line_eq(t, "u8") == 1 { return 1; }
    check line_eq(t, "i16") == 1 { return 1; }
    check line_eq(t, "u16") == 1 { return 1; }
    check line_eq(t, "i32") == 1 { return 1; }
    check line_eq(t, "u32") == 1 { return 1; }
    check line_eq(t, "u64") == 1 { return 1; }
    check line_eq(t, "i128") == 1 { return 1; }
    check line_eq(t, "u128") == 1 { return 1; }
    check line_eq(t, "bag") == 1 { return 1; }
    check starts(t, "list<") { return 1; }
    check starts(t, "bag<") { return 1; }
    check starts(t, "table<") { return 1; }
    check starts(t, "result<") { return 1; }
    return 0;
}

// Extract the element type from a "list<ELEM>" type string (e.g. "list<i128>"
// -> "i128", "list<str>" -> "str"). Returns "" if `ty` is not a list type.
// Used by the index-read and push paths to manage 128-bit element boxes and to
// reject ill-typed elements. Handles nested generics by taking everything
// between the first '<' and the final '>'.
df list_elem_type(ty: str) -> str {
    set out: str = "";
    check starts(ty, "list<") {
        fixed n: i64 = len(ty);
        check n > 6 { out = substr(ty, 5, n - 1); }
    }
    return out;
}

// Extract the value type V from a "table<K,V>" annotation (first comma splits
// K from V; the outer '>' is dropped). Returns "" when ty isn't a typed table.
df table_val_type(ty: str) -> str {
    set out: str = "";
    check starts(ty, "table<") {
        fixed n: i64 = len(ty);
        set ci: i64 = 0;
        set i: i64 = 6;
        whilst i < n && ci == 0 {
            check byte_at(ty, i) == 44 { ci = i; }
            i += 1;
        }
        check ci > 0 && n > ci + 1 { out = substr(ty, ci + 1, n - 1); }
    }
    return out;
}

// ── fold_chain6 ──────────────────────────────────────────────────────────────
// Six-tier precedence-climbing arithmetic/bitwise chain, factored out of the
// identifier path so call/index results can feed the same machinery (expression
// chaining stage 2). Starts from a caller-supplied i64 accumulator `chcur_in`
// at position p_in and folds `OP operand` pairs while the next token is a chain
// operator and the operand is foldable. Returns the result i64, plus updated
// p/s/an, via out-params. Stage 1 keeps the original int/plain-var operand
// reader byte-for-byte; stage 2 widens it to call/index operands below.
df fold_chain6(tokens: list<i64>, strings: list<str>, allnames: list<str>, chcur_in: str, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, var_names: list<str>, var_types: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, uns: i64) -> void {
    set chcur: str = chcur_in;
    set p: i64 = p_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    set opnd6: str = "0";
    set op6: i64 = 0;
    set has6: i64 = 0;
    set opnd5: str = "0";
    set op5: i64 = 0;
    set has5: i64 = 0;
    set opnd4: str = "0";
    set op4: i64 = 0;
    set has4: i64 = 0;
    set opnd3: str = "0";
    set op3: i64 = 0;
    set has3: i64 = 0;
    set opnd2: str = "0";
    set op2: i64 = 0;
    set has2: i64 = 0;
    set opnd1: str = "0";
    set op1: i64 = 0;
    set has1: i64 = 0;
    set more: i64 = 1;
    whilst more == 1 {
        fixed nop: i64 = tok_peek(tokens, p);
        fixed tier: i64 = chain_tier6(nop);
        check tier == 0 { more = 0; } fallback {
            fixed nxp: i64 = tok_peek(tokens, p + 1);
            fixed nx2: i64 = tok_peek(tokens, p + 2);
            fixed ni: i64 = 0; check nxp == TOK_INT { ni = 1; }
            fixed nxv: i64 = 0; check nxp == TOK_IDENT && nx2 != PUNCT_LPAREN && nx2 != PUNCT_LBRACKET { nxv = 1; }
            fixed nxcall: i64 = 0; check nxp == TOK_IDENT && nx2 == PUNCT_LPAREN { nxcall = 1; }
            fixed nxidx: i64 = 0; check nxp == TOK_IDENT && nx2 == PUNCT_LBRACKET { nxidx = 1; }
            fixed nxpar: i64 = 0; check nxp == PUNCT_LPAREN { nxpar = 1; }
            check ni == 0 && nxv == 0 && nxcall == 0 && nxidx == 0 && nxpar == 0 { more = 0; } fallback {
                set operand_i: str = "0";
                set simple: i64 = 1;
                check ni == 1 {
                    fixed iv2: str = strings[s];
                    fixed it2: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", it2), " = add i64 0, "), iv2));
                    operand_i = it2; s += 1;
                }
                check nxv == 1 {
                    fixed vn2: str = allnames[an];
                    check line_eq(lookup_var_type(vn2, var_names, var_types), "f64") == 1 {
                        echo!("torvc: codegen error: float operand in an integer expression. Lead the expression with the float (e.g. `x * 2`), or convert with tofloat(...).");
                        exit(1);
                    }
                    fixed vn2ty: str = lookup_var_type(vn2, var_names, var_types);
                    check line_eq(vn2ty, "i128") == 1 || line_eq(vn2ty, "u128") == 1 {
                        echo!("torvc: codegen error: a 128-bit value as a non-leading operand in an i64 expression is not yet supported. Lead the expression with the 128-bit operand (the whole expression is then 128-bit), or convert explicitly.");
                        exit(1);
                    }
                    fixed vt2: str = make_tmp(ctr);
                    fixed vp2: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  ", vt2), " = load ptr, ptr %"), vn2), "_slot, align 8"));
                    emit(ir, str_concat(str_concat(str_concat("  ", vp2), " = ptrtoint ptr "), str_concat(vt2, " to i64")));
                    operand_i = vp2; an += 1;
                }
                check nxcall == 1 || nxidx == 1 || nxpar == 1 {
                    // Stage 2: a call / index / parenthesized expression as a chain
                    // operand. Evaluate the single primary via compile_expr at p+1.
                    // Set the suppression flag so that primary resolves to itself
                    // and does NOT fold the chain we are in the middle of (which
                    // would break precedence, e.g. `a * f(x) + 1`).
                    check len(ctr) > 1 { ctr[1] = 1; }
                    set ev: list<str> = list_new(); set ep: list<i64> = list_new(); set es: list<i64> = list_new(); set ea: list<i64> = list_new(); set ety: list<str> = list_new();
                    compile_expr(tokens, strings, allnames, p + 1, s, an, ir, ctr, gvals, gnames, ev, ep, es, ea, ety, var_names, var_types);
                    fixed evv: str = "0"; check len(ev) > 0 { evv = ev[0]; }
                    fixed evty: str = "ptr"; check len(ety) > 0 { evty = ety[0]; }
                    // It DOES fold a trailing comparison after a call/index. If that
                    // happened (operand came back i1), the user wrote something like
                    // `a + f(x) > b`, whose precedence is ambiguous to this folder.
                    // Refuse loudly rather than silently bind it as `a + (f(x) > b)`.
                    check evty == "i1" {
                        echo!("torvc: codegen error: comparison/boolean inside an arithmetic chain operand. Parenthesize the comparison, e.g. `(a + f(x)) > b`, or bind the call to a local first.");
                        exit(1);
                    }
                    set evi: str = evv; check evty != "i64" { evi = coerce_i64(evv, ir, ctr); }
                    operand_i = evi;
                    check len(es) > 0 { s = es[0]; }
                    check len(ea) > 0 { an = ea[0]; }
                    check len(ep) > 0 { p = ep[0]; }
                    simple = 0;
                }
                check has6 == 1 { chcur = chain_emit_binop1(op6, opnd6, chcur, ir, ctr, uns); has6 = 0; }
                check tier <= 5 && has5 == 1 { chcur = chain_emit_binop1(op5, opnd5, chcur, ir, ctr, uns); has5 = 0; }
                check tier <= 4 && has4 == 1 { chcur = chain_emit_binop1(op4, opnd4, chcur, ir, ctr, uns); has4 = 0; }
                check tier <= 3 && has3 == 1 { chcur = chain_emit_binop1(op3, opnd3, chcur, ir, ctr, uns); has3 = 0; }
                check tier <= 2 && has2 == 1 { chcur = chain_emit_binop1(op2, opnd2, chcur, ir, ctr, uns); has2 = 0; }
                check tier <= 1 && has1 == 1 { chcur = chain_emit_binop1(op1, opnd1, chcur, ir, ctr, uns); has1 = 0; }
                check tier == 6 { opnd6 = chcur; op6 = nop; has6 = 1; }
                check tier == 5 { opnd5 = chcur; op5 = nop; has5 = 1; }
                check tier == 4 { opnd4 = chcur; op4 = nop; has4 = 1; }
                check tier == 3 { opnd3 = chcur; op3 = nop; has3 = 1; }
                check tier == 2 { opnd2 = chcur; op2 = nop; has2 = 1; }
                check tier == 1 { opnd1 = chcur; op1 = nop; has1 = 1; }
                chcur = operand_i;
                check simple == 1 { p += 2; }
            }
        }
    }
    check has6 == 1 { chcur = chain_emit_binop1(op6, opnd6, chcur, ir, ctr, uns); has6 = 0; }
    check has5 == 1 { chcur = chain_emit_binop1(op5, opnd5, chcur, ir, ctr, uns); has5 = 0; }
    check has4 == 1 { chcur = chain_emit_binop1(op4, opnd4, chcur, ir, ctr, uns); has4 = 0; }
    check has3 == 1 { chcur = chain_emit_binop1(op3, opnd3, chcur, ir, ctr, uns); has3 = 0; }
    check has2 == 1 { chcur = chain_emit_binop1(op2, opnd2, chcur, ir, ctr, uns); has2 = 0; }
    check has1 == 1 { chcur = chain_emit_binop1(op1, opnd1, chcur, ir, ctr, uns); has1 = 0; }
    push(out_val, chcur); push(out_pos, p); push(out_si, s); push(out_ani, an);
}

// ── i128/u128 arithmetic chain ─────────────────────────────────────────────────
// A 128-bit value is a heap-box ptr (uniform-ptr model), so it can NEVER ride the
// i64 chain: coerce_i64 would ptrtoint the box address. These three helpers are a
// parallel path that loads operands to native LLVM `i128` SSA values, emits native
// i128 ops, and (for arithmetic) re-boxes the result. Signedness is lead-operand
// driven (uns), exactly like u64. Mixed i128/i64 operands are a CLEAN error, never
// a silent coercion.

df chain_emit_binop1_i128(op: i64, lhs: str, rhs: str, ir: list<str>, ctr: list<i64>, uns: i64) -> str {
    fixed res: str = make_tmp(ctr);
    fixed pre: str = str_concat(str_concat("  ", res), " = ");
    fixed tail: str = str_concat(lhs, str_concat(", ", rhs));
    fixed divf: str = "torvik_i128_div"; fixed modf: str = "torvik_i128_mod"; fixed shrop: str = "ashr i128 ";
    set df2: str = divf; set mf2: str = modf; set sh2: str = shrop;
    check uns == 1 { df2 = "torvik_u128_div"; mf2 = "torvik_u128_mod"; sh2 = "lshr i128 "; }
    check op == OP_PLUS    { emit(ir, str_concat(pre, str_concat("add i128 ", tail))); }
    check op == OP_MINUS   { emit(ir, str_concat(pre, str_concat("sub i128 ", tail))); }
    check op == OP_STAR    { emit(ir, str_concat(pre, str_concat("mul i128 ", tail))); }
    check op == OP_SLASH   { emit(ir, str_concat(pre, str_concat(str_concat(str_concat("call i128 @", df2), str_concat("(i128 ", lhs)), str_concat(", i128 ", str_concat(rhs, ")"))))); }
    check op == OP_PERCENT { emit(ir, str_concat(pre, str_concat(str_concat(str_concat("call i128 @", mf2), str_concat("(i128 ", lhs)), str_concat(", i128 ", str_concat(rhs, ")"))))); }
    check op == OP_SHL     { emit(ir, str_concat(pre, str_concat("shl i128 ", tail))); }
    check op == OP_SHR     { emit(ir, str_concat(pre, str_concat(sh2, tail))); }
    check op == OP_AMP     { emit(ir, str_concat(pre, str_concat("and i128 ", tail))); }
    check op == OP_CARET   { emit(ir, str_concat(pre, str_concat("xor i128 ", tail))); }
    check op == OP_PIPE    { emit(ir, str_concat(pre, str_concat("or i128 ", tail))); }
    return res;
}

// Read ONE i128 operand at position p (the operand token itself). int literal ->
// `add i128 0, <lit>` (LLVM takes arbitrary-precision i128 immediates); 128-bit var
// -> load box ptr then torvik_i128_load. Any other operand (i64 var, call, index,
// paren, float) is a clean mixed-operand error. Pushes updated p/s/an; returns the
// i128 SSA.
df read_i128_operand(tokens: list<i64>, strings: list<str>, allnames: list<str>, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, var_names: list<str>, var_types: list<str>, out_p: list<i64>, out_s: list<i64>, out_an: list<i64>) -> str {
    set p: i64 = p_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    fixed t1: i64 = tok_peek(tokens, p);
    fixed t2: i64 = tok_peek(tokens, p + 1);
    check t1 == TOK_INT {
        fixed iv: str = strings[s];
        fixed it: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", it), " = add i128 0, "), iv));
        s += 1; p += 1;
        push(out_p, p); push(out_s, s); push(out_an, an);
        return it;
    }
    check t1 == TOK_IDENT && t2 != PUNCT_LPAREN && t2 != PUNCT_LBRACKET {
        fixed vn: str = allnames[an];
        fixed vty: str = lookup_var_type(vn, var_names, var_types);
        check line_eq(vty, "i128") == 1 || line_eq(vty, "u128") == 1 {
            fixed vt: str = make_tmp(ctr);
            fixed vp: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat(str_concat("  ", vt), " = load ptr, ptr %"), vn), "_slot, align 8"));
            emit(ir, str_concat(str_concat(str_concat("  ", vp), " = call i128 @torvik_i128_load(ptr "), str_concat(vt, ")")));
            an += 1; p += 1;
            push(out_p, p); push(out_s, s); push(out_an, an);
            return vp;
        }
        echo!("torvc: codegen error: mixed 128-bit and non-128-bit operands in one expression are not yet supported. Use 128-bit variables (or integer literals) throughout, or convert explicitly.");
        exit(1);
    }
    echo!("torvc: codegen error: unsupported operand in a 128-bit expression. v1.0 supports 128-bit variables and integer literals; calls, indexes, and parenthesized sub-expressions are not yet foldable in a 128-bit chain.");
    exit(1);
    push(out_p, p); push(out_s, s); push(out_an, an);
    return "0";
}

// Six-tier precedence-climbing chain for i128/u128. Structurally identical to
// fold_chain6 (same has6..has1 / tier folding), but the accumulator and operands
// are native i128 and ops go through chain_emit_binop1_i128. Operand reading is
// delegated to read_i128_operand (literals + 128-bit vars only).
df fold_chain6_i128(tokens: list<i64>, strings: list<str>, allnames: list<str>, chcur_in: str, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, var_names: list<str>, var_types: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, uns: i64) -> void {
    set chcur: str = chcur_in;
    set p: i64 = p_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    set opnd6: str = "0"; set op6: i64 = 0; set has6: i64 = 0;
    set opnd5: str = "0"; set op5: i64 = 0; set has5: i64 = 0;
    set opnd4: str = "0"; set op4: i64 = 0; set has4: i64 = 0;
    set opnd3: str = "0"; set op3: i64 = 0; set has3: i64 = 0;
    set opnd2: str = "0"; set op2: i64 = 0; set has2: i64 = 0;
    set opnd1: str = "0"; set op1: i64 = 0; set has1: i64 = 0;
    set more: i64 = 1;
    whilst more == 1 {
        fixed nop: i64 = tok_peek(tokens, p);
        fixed tier: i64 = chain_tier6(nop);
        check tier == 0 { more = 0; } fallback {
            // Operand is at p+1. Read it via read_i128_operand (which errors cleanly
            // on calls/index/paren/i64). The reader advances from p+1.
            set rop: list<i64> = list_new(); set ros: list<i64> = list_new(); set roa: list<i64> = list_new();
            fixed operand_i: str = read_i128_operand(tokens, strings, allnames, p + 1, s, an, ir, ctr, var_names, var_types, rop, ros, roa);
            check len(rop) > 0 { p = rop[0]; }
            check len(ros) > 0 { s = ros[0]; }
            check len(roa) > 0 { an = roa[0]; }
            check has6 == 1 { chcur = chain_emit_binop1_i128(op6, opnd6, chcur, ir, ctr, uns); has6 = 0; }
            check tier <= 5 && has5 == 1 { chcur = chain_emit_binop1_i128(op5, opnd5, chcur, ir, ctr, uns); has5 = 0; }
            check tier <= 4 && has4 == 1 { chcur = chain_emit_binop1_i128(op4, opnd4, chcur, ir, ctr, uns); has4 = 0; }
            check tier <= 3 && has3 == 1 { chcur = chain_emit_binop1_i128(op3, opnd3, chcur, ir, ctr, uns); has3 = 0; }
            check tier <= 2 && has2 == 1 { chcur = chain_emit_binop1_i128(op2, opnd2, chcur, ir, ctr, uns); has2 = 0; }
            check tier <= 1 && has1 == 1 { chcur = chain_emit_binop1_i128(op1, opnd1, chcur, ir, ctr, uns); has1 = 0; }
            check tier == 6 { opnd6 = chcur; op6 = nop; has6 = 1; }
            check tier == 5 { opnd5 = chcur; op5 = nop; has5 = 1; }
            check tier == 4 { opnd4 = chcur; op4 = nop; has4 = 1; }
            check tier == 3 { opnd3 = chcur; op3 = nop; has3 = 1; }
            check tier == 2 { opnd2 = chcur; op2 = nop; has2 = 1; }
            check tier == 1 { opnd1 = chcur; op1 = nop; has1 = 1; }
            chcur = operand_i;
        }
    }
    check has6 == 1 { chcur = chain_emit_binop1_i128(op6, opnd6, chcur, ir, ctr, uns); has6 = 0; }
    check has5 == 1 { chcur = chain_emit_binop1_i128(op5, opnd5, chcur, ir, ctr, uns); has5 = 0; }
    check has4 == 1 { chcur = chain_emit_binop1_i128(op4, opnd4, chcur, ir, ctr, uns); has4 = 0; }
    check has3 == 1 { chcur = chain_emit_binop1_i128(op3, opnd3, chcur, ir, ctr, uns); has3 = 0; }
    check has2 == 1 { chcur = chain_emit_binop1_i128(op2, opnd2, chcur, ir, ctr, uns); has2 = 0; }
    check has1 == 1 { chcur = chain_emit_binop1_i128(op1, opnd1, chcur, ir, ctr, uns); has1 = 0; }
    push(out_val, chcur); push(out_pos, p); push(out_si, s); push(out_ani, an);
}


// ── chain_tail ───────────────────────────────────────────────────────────────
// Given a primary already lowered to an i64 value (`init_i64`) sitting at p_in,
// fold any following arithmetic/bitwise chain (via fold_chain6) and then an
// optional trailing comparison, pushing the final value+type. This lets an
// integer literal, a call result, or an index result *begin* a chain — the
// counterpart to fold_chain6's widened operand reader, which lets them appear
// as later operands. Mutually recursive with compile_expr (forward ref is fine).
df chain_tail(tokens: list<i64>, strings: list<str>, allnames: list<str>, init_i64: str, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, var_names: list<str>, var_types: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>, uns: i64) -> void {
    set cur: str = init_i64;
    set p: i64 = p_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    check chain_tier6(tok_peek(tokens, p)) > 0 {
        set fcv: list<str> = list_new(); set fcp: list<i64> = list_new(); set fcs: list<i64> = list_new(); set fca: list<i64> = list_new();
        fold_chain6(tokens, strings, allnames, cur, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, fcv, fcp, fcs, fca, uns);
        check len(fcv) > 0 { cur = fcv[0]; }
        check len(fcp) > 0 { p = fcp[0]; }
        check len(fcs) > 0 { s = fcs[0]; }
        check len(fca) > 0 { an = fca[0]; }
    }
    fixed cop: i64 = tok_peek(tokens, p);
    check cop == OP_EQEQ || cop == OP_BANGEQ || cop == OP_LT || cop == OP_GT || cop == OP_LTEQ || cop == OP_GTEQ {
        p += 1;
        set rv: list<str> = list_new(); set rp: list<i64> = list_new(); set rs: list<i64> = list_new(); set ra: list<i64> = list_new(); set rty: list<str> = list_new();
        compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rv, rp, rs, ra, rty, var_names, var_types);
        check len(rp) > 0 { p = rp[0]; } check len(rs) > 0 { s = rs[0]; } check len(ra) > 0 { an = ra[0]; }
        fixed rhs: str = "0"; check len(rv) > 0 { rhs = rv[0]; }
        fixed rhsty: str = "ptr"; check len(rty) > 0 { rhsty = rty[0]; }
        fixed rhsi: str = rhs; check rhsty != "i64" { rhsi = coerce_i64(rhs, ir, ctr); }
        fixed cmp: str = make_tmp(ctr);
        set ctpred: str = "";
        check cop == OP_EQEQ  { ctpred = "eq "; }
        check cop == OP_BANGEQ { ctpred = "ne "; }
        check cop == OP_LT    { ctpred = "slt"; check uns == 1 { ctpred = "ult"; } }
        check cop == OP_GT    { ctpred = "sgt"; check uns == 1 { ctpred = "ugt"; } }
        check cop == OP_LTEQ  { ctpred = "sle"; check uns == 1 { ctpred = "ule"; } }
        check cop == OP_GTEQ  { ctpred = "sge"; check uns == 1 { ctpred = "uge"; } }
        emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", cmp), " = icmp "), ctpred), str_concat(" i64 ", cur)), str_concat(", ", rhsi)));
        push(out_val, cmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;
    }
    set ct_ty: str = "i64";
    check uns == 1 { ct_ty = "u64"; }
    push(out_val, cur); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, ct_ty);
}


// ── float arithmetic chain (isolated f64 path) ───────────────────────────────
// Mirrors fold_chain6/chain_tail but for f64: two precedence tiers (* / then
// + -) since modulo/bitwise/shift are undefined on floats. Entered only when a
// leading primary is float-typed; int operands inside the chain are promoted to
// double via sitofp, so e.g. `2.0 * count` works. The i64 chain is untouched.
df float_tier(op: i64) -> i64 {
    check op == OP_STAR || op == OP_SLASH { return 2; }
    check op == OP_PLUS || op == OP_MINUS { return 1; }
    return 0;
}

df float_emit_binop(op: i64, lhs: str, rhs: str, ir: list<str>, ctr: list<i64>) -> str {
    fixed res: str = make_tmp(ctr);
    fixed pre: str = str_concat(str_concat("  ", res), " = ");
    fixed tail: str = str_concat(lhs, str_concat(", ", rhs));
    check op == OP_PLUS  { emit(ir, str_concat(pre, str_concat("fadd double ", tail))); }
    check op == OP_MINUS { emit(ir, str_concat(pre, str_concat("fsub double ", tail))); }
    check op == OP_STAR  { emit(ir, str_concat(pre, str_concat("fmul double ", tail))); }
    check op == OP_SLASH { emit(ir, str_concat(pre, str_concat("fdiv double ", tail))); }
    return res;
}

// Coerce a (value,type) pair to an f64 SSA value. f64 passes through; i64 (and
// anything else, via ptrtoint) is promoted with sitofp.
df as_double(val: str, ty: str, ir: list<str>, ctr: list<i64>) -> str {
    check ty == "f64" { return val; }
    set iv: str = val;
    check ty != "i64" { iv = coerce_i64(val, ir, ctr); }
    fixed d: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat("  ", d), " = sitofp i64 "), str_concat(iv, " to double")));
    return d;
}

df fold_float_chain(tokens: list<i64>, strings: list<str>, allnames: list<str>, fcur_in: str, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, var_names: list<str>, var_types: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>) -> void {
    set fcur: str = fcur_in;
    set p: i64 = p_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    set opnd2: str = "0"; set op2: i64 = 0; set has2: i64 = 0;
    set opnd1: str = "0"; set op1: i64 = 0; set has1: i64 = 0;
    set more: i64 = 1;
    whilst more == 1 {
        fixed nop: i64 = tok_peek(tokens, p);
        fixed tier: i64 = float_tier(nop);
        check tier == 0 { more = 0; } fallback {
            fixed nxp: i64 = tok_peek(tokens, p + 1);
            fixed nx2: i64 = tok_peek(tokens, p + 2);
            fixed ni: i64 = 0; check nxp == TOK_INT { ni = 1; }
            fixed nf: i64 = 0; check nxp == TOK_FLOAT { nf = 1; }
            fixed nxv: i64 = 0; check nxp == TOK_IDENT && nx2 != PUNCT_LPAREN && nx2 != PUNCT_LBRACKET { nxv = 1; }
            fixed nxcall: i64 = 0; check nxp == TOK_IDENT && nx2 == PUNCT_LPAREN { nxcall = 1; }
            fixed nxidx: i64 = 0; check nxp == TOK_IDENT && nx2 == PUNCT_LBRACKET { nxidx = 1; }
            fixed nxpar: i64 = 0; check nxp == PUNCT_LPAREN { nxpar = 1; }
            check ni == 0 && nf == 0 && nxv == 0 && nxcall == 0 && nxidx == 0 && nxpar == 0 { more = 0; } fallback {
                set operand_f: str = "0.0";
                set simple: i64 = 1;
                check nf == 1 {
                    fixed fv2: str = strings[s];
                    fixed ft2: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", ft2), " = fadd double 0.0, "), fv2));
                    operand_f = ft2; s += 1;
                }
                check ni == 1 {
                    fixed iv2: str = strings[s];
                    fixed itmp: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", itmp), " = add i64 0, "), iv2));
                    operand_f = as_double(itmp, "i64", ir, ctr); s += 1;
                }
                check nxv == 1 {
                    fixed vn2: str = allnames[an];
                    fixed vty2: str = lookup_var_type(vn2, var_names, var_types);
                    fixed vld: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  ", vld), " = load ptr, ptr %"), vn2), "_slot, align 8"));
                    fixed vbits: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", vbits), " = ptrtoint ptr "), str_concat(vld, " to i64")));
                    check line_eq(vty2, "f64") == 1 {
                        fixed vd: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", vd), " = bitcast i64 "), str_concat(vbits, " to double")));
                        operand_f = vd;
                    } fallback {
                        operand_f = as_double(vbits, "i64", ir, ctr);
                    }
                    an += 1;
                }
                check nxcall == 1 || nxidx == 1 || nxpar == 1 {
                    check len(ctr) > 1 { ctr[1] = 1; }
                    set ev: list<str> = list_new(); set ep: list<i64> = list_new(); set es: list<i64> = list_new(); set ea: list<i64> = list_new(); set ety: list<str> = list_new();
                    compile_expr(tokens, strings, allnames, p + 1, s, an, ir, ctr, gvals, gnames, ev, ep, es, ea, ety, var_names, var_types);
                    fixed evv: str = "0"; check len(ev) > 0 { evv = ev[0]; }
                    fixed evty: str = "ptr"; check len(ety) > 0 { evty = ety[0]; }
                    operand_f = as_double(evv, evty, ir, ctr);
                    check len(es) > 0 { s = es[0]; }
                    check len(ea) > 0 { an = ea[0]; }
                    check len(ep) > 0 { p = ep[0]; }
                    simple = 0;
                }
                check has2 == 1 { fcur = float_emit_binop(op2, opnd2, fcur, ir, ctr); has2 = 0; }
                check tier <= 1 && has1 == 1 { fcur = float_emit_binop(op1, opnd1, fcur, ir, ctr); has1 = 0; }
                check tier == 2 { opnd2 = fcur; op2 = nop; has2 = 1; }
                check tier == 1 { opnd1 = fcur; op1 = nop; has1 = 1; }
                fcur = operand_f;
                check simple == 1 { p += 2; }
            }
        }
    }
    check has2 == 1 { fcur = float_emit_binop(op2, opnd2, fcur, ir, ctr); has2 = 0; }
    check has1 == 1 { fcur = float_emit_binop(op1, opnd1, fcur, ir, ctr); has1 = 0; }
    push(out_val, fcur); push(out_pos, p); push(out_si, s); push(out_ani, an);
}

df chain_tail_f(tokens: list<i64>, strings: list<str>, allnames: list<str>, init_f64: str, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, var_names: list<str>, var_types: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>) -> void {
    set cur: str = init_f64;
    set p: i64 = p_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    check float_tier(tok_peek(tokens, p)) > 0 {
        set fcv: list<str> = list_new(); set fcp: list<i64> = list_new(); set fcs: list<i64> = list_new(); set fca: list<i64> = list_new();
        fold_float_chain(tokens, strings, allnames, cur, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, fcv, fcp, fcs, fca);
        check len(fcv) > 0 { cur = fcv[0]; }
        check len(fcp) > 0 { p = fcp[0]; }
        check len(fcs) > 0 { s = fcs[0]; }
        check len(fca) > 0 { an = fca[0]; }
    }
    fixed cop: i64 = tok_peek(tokens, p);
    check cop == OP_PERCENT || cop == OP_SHL || cop == OP_SHR || cop == OP_AMP || cop == OP_CARET || cop == OP_PIPE {
        echo!("torvc: codegen error: modulo/bitwise/shift operators are not defined on floats.");
        exit(1);
    }
    check cop == OP_EQEQ || cop == OP_BANGEQ || cop == OP_LT || cop == OP_GT || cop == OP_LTEQ || cop == OP_GTEQ {
        p += 1;
        set rv: list<str> = list_new(); set rp: list<i64> = list_new(); set rs: list<i64> = list_new(); set ra: list<i64> = list_new(); set rty: list<str> = list_new();
        compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rv, rp, rs, ra, rty, var_names, var_types);
        check len(rp) > 0 { p = rp[0]; } check len(rs) > 0 { s = rs[0]; } check len(ra) > 0 { an = ra[0]; }
        fixed rhs: str = "0"; check len(rv) > 0 { rhs = rv[0]; }
        fixed rhsty: str = "ptr"; check len(rty) > 0 { rhsty = rty[0]; }
        fixed rhsf: str = as_double(rhs, rhsty, ir, ctr);
        fixed cmp: str = make_tmp(ctr);
        check cop == OP_EQEQ   { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp), " = fcmp oeq double "), cur), str_concat(", ", rhsf))); }
        check cop == OP_BANGEQ { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp), " = fcmp one double "), cur), str_concat(", ", rhsf))); }
        check cop == OP_LT     { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp), " = fcmp olt double "), cur), str_concat(", ", rhsf))); }
        check cop == OP_GT     { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp), " = fcmp ogt double "), cur), str_concat(", ", rhsf))); }
        check cop == OP_LTEQ   { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp), " = fcmp ole double "), cur), str_concat(", ", rhsf))); }
        check cop == OP_GTEQ   { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp), " = fcmp oge double "), cur), str_concat(", ", rhsf))); }
        push(out_val, cmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;
    }
    push(out_val, cur); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "f64");
}


// True when a string literal contains real interpolation/escaping work: a brace
// escape ({{ or }}) or a '{' that opens an identifier. A lone '{' or the empty
// '{}' (used by fmt) are left untouched, so existing constants stay byte-identical.
df needs_interp(sv: str) -> i64 {
    fixed n: i64 = len(sv);
    set i: i64 = 0;
    whilst i < n {
        fixed c: i64 = byte_at(sv, i);
        check c == 123 {
            check i + 1 < n {
                fixed d: i64 = byte_at(sv, i + 1);
                check d == 123 { return 1; }
                check (d >= 65 && d <= 90) || (d >= 97 && d <= 122) || d == 95 { return 1; }
            }
        }
        check c == 125 {
            check i + 1 < n && byte_at(sv, i + 1) == 125 { return 1; }
        }
        i += 1;
    }
    return 0;
}

// Build an interpolated string literal at runtime: literal chunks are interned
// constants, "{name}" spans load the variable and stringify it (any type), and
// {{ / }} collapse to single braces. An unknown variable emits a tv.undefvar
// marker so collect_undef_vars turns it into a clean located compile error.
df emit_interp(sv: str, p: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, var_names: list<str>, var_types: list<str>) -> str {
    fixed e0: str = intern_str("", gvals, gnames);
    set result: str = emit_str_ref(e0, "", ir, ctr);
    set lit: str = "";
    set i: i64 = 0;
    fixed n: i64 = len(sv);
    whilst i < n {
        fixed ch: i64 = byte_at(sv, i);
        check ch == 123 {
            check i + 1 < n && byte_at(sv, i + 1) == 123 { lit = str_concat(lit, "{"); i += 2; continue; }
            set d: i64 = 0;
            check i + 1 < n { d = byte_at(sv, i + 1); }
            set is_id: i64 = 0;
            check (d >= 65 && d <= 90) || (d >= 97 && d <= 122) || d == 95 { is_id = 1; }
            check is_id == 0 { lit = str_concat(lit, "{"); i += 1; continue; }
            // scan the name up to '}'
            set j: i64 = i + 1;
            set vname: str = "";
            set closed: i64 = 0;
            whilst j < n && closed == 0 {
                fixed cj: i64 = byte_at(sv, j);
                check cj == 125 { closed = 1; j += 1; } fallback { vname = str_concat(vname, substr(sv, j, j + 1)); j += 1; }
            }
            // An unclosed '{' (reached end of string with no '}') is a malformed
            // interpolation — flag it as a located error rather than silently
            // interpolating whatever was collected.
            check closed == 0 {
                emit(ir, str_concat("  ; tv.unclosedinterp:", int_to_str(p)));
                i = n; continue;
            }
            // flush pending literal text
            check len(lit) > 0 {
                fixed gl: str = intern_str(lit, gvals, gnames);
                fixed lr: str = emit_str_ref(gl, lit, ir, ctr);
                fixed tc: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tc), " = call ptr @torvik_str_concat(ptr "), str_concat(result, ", ptr ")), str_concat(lr, ")")));
                result = tc; lit = "";
            }
            check slot_defined(ir, vname) == 0 {
                emit(ir, str_concat(str_concat(str_concat("  ; tv.undefvar:", vname), ":"), int_to_str(p)));
            }
            check slot_defined(ir, vname) == 1 {
                fixed ld: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat(str_concat("  ", ld), " = load ptr, ptr %"), vname), "_slot, align 8"));
                fixed dty: str = lookup_var_type(vname, var_names, var_types);
                fixed sval: str = echo_stringify(ld, "ptr", dty, ir, ctr);
                fixed tc2: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tc2), " = call ptr @torvik_str_concat(ptr "), str_concat(result, ", ptr ")), str_concat(sval, ")")));
                result = tc2;
            }
            i = j; continue;
        }
        check ch == 125 {
            check i + 1 < n && byte_at(sv, i + 1) == 125 { lit = str_concat(lit, "}"); i += 2; continue; }
            lit = str_concat(lit, "}"); i += 1; continue;
        }
        lit = str_concat(lit, substr(sv, i, i + 1)); i += 1;
    }
    check len(lit) > 0 {
        fixed gl2: str = intern_str(lit, gvals, gnames);
        fixed lr2: str = emit_str_ref(gl2, lit, ir, ctr);
        fixed tc3: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tc3), " = call ptr @torvik_str_concat(ptr "), str_concat(result, ", ptr ")), str_concat(lr2, ")")));
        result = tc3;
    }
    return result;
}

// Fold a '+' concatenation chain. `cur` is the already-compiled left operand (a
// string value); `pp_in` points at the first '+'. Each following operand is
// compiled with the chain suppressed so it consumes exactly one primary, then
// stringified (any type) and appended. Walks the chain by loop, keeping cursors
// in sync. Shared by the string-literal lead and the string-variable lead.
df emit_concat_chain(cur: str, pp_in: i64, s_in: i64, an_in: i64, tokens: list<i64>, strings: list<str>, allnames: list<str>, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, var_names: list<str>, var_types: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>) -> void {
    set acc: str = cur;
    set pp: i64 = pp_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    whilst tok_peek(tokens, pp) == OP_PLUS {
        set rhs_eff: str = "";
        check tok_peek(tokens, pp + 1) == TOK_IDENT {
            fixed nx: i64 = tok_peek(tokens, pp + 2);
            check nx == OP_PLUS || nx == PUNCT_RPAREN || nx == PUNCT_SEMI || nx == PUNCT_COMMA {
                rhs_eff = lookup_var_type(allnames[an], var_names, var_types);
            }
        }
        check len(ctr) > 1 { ctr[1] = 1; }
        set rv: list<str> = list_new();
        set rp: list<i64> = list_new();
        set rs: list<i64> = list_new();
        set ra: list<i64> = list_new();
        set rt: list<str> = list_new();
        compile_expr(tokens, strings, allnames, pp + 1, s, an, ir, ctr, gvals, gnames, rv, rp, rs, ra, rt, var_names, var_types);
        check len(rp) > 0 { pp = rp[0]; }
        check len(rs) > 0 { s = rs[0]; }
        check len(ra) > 0 { an = ra[0]; }
        set ev_eff: str = rt[0];
        check len(rhs_eff) > 0 { ev_eff = rhs_eff; }
        fixed osval: str = echo_stringify(rv[0], rt[0], ev_eff, ir, ctr);
        fixed cc: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cc), " = call ptr @torvik_str_concat(ptr "), str_concat(acc, ", ptr ")), str_concat(osval, ")")));
        acc = cc;
    }
    push(out_val, acc); push(out_pos, pp); push(out_si, s); push(out_ani, an); push(out_ty, "str");
}


df compile_expr(tokens: list<i64>, strings: list<str>, allnames: list<str>, pos: i64, si: i64, ani: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>, var_names: list<str>, var_types: list<str>) -> void {
    fixed t: i64 = tok_peek(tokens, pos);
    set p: i64 = pos;
    set s: i64 = si;
    set an: i64 = ani;
    // Chain-suppression (stage 2): fold_chain6 sets ctr[1]=1 before evaluating a
    // call/index/paren *operand*, so that primary resolves to itself WITHOUT
    // folding the surrounding chain (otherwise `a * f(x) + 1` would over-consume
    // `f(x) + 1` and break precedence). We capture it and clear immediately, so
    // it applies only to THIS leading primary — nested arguments chain normally.
    set suppress_chain: i64 = 0;
    check len(ctr) > 1 { suppress_chain = ctr[1]; ctr[1] = 0; }

    // ── Unary prefix (leading position only): !x logical-not, -x negate ──
    // Fires only when ! or - is the FIRST token of this expression. Binary
    // subtraction never reaches here (it follows a value, handled by the chain).
    check t == OP_BANG {
        set uv: list<str> = list_new(); set up2: list<i64> = list_new(); set us: list<i64> = list_new(); set us_ai: list<i64> = list_new(); set uty: list<str> = list_new();
        compile_expr(tokens, strings, allnames, p + 1, s, an, ir, ctr, gvals, gnames, uv, up2, us, us_ai, uty, var_names, var_types);
        check len(up2) > 0 { p = up2[0]; }
        check len(us) > 0 { s = us[0]; }
        check len(us_ai) > 0 { an = us_ai[0]; }
        fixed uval: str = "0"; check len(uv) > 0 { uval = uv[0]; }
        fixed uvty: str = "ptr"; check len(uty) > 0 { uvty = uty[0]; }
        set uvi: str = uval;
        check uvty == "i1" {
            fixed uzx: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", uzx), " = zext i1 "), str_concat(uval, " to i64")));
            uvi = uzx;
        } fallback {
            check uvty != "i64" { uvi = coerce_i64(uval, ir, ctr); }
        }
        fixed ures: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", ures), " = icmp eq i64 "), str_concat(uvi, ", 0")));
        push(out_val, ures); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;
    }
    check t == OP_MINUS {
        set nv: list<str> = list_new(); set np2: list<i64> = list_new(); set ns: list<i64> = list_new(); set ns_ai: list<i64> = list_new(); set nty: list<str> = list_new();
        compile_expr(tokens, strings, allnames, p + 1, s, an, ir, ctr, gvals, gnames, nv, np2, ns, ns_ai, nty, var_names, var_types);
        check len(np2) > 0 { p = np2[0]; }
        check len(ns) > 0 { s = ns[0]; }
        check len(ns_ai) > 0 { an = ns_ai[0]; }
        fixed nval: str = "0"; check len(nv) > 0 { nval = nv[0]; }
        fixed nvty: str = "ptr"; check len(nty) > 0 { nvty = nty[0]; }
        set nvi: str = nval;
        check nvty == "i1" {
            fixed nzx: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", nzx), " = zext i1 "), str_concat(nval, " to i64")));
            nvi = nzx;
        } fallback {
            check nvty != "i64" { nvi = coerce_i64(nval, ir, ctr); }
        }
        fixed nres: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", nres), " = sub i64 0, "), nvi));
        push(out_val, nres); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
    }

    // String literal — advance an to keep allnames in sync (strings are in allnames too)
    check t == TOK_STRING {
        fixed sv: str = strings[s];
        s += 1;
        an += 1;  // allnames has an entry for this string literal
        set val: str = "";
        set vty: str = "str";
        check needs_interp(sv) == 1 {
            val = emit_interp(sv, p, ir, ctr, gvals, gnames, var_names, var_types); vty = "str";
        } fallback {
            fixed gn: str = intern_str(sv, gvals, gnames);
            val = emit_str_ref(gn, sv, ir, ctr);
        }
        // '+' concatenation: a string/char/interpolated literal on the left folds
        // each following operand and appends it, stringifying any value type. Each
        // operand is compiled with the chain suppressed (ctr[1]=1) so it consumes
        // exactly one primary — the loop, not recursion, walks the '+' chain. This
        // keeps cursors in sync even for `"a " + n + " b"` (a var mid-chain).
        check suppress_chain == 0 && tok_peek(tokens, p + 1) == OP_PLUS {
            emit_concat_chain(val, p + 1, s, an, tokens, strings, allnames, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
            return;
        }
        push(out_val, val); push(out_pos, p + 1); push(out_si, s); push(out_ani, an); push(out_ty, vty); return;
    }

    // Integer literal — read actual value from strings[]
    check t == TOK_INT {
        fixed int_val: str = strings[s];
        fixed tmp: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = add i64 0, "), int_val));
        // Stage 2: an integer literal may begin an arithmetic chain (`2 + 3 * 4`)
        // or a comparison (`2 > 1`). Route through chain_tail when one follows.
        fixed after_int: i64 = tok_peek(tokens, p + 1);
        check suppress_chain == 0 && (chain_tier6(after_int) > 0 || after_int == OP_EQEQ || after_int == OP_BANGEQ || after_int == OP_LT || after_int == OP_GT || after_int == OP_LTEQ || after_int == OP_GTEQ) {
            chain_tail(tokens, strings, allnames, tmp, p + 1, s + 1, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0);
            return;
        }
        push(out_val, tmp); push(out_pos, p + 1); push(out_si, s + 1); push(out_ani, an); push(out_ty, "i64"); return;
    }

    // Float literal: materialize into an f64 SSA temp, then fold any float chain
    // or comparison via the isolated f64 path.
    check t == TOK_FLOAT {
        fixed flt_val: str = strings[s];
        fixed ftmp: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", ftmp), " = fadd double 0.0, "), flt_val));
        check suppress_chain == 0 {
            chain_tail_f(tokens, strings, allnames, ftmp, p + 1, s + 1, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
            return;
        }
        push(out_val, ftmp); push(out_pos, p + 1); push(out_si, s + 1); push(out_ani, an); push(out_ty, "f64"); return;
    }
    check t == KW_TRUE {
        fixed tmp_t: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat("  ", tmp_t), " = add i64 0, 1"));
        push(out_val, tmp_t); push(out_pos, p + 1); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
    }
    check t == KW_FALSE {
        fixed tmp_f: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat("  ", tmp_f), " = add i64 0, 0"));
        push(out_val, tmp_f); push(out_pos, p + 1); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
    }

    // Parenthesized expression: ( EXPR ) with && / || support inside
    check t == PUNCT_LPAREN {
        p += 1; // skip "("
        set iv: list<str> = list_new();
        set ip: list<i64> = list_new();
        set is2: list<i64> = list_new();
        set iai: list<i64> = list_new();
        set ity: list<str> = list_new();
        compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, iv, ip, is2, iai, ity, var_names, var_types);
        check len(ip) > 0 { p = ip[0]; }
        check len(is2) > 0 { s = is2[0]; }
        check len(iai) > 0 { an = iai[0]; }
        set cur: str = "null"; check len(iv) > 0 { cur = iv[0]; }
        set cur_ty: str = "ptr"; check len(ity) > 0 { cur_ty = ity[0]; }
        // Combine && / || operands inside the parentheses
        whilst tok_peek(tokens, p) == OP_AMPAMP || tok_peek(tokens, p) == OP_PIPEPIPE {
            set p_is_and: i64 = 0; check tok_peek(tokens, p) == OP_AMPAMP { p_is_and = 1; }
            p += 1;
            set rv2: list<str> = list_new(); set rp2: list<i64> = list_new(); set rs2: list<i64> = list_new(); set rs2_ai: list<i64> = list_new(); set rs2_ty: list<str> = list_new();
            compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rv2, rp2, rs2, rs2_ai, rs2_ty, var_names, var_types);
            check len(rp2) > 0 { p = rp2[0]; } check len(rs2) > 0 { s = rs2[0]; } check len(rs2_ai) > 0 { an = rs2_ai[0]; }
            set rhs2v: str = "null"; check len(rv2) > 0 { rhs2v = rv2[0]; }
            set rhs2ty: str = "ptr"; check len(rs2_ty) > 0 { rhs2ty = rs2_ty[0]; }
            set lhs_i1: str = cur; check cur_ty != "i1" { fixed zt: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", zt), " = icmp ne i64 "), str_concat(coerce_i64(cur, ir, ctr), ", 0"))); lhs_i1 = zt; }
            set rhs_i1: str = rhs2v; check rhs2ty != "i1" { fixed zt2: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", zt2), " = icmp ne i64 "), str_concat(coerce_i64(rhs2v, ir, ctr), ", 0"))); rhs_i1 = zt2; }
            fixed cmb: str = make_tmp(ctr);
            check p_is_and == 1 { emit(ir, str_concat(str_concat(str_concat("  ", cmb), " = and i1 "), str_concat(lhs_i1, str_concat(", ", rhs_i1)))); }
            check p_is_and == 0 { emit(ir, str_concat(str_concat(str_concat("  ", cmb), " = or i1 "), str_concat(lhs_i1, str_concat(", ", rhs_i1)))); }
            cur = cmb; cur_ty = "i1";
        }
        check tok_peek(tokens, p) == PUNCT_RPAREN { p += 1; } fallback {
            echo!("torvc: codegen error: expected ')' to close a parenthesized expression (a '(' is unclosed).");
            exit(1);
        }
        // Stage 2: `(expr)` may begin an arithmetic chain (`(a + b) * c`) or be
        // compared (`(a + b) > c`). Only for non-boolean results; an i1 from an
        // inner &&/|| isn't an arithmetic operand. chain_tail handles both.
        fixed paren_next: i64 = tok_peek(tokens, p);
        check suppress_chain == 0 && cur_ty == "f64" && (float_tier(paren_next) > 0 || paren_next == OP_EQEQ || paren_next == OP_BANGEQ || paren_next == OP_LT || paren_next == OP_GT || paren_next == OP_LTEQ || paren_next == OP_GTEQ) {
            chain_tail_f(tokens, strings, allnames, cur, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
            return;
        }
        check suppress_chain == 0 && cur_ty != "i1" && cur_ty != "f64" && (chain_tier6(paren_next) > 0 || paren_next == OP_EQEQ || paren_next == OP_BANGEQ || paren_next == OP_LT || paren_next == OP_GT || paren_next == OP_LTEQ || paren_next == OP_GTEQ) {
            fixed pci: str = coerce_i64(cur, ir, ctr);
            chain_tail(tokens, strings, allnames, pci, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0);
            return;
        }
        push(out_val, cur); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, cur_ty); return;
    }

    // Identifier or call
    check t == TOK_IDENT {
        fixed nm: str = allnames[an];
        fixed nm_pos: i64 = p;
        an += 1; p += 1;

        check tok_peek(tokens, p) == PUNCT_LPAREN {
            p += 1;
            // Stage 4: capture a lone bare-identifier argument's name (for len dispatch).
            set lone_arg_name: str = "";
            check tok_peek(tokens, p) == TOK_IDENT && tok_peek(tokens, p + 1) == PUNCT_RPAREN {
                lone_arg_name = allnames[an];
            }
            // First-argument identifier name (any follower), used to recover a list's
            // element type for push/insert managed-element validation.
            set first_arg_name: str = "";
            check tok_peek(tokens, p) == TOK_IDENT {
                first_arg_name = allnames[an];
            }
            // First-argument string-literal text (for fmt placeholder counting). The
            // literal at the current string-table index is this arg's text when the
            // first token is a string literal.
            set first_arg_lit: str = "";
            set first_arg_is_lit: i64 = 0;
            check tok_peek(tokens, p) == TOK_STRING {
                first_arg_lit = strings[s];
                first_arg_is_lit = 1;
            }
            set args: list<str> = list_new();
            set args_ty: list<str> = list_new();
            whilst tok_peek(tokens, p) != PUNCT_RPAREN && tok_peek(tokens, p) != TOK_EOF && tok_peek(tokens, p) != PUNCT_SEMI && tok_peek(tokens, p) != PUNCT_RBRACE {
                set rv: list<str> = list_new();
                set rp: list<i64> = list_new();
                set rs: list<i64> = list_new();
                set rs_ai: list<i64> = list_new();
                set rs_ty: list<str> = list_new();
                compile_value(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rv, rp, rs, rs_ai, rs_ty, var_names, var_types);
                check len(rv) > 0 { push(args, rv[0]); }
                check len(rs_ty) > 0 { push(args_ty, rs_ty[0]); } fallback { push(args_ty, "ptr"); }
                check len(rp) > 0 { p = rp[0]; }
                check len(rs) > 0 { s = rs[0]; }
                check len(rs_ai) > 0 { an = rs_ai[0]; }
                check tok_peek(tokens, p) == PUNCT_COMMA { p += 1; }
            }
            check tok_peek(tokens, p) == PUNCT_RPAREN { p += 1; } fallback {
                echo!(fmt("torvc: codegen error: expected ')' to close the arguments of '{}' (a '(' is unclosed).", nm));
                exit(1);
            }

            fixed tmp: str = make_tmp(ctr);

            check nm == "str_concat" && len(args) >= 2 {
                emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_str_concat(ptr "), args[0]), ", ptr "), str_concat(args[1], ")")));
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "ptr"); return;
            }
            check nm == "int_to_str" && len(args) >= 1 {
                fixed its_arg_ty: str = "ptr";
                check len(args_ty) > 0 { its_arg_ty = args_ty[0]; }
                set its_val: str = args[0];
                check its_arg_ty != "i64" { its_val = coerce_i64(args[0], ir, ctr); }
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_int_to_str(i64 "), str_concat(its_val, ")")));
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "str"); return;
            }
            check nm == "len" && len(args) >= 1 {
                // Type-aware dispatch: if the argument is a variable of known type,
                // emit strlen (str) or torvik_list_len (list) directly; else fall
                // back to torvik_len's runtime magic-header dispatch.
                set len_arg_ty: str = "";
                check len(lone_arg_name) > 0 { len_arg_ty = lookup_var_type(lone_arg_name, var_names, var_types); }
                check starts(len_arg_ty, "str") {
                    emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i64 @strlen(ptr "), str_concat(args[0], ")")));
                } fallback {
                    check starts(len_arg_ty, "list") {
                        emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_list_len(ptr "), str_concat(args[0], ")")));
                    } fallback {
                        emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_len(ptr "), str_concat(args[0], ")")));
                    }
                }
                fixed len_nop: i64 = tok_peek(tokens, p);
                check len_nop == OP_EQEQ || len_nop == OP_BANGEQ || len_nop == OP_LT || len_nop == OP_GT || len_nop == OP_LTEQ || len_nop == OP_GTEQ { p += 1; set rv_ln: list<str> = list_new(); set rp_ln: list<i64> = list_new(); set rs_ln: list<i64> = list_new(); set rs_ln_ai: list<i64> = list_new(); set rs_ln_ty: list<str> = list_new(); compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rv_ln, rp_ln, rs_ln, rs_ln_ai, rs_ln_ty, var_names, var_types); check len(rp_ln) > 0 { p = rp_ln[0]; } check len(rs_ln) > 0 { s = rs_ln[0]; } check len(rs_ln_ai) > 0 { an = rs_ln_ai[0]; } fixed rhs_ln: str = "0"; check len(rv_ln) > 0 { rhs_ln = rv_ln[0]; } fixed rhs_ln_ty: str = "ptr"; check len(rs_ln_ty) > 0 { rhs_ln_ty = rs_ln_ty[0]; } fixed rv_ln_i: str = rhs_ln; check rhs_ln_ty != "i64" { rv_ln_i = coerce_i64(rhs_ln, ir, ctr); } fixed cmp_ln: str = make_tmp(ctr); check len_nop == OP_EQEQ  { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp_ln), " = icmp eq  i64 "), tmp), str_concat(", ", rv_ln_i))); } check len_nop == OP_BANGEQ { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp_ln), " = icmp ne  i64 "), tmp), str_concat(", ", rv_ln_i))); } check len_nop == OP_LT    { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp_ln), " = icmp slt i64 "), tmp), str_concat(", ", rv_ln_i))); } check len_nop == OP_GT    { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp_ln), " = icmp sgt i64 "), tmp), str_concat(", ", rv_ln_i))); } check len_nop == OP_LTEQ  { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp_ln), " = icmp sle i64 "), tmp), str_concat(", ", rv_ln_i))); } check len_nop == OP_GTEQ  { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp_ln), " = icmp sge i64 "), tmp), str_concat(", ", rv_ln_i))); } push(out_val, cmp_ln); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return; }
                check len_nop == OP_PLUS || len_nop == OP_MINUS || len_nop == OP_STAR {
                    p += 1;
                    set rv_la: list<str> = list_new(); set rp_la: list<i64> = list_new(); set rs_la: list<i64> = list_new(); set rs_la_ai: list<i64> = list_new(); set rs_la_ty: list<str> = list_new();
                    compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rv_la, rp_la, rs_la, rs_la_ai, rs_la_ty, var_names, var_types);
                    check len(rp_la) > 0 { p = rp_la[0]; } check len(rs_la) > 0 { s = rs_la[0]; } check len(rs_la_ai) > 0 { an = rs_la_ai[0]; }
                    fixed rhs_la: str = "0"; check len(rv_la) > 0 { rhs_la = rv_la[0]; }
                    fixed rhs_la_ty: str = "ptr"; check len(rs_la_ty) > 0 { rhs_la_ty = rs_la_ty[0]; }
                    fixed rv_la_i: str = rhs_la; check rhs_la_ty != "i64" { rv_la_i = coerce_i64(rhs_la, ir, ctr); }
                    fixed la_r: str = make_tmp(ctr);
                    check len_nop == OP_PLUS  { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", la_r), " = add i64 "), tmp), str_concat(", ", rv_la_i))); }
                    check len_nop == OP_MINUS { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", la_r), " = sub i64 "), tmp), str_concat(", ", rv_la_i))); }
                    check len_nop == OP_STAR  { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", la_r), " = mul i64 "), tmp), str_concat(", ", rv_la_i))); }
                    push(out_val, la_r); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
                }
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
            }
            check nm == "args" {
                emit(ir, str_concat(str_concat("  ", tmp), " = load i64, ptr @torvik_argc, align 8"));
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
            }
            check nm == "args_get" && len(args) >= 1 {
                fixed av: str = make_tmp(ctr);
                fixed ap: str = make_tmp(ctr);
                set idx_i64: str = args[0];
                fixed arg0_ty: str = "ptr";
                check len(args_ty) > 0 { arg0_ty = args_ty[0]; }
                check arg0_ty != "i64" { idx_i64 = coerce_i64(args[0], ir, ctr); }
                emit(ir, str_concat(str_concat("  ", av), " = load ptr, ptr @torvik_argv, align 8"));
                emit(ir, str_concat(str_concat(str_concat(str_concat("  ", ap), " = getelementptr ptr, ptr "), av), str_concat(", i64 ", idx_i64)));
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = load ptr, ptr "), str_concat(ap, ", align 8")));
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "ptr"); return;
            }
            check nm == "readfile" && len(args) >= 1 {
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_readfile(ptr "), str_concat(args[0], ")")));
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "ptr"); return;
            }
            check nm == "cwd" {
                emit(ir, str_concat(str_concat("  ", tmp), " = call ptr @torvik_sys_cwd()"));
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "ptr"); return;
            }
            check nm == "sys_home_dir" {
                emit(ir, str_concat(str_concat("  ", tmp), " = call ptr @torvik_sys_home_dir()"));
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "ptr"); return;
            }
            check nm == "fs_mtime" && len(args) >= 1 {
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_fs_mtime(ptr "), str_concat(args[0], ")")));
                fixed _fm_nop: i64 = tok_peek(tokens, p);
                check _fm_nop == OP_EQEQ || _fm_nop == OP_BANGEQ || _fm_nop == OP_LT || _fm_nop == OP_GT || _fm_nop == OP_LTEQ || _fm_nop == OP_GTEQ { p += 1; set rv_fm: list<str> = list_new(); set rp_fm: list<i64> = list_new(); set rs_fm: list<i64> = list_new(); set rs_fm_ai: list<i64> = list_new(); set rs_fm_ty: list<str> = list_new(); compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rv_fm, rp_fm, rs_fm, rs_fm_ai, rs_fm_ty, var_names, var_types); check len(rp_fm) > 0 { p = rp_fm[0]; } check len(rs_fm) > 0 { s = rs_fm[0]; } check len(rs_fm_ai) > 0 { an = rs_fm_ai[0]; } fixed rhs_fm: str = "0"; check len(rv_fm) > 0 { rhs_fm = rv_fm[0]; } fixed rhs_fm_ty: str = "ptr"; check len(rs_fm_ty) > 0 { rhs_fm_ty = rs_fm_ty[0]; } fixed rv_fm_i: str = rhs_fm; check rhs_fm_ty != "i64" { rv_fm_i = coerce_i64(rhs_fm, ir, ctr); } fixed cmp_fm: str = make_tmp(ctr); check _fm_nop == OP_EQEQ  { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp_fm), " = icmp eq  i64 "), tmp), str_concat(", ", rv_fm_i))); } check _fm_nop == OP_BANGEQ { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp_fm), " = icmp ne  i64 "), tmp), str_concat(", ", rv_fm_i))); } check _fm_nop == OP_LT    { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp_fm), " = icmp slt i64 "), tmp), str_concat(", ", rv_fm_i))); } check _fm_nop == OP_GT    { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp_fm), " = icmp sgt i64 "), tmp), str_concat(", ", rv_fm_i))); } check _fm_nop == OP_LTEQ  { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp_fm), " = icmp sle i64 "), tmp), str_concat(", ", rv_fm_i))); } check _fm_nop == OP_GTEQ  { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp_fm), " = icmp sge i64 "), tmp), str_concat(", ", rv_fm_i))); } push(out_val, cmp_fm); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return; }
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
            }
            check nm == "fs_exists" && len(args) >= 1 {
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_fs_exists(ptr "), str_concat(args[0], ")")));
                fixed _fe_nop: i64 = tok_peek(tokens, p);

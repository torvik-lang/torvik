            check nm == "abs" && len(args) >= 1 { fixed a0: str = args[0]; set a0t: str = "ptr"; check len(args_ty) >= 1 { a0t = args_ty[0]; } set a0i: str = a0; check a0t != "i64" { a0i = coerce_i64(a0, ir, ctr); } emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_abs(i64 "), str_concat(a0i, ")"))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "max" && len(args) >= 2 { fixed m0: str = args[0]; set m0t: str = "ptr"; check len(args_ty) >= 1 { m0t = args_ty[0]; } set m0i: str = m0; check m0t != "i64" { m0i = coerce_i64(m0, ir, ctr); } fixed m1: str = args[1]; set m1t: str = "ptr"; check len(args_ty) >= 2 { m1t = args_ty[1]; } set m1i: str = m1; check m1t != "i64" { m1i = coerce_i64(m1, ir, ctr); } emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_max(i64 "), str_concat(m0i, ", i64 ")), str_concat(m1i, ")"))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "min" && len(args) >= 2 { fixed n0: str = args[0]; set n0t: str = "ptr"; check len(args_ty) >= 1 { n0t = args_ty[0]; } set n0i: str = n0; check n0t != "i64" { n0i = coerce_i64(n0, ir, ctr); } fixed n1: str = args[1]; set n1t: str = "ptr"; check len(args_ty) >= 2 { n1t = args_ty[1]; } set n1i: str = n1; check n1t != "i64" { n1i = coerce_i64(n1, ir, ctr); } emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_min(i64 "), str_concat(n0i, ", i64 ")), str_concat(n1i, ")"))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "randint" && len(args) >= 2 { fixed r0: str = args[0]; set r0t: str = "ptr"; check len(args_ty) >= 1 { r0t = args_ty[0]; } set r0i: str = r0; check r0t != "i64" { r0i = coerce_i64(r0, ir, ctr); } fixed r1: str = args[1]; set r1t: str = "ptr"; check len(args_ty) >= 2 { r1t = args_ty[1]; } set r1i: str = r1; check r1t != "i64" { r1i = coerce_i64(r1, ir, ctr); } emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_randint(i64 "), str_concat(r0i, ", i64 ")), str_concat(r1i, ")"))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "time_now" { emit(ir, str_concat(str_concat("  ", tmp), " = call i64 @torvik_time_now()")); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "time_ms" { emit(ir, str_concat(str_concat("  ", tmp), " = call i64 @torvik_time_ms()")); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "readint" { set rip0: str = ""; check len(args) >= 1 { rip0 = args[0]; } fallback { rip0 = emit_str_ref(intern_str("", gvals, gnames), "", ir, ctr); } emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_readint(ptr "), str_concat(rip0, ")"))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            // readkey() keeps its original i64 byte-code return (matching
            // byte_at) so existing code is unbroken; readkey_str() is the
            // additive v1.1.3 form returning the keypress as a 1-char string
            // (matching char_at). STDLIB.md documents both.
            check nm == "readkey" { fixed rk8: str = make_tmp(ctr); emit(ir, str_concat(str_concat("  ", rk8), " = call i8 @torvik_readkey()")); emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = sext i8 "), str_concat(rk8, " to i64"))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "readkey_str" { fixed rks8: str = make_tmp(ctr); emit(ir, str_concat(str_concat("  ", rks8), " = call i8 @torvik_readkey()")); fixed rks64: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", rks64), " = sext i8 "), str_concat(rks8, " to i64"))); emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_byte_str(i64 "), str_concat(rks64, ")"))); finish_str_result(tokens, strings, allnames, tmp, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types); return; }
            // v1.2.0: find(s, sub) - byte index of the first occurrence, -1 if absent.
            check nm == "find" && len(args) >= 2 { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_find(ptr "), args[0]), str_concat(", ptr ", str_concat(args[1], ")")))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "contains" && len(args) >= 2 { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call i32 @torvik_contains(ptr "), args[0]), str_concat(", ptr ", str_concat(args[1], ")")))); fixed ctb: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", ctb), " = icmp ne i32 "), str_concat(tmp, ", 0"))); push(out_val, ctb); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return; }
            check nm == "readbool" { set rbp0: str = ""; check len(args) >= 1 { rbp0 = args[0]; } fallback { rbp0 = emit_str_ref(intern_str("", gvals, gnames), "", ir, ctr); } emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i32 @torvik_readbool(ptr "), str_concat(rbp0, ")"))); fixed rbb: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", rbb), " = icmp ne i32 "), str_concat(tmp, ", 0"))); push(out_val, rbb); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return; }
            check nm == "trim" && len(args) >= 1 {
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_trim(ptr "), str_concat(args[0], ")")));
                finish_str_result(tokens, strings, allnames, tmp, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types); return;
            }
            // v1.1.3: upper/lower as ordinary calls. They previously existed
            // ONLY as weave stages (`s ~> upper`); a direct `upper(s)` call was
            // "undefined function" despite the docs listing them as builtins.
            check nm == "upper" && len(args) >= 1 {
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_upper(ptr "), str_concat(args[0], ")")));
                finish_str_result(tokens, strings, allnames, tmp, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types); return;
            }
            check nm == "lower" && len(args) >= 1 {
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_lower(ptr "), str_concat(args[0], ")")));
                finish_str_result(tokens, strings, allnames, tmp, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types); return;
            }
            check nm == "triml" && len(args) >= 1 {
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_triml(ptr "), str_concat(args[0], ")")));
                finish_str_result(tokens, strings, allnames, tmp, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types); return;
            }
            check nm == "trimr" && len(args) >= 1 {
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_trimr(ptr "), str_concat(args[0], ")")));
                finish_str_result(tokens, strings, allnames, tmp, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types); return;
            }
            // Generic call fallback — emit actual call with all args as ptr
            fixed callee_ptypes: list<str> = split_words(lookup_var_type(str_concat("@p@", nm), var_names, var_types));
            set generic_args: str = "";
            set gi2: i64 = 0;
            whilst gi2 < len(args) {
                check len(generic_args) > 0 { generic_args = str_concat(generic_args, ", "); }
                set garg_ty: str = "ptr";
                check gi2 < len(args_ty) { garg_ty = args_ty[gi2]; }
                // A 128-bit value is a heap-box ptr that the callee dereferences via
                // torvik_i128_load. Passing a non-128-bit scalar (an int literal, i64,
                // bool, or float) would reinterpret its bits as a box address and
                // segfault. Require 128-bit args to be 128-bit-typed (bind a literal
                // to an i128 variable first). Conversely, a 128-bit value passed where
                // a non-128-bit int is expected would have its box ADDRESS read as the
                // value — also a clean error.
                check gi2 < len(callee_ptypes) {
                    fixed ppt: str = callee_ptypes[gi2];
                    set param_is_128: i64 = 0; check line_eq(ppt, "i128") == 1 || line_eq(ppt, "u128") == 1 { param_is_128 = 1; }
                    set arg_is_128: i64 = 0; check garg_ty == "i128" || garg_ty == "u128" { arg_is_128 = 1; }
                    check param_is_128 == 1 && arg_is_128 == 0 && (garg_ty == "i64" || garg_ty == "i1" || garg_ty == "bool" || garg_ty == "f64") {
                        emit_uerr(ir, pos, "a non-128-bit value cannot be passed to a 128-bit parameter. Bind the value to an i128/u128 variable first, then pass that.");
                    }
                    check param_is_128 == 0 && arg_is_128 == 1 && int_width(ppt) > 0 {
                        emit_uerr(ir, pos, "a 128-bit value cannot be passed to a non-128-bit integer parameter. Use a matching 128-bit parameter type, or convert explicitly.");
                    }
                }
                check garg_ty == "i1" || garg_ty == "i64" || garg_ty == "bool" {
                    generic_args = str_concat(generic_args, str_concat("i64 ", args[gi2]));
                }
                check garg_ty == "f64" {
                    fixed gfb: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", gfb), " = bitcast double "), str_concat(args[gi2], " to i64")));
                    fixed gfp: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", gfp), " = inttoptr i64 "), str_concat(gfb, " to ptr")));
                    generic_args = str_concat(generic_args, str_concat("ptr ", gfp));
                }
                check garg_ty != "i1" && garg_ty != "i64" && garg_ty != "f64" {
                    generic_args = str_concat(generic_args, str_concat("ptr ", args[gi2]));
                }
                gi2 += 1;
            }
            check starts(lookup_var_type(nm, var_names, var_types), "fnret:") {
                check len(args) != len(callee_ptypes) {
                    emit_uerr(ir, nm_pos, fmt("function '{}' expects {} argument(s) but got {}.", nm, len(callee_ptypes), len(args)));
                }
            } fallback {
                emit(ir, str_concat(str_concat(str_concat("  ; tv.undeffn:", nm), ":"), int_to_str(nm_pos)));
            }
            emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call ptr @"), nm), str_concat("(", str_concat(generic_args, ")"))));
            fixed call_is_u64: bool = line_eq(lookup_var_type(nm, var_names, var_types), "fnret:u64") == 1;
            // Float-returning user function: the result is a bit-packed ptr; recover
            // the double and route through the f64 path (chain/comparison/print).
            check line_eq(lookup_var_type(nm, var_names, var_types), "fnret:f64") == 1 {
                fixed cfb: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", cfb), " = ptrtoint ptr "), str_concat(tmp, " to i64")));
                fixed cfd: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", cfd), " = bitcast i64 "), str_concat(cfb, " to double")));
                check suppress_chain == 0 {
                    chain_tail_f(tokens, strings, allnames, cfd, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
                    return;
                }
                push(out_val, cfd); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "f64"); return;
            }
            // Trailing comparison after a user function call (stage 2: routed
            // through the shared tail — a str-returning function now compares by
            // CONTENT, not by pointer, and the tail is suppressed when this call
            // is an operand inside an enclosing arithmetic chain).
            fixed call_next_op: i64 = tok_peek(tokens, p);
            check suppress_chain == 0 && is_cmp_op(call_next_op) == 1 {
                fixed ck_ret: str = lookup_var_type(nm, var_names, var_types);
                set ck_ty: str = "ptr";
                check line_eq(ck_ret, "fnret:str") == 1 { ck_ty = "str"; }
                set ck_hint: i64 = 0;
                check starts(ck_ret, "fnret:") {
                    fixed ck_rt: str = substr(ck_ret, 6, len(ck_ret));
                    check line_eq(ty_kind(ck_rt), "num") == 1 { ck_hint = 1; }
                }
                set ck_u64: i64 = 0;
                check call_is_u64 { ck_u64 = 1; }
                p += 1;
                compile_cmp_tail(tokens, strings, allnames, tmp, ck_ty, ck_hint, ck_u64, call_next_op, p, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
                return;
            }
            check suppress_chain == 0 && call_next_op == OP_BOUND {
                fixed cb_ret: str = lookup_var_type(nm, var_names, var_types);
                set cb_str: i64 = 0; check line_eq(cb_ret, "fnret:str") == 1 { cb_str = 1; }
                set cb_hint: i64 = 0;
                check starts(cb_ret, "fnret:") {
                    fixed cb_rt: str = substr(cb_ret, 6, len(cb_ret));
                    check line_eq(ty_kind(cb_rt), "num") == 1 { cb_hint = 1; }
                }
                compile_bound_tail(tokens, strings, allnames, tmp, cb_str, cb_hint, p + 1, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
                return;
            }
            check suppress_chain == 0 && call_next_op == OP_WEAVE {
                compile_weave_tail(tokens, strings, allnames, tmp, cb_rt, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
                return;
            }
            // Stage 2: a call result may begin an arithmetic chain (`f(x) + 16`,
            // `f(x) * n - 1`). Trailing comparison-only is already handled above;
            // here we catch a following arithmetic/bitwise operator. chain_tail
            // also folds a comparison after the chain (`f(x) + 1 == b`).
            check suppress_chain == 0 && chain_tier6(tok_peek(tokens, p)) > 0 {
                fixed gci: str = coerce_i64(tmp, ir, ctr);
                chain_tail(tokens, strings, allnames, gci, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, call_is_u64);
                return;
            }
            // String-returning user function: tag the result "str" (not bare
            // "ptr") so consumers that distinguish strings from packed integers
            // — fmt's argument stringifier, in particular — treat it correctly.
            check line_eq(lookup_var_type(nm, var_names, var_types), "fnret:str") == 1 {
                finish_str_result(tokens, strings, allnames, tmp, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types); return;
            }
            check call_is_u64 {
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "u64"); return;
            }
            // Resolve the remaining return types from the registered fnret:<ty> so a
            // lone call result (e.g. `echo!(f(x))`, `set r: i64 = f(x);`) is typed
            // correctly instead of falling through as a bare "ptr" (which made echo
            // print raw pointer bits and segfault). i128/u128 results are box ptrs
            // (passed through, typed); narrow/bool results are reinterpreted scalars
            // that echo_stringify recovers via coerce_i64 (ev_ty != "i64"); a plain
            // i64 must be ptrtoint'd here because echo_stringify skips coercion when
            // ev_ty == "i64".
            fixed crt: str = lookup_var_type(nm, var_names, var_types);
            check starts(crt, "fnret:") {
                fixed crtt: str = substr(crt, 6, len(crt));
                check crtt == "void" {
                    emit_uerr(ir, nm_pos, fmt("'{}' returns nothing (void); its result can't be used as a value.", nm));
                }
                check crtt == "i128" || crtt == "u128" {
                    push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, crtt); return;
                }
                check line_eq(crtt, "i64") == 1 {
                    fixed cti: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", cti), " = ptrtoint ptr "), str_concat(tmp, " to i64")));
                    push(out_val, cti); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
                }
                check (int_width(crtt) > 0) || crtt == "bool" {
                    push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, crtt); return;
                }
            }
            push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "ptr"); return;
        }
        // Undefined variable: nm is read as a value but has no slot in this function
        // (not a param, global, or already-declared local — e.g. a typo or a local
        // that belongs to a different function). Mark it for a clean located error
        // instead of clang's internal "undefined value %nm_slot" (TVC-5002).
        check slot_defined(ir, nm) == 1 { } fallback {
            emit(ir, str_concat(str_concat(str_concat("  ; tv.undefvar:", nm), ":"), int_to_str(nm_pos)));
        }
        fixed tmp: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = load ptr, ptr %"), nm), "_slot, align 8"));
        // Float variable: recover the double from the ptr slot (ptrtoint+bitcast)
        // and route to the f64 chain — must precede the i64 index/chain logic.
        // NOTE: type-map lookups are heap strings, so compare by content (line_eq),
        // not `==` (which lowers to pointer identity here).
        check line_eq(lookup_var_type(nm, var_names, var_types), "f64") == 1 {
            fixed fbits: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", fbits), " = ptrtoint ptr "), str_concat(tmp, " to i64")));
            fixed fdv: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", fdv), " = bitcast i64 "), str_concat(fbits, " to double")));
            check suppress_chain == 0 {
                chain_tail_f(tokens, strings, allnames, fdv, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
                return;
            }
            push(out_val, fdv); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "f64"); return;
        }
        // Index expression: NAME[ EXPR ]
        check tok_peek(tokens, p) == PUNCT_LBRACKET {
            // Indexing requires a list. A known scalar target (`x[0]` where x is an
            // i64/f64/bool/128-bit/str) would pass a non-list ptr to torvik_list_get
            // and crash. Reject cleanly. An unknown/unannotated type is left alone
            // (it may legitimately be a list created via `set xs = list_new();`).
            fixed idx_ty: str = lookup_var_type(nm, var_names, var_types);
            set idx_is_list: i64 = 0; check starts(idx_ty, "list") { idx_is_list = 1; }
            set idx_scalar: i64 = 0;
            check int_width(idx_ty) > 0 { idx_scalar = 1; }
            check idx_ty == "f64" || idx_ty == "bool" || idx_ty == "i128" || idx_ty == "u128" || idx_ty == "str" { idx_scalar = 1; }
            check idx_is_list == 0 && idx_scalar == 1 {
                emit_uerr(ir, p, fmt("cannot index into '{}' - it is type {}, not a list.", nm, idx_ty));
            }
            p += 1;
            set ixv: list<str> = list_new(); set ixp: list<i64> = list_new(); set ixs: list<i64> = list_new(); set ixs_ai: list<i64> = list_new(); set ixv_ty: list<str> = list_new();
            compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, ixv, ixp, ixs, ixs_ai, ixv_ty, var_names, var_types);
            check len(ixp) > 0 { p = ixp[0]; } check len(ixs) > 0 { s = ixs[0]; } check len(ixs_ai) > 0 { an = ixs_ai[0]; }
            check tok_peek(tokens, p) == PUNCT_RBRACKET { p += 1; }
            set ixval: str = "0"; check len(ixv) > 0 { ixval = ixv[0]; }
            set ixval_ty: str = "ptr"; check len(ixv_ty) > 0 { ixval_ty = ixv_ty[0]; }
            set ixi: str = ixval; check ixval_ty != "i64" { ixi = coerce_i64(ixval, ir, ctr); }
            fixed gtmp: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat(str_concat("  ", gtmp), " = call ptr @torvik_list_get(ptr "), tmp), str_concat(", i64 ", str_concat(ixi, ")"))));
            // Element type of the indexed list (from `list<ELEM>`). Drives how the
            // raw cell ptr is interpreted: a 128-bit element is a heap-box ptr (kept
            // as-is, typed for echo/store), an i64/narrow/bool element is an
            // inttoptr'd scalar (recovered via ptrtoint so it prints as a number
            // instead of being dereferenced as an address — the old lone-read crash).
            fixed lelem: str = list_elem_type(lookup_var_type(nm, var_names, var_types));
            set elem_is_128: i64 = 0; check line_eq(lelem, "i128") == 1 || line_eq(lelem, "u128") == 1 { elem_is_128 = 1; }
            // A 128-bit element can't ride the i64 compare/arith machinery below
            // (coerce_i64 would arithmetic-on-the-box-address). Bind it to an i128
            // variable first. (Matches the bare-var and call-arg 128-bit rules.)
            fixed ix_peek: i64 = tok_peek(tokens, p);
            set ix_peek_cmp: i64 = 0;
            check ix_peek == OP_EQEQ || ix_peek == OP_BANGEQ || ix_peek == OP_LT || ix_peek == OP_GT || ix_peek == OP_LTEQ || ix_peek == OP_GTEQ { ix_peek_cmp = 1; }
            // A 128-bit element followed by an arith/comparison op now folds via
            // the native i128 path (mirrors bare i128 variables): load the element
            // box to a native i128 lead, then either compare to i1 or fold an
            // arithmetic chain and re-box. Signedness follows the element type.
            check elem_is_128 == 1 && (ix_peek_cmp == 1 || (chain_tier6(ix_peek) > 0)) {
                fixed elead: str = i128_load_ir(gtmp, ir, ctr);
                set euns: i64 = 0; check int_signed(lelem) == 0 { euns = 1; }
                // Pure comparison: element <cmp> rhs -> i1.
                check ix_peek_cmp == 1 {
                    p += 1; // consume comparison op
                    set ecrp: list<i64> = list_new(); set ecrs: list<i64> = list_new(); set ecra: list<i64> = list_new();
                    fixed ecrhs: str = read_i128_operand(tokens, strings, allnames, p, s, an, ir, ctr, var_names, var_types, ecrp, ecrs, ecra);
                    check len(ecrp) > 0 { p = ecrp[0]; } check len(ecrs) > 0 { s = ecrs[0]; } check len(ecra) > 0 { an = ecra[0]; }
                    set epred: str = "";
                    check ix_peek == OP_EQEQ  { epred = "eq "; }
                    check ix_peek == OP_BANGEQ { epred = "ne "; }
                    check ix_peek == OP_LT    { epred = "slt"; check euns == 1 { epred = "ult"; } }
                    check ix_peek == OP_GT    { epred = "sgt"; check euns == 1 { epred = "ugt"; } }
                    check ix_peek == OP_LTEQ  { epred = "sle"; check euns == 1 { epred = "ule"; } }
                    check ix_peek == OP_GTEQ  { epred = "sge"; check euns == 1 { epred = "uge"; } }
                    fixed ecmp: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", ecmp), " = icmp "), epred), str_concat(" i128 ", elead)), str_concat(", ", ecrhs)));
                    push(out_val, ecmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;
                }
                // Arithmetic/bitwise chain: fold to a native i128 result, then re-box.
                set efp: list<str> = list_new(); set efpp: list<i64> = list_new(); set efps: list<i64> = list_new(); set efpa: list<i64> = list_new();
                fold_chain6_i128(tokens, strings, allnames, elead, p, s, an, ir, ctr, var_names, var_types, efp, efpp, efps, efpa, euns);
                fixed eres: str = efp[0];
                check len(efpp) > 0 { p = efpp[0]; } check len(efps) > 0 { s = efps[0]; } check len(efpa) > 0 { an = efpa[0]; }
                fixed ebox: str = i128_box_ir(eres, ir, ctr);
                push(out_val, ebox); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, lelem); return;
            }
            // Optional trailing comparison: NAME[i] == X etc. (stage 2: routed
            // through the shared tail — a list<str> element now compares by
            // CONTENT, not by pointer; suppressed when this index read is an
            // operand inside an enclosing arithmetic chain.)
            fixed ix_nop: i64 = tok_peek(tokens, p);
            // f64 element comparison uses float predicates (fcmp), not the integer
            // cmp tail — recover the double and compare against the float RHS.
            check suppress_chain == 0 && is_cmp_op(ix_nop) == 1 && line_eq(lelem, "f64") == 1 {
                fixed ixfcb: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", ixfcb), " = ptrtoint ptr "), str_concat(gtmp, " to i64")));
                fixed ixfcd: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", ixfcd), " = bitcast i64 "), str_concat(ixfcb, " to double")));
                chain_tail_f(tokens, strings, allnames, ixfcd, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
                return;
            }
            check suppress_chain == 0 && is_cmp_op(ix_nop) == 1 {
                set ixc_ty: str = "ptr";
                check line_eq(lelem, "str") == 1 { ixc_ty = "str"; }
                set ixc_hint: i64 = 0;
                check line_eq(ty_kind(lelem), "num") == 1 { ixc_hint = 1; }
                set ixc_u64: i64 = 0;
                check line_eq(lelem, "u64") == 1 { ixc_u64 = 1; }
                p += 1;
                compile_cmp_tail(tokens, strings, allnames, gtmp, ixc_ty, ixc_hint, ixc_u64, ix_nop, p, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
                return;
            }
            check suppress_chain == 0 && ix_nop == OP_BOUND {
                set ixb_str: i64 = 0; check line_eq(lelem, "str") == 1 { ixb_str = 1; }
                set ixb_hint: i64 = 0; check line_eq(ty_kind(lelem), "num") == 1 { ixb_hint = 1; }
                compile_bound_tail(tokens, strings, allnames, gtmp, ixb_str, ixb_hint, p + 1, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
                return;
            }
            check suppress_chain == 0 && ix_nop == OP_WEAVE {
                compile_weave_tail(tokens, strings, allnames, gtmp, lelem, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
                return;
            }
            // Stage 2: an index result may begin an arithmetic chain
            // (`xs[i] + xs[j]`, `xs[i] * 2`). Comparison-only handled above.
            // f64 elements use the FLOAT chain instead (recovered below).
            check suppress_chain == 0 && chain_tier6(tok_peek(tokens, p)) > 0 && line_eq(lelem, "f64") == 0 {
                fixed ixci: str = coerce_i64(gtmp, ir, ctr);
                // v1.1.3: a list<u64> element LEADING the chain selects unsigned
                // ops (previously hardcoded signed - `us[0] / 2` on a huge u64
                // divided as a negative signed value, a silent wrong answer).
                set ixcu: i64 = 0;
                check line_eq(lelem, "u64") == 1 { ixcu = 1; }
                chain_tail(tokens, strings, allnames, ixci, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, ixcu);
                return;
            }
            // Lone element read. A 128-bit element stays a box ptr (typed so echo
            // loads it and a store retains it); an integer/narrow element is
            // recovered to its scalar value; pointer-like elements (str, etc.) pass
            // through as before.
            check elem_is_128 == 1 {
                push(out_val, gtmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, lelem); return;
            }
            // v1.1.0: f64 element. The cell holds the double's bits (stored via
            // bitcast on push); recover the double by ptrtoint then bitcast. A
            // trailing float chain (`xs[i] + 1.5`) folds via chain_tail_f.
            check line_eq(lelem, "f64") == 1 {
                fixed ixfbits: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", ixfbits), " = ptrtoint ptr "), str_concat(gtmp, " to i64")));
                fixed ixfd: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", ixfd), " = bitcast i64 "), str_concat(ixfbits, " to double")));
                check suppress_chain == 0 && (chain_tier6(tok_peek(tokens, p)) > 0 || is_cmp_op(tok_peek(tokens, p)) == 1) {
                    chain_tail_f(tokens, strings, allnames, ixfd, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
                    return;
                }
                push(out_val, ixfd); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "f64"); return;
            }
            check (int_width(lelem) > 0) {
                fixed ixsc: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", ixsc), " = ptrtoint ptr "), str_concat(gtmp, " to i64")));
                push(out_val, ixsc); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, lelem); return;
            }
            // v1.1.3: a bool element is recovered to its scalar 0/1 and tagged
            // "bool" (previously it fell through as an untyped ptr, so
            // `echo!(bs[0])` stringified 0/1 as a string POINTER - a segfault).
            check line_eq(lelem, "bool") == 1 {
                fixed ixbc: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", ixbc), " = ptrtoint ptr "), str_concat(gtmp, " to i64")));
                push(out_val, ixbc); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "bool"); return;
            }
            // v1.1.0: a str element carries its type (fixes fmt("{}", xs[i])
            // printing a pointer address, and gives concat/comparison tails).
            check line_eq(lelem, "str") == 1 {
                finish_str_result(tokens, strings, allnames, gtmp, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types); return;
            }
            push(out_val, gtmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "ptr"); return;
        }
        // Check for binary operator following the identifier
        fixed next_op: i64 = tok_peek(tokens, p);
        // INCREMENT 4: var OP {int|plain-var} over six tiers (arith + bitwise).
        fixed wtier: i64 = chain_tier6(next_op);
        // A string-typed lead never enters the integer chain: '+' is concatenation
        // (handled below at the bare-value relabel), and other arithmetic operators
        // on a string fall through to a clean parse error rather than silently
        // coercing the pointer to i64.
        fixed lead_vty_pre: str = lookup_var_type(nm, var_names, var_types);
        set lead_is_str_pre: i64 = 0; check starts(lead_vty_pre, "str") { lead_is_str_pre = 1; }
        // Tier 3: 128-bit integers are heap-boxed, so they can never ride the i64
        // chain (coerce_i64 would arithmetic-on-the-box-address). An i128/u128 lead
        // followed by an arith/bitwise or comparison op takes the parallel native
        // i128 path: load the lead from its box, fold (arith) via fold_chain6_i128
        // and re-box, or compare directly to an i1. Signedness is lead-driven.
        set lead_is_128_pre: i64 = 0;
        check line_eq(lead_vty_pre, "i128") == 1 || line_eq(lead_vty_pre, "u128") == 1 { lead_is_128_pre = 1; }
        check lead_is_128_pre == 1 && (wtier > 0 || next_op == OP_EQEQ || next_op == OP_BANGEQ || next_op == OP_LT || next_op == OP_GT || next_op == OP_LTEQ || next_op == OP_GTEQ) {
            fixed lead128: str = i128_load_ir(tmp, ir, ctr);
            set uns128: i64 = 0; check int_signed(lead_vty_pre) == 0 { uns128 = 1; }
            // Pure comparison (no arithmetic): i128 lead <cmp> rhs -> i1.
            check wtier == 0 {
                p += 1; // consume the comparison operator
                set crp: list<i64> = list_new(); set crs: list<i64> = list_new(); set cra: list<i64> = list_new();
                fixed crhs: str = read_i128_operand(tokens, strings, allnames, p, s, an, ir, ctr, var_names, var_types, crp, crs, cra);
                check len(crp) > 0 { p = crp[0]; } check len(crs) > 0 { s = crs[0]; } check len(cra) > 0 { an = cra[0]; }
                set cpred: str = "";
                check next_op == OP_EQEQ  { cpred = "eq "; }
                check next_op == OP_BANGEQ { cpred = "ne "; }
                check next_op == OP_LT    { cpred = "slt"; check uns128 == 1 { cpred = "ult"; } }
                check next_op == OP_GT    { cpred = "sgt"; check uns128 == 1 { cpred = "ugt"; } }
                check next_op == OP_LTEQ  { cpred = "sle"; check uns128 == 1 { cpred = "ule"; } }
                check next_op == OP_GTEQ  { cpred = "sge"; check uns128 == 1 { cpred = "uge"; } }
                fixed ccmp: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", ccmp), " = icmp "), cpred), str_concat(" i128 ", lead128)), str_concat(", ", crhs)));
                push(out_val, ccmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;
            }
            // Arithmetic/bitwise chain: fold to a native i128 result.
            set f8v: list<str> = list_new(); set f8p: list<i64> = list_new(); set f8s: list<i64> = list_new(); set f8a: list<i64> = list_new();
            fold_chain6_i128(tokens, strings, allnames, lead128, p, s, an, ir, ctr, var_names, var_types, f8v, f8p, f8s, f8a, uns128);
            set cr128: str = lead128;
            check len(f8v) > 0 { cr128 = f8v[0]; }
            check len(f8p) > 0 { p = f8p[0]; }
            check len(f8s) > 0 { s = f8s[0]; }
            check len(f8a) > 0 { an = f8a[0]; }
            // Optional trailing comparison on the chain result: (a + b) > c -> i1.
            fixed t8_nop: i64 = tok_peek(tokens, p);
            check t8_nop == OP_EQEQ || t8_nop == OP_BANGEQ || t8_nop == OP_LT || t8_nop == OP_GT || t8_nop == OP_LTEQ || t8_nop == OP_GTEQ {
                p += 1;
                set t8p: list<i64> = list_new(); set t8s: list<i64> = list_new(); set t8a: list<i64> = list_new();
                fixed t8rhs: str = read_i128_operand(tokens, strings, allnames, p, s, an, ir, ctr, var_names, var_types, t8p, t8s, t8a);
                check len(t8p) > 0 { p = t8p[0]; } check len(t8s) > 0 { s = t8s[0]; } check len(t8a) > 0 { an = t8a[0]; }
                set t8pred: str = "";
                check t8_nop == OP_EQEQ  { t8pred = "eq "; }
                check t8_nop == OP_BANGEQ { t8pred = "ne "; }
                check t8_nop == OP_LT    { t8pred = "slt"; check uns128 == 1 { t8pred = "ult"; } }
                check t8_nop == OP_GT    { t8pred = "sgt"; check uns128 == 1 { t8pred = "ugt"; } }
                check t8_nop == OP_LTEQ  { t8pred = "sle"; check uns128 == 1 { t8pred = "ule"; } }
                check t8_nop == OP_GTEQ  { t8pred = "sge"; check uns128 == 1 { t8pred = "uge"; } }
                fixed t8cmp: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", t8cmp), " = icmp "), t8pred), str_concat(" i128 ", cr128)), str_concat(", ", t8rhs)));
                push(out_val, t8cmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;
            }
            // Re-box the arithmetic result. This box is classified "a:i128" in
            // temp_producer_code: retained at production, released at the next
            // statement flush — freed iff no slot claimed it (a store retains).
            fixed box128: str = i128_box_ir(cr128, ir, ctr);
            push(out_val, box128); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, lead_vty_pre); return;
        }
        check wtier > 0 && lead_is_str_pre == 0 {
            fixed peek2: i64 = tok_peek(tokens, p + 1);
            check peek2 == TOK_FLOAT {
                emit_uerr(ir, p, "float operand in an integer expression. Lead the expression with the float (e.g. `2.5 * count`), or convert with tofloat(...).");
            }
            fixed peek3: i64 = tok_peek(tokens, p + 2);
            set rhs_is_int: i64 = 0; check peek2 == TOK_INT { rhs_is_int = 1; }
            set rhs_is_var: i64 = 0; check peek2 == TOK_IDENT && peek3 != PUNCT_LPAREN && peek3 != PUNCT_LBRACKET { rhs_is_var = 1; }
            // Stage 2: a call/index/paren after the operator is also a foldable
            // operand now (fold_chain6 evaluates it via compile_expr), so enter
            // the chain for those too — not just int/plain-var.
            set rhs_is_call: i64 = 0; check peek2 == TOK_IDENT && (peek3 == PUNCT_LPAREN || peek3 == PUNCT_LBRACKET) { rhs_is_call = 1; }
            set rhs_is_par: i64 = 0; check peek2 == PUNCT_LPAREN { rhs_is_par = 1; }
            // v1.1.0 operator edges: `a - -b`, `a + -5`, `a * -f(x)` — a unary
            // minus prefixing the operand also enters the chain; fold_chain6
            // consumes the minus and negates the operand.
            set rhs_is_neg: i64 = 0;
            check peek2 == OP_MINUS {
                fixed peek3n: i64 = tok_peek(tokens, p + 2);
                check peek3n == TOK_INT || peek3n == TOK_IDENT || peek3n == PUNCT_LPAREN { rhs_is_neg = 1; }
            }
            check rhs_is_int == 1 || rhs_is_var == 1 || rhs_is_call == 1 || rhs_is_par == 1 || rhs_is_neg == 1 {
                set chcur: str = coerce_i64(tmp, ir, ctr);
                fixed lead_uns: i64 = line_eq(lead_vty_pre, "u64");
                set fcv: list<str> = list_new(); set fcp: list<i64> = list_new(); set fcs: list<i64> = list_new(); set fca: list<i64> = list_new();
                set fcu2: list<i64> = list_new();
                fold_chain6(tokens, strings, allnames, chcur, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, fcv, fcp, fcs, fca, lead_uns, fcu2);
                set c1_uns: i64 = lead_uns;
                check len(fcu2) > 0 { check fcu2[0] == 1 { c1_uns = 1; } }
                check len(fcv) > 0 { chcur = fcv[0]; }
                check len(fcp) > 0 { p = fcp[0]; }
                check len(fcs) > 0 { s = fcs[0]; }
                check len(fca) > 0 { an = fca[0]; }
                set cr: str = chcur;
                // ~> weave on the chain result: a + b ~> f == f(a+b). Loosest precedence.
                check tok_peek(tokens, p) == OP_WEAVE {
                    fixed cr_p: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", cr_p), " = inttoptr i64 "), str_concat(cr, " to ptr")));
                    set wcv: str = cr_p;
                    set wcg: i64 = 1;
                    whilst wcg == 1 {
                        check tok_peek(tokens, p) != OP_WEAVE { wcg = 0; } fallback {
                            p += 1;
                            check tok_peek(tokens, p) == TOK_IDENT {
                                fixed wcf: str = allnames[an]; an += 1; p += 1;
                                set wcsym: str = wcf;
                                check wcf == "trim"  { wcsym = "torvik_trim"; }
                                check wcf == "triml" { wcsym = "torvik_triml"; }
                                check wcf == "trimr" { wcsym = "torvik_trimr"; }
                                check wcf == "upper" { wcsym = "torvik_upper"; }
                                check wcf == "lower" { wcsym = "torvik_lower"; }
                                fixed wcr: str = make_tmp(ctr);
                                emit(ir, str_concat(str_concat(str_concat(str_concat("  ", wcr), " = call ptr @"), wcsym), str_concat("(ptr ", str_concat(wcv, ")"))));
                                wcv = wcr;
                            } fallback { wcg = 0; }
                        }
                    }
                    push(out_val, wcv); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "ptr"); return;
                }
                // trailing comparison reuses the existing pattern
                fixed c1_nop: i64 = tok_peek(tokens, p);
                check c1_nop == OP_EQEQ || c1_nop == OP_BANGEQ || c1_nop == OP_LT || c1_nop == OP_GT || c1_nop == OP_LTEQ || c1_nop == OP_GTEQ {
                    p += 1;
                    check tok_peek(tokens, p) == TOK_IDENT && tok_peek(tokens, p + 1) != PUNCT_LPAREN && tok_peek(tokens, p + 1) != PUNCT_LBRACKET {
                        check line_eq(lookup_var_type(allnames[an], var_names, var_types), "u64") == 1 { c1_uns = 1; }
                    }
                    set rvz: list<str> = list_new(); set rpz: list<i64> = list_new(); set rsz: list<i64> = list_new(); set rsz_ai: list<i64> = list_new(); set rsz_ty: list<str> = list_new();
                    compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rvz, rpz, rsz, rsz_ai, rsz_ty, var_names, var_types);
                    check len(rpz) > 0 { p = rpz[0]; } check len(rsz) > 0 { s = rsz[0]; } check len(rsz_ai) > 0 { an = rsz_ai[0]; }
                    set rhz: str = "0"; check len(rvz) > 0 { rhz = rvz[0]; }
                    set rhz_ty: str = "ptr"; check len(rsz_ty) > 0 { rhz_ty = rsz_ty[0]; }
                    set rhz_i: str = rhz; check rhz_ty != "i64" { rhz_i = coerce_i64(rhz, ir, ctr); }
                    check line_eq(rhz_ty, "u64") == 1 { c1_uns = 1; }
                    fixed c1cmp: str = make_tmp(ctr);
                    set c1pred: str = "";
                    check c1_nop == OP_EQEQ  { c1pred = "eq "; }
                    check c1_nop == OP_BANGEQ { c1pred = "ne "; }
                    check c1_nop == OP_LT    { c1pred = "slt"; check c1_uns == 1 { c1pred = "ult"; } }
                    check c1_nop == OP_GT    { c1pred = "sgt"; check c1_uns == 1 { c1pred = "ugt"; } }
                    check c1_nop == OP_LTEQ  { c1pred = "sle"; check c1_uns == 1 { c1pred = "ule"; } }
                    check c1_nop == OP_GTEQ  { c1pred = "sge"; check c1_uns == 1 { c1pred = "uge"; } }
                    emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", c1cmp), " = icmp "), c1pred), str_concat(" i64 ", cr)), str_concat(", ", rhz_i)));
                    push(out_val, c1cmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;
                }
                set chain_ty: str = "i64";
                check c1_uns == 1 { chain_ty = "u64"; }
                push(out_val, cr); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, chain_ty); return;
            }
        }
        // <| bound: membership. `item <| collection` -> torvik_contains(collection, item).
        // v1.0.0: i64/identity comparison per element (string-value membership is post-1.0).
        check next_op == OP_BOUND {
            p += 1; // skip <|
            // v1.1.0: routed through the shared tail — list<str> membership is
            // by CONTENT; the item may be any shape (this path: a variable).
            fixed vb_decl: str = lookup_var_type(nm, var_names, var_types);
            set vb_str: i64 = 0; check starts(vb_decl, "str") { vb_str = 1; }
            set vb_hint: i64 = 0; check line_eq(ty_kind(vb_decl), "num") == 1 { vb_hint = 1; }
            compile_bound_tail(tokens, strings, allnames, tmp, vb_str, vb_hint, p, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
            return;
        }
        // =|= kindred: identity / same-reference. Compare raw representations as
        // i64 (pointer address for ptr values, value bits for i64). Unlike ==,
        // never uses strcmp — distinct objects are not kindred even if equal-valued.
        check next_op == OP_KINDRED {
            p += 1; // skip =|=
            set rvk2: list<str> = list_new(); set rpk2: list<i64> = list_new(); set rsk2: list<i64> = list_new(); set rsk2_ai: list<i64> = list_new(); set rsk2_ty: list<str> = list_new();
            compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rvk2, rpk2, rsk2, rsk2_ai, rsk2_ty, var_names, var_types);
            check len(rpk2) > 0 { p = rpk2[0]; }
            check len(rsk2) > 0 { s = rsk2[0]; }
            check len(rsk2_ai) > 0 { an = rsk2_ai[0]; }
            set krhs: str = "null"; check len(rvk2) > 0 { krhs = rvk2[0]; }
            set krhs_ty: str = "ptr"; check len(rsk2_ty) > 0 { krhs_ty = rsk2_ty[0]; }
            fixed klhs_i: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", klhs_i), " = ptrtoint ptr "), str_concat(tmp, " to i64")));
            set krhs_i: str = krhs;
            check krhs_ty == "i1" {
                fixed kzx: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", kzx), " = zext i1 "), str_concat(krhs, " to i64")));
                krhs_i = kzx;
            } fallback {
                check krhs_ty != "i64" {
                    fixed krc: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", krc), " = ptrtoint ptr "), str_concat(krhs, " to i64")));
                    krhs_i = krc;
                }
            }
            fixed kres: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat(str_concat("  ", kres), " = icmp eq i64 "), klhs_i), str_concat(", ", krhs_i)));
            push(out_val, kres); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;
        }
        // ~> weave on a bare variable: s ~> trim ~> upper == upper(trim(s)).
        // v1.1.0: shared tail (typed results + trailing-comparison folding).
        check next_op == OP_WEAVE {
            compile_weave_tail(tokens, strings, allnames, tmp, lookup_var_type(nm, var_names, var_types), p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
            return;
        }
        check is_cmp_op(next_op) == 1 {
            p += 1; // skip operator
            // Stage 2: all variable comparisons go through the shared tail.
            // A str-typed variable (declared, or inferable) compares by content
            // for all six operators; numeric variables get the mixed-type guard
            // and the icmp path (unsigned ordering for u64).
            fixed lhs_decl_ty: str = lookup_var_type(nm, var_names, var_types);
            set vc_ty: str = "ptr";
            check starts(lhs_decl_ty, "str") { vc_ty = "str"; }
            set vc_hint: i64 = 0;
            check line_eq(ty_kind(lhs_decl_ty), "num") == 1 { vc_hint = 1; }
            set vc_u64: i64 = 0;
            check line_eq(lhs_decl_ty, "u64") == 1 { vc_u64 = 1; }
            compile_cmp_tail(tokens, strings, allnames, tmp, vc_ty, vc_hint, vc_u64, next_op, p, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
            return;
        }
        // Bare variable used as a plain value: report its mapped type when str/list
        // (both ptr-shaped — truthful relabel). Consumers that ptrtoint/store now
        // handle str/list alongside ptr (fixes above). i64/bool untouched.
        fixed vld_ty: str = lookup_var_type(nm, var_names, var_types);
        check starts(vld_ty, "str") {
            check suppress_chain == 0 && tok_peek(tokens, p) == OP_PLUS {
                emit_concat_chain(tmp, p, s, an, tokens, strings, allnames, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
                return;
            }
            finish_str_result(tokens, strings, allnames, tmp, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types); return;
        }
        check starts(vld_ty, "list") { push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "list"); return; }
        check line_eq(vld_ty, "i128") == 1 { push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i128"); return; }
        check line_eq(vld_ty, "u128") == 1 { push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "u128"); return; }
        push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "ptr"); return;
    }
    push(out_val, "null"); push(out_pos, p + 1); push(out_si, s); push(out_ani, an); push(out_ty, "ptr");
    }

// ─── Statement compiler ───────────────────────────────────────────────────────

// ── Unconsumed-tokens diagnostic (v1.0 hardening) ────────────────────────────
// compile_expr resolves a call/index/builtin primary and then only folds a
// trailing COMPARISON operator; a trailing arithmetic/bitwise operator is left
// unconsumed and the lenient `;`/`{` consumers below let it vanish. That is the
// silent miscompile that bit twice during the memory work (`f(x) + 16` dropped
// the `+ 16`; `starts(s,p) == 0` dropped the `== 0`). This guard, placed at the
// statement- and condition-level chokepoints, turns that class into a loud
// compile error. Operator token codes are 200..250 (lexer); delimiters (`;` `{`
// `)` `]`) are 300+, so a stranded operator is unambiguous here. Returns pos
// unchanged when clean; exits with a message (and the fix) when not.
// Classify a type for ternary branch unification: "ref" (str/list/bag/table/
// boxed 128-bit/result -> select on ptr), "float", "bool", or "int" (every other
// integer width, plus the uniform "ptr" that a bare int var read decays to).
df tern_kind(t: str) -> str {
    check line_eq(t, "f64") == 1 { return "float"; }
    check line_eq(t, "i1") == 1 { return "bool"; }
    check line_eq(t, "str") == 1 { return "ref"; }
    check starts(t, "list") { return "ref"; }
    check line_eq(t, "bag") == 1 { return "ref"; }
    check line_eq(t, "table") == 1 { return "ref"; }
    check line_eq(t, "i128") == 1 { return "ref"; }
    check line_eq(t, "u128") == 1 { return "ref"; }
    check starts(t, "result") { return "ref"; }
    return "int";
}

// Map a ref-kind branch type to its ARC runtime-family name ("" for value types).
// Used by the ternary's cross-edge retain and by the phi's tv.ternphi marker.
df tern_rc_kind(t: str) -> str {
    check line_eq(t, "str") == 1 { return "str"; }
    check starts(t, "list") { return "list"; }
    check line_eq(t, "bag") == 1 { return "bag"; }
    check starts(t, "table") { return "table"; }
    check starts(t, "result") { return "result"; }
    check line_eq(t, "i128") == 1 { return "i128"; }
    check line_eq(t, "u128") == 1 { return "i128"; }
    return "";
}

// The label of the block that is CURRENT at the end of `ir`, considering only
// labels emitted at index >= from_idx; `dflt` when none was (the branch stayed
// in its opening block). A nested ternary inside a branch ends in its own
// tern.end.M block — the phi's incoming label must be that actual predecessor.
df last_label_since(ir: list<str>, from_idx: i64, dflt: str) -> str {
    set lbl: str = dflt;
    set i: i64 = from_idx;
    whilst i < len(ir) {
        fixed l: str = ir[i];
        check len(l) > 1 {
            set indented: i64 = 0;
            check starts(l, " ") { indented = 1; }
            check indented == 0 {
                check ends(l, ":") { lbl = substr(l, 0, len(l) - 1); }
            }
        }
        i += 1;
    }
    return lbl;
}

// ── compile_value: an expression with an optional ternary tail ───────────────
// Torvik's ternary is  `cond ?> a !> b`  (?> = then, !> = else). This wraps
// compile_expr: with no `?>` following, it is a faithful pass-through, so it
// changes nothing for ternary-free code (the self-host fixpoint stays identical).
// The else-branch parses via compile_value, giving right-associative chaining:
//   a ?> x !> b ?> y !> z  ==  a ?> x !> (b ?> y !> z)
// v1.1.0: lowers to branch + phi, so ONLY the taken branch is evaluated (true
// short-circuit; v1.0 used a `select`, which evaluated both). ARC across the
// branch edges: each ref-kind branch retains its value before its `br` (the
// per-block flush then releases producer temps without freeing the carried
// value), and the merge phi is tagged `; tv.ternphi:KIND` so Stage E treats the
// result as an owned in-flight temp — one release at the statement flush, after
// any slot store has taken its own claim. Integer-family coercion to i64 is
// emitted INSIDE each branch block, so it too runs only on the taken path.
// ── compile_tern_tail: the `?> a !> b` tail of a ternary ─────────────────────
// The caller has compiled the condition (cond_v/cond_ty) and verified the token
// at vp is `?>`; this consumes it and both branches. Shared by compile_value
// (top-level ternaries) and the parenthesized-expression path in compile_expr
// (`(cond ?> a !> b)`), so the ternary works anywhere parentheses do.
df compile_tern_tail(tokens: list<i64>, strings: list<str>, allnames: list<str>, cond_v: str, cond_ty: str, pos: i64, si: i64, ani: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>, var_names: list<str>, var_types: list<str>) -> void {
    set vp: i64 = pos + 1;   // consume `?>`
    set vs: i64 = si;
    set va: i64 = ani;

    set cond_i1: str = cond_v;
    check cond_ty != "i1" {
        fixed zt: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", zt), " = icmp ne i64 "), str_concat(coerce_i64(cond_v, ir, ctr), ", 0")));
        cond_i1 = zt;
    }

    fixed tn: i64 = ctr[0];
    ctr[0] = tn + 1;
    fixed lthen: str = str_concat("tern.then.", int_to_str(tn));
    fixed lelse: str = str_concat("tern.else.", int_to_str(tn));
    fixed lend:  str = str_concat("tern.end.",  int_to_str(tn));

    emit(ir, fmt("  br i1 {}, label %{}, label %{}", cond_i1, lthen, lelse));
    emit(ir, str_concat(lthen, ":"));
    fixed then_start: i64 = len(ir);

    set tv: list<str> = list_new(); set tp: list<i64> = list_new(); set ts: list<i64> = list_new(); set ta: list<i64> = list_new(); set tty: list<str> = list_new();
    compile_expr(tokens, strings, allnames, vp, vs, va, ir, ctr, gvals, gnames, tv, tp, ts, ta, tty, var_names, var_types);
    check len(tp) > 0 { vp = tp[0]; } check len(ts) > 0 { vs = ts[0]; } check len(ta) > 0 { va = ta[0]; }
    set then_v: str = "null"; check len(tv) > 0 { then_v = tv[0]; }
    set then_ty: str = "ptr"; check len(tty) > 0 { then_ty = tty[0]; }

    // Finish the then block: coerce (int family) / retain (ref family) IN the
    // branch, then jump to the merge. The retain carries the value across the
    // edge past the flush-at-br release of producer temps.
    set then_out: str = then_v;
    check line_eq(tern_kind(then_ty), "int") == 1 { then_out = coerce_i64(then_v, ir, ctr); }
    fixed rck_t: str = tern_rc_kind(then_ty);
    check len(rck_t) > 0 {
        check then_v != "null" {
            emit(ir, fmt("  call ptr @torvik_{}_retain(ptr {})", rck_t, then_v));
        }
    }
    emit(ir, str_concat("  br label %", lend));
    fixed pred_then: str = last_label_since(ir, then_start, lthen);

    check tok_peek(tokens, vp) == OP_TERNELSE { vp += 1; } fallback {
        emit_uerr(ir, vp, "this ternary is missing its `!>` else-branch (the form is `cond ?> a !> b`).");
    }

    emit(ir, str_concat(lelse, ":"));
    fixed else_start: i64 = len(ir);

    set ev: list<str> = list_new(); set ep: list<i64> = list_new(); set es: list<i64> = list_new(); set ea: list<i64> = list_new(); set ety: list<str> = list_new();
    compile_value(tokens, strings, allnames, vp, vs, va, ir, ctr, gvals, gnames, ev, ep, es, ea, ety, var_names, var_types);
    check len(ep) > 0 { vp = ep[0]; } check len(es) > 0 { vs = es[0]; } check len(ea) > 0 { va = ea[0]; }
    set else_v: str = "null"; check len(ev) > 0 { else_v = ev[0]; }
    set else_ty: str = "ptr"; check len(ety) > 0 { else_ty = ety[0]; }

    set else_out: str = else_v;
    check line_eq(tern_kind(else_ty), "int") == 1 { else_out = coerce_i64(else_v, ir, ctr); }
    fixed rck_e: str = tern_rc_kind(else_ty);
    check len(rck_e) > 0 {
        check else_v != "null" {
            emit(ir, fmt("  call ptr @torvik_{}_retain(ptr {})", rck_e, else_v));
        }
    }
    emit(ir, str_concat("  br label %", lend));
    fixed pred_else: str = last_label_since(ir, else_start, lelse);

    fixed tk_then: str = tern_kind(then_ty);
    fixed tk_else: str = tern_kind(else_ty);
    check line_eq(tk_then, tk_else) == 0 {
        emit_uerr(ir, vp, fmt("a ternary's branches must be the same type, but got '{}' and '{}'.", then_ty, else_ty));
    }

    emit(ir, str_concat(lend, ":"));
    fixed selr: str = make_tmp(ctr);
    check line_eq(tk_then, "bool") == 1 {
        emit(ir, fmt("  {} = phi i1 [ {}, %{} ], [ {}, %{} ]", selr, then_v, pred_then, else_v, pred_else));
        push(out_val, selr); push(out_pos, vp); push(out_si, vs); push(out_ani, va); push(out_ty, "i1");
        return;
    }
    check line_eq(tk_then, "float") == 1 {
        emit(ir, fmt("  {} = phi double [ {}, %{} ], [ {}, %{} ]", selr, then_v, pred_then, else_v, pred_else));
        push(out_val, selr); push(out_pos, vp); push(out_si, vs); push(out_ani, va); push(out_ty, "f64");
        return;
    }
    check line_eq(tk_then, "ref") == 1 {
        emit(ir, fmt("  {} = phi ptr [ {}, %{} ], [ {}, %{} ] ; tv.ternphi:{}", selr, then_v, pred_then, else_v, pred_else, rck_t));
        push(out_val, selr); push(out_pos, vp); push(out_si, vs); push(out_ani, va); push(out_ty, then_ty);
        return;
    }
    // Integer family (incl. ptr-erased int var reads): both sides were coerced
    // to i64 inside their own branch blocks.
    emit(ir, fmt("  {} = phi i64 [ {}, %{} ], [ {}, %{} ]", selr, then_out, pred_then, else_out, pred_else));
    push(out_val, selr); push(out_pos, vp); push(out_si, vs); push(out_ani, va); push(out_ty, "i64");
}

df compile_value(tokens: list<i64>, strings: list<str>, allnames: list<str>, pos: i64, si: i64, ani: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>, var_names: list<str>, var_types: list<str>) -> void {
    set cv: list<str> = list_new(); set cp: list<i64> = list_new(); set cs: list<i64> = list_new(); set ca: list<i64> = list_new(); set cty: list<str> = list_new();
    compile_expr(tokens, strings, allnames, pos, si, ani, ir, ctr, gvals, gnames, cv, cp, cs, ca, cty, var_names, var_types);
    set vp: i64 = pos; check len(cp) > 0 { vp = cp[0]; }
    set vs: i64 = si;  check len(cs) > 0 { vs = cs[0]; }
    set va: i64 = ani; check len(ca) > 0 { va = ca[0]; }
    set cond_v: str = "null"; check len(cv) > 0 { cond_v = cv[0]; }
    set cond_ty: str = "ptr"; check len(cty) > 0 { cond_ty = cty[0]; }

    check tok_peek(tokens, vp) != OP_TERNTHEN {
        push(out_val, cond_v); push(out_pos, vp); push(out_si, vs); push(out_ani, va); push(out_ty, cond_ty);
        return;
    }
    compile_tern_tail(tokens, strings, allnames, cond_v, cond_ty, vp, vs, va, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
}

df check_no_stranded_op(tokens: list<i64>, pos: i64, ir: list<str>) -> i64 {
    fixed t: i64 = tok_peek(tokens, pos);
    set stranded: i64 = 0;
    check t >= 200 && t <= 250 && t != OP_TERNTHEN && t != OP_TERNELSE && t != OP_DOTDOT && t != OP_DOTDOTPLUS { stranded = 1; }
    check stranded == 1 {
        emit_uerr(ir, pos, "this expression leaves an operator that could not be folded. If it mixes arithmetic and a comparison, parenthesize the comparison side - e.g. `(a + f(x)) > b`");
    }
    return pos;
}

df compile_stmts(tokens: list<i64>, strings: list<str>, allnames: list<str>, start: i64, end: i64, si: i64, ani: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, lctr: list<i64>, fn_ret_type: str, var_names: list<str>, var_types: list<str>, global_names: list<str>, err_pos: list<i64>, err_msg: list<str>) -> i64 {
    set pos: i64 = start;
    set s: i64 = si;
    set an: i64 = ani;
    // return value encodes both s and an: (an * 100000) + s
    // caller unpacks: s = ret % 100000; an = ret / 100000
    fixed ntok: i64 = len(tokens);

    // v1.2.0: 0 = normal; 1 = previous statement was a terminator (warn on the
    // next statement); 2 = already warned in this block (stay quiet).
    set after_term: i64 = 0;

    whilst pos < end && pos < ntok && tok_peek(tokens, pos) != TOK_EOF {
        // Memory Stage E: statement boundary marker. inject_temp_cleanup flushes
        // unclaimed producer temps here and strips the marker from final IR.
        emit(ir, "  ; tv.stmt");
        // `unsafe` prefixes a statement to opt into operations the compiler would
        // otherwise reject — currently out-of-range literal truncation. The flag
        // applies to the single statement that follows.
        set unsafe_decl: i64 = 0;
        check tok_peek(tokens, pos) == KW_UNSAFE { unsafe_decl = 1; pos += 1; }
        // `unsafe` only opts into a compiler-rejected operation (currently: wrapping an
        // out-of-range integer literal into a sized type), which can only occur on a
        // declaration or an assignment. On any other statement it overrides nothing, so
        // reject it with a clean error rather than accepting it as a silent no-op.
        check unsafe_decl == 1 {
            fixed _unt: i64 = tok_peek(tokens, pos);
            set _unok: i64 = 0;
            check _unt == KW_FIXED { _unok = 1; }
            check _unt == KW_SET { _unok = 1; }
            check _unt == TOK_IDENT {
                fixed _unn: i64 = tok_peek(tokens, pos + 1);
                check _unn != PUNCT_LPAREN { _unok = 1; }
            }
            check _unok == 0 {
                push(err_pos, pos);
                push(err_msg, "unsafe can only prefix a declaration or assignment - it opts into wrapping an out-of-range integer literal into a sized type, and has no meaning on this statement");
            }
        }
        fixed t: i64 = tok_peek(tokens, pos);

        // v1.2.0: unreachable-code warning. If the PREVIOUS statement in this
        // block was a terminator (return / break / continue / halt / exit),
        // this statement can never run. Warn once per block and keep compiling.
        check after_term == 1 && t != KW_RETURN {
            emit_warn(ir, pos, "unreachable_code", "unreachable code - this statement follows a return/break/continue/halt/exit and can never run");
            after_term = 2;
        }
        // A `return` in unreachable position is exempt: `halt(...); return "";`
        // is the sanctioned idiom for satisfying the all-paths-return check
        // after a terminating call. Statements after THAT return still warn.
        check after_term != 2 {
            after_term = 0;
            check t == KW_RETURN || t == KW_BREAK || t == KW_CONTINUE { after_term = 1; }
            check t == TOK_IDENT && tok_peek(tokens, pos + 1) == PUNCT_LPAREN {
                fixed _tsn: str = allnames[an];
                check line_eq(_tsn, "halt") == 1 || line_eq(_tsn, "exit") == 1 { after_term = 1; }
            }
        }

        // fixed/set NAME: TYPE = EXPR;
        check t == KW_FIXED || t == KW_SET {
            fixed decl_pos: i64 = pos;
            pos += 1;
            set vname: str = "";
            check tok_peek(tokens, pos) == TOK_IDENT {
                vname = allnames[an]; an += 1; pos += 1; }
            // A local that reuses a global's name would emit a second %NAME_slot,
            // colliding with the global's slot (clang TVC-5002). Report it cleanly.
            // Recover to the next ';' so indices stay synced.
            check len(vname) > 0 {
                set g_dup: i64 = 0;
                set g_di: i64 = 0;
                whilst g_di < len(global_names) {
                    check line_eq(global_names[g_di], vname) == 1 { g_dup = 1; }
                    g_di += 1;
                }
                check g_dup == 1 {
                    push(err_pos, pos - 1);
                    push(err_msg, str_concat(str_concat("'", vname), "' is already declared as a global variable - assign it with 'name = value;' (no 'set'), or rename the local"));
                    whilst pos < end && pos < ntok && tok_peek(tokens, pos) != PUNCT_SEMI {
                        fixed _gtk: i64 = tok_peek(tokens, pos);
                        check _gtk == TOK_INT || _gtk == TOK_FLOAT { s += 1; }
                        check _gtk == TOK_STRING { s += 1; an += 1; }
                        check _gtk == TOK_IDENT { an += 1; }
                        pos += 1;
                    }
                    check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
                    continue;
                }
            }
            // Capture : TYPE annotation while advancing indices IDENTICALLY to before.
            // Records the annotation text (e.g. "list<str>", "str", "i64") into the type map.
            set vann: str = "";
            set had_colon: i64 = 0;
            set ann_start: i64 = pos;
            check tok_peek(tokens, pos) == PUNCT_COLON {
                had_colon = 1;
                pos += 1;
                ann_start = pos;
                whilst pos < ntok && tok_peek(tokens, pos) != OP_EQ && tok_peek(tokens, pos) != PUNCT_SEMI && tok_peek(tokens, pos) != OP_GTEQ {
                    fixed _atk: i64 = tok_peek(tokens, pos);
                    check _atk == TOK_STRING { s += 1; an += 1; }
                    check _atk == TOK_IDENT  { vann = str_concat(vann, allnames[an]); an += 1; }
                    check _atk == OP_LT { vann = str_concat(vann, "<"); }
                    check _atk == OP_GT { vann = str_concat(vann, ">"); }
                    check _atk == OP_SHR { vann = str_concat(vann, ">>"); }
                    check _atk == PUNCT_COMMA { vann = str_concat(vann, ","); }
                    pos += 1;
                }
                // A generic close glued to the assignment lexes as one token:
                // `list<i64>=` -> OP_GTEQ, `list<list<i64>>=` -> OP_SHR + OP_EQ.
                // Treat OP_GTEQ as the closing `>` plus the `=`; without this the
                // loop runs past the assignment and swallows the RHS into the
                // annotation (e.g. vann "list<i64list_new", leaving the var null).
                check tok_peek(tokens, pos) == OP_GTEQ { vann = str_concat(vann, ">"); pos += 1; }
            }
            // An explicit ':' must be followed by a type name. `set x: = ...`
            // (colon present, no type) was silently accepted before. Caret on ':'.
            // v1.2.1: an unannotated declaration is only supported for the
            // documented inference case, `set xs = list_new();`. Every other
            // shape previously compiled SILENTLY BROKEN: a call result read
            // back as garbage aliasing unrelated memory, and a plain variable
            // copy (`set b = a;`) segfaulted. The guide has always said
            // declarations require a type annotation - now the compiler does.
            check had_colon == 0 {
                set uad_ok: i64 = 0;
                check tok_peek(tokens, pos) == OP_EQ && tok_peek(tokens, pos + 1) == TOK_IDENT && tok_peek(tokens, pos + 2) == PUNCT_LPAREN && tok_peek(tokens, pos + 3) == PUNCT_RPAREN {
                    check line_eq(allnames[an], "list_new") == 1 { uad_ok = 1; }
                }
                check uad_ok == 0 {
                    push(err_pos, decl_pos);
                    push(err_msg, fmt("'{}' needs a type annotation - write `set {}: str = ...;` (or i64, f64, bool, ...). Only `set xs = list_new();` may omit it: the element type is inferred from the first push.", vname, vname));
                    whilst pos < end && pos < ntok && tok_peek(tokens, pos) != PUNCT_SEMI {
                        fixed _uak: i64 = tok_peek(tokens, pos);
                        check _uak == TOK_INT || _uak == TOK_FLOAT { s += 1; }
                        check _uak == TOK_STRING { s += 1; an += 1; }
                        check _uak == TOK_IDENT { an += 1; }
                        pos += 1;
                    }
                    check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
                    continue;
                }
            }
            check had_colon == 1 && len(vann) == 0 {
                push(err_pos, pos - 1);
                push(err_msg, "expected a type after ':'");
                whilst pos < end && pos < ntok && tok_peek(tokens, pos) != PUNCT_SEMI {
                    fixed _dtk: i64 = tok_peek(tokens, pos);
                    check _dtk == TOK_INT || _dtk == TOK_FLOAT { s += 1; }
                        check _dtk == TOK_STRING { s += 1; an += 1; }
                    check _dtk == TOK_IDENT { an += 1; }
                    pos += 1;
                }
                check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
                continue;
            }
            // An annotation that names no known type (e.g. `set x: zorp = 5`) would
            // otherwise be recorded and reach codegen, producing broken IR or a
            // crash. Reject cleanly; caret on the annotation. Recover to the ';'.
            check had_colon == 1 && len(vann) > 0 && is_value_type(vann) == 0 && is_aett_name(vann) == 0 {
                push(err_pos, ann_start);
                push(err_msg, str_concat(str_concat("unknown type '", vann), "' - expected i64, f64, str, bool, or a list/bag/table/result type"));
                whilst pos < end && pos < ntok && tok_peek(tokens, pos) != PUNCT_SEMI {
                    fixed _utk: i64 = tok_peek(tokens, pos);
                    check _utk == TOK_INT || _utk == TOK_FLOAT { s += 1; }
                        check _utk == TOK_STRING { s += 1; an += 1; }
                    check _utk == TOK_IDENT { an += 1; }
                    pos += 1;
                }
                check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
                continue;
            }
            // Redeclaring a name with a DIFFERENT type in the same function is
            // memory corruption, not shadowing: both declarations share one slot.
            // Reject cleanly; caret on the variable name. Recover to the ';'.
            check len(vname) > 0 && len(vann) > 0 {
                check redecl_conflict(vname, vann, var_names, var_types) == 1 {
                    set _rmsg: str = str_concat("'", vname);
                    _rmsg = str_concat(_rmsg, "' is already declared with type ");
                    _rmsg = str_concat(_rmsg, lookup_var_type(vname, var_names, var_types));
                    _rmsg = str_concat(_rmsg, " in this function - redeclaring it as ");
                    _rmsg = str_concat(_rmsg, vann);
                    _rmsg = str_concat(_rmsg, " would corrupt its storage; use a different name");
                    push(err_pos, decl_pos + 1);
                    push(err_msg, _rmsg);
                    whilst pos < end && pos < ntok && tok_peek(tokens, pos) != PUNCT_SEMI {
                        fixed _rtk: i64 = tok_peek(tokens, pos);
                        check _rtk == TOK_INT || _rtk == TOK_FLOAT { s += 1; }
                        check _rtk == TOK_STRING { s += 1; an += 1; }
                        check _rtk == TOK_IDENT { an += 1; }
                        pos += 1;
                    }
                    check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
                    continue;
                }
            }
            // Stage 1: record (vname, annotation). Nothing reads this yet.
            set vt_idx: i64 = 0 - 1;
            check len(vname) > 0 { push(var_names, vname); push(var_types, vann); vt_idx = len(var_types) - 1; }
            // v1.1.3: record the binding's mutability so reassignment of a
            // `fixed` binding is a clean compile error (previously unenforced -
            // `set x = 1; x = 2;` compiled and mutated silently).
            check len(vname) > 0 && t == KW_FIXED { push(var_names, str_concat("@fixed@", vname)); push(var_types, "1"); }
            // v1.2.0: declaration marker for the unused-variable warning pass.
            check len(vname) > 0 {
                emit(ir, str_concat(str_concat(str_concat("  ; tv.declpos:", vname), ":"), int_to_str(decl_pos)));
            }
            set had_eq: i64 = 0;
            check tok_peek(tokens, pos) == OP_EQ { pos += 1; had_eq = 1; }
            // Reject an empty right-hand side: `fixed x: T = ;` — the '=' is present
            // but no initializer expression follows. Caret lands on the '='. Recover
            // by consuming the ';' so further errors in the file still surface.
            check had_eq == 1 && tok_peek(tokens, pos) == PUNCT_SEMI {
                push(err_pos, pos - 1);
                push(err_msg, "expected an expression after '='");
                pos += 1;
                continue;
            }
            // Reject an out-of-range integer literal for a sized type. Silent
            // truncation would change the value and hide bugs; `unsafe` opts in.
            check unsafe_decl == 0 && tok_peek(tokens, pos) == TOK_INT && tok_peek(tokens, pos + 1) == PUNCT_SEMI {
                set _rlo: list<i64> = list_new();
                set _rhi: list<i64> = list_new();
                check int_range(vann, _rlo, _rhi) == 1 {
                    fixed _lit: str = strings[s];
                    fixed _lv: i64 = toint(_lit);
                    check _lv < _rlo[0] || _lv > _rhi[0] {
                        set _emsg: str = str_concat("literal ", _lit);
                        _emsg = str_concat(_emsg, " is out of range for ");
                        _emsg = str_concat(_emsg, vann);
                        _emsg = str_concat(_emsg, " (valid ");
                        _emsg = str_concat(_emsg, int_to_str(_rlo[0]));
                        _emsg = str_concat(_emsg, " to ");
                        _emsg = str_concat(_emsg, int_to_str(_rhi[0]));
                        _emsg = str_concat(_emsg, ") - prefix the statement with 'unsafe' to wrap intentionally");
                        push(err_pos, pos);
                        push(err_msg, _emsg);
                        pos += 1; s += 1;
                        check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
                        continue;
                    }
                }
                check line_eq(vann, "u64") == 1 {
                    fixed _ulit: str = strings[s];
                    check u64_in_range(_ulit) == 0 {
                        set _umsg: str = str_concat("literal ", _ulit);
                        _umsg = str_concat(_umsg, " is out of range for u64 (valid 0 to 18446744073709551615) - prefix the statement with 'unsafe' to wrap intentionally");
                        push(err_pos, pos);
                        push(err_msg, _umsg);
                        pos += 1; s += 1;
                        check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
                        continue;
                    }
                }
            }
            // Detect type from RHS token before compiling
            set vtype: str = "ptr";
            fixed rhs_tok: i64 = tok_peek(tokens, pos);
            check rhs_tok == TOK_INT { vtype = "i64"; }
            check rhs_tok == KW_TRUE || rhs_tok == KW_FALSE { vtype = "i1"; }
            // For function calls: check if function name is known to return i64
            check rhs_tok == TOK_IDENT {
                fixed fn_peek: str = allnames[an];
                check fn_peek == "args" || fn_peek == "args_count" { vtype = "i64"; }
                check fn_peek == "len" || fn_peek == "length" { vtype = "i64"; }
                check fn_peek == "tok_peek" || fn_peek == "char_at" { vtype = "i64"; }
                check fn_peek == "strcmp_result" || fn_peek == "atoi" { vtype = "i64"; }
                check fn_peek == "skip_to_close_brace" || fn_peek == "skip_to_close_paren" { vtype = "i64"; }
                check fn_peek == "keyword_for" || fn_peek == "is_whitespace" { vtype = "i64"; }
                check fn_peek == "int_to_str" { vtype = "ptr"; }
            }
            set rv: list<str> = list_new();
            set rp: list<i64> = list_new();
            set rs: list<i64> = list_new();
            set rs_ai: list<i64> = list_new();
            set rv_ty: list<str> = list_new();
            set _i128lit: i64 = 0;
            // Positive i128/u128 literal: `NN;`. Negative: `- NN;` (unary minus
            // then int). Both take the boxing fast-path; compile_value's generic
            // unary-minus handling is i64-only and can't box a 128-bit literal.
            set _i128_neg: i64 = 0;
            check line_eq(vann, "i128") == 1 && tok_peek(tokens, pos) == OP_MINUS && tok_peek(tokens, pos + 1) == TOK_INT && tok_peek(tokens, pos + 2) == PUNCT_SEMI { _i128_neg = 1; }
            // A negative literal assigned to an unsigned u128 is a clean error
            // (rather than falling through to the i64-only unary-minus path).
            check line_eq(vann, "u128") == 1 && tok_peek(tokens, pos) == OP_MINUS && tok_peek(tokens, pos + 1) == TOK_INT {
                push(err_pos, pos); push(err_msg, str_concat(str_concat("literal -", strings[s]), " is out of range for u128 (unsigned)"));
                pos += 2; s += 1;
                check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
                continue;
            }
            check (line_eq(vann, "i128") == 1 || line_eq(vann, "u128") == 1) && tok_peek(tokens, pos) == TOK_INT && tok_peek(tokens, pos + 1) == PUNCT_SEMI {
                fixed _lit: str = strings[s];
                set _ok: i64 = 1;
                check line_eq(vann, "i128") == 1 { _ok = i128_in_range(_lit); }
                check line_eq(vann, "u128") == 1 { _ok = u128_in_range(_lit); }
                check _ok == 0 {
                    set _m: str = str_concat(str_concat(str_concat("literal ", _lit), " is out of range for "), vann);
                    push(err_pos, pos); push(err_msg, _m);
                    pos += 1; s += 1;
                    check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
                    continue;
                }
                fixed _bx: str = i128_box_lit(_lit, ir, ctr);
                push(rv, _bx); push(rp, pos + 1); push(rs, s + 1); push(rs_ai, an); push(rv_ty, vann);
                _i128lit = 1;
            }
            check _i128_neg == 1 && _i128lit == 0 {
                fixed _nlit: str = strings[s];
                fixed _nfull: str = str_concat("-", _nlit);
                check i128_neg_in_range(_nlit) == 0 {
                    set _m2: str = str_concat(str_concat(str_concat("literal ", _nfull), " is out of range for "), vann);
                    push(err_pos, pos); push(err_msg, _m2);
                    pos += 2; s += 1;
                    check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
                    continue;
                }
                fixed _nbx: str = i128_box_lit(_nfull, ir, ctr);
                push(rv, _nbx); push(rp, pos + 2); push(rs, s + 1); push(rs_ai, an); push(rv_ty, vann);
                _i128lit = 1;
            }
            check _i128lit == 0 {
                compile_value(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, rv, rp, rs, rs_ai, rv_ty, var_names, var_types);
            }
            check len(rp) > 0 { pos = rp[0]; }
            check len(rs) > 0 { s   = rs[0]; }
            check len(rs_ai) > 0 { an = rs_ai[0]; }
            // Use actual return type from compile_expr if available
            check len(rv_ty) > 0 { vtype = rv_ty[0]; }
            // A list bound without an element-type annotation (`set xs = list_new();`)
            // has an unknown element type. v1.1.0: try to INFER it from the first
            // push(xs, VALUE) in this function. If inference finds a concrete
            // element type, record `list<ELEM>` in the type map (so reads, each,
            // membership, and pop are all typed). Only when inference fails do we
            // fall back to requiring the annotation.
            check len(vann) == 0 && starts(vtype, "list") {
                fixed inferred: str = infer_list_elem(vname, tokens, strings, allnames, pos, s, an, end, var_names, var_types);
                check len(inferred) > 0 {
                    fixed full_lt: str = str_concat(str_concat("list<", inferred), ">");
                    // rewrite the recorded type (was bare "list" or the RHS "list")
                    set _vi: i64 = len(var_types) - 1;
                    set _found: i64 = 0;
                    whilst _vi >= 0 && _found == 0 {
                        check line_eq(var_names[_vi], vname) == 1 { var_types[_vi] = full_lt; _found = 1; }
                        _vi -= 1;
                    }
                    vann = full_lt;
                } fallback {
                    push(err_pos, decl_pos);
                    push(err_msg, "a list needs an element type - annotate it (`set xs: list<i64> = list_new();`) or push a value so it can be inferred");
                    continue;
                }
            }
            // Assignment type-compatibility: when both the annotation and the RHS
            // resolve to a concrete kind (num/str/list), they must match. Mismatches
            // like `set x: i64 = "hello"` or `set s: str = 5` would otherwise store a
            // pointer-as-int (or vice versa) and print garbage. "other" kinds
            // (bag/table/result, or the ambiguous uniform "ptr") are never flagged.
            check len(vann) > 0 && len(rv_ty) > 0 {
                fixed rtt: str = rv_ty[0];
                fixed vk: str = ty_kind(vann);
                fixed rk: str = ty_kind(rtt);
                check line_eq(vk, "other") == 0 && line_eq(rk, "other") == 0 && line_eq(vk, rk) == 0 {
                    push(err_pos, decl_pos);
                    push(err_msg, fmt("type mismatch: can't assign a value of type {} to '{}', which has type {}", rtt, vname, vann));
                    continue;
                }
            }
            // Inferred (unannotated) locals carry no type in the map, so a scalar
            // (float/int/bool) would read back as raw ptr bits and a lone read (e.g.
            // `echo!(x)`) would dereference them — a crash. Once the RHS type is
            // known, record it for unannotated scalar locals so reads recover the
            // value. Pointer-shaped inferred types (str/list/...) already relabel
            // correctly on read and keep their existing behavior.
            check vt_idx >= 0 && len(vann) == 0 && (vtype == "f64" || vtype == "i64" || vtype == "u64" || vtype == "i1" || vtype == "bool") {
                var_types[vt_idx] = vtype;
            }
            // Store all values as ptr (convert non-ptr via inttoptr)
            fixed slot: str = str_concat(str_concat("%", vname), "_slot");
            fixed alloca_line: str = str_concat(str_concat("  ", slot), " = alloca ptr, align 8");
            check slot_exists(ir, alloca_line) == 0 { emit(ir, alloca_line); }
            // ARC Stage A/B3: refcounted slot kinds. rc_kind selects which runtime
            // family (torvik_list_* / torvik_str_*) guards this slot; "" = raw slot
            // (i64/i1/bool/unannotated) with no refcount ops anywhere — coherent
            // with the reassignment path, which gates on the same type map.
            set rc_kind: str = "";
            check starts(vann, "list") { rc_kind = "list"; }
            check vann == "str" { rc_kind = "str"; }
            check starts(vann, "bag") { rc_kind = "bag"; }  // v1.1.3: starts(), not == - `bag<str>` never matched, so bag slots skipped ARC entirely (use-after-free)
            check vann == "i128" || vann == "u128" { rc_kind = "i128"; }
            check starts(vann, "table") { rc_kind = "table"; }
            check starts(vann, "result") { rc_kind = "result"; }
            // Refcounted slots must start null so release-of-old-contents is safe
            // on the first store. Tagged ; tv.rcinit so hoist_allocas moves it to
            // the entry block — it must run ONCE per function, NOT per loop
            // iteration (an in-place re-null would leak the previous iteration's
            // value before the release below could see it).
            check len(rc_kind) > 0 {
                fixed init_line: str = str_concat(str_concat("  store ptr null, ptr ", slot), str_concat(", align 8 ; tv.rcinit:", rc_kind));
                check slot_exists(ir, init_line) == 0 { emit(ir, init_line); }
            }
            check len(rv) > 0 && rv[0] != "void" {
                check vtype == "i64" || vtype == "u64" || vtype == "bool" {
                    // Narrow integer types wrap to their width on store (no-op for i64/u64).
                    // v1.1.3: "bool" (an i64 SSA 0/1, e.g. a true/false literal)
                    // stores through the same path - previously it matched NO
                    // branch and the store was silently dropped.
                    fixed canon_v: str = canonicalize_int(rv[0], vann, ir, ctr);
                    fixed cast_tmp: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", cast_tmp), " = inttoptr i64 "), str_concat(canon_v, " to ptr")));
                    emit(ir, str_concat(str_concat(str_concat("  store ptr ", cast_tmp), ", ptr "), str_concat(slot, ", align 8")));
                }
                check vtype == "f64" {
                    // Float stored bit-for-bit through the uniform ptr slot:
                    // double -> i64 (bitcast) -> ptr (inttoptr) -> store.
                    fixed fbc: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", fbc), " = bitcast double "), str_concat(rv[0], " to i64")));
                    fixed fpt: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", fpt), " = inttoptr i64 "), str_concat(fbc, " to ptr")));
                    emit(ir, str_concat(str_concat(str_concat("  store ptr ", fpt), ", ptr "), str_concat(slot, ", align 8")));
                }
                check vtype == "ptr" || vtype == "str" || starts(vtype, "list") || vtype == "i128" || vtype == "u128" {
                    // ARC slot-counting: retain the NEW value BEFORE releasing the
                    // old slot contents — order makes self-assignment safe. Gated
                    // on the DECLARED annotation via rc_kind, not the expression's
                    // reported type. Old contents start null (rcinit). Immortal
                    // interned literals no-op through both calls.
                    check len(rc_kind) > 0 {
                        emit(ir, str_concat(str_concat("  call ptr @torvik_", rc_kind), str_concat("_retain(ptr ", str_concat(rv[0], ")"))));
                        fixed rc_old: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", rc_old), " = load ptr, ptr "), str_concat(slot, ", align 8")));
                        emit(ir, str_concat(str_concat("  call void @torvik_", rc_kind), str_concat("_release(ptr ", str_concat(rc_old, ")"))));
                    }
                    emit(ir, str_concat(str_concat(str_concat("  store ptr ", rv[0]), ", ptr "), str_concat(slot, ", align 8")));
                    // B3: list<str> objects get managed elements — push/insert
                    // retain, remove/set release, list-free releases all cells.
                    // Marked at creation-by-declaration; idempotent on aliases.
                    check vann == "list<str>" {
                        emit(ir, str_concat("  call void @torvik_list_mark_managed(ptr ", str_concat(rv[0], ")")));
                    }
                    check vann == "list<i128>" || vann == "list<u128>" {
                        emit(ir, str_concat("  call void @torvik_list_mark_managed_i128(ptr ", str_concat(rv[0], ")")));
                    }
                    check vann == "table<str,str>" {
                        emit(ir, str_concat("  call void @torvik_table_mark_managed(ptr ", str_concat(rv[0], ")")));
                    }
                    check vann == "result<str>" {
                        emit(ir, str_concat("  call void @torvik_result_mark_managed(ptr ", str_concat(rv[0], ")")));
                    }
                }
                check vtype == "i1" {
                    fixed cast_tmp: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", cast_tmp), " = zext i1 "), str_concat(rv[0], " to i64")));
                    fixed cast_tmp2: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", cast_tmp2), " = inttoptr i64 "), str_concat(cast_tmp, " to ptr")));
                    emit(ir, str_concat(str_concat(str_concat("  store ptr ", cast_tmp2), ", ptr "), str_concat(slot, ", align 8")));
                }
            }
            pos = check_no_stranded_op(tokens, pos, ir);
            check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; } fallback { push(err_pos, pos - 1); push(err_msg, "expected a semicolon after this statement"); }
            continue;
        }

        // echo(EXPR) — print without a trailing newline (echo! adds one)
        check t == KW_ECHO {
            pos += 1;
            check tok_peek(tokens, pos) == PUNCT_LPAREN { pos += 1; }
            // A bare variable surfaces as "ptr" whether it holds a string or a
            // boxed scalar; its declared type disambiguates so we print correctly.
            set eff_pre: str = "";
            check tok_peek(tokens, pos) == TOK_IDENT && (tok_peek(tokens, pos + 1) == PUNCT_RPAREN || tok_peek(tokens, pos + 1) == PUNCT_COMMA) {
                eff_pre = lookup_var_type(allnames[an], var_names, var_types);
            }
            set ev: list<str> = list_new();
            set ep: list<i64> = list_new();
            set es: list<i64> = list_new();
            set es_ai: list<i64> = list_new();
            set ev_ty: list<str> = list_new();
            compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, ev, ep, es, es_ai, ev_ty, var_names, var_types);
            check len(ep) > 0 { pos = ep[0]; }
            check len(es) > 0 { s   = es[0]; }
            check len(es_ai) > 0 { an = es_ai[0]; }
            set sval: str = "";
            check len(ev) > 0 && ev[0] != "void" {
                set eff_ty: str = ev_ty[0];
                check len(eff_pre) > 0 { eff_ty = eff_pre; }
                sval = echo_stringify(ev[0], ev_ty[0], eff_ty, ir, ctr);
            }
            check len(sval) > 0 { emit(ir, str_concat("  call void @torvik_print(ptr ", str_concat(sval, ")"))); }
            // Additional comma-separated values print space-separated (no newline).
            whilst tok_peek(tokens, pos) == PUNCT_COMMA {
                pos += 1;
                fixed sp: str = emit_str_ref(intern_str(" ", gvals, gnames), " ", ir, ctr);
                emit(ir, str_concat("  call void @torvik_print(ptr ", str_concat(sp, ")")));
                set effn: str = "";
                check tok_peek(tokens, pos) == TOK_IDENT && (tok_peek(tokens, pos + 1) == PUNCT_RPAREN || tok_peek(tokens, pos + 1) == PUNCT_COMMA) {
                    effn = lookup_var_type(allnames[an], var_names, var_types);
                }
                set nv: list<str> = list_new(); set nps: list<i64> = list_new(); set nss: list<i64> = list_new(); set nsa: list<i64> = list_new(); set nty: list<str> = list_new();
                compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, nv, nps, nss, nsa, nty, var_names, var_types);
                check len(nps) > 0 { pos = nps[0]; }
                check len(nss) > 0 { s = nss[0]; }
                check len(nsa) > 0 { an = nsa[0]; }
                check len(nv) > 0 && nv[0] != "void" {
                    set neff: str = nty[0];
                    check len(effn) > 0 { neff = effn; }
                    fixed nsval: str = echo_stringify(nv[0], nty[0], neff, ir, ctr);
                    emit(ir, str_concat("  call void @torvik_print(ptr ", str_concat(nsval, ")")));
                }
            }
            check tok_peek(tokens, pos) == PUNCT_RPAREN { pos += 1; } fallback { push(err_pos, pos); push(err_msg, "expected ')' to close `echo(`"); }
            check tok_peek(tokens, pos) == PUNCT_SEMI   { pos += 1; } fallback { push(err_pos, pos - 1); push(err_msg, "expected a semicolon after this statement"); }
            continue;
        }
        // echo!(EXPR, ...)
        check t == KW_ECHO_BANG {
            pos += 1;
            check tok_peek(tokens, pos) == PUNCT_LPAREN { pos += 1; }
            set eff_pre_b: str = "";
            check tok_peek(tokens, pos) == TOK_IDENT && (tok_peek(tokens, pos + 1) == PUNCT_RPAREN || tok_peek(tokens, pos + 1) == PUNCT_COMMA) {
                eff_pre_b = lookup_var_type(allnames[an], var_names, var_types);
            }
            set rv: list<str> = list_new();
            set rp: list<i64> = list_new();
            set rs: list<i64> = list_new();
            set rs_ai: list<i64> = list_new();
            set rv_ty: list<str> = list_new();
            compile_value(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, rv, rp, rs, rs_ai, rv_ty, var_names, var_types);
            check len(rp) > 0 { pos = rp[0]; }
            check len(rs) > 0 { s   = rs[0]; }
            check len(rs_ai) > 0 { an = rs_ai[0]; }
            set sval_b: str = "";
            check len(rv) > 0 && rv[0] != "void" {
                set eff_ty_b: str = rv_ty[0];
                check len(eff_pre_b) > 0 { eff_ty_b = eff_pre_b; }
                sval_b = echo_stringify(rv[0], rv_ty[0], eff_ty_b, ir, ctr);
            }
            check tok_peek(tokens, pos) == PUNCT_COMMA {
                // Multiple values: print each space-separated, newline at the end.
                check len(sval_b) > 0 { emit(ir, str_concat("  call void @torvik_print(ptr ", str_concat(sval_b, ")"))); }
                whilst tok_peek(tokens, pos) == PUNCT_COMMA {
                    pos += 1;
                    fixed sp: str = emit_str_ref(intern_str(" ", gvals, gnames), " ", ir, ctr);
                    emit(ir, str_concat("  call void @torvik_print(ptr ", str_concat(sp, ")")));
                    set effn: str = "";
                    check tok_peek(tokens, pos) == TOK_IDENT && (tok_peek(tokens, pos + 1) == PUNCT_RPAREN || tok_peek(tokens, pos + 1) == PUNCT_COMMA) {
                        effn = lookup_var_type(allnames[an], var_names, var_types);
                    }
                    set nv: list<str> = list_new(); set nps: list<i64> = list_new(); set nss: list<i64> = list_new(); set nsa: list<i64> = list_new(); set nty: list<str> = list_new();
                    compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, nv, nps, nss, nsa, nty, var_names, var_types);
                    check len(nps) > 0 { pos = nps[0]; }
                    check len(nss) > 0 { s = nss[0]; }
                    check len(nsa) > 0 { an = nsa[0]; }
                    check len(nv) > 0 && nv[0] != "void" {
                        set neff: str = nty[0];
                        check len(effn) > 0 { neff = effn; }
                        fixed nsval: str = echo_stringify(nv[0], nty[0], neff, ir, ctr);
                        emit(ir, str_concat("  call void @torvik_print(ptr ", str_concat(nsval, ")")));
                    }
                }
                fixed nlref: str = emit_str_ref(intern_str("", gvals, gnames), "", ir, ctr);
                emit(ir, str_concat("  call i32 @puts(ptr ", str_concat(nlref, ")")));
            } fallback {
                // Single value: unchanged — puts adds the trailing newline.
                check len(sval_b) > 0 { emit(ir, str_concat("  call i32 @puts(ptr ", str_concat(sval_b, ")"))); }
            }
            check tok_peek(tokens, pos) == PUNCT_RPAREN { pos += 1; } fallback { push(err_pos, pos); push(err_msg, "expected ')' to close `echo!(`"); }
            check tok_peek(tokens, pos) == PUNCT_SEMI   { pos += 1; } fallback { push(err_pos, pos - 1); push(err_msg, "expected a semicolon after this statement"); }
            continue;
        }

        // check EXPR { BODY } fallback { BODY }
        // v1.2.0: when - pattern matching over an aett (or integers).
        //   when s { Status::A => stmt; Status::B => { ... } fallback => stmt; }
        // Aett scrutinee without a fallback must cover every variant (compile
        // error listing the missing ones). Non-aett scrutinee requires fallback.
        check t == KW_WHEN {
            fixed when_pos: i64 = pos;
            pos += 1;
            // Aett detection: a bare-variable scrutinee's declared type, or a
            // direct Name::Variant expression's aett name.
            set when_aett: str = "";
            check tok_peek(tokens, pos) == TOK_IDENT {
                fixed _wsn: str = allnames[an];
                check tok_peek(tokens, pos + 1) == PUNCT_LBRACE {
                    check is_aett_name(lookup_var_type(_wsn, var_names, var_types)) == 1 { when_aett = lookup_var_type(_wsn, var_names, var_types); }
                }
                check tok_peek(tokens, pos + 1) == PUNCT_COLONCOLON && is_aett_name(_wsn) == 1 { when_aett = _wsn; }
            }
            set wv: list<str> = list_new();
            set wp: list<i64> = list_new();
            set ws: list<i64> = list_new();
            set ws_ai: list<i64> = list_new();
            set wv_ty: list<str> = list_new();
            compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, wv, wp, ws, ws_ai, wv_ty, var_names, var_types);
            check len(wp) > 0 { pos = wp[0]; }
            check len(ws) > 0 { s = ws[0]; }
            check len(ws_ai) > 0 { an = ws_ai[0]; }
            set wsc: str = "%undef_when"; check len(wv) > 0 { wsc = wv[0]; }
            fixed wsc_i64: str = coerce_i64(wsc, ir, ctr);
            check tok_peek(tokens, pos) != PUNCT_LBRACE {
                push(err_pos, when_pos);
                push(err_msg, "expected `{` after the when scrutinee - `when value { pattern => ...; }`");
            }
            pos += 1;
            fixed wnum: i64 = lctr[0];
            lctr[0] = wnum + 1;
            fixed wend: str = str_concat("wend", int_to_str(wnum));
            set warm: i64 = 0;
            set saw_fallback: i64 = 0;
            set covered: str = "";
            set all_term: i64 = 1;
            emit(ir, str_concat(str_concat("  br label %wchk", int_to_str(wnum)), "_0"));
            whilst pos < end && tok_peek(tokens, pos) != PUNCT_RBRACE && tok_peek(tokens, pos) != TOK_EOF {
                fixed chk_lbl: str = str_concat(str_concat(str_concat("wchk", int_to_str(wnum)), "_"), int_to_str(warm));
                fixed body_lbl: str = str_concat(str_concat(str_concat("wbody", int_to_str(wnum)), "_"), int_to_str(warm));
                fixed next_lbl: str = str_concat(str_concat(str_concat("wchk", int_to_str(wnum)), "_"), int_to_str(warm + 1));
                emit(ir, str_concat(chk_lbl, ":"));
                fixed pt: i64 = tok_peek(tokens, pos);
                check saw_fallback == 1 {
                    push(err_pos, pos);
                    push(err_msg, "the fallback arm must be the last arm of a when");
                }
                check pt == KW_FALLBACK {
                    saw_fallback = 1;
                    pos += 1;
                    emit(ir, str_concat("  br label %", body_lbl));
                }
                check pt == TOK_IDENT {
                    fixed pan: str = allnames[an];
                    an += 1; pos += 1;
                    check tok_peek(tokens, pos) != PUNCT_COLONCOLON || tok_peek(tokens, pos + 1) != TOK_IDENT {
                        push(err_pos, pos - 1);
                        push(err_msg, "a when pattern is an aett variant (Name::Variant), an integer literal, or `fallback`");
                    }
                    set pvn: str = "";
                    check tok_peek(tokens, pos) == PUNCT_COLONCOLON && tok_peek(tokens, pos + 1) == TOK_IDENT {
                        pvn = allnames[an];
                        an += 1; pos += 2;
                    }
                    check len(when_aett) > 0 && line_eq(pan, when_aett) == 0 {
                        push(err_pos, pos - 2);
                        push(err_msg, fmt("this when matches over aett '{}', but the pattern names aett '{}'.", when_aett, pan));
                    }
                    fixed pkey: str = str_concat(str_concat(pan, "::"), pvn);
                    fixed pord: i64 = aett_ord_for(pkey);
                    check pord < 0 && is_aett_name(pan) == 1 {
                        push(err_pos, pos - 1);
                        push(err_msg, fmt("aett '{}' has no variant '{}' - its variants are: {}.", pan, pvn, aett_variants_of(pan)));
                    }
                    check pord < 0 && is_aett_name(pan) == 0 {
                        push(err_pos, pos - 2);
                        push(err_msg, fmt("'{}' is not an aett - a when pattern is Name::Variant, an integer literal, or `fallback`.", pan));
                    }
                    check len(covered) == 0 { covered = pvn; } fallback { covered = str_concat(str_concat(covered, " "), pvn); }
                    set wpval: i64 = pord; check wpval < 0 { wpval = 0; }
                    fixed pc: str = make_tmp(ctr);
                    emit(ir, fmt("  {} = icmp eq i64 {}, {}", pc, wsc_i64, wpval));
                    emit(ir, fmt("  br i1 {}, label %{}, label %{}", pc, body_lbl, next_lbl));
                }
                set is_int_pat: i64 = 0;
                check pt == TOK_INT { is_int_pat = 1; }
                check pt == OP_MINUS && tok_peek(tokens, pos + 1) == TOK_INT { is_int_pat = 1; }
                check is_int_pat == 1 {
                    set ilit: str = "";
                    check pt == OP_MINUS { pos += 1; ilit = "-"; }
                    ilit = str_concat(ilit, strings[s]);
                    s += 1; pos += 1;
                    fixed pc2: str = make_tmp(ctr);
                    emit(ir, fmt("  {} = icmp eq i64 {}, {}", pc2, wsc_i64, ilit));
                    emit(ir, fmt("  br i1 {}, label %{}, label %{}", pc2, body_lbl, next_lbl));
                }
                check pt != KW_FALLBACK && pt != TOK_IDENT && pt != TOK_INT && pt != OP_MINUS {
                    push(err_pos, pos);
                    push(err_msg, "a when pattern is an aett variant (Name::Variant), an integer literal, or `fallback`");
                    pos += 1;
                }
                check tok_peek(tokens, pos) != OP_FATARROW {
                    push(err_pos, pos);
                    push(err_msg, "expected `=>` after the when pattern");
                }
                check tok_peek(tokens, pos) == OP_FATARROW { pos += 1; }
                emit(ir, str_concat(body_lbl, ":"));
                check tok_peek(tokens, pos) == PUNCT_LBRACE {
                    pos += 1;
                    fixed abe: i64 = skip_to_close_brace(tokens, pos);
                    {
                        fixed cs_ret: i64 = compile_stmts(tokens, strings, allnames, pos, abe - 1, s, an, ir, ctr, gvals, gnames, lctr, fn_ret_type, var_names, var_types, global_names, err_pos, err_msg);
                        s = cs_ret % 100000;
                        an = cs_ret / 100000;
                    }
                    pos = abe;
                } fallback {
                    // single-statement arm: compile to the terminating `;`
                    set ase: i64 = pos;
                    whilst ase < end && tok_peek(tokens, ase) != PUNCT_SEMI && tok_peek(tokens, ase) != PUNCT_LBRACE && tok_peek(tokens, ase) != TOK_EOF { ase += 1; }
                    check tok_peek(tokens, ase) != PUNCT_SEMI {
                        push(err_pos, pos);
                        push(err_msg, "a when arm is a single statement ending in `;`, or a block - use `=> { ... }` for multiple statements");
                    }
                    {
                        fixed cs_ret: i64 = compile_stmts(tokens, strings, allnames, pos, ase + 1, s, an, ir, ctr, gvals, gnames, lctr, fn_ret_type, var_names, var_types, global_names, err_pos, err_msg);
                        s = cs_ret % 100000;
                        an = cs_ret / 100000;
                    }
                    pos = ase + 1;
                }
                check block_terminated(ir) == 0 { all_term = 0; }
                emit(ir, str_concat("  br label %", wend));
                warm += 1;
            }
            check tok_peek(tokens, pos) == PUNCT_RBRACE { pos += 1; }
            // the final chk label: nothing matched - fall through to the end
            emit(ir, str_concat(str_concat(str_concat("wchk", int_to_str(wnum)), "_"), str_concat(int_to_str(warm), ":")));
            emit(ir, str_concat("  br label %", wend));
            check saw_fallback == 0 && all_term == 1 { all_term = 0; }
            // Exhaustiveness
            check len(when_aett) > 0 && saw_fallback == 0 {
                fixed wants: list<str> = split_words(aett_variants_of(when_aett));
                fixed haves: list<str> = split_words(covered);
                set missing: str = "";
                set wvi: i64 = 0;
                whilst wvi < len(wants) {
                    set found_v: i64 = 0;
                    set hj: i64 = 0;
                    whilst hj < len(haves) {
                        check line_eq(haves[hj], wants[wvi]) == 1 { found_v = 1; }
                        hj += 1;
                    }
                    check found_v == 0 {
                        check len(missing) == 0 { missing = wants[wvi]; } fallback { missing = str_concat(str_concat(missing, ", "), wants[wvi]); }
                    }
                    wvi += 1;
                }
                check len(missing) > 0 {
                    push(err_pos, when_pos);
                    push(err_msg, fmt("this when over aett '{}' is missing variants: {} - add arms for them, or a `fallback =>` arm.", when_aett, missing));
                }
            }
            check len(when_aett) == 0 && saw_fallback == 0 {
                push(err_pos, when_pos);
                push(err_msg, "a when over a non-aett value needs a `fallback =>` arm - the compiler can't prove the patterns cover every value.");
            }
            emit(ir, str_concat(wend, ":"));
            continue;
        }

        check t == KW_CHECK {
            pos += 1;
            set cv: list<str> = list_new();
            set cp: list<i64> = list_new();
            set cs: list<i64> = list_new();
            set cs_ai: list<i64> = list_new();
            set cv_ty: list<str> = list_new();
            compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, cv, cp, cs, cs_ai, cv_ty, var_names, var_types);
            check len(cp) > 0 { pos = cp[0]; }
            check len(cs) > 0 { s   = cs[0]; }
            check len(cs_ai) > 0 { an = cs_ai[0]; }
            // Accumulators for the running condition value/type
            set cur_cond: str = "%undef_cond"; check len(cv) > 0 { cur_cond = cv[0]; }
            set cur_ty: str = "ptr"; check len(cv_ty) > 0 { cur_ty = cv_ty[0]; }
            // Handle && and || compound conditions
            whilst tok_peek(tokens, pos) == OP_AMPAMP || tok_peek(tokens, pos) == OP_PIPEPIPE {
                set is_and_op: i64 = 0; check tok_peek(tokens, pos) == OP_AMPAMP { is_and_op = 1; }
                pos += 1;
                set cv2: list<str> = list_new(); set cp2: list<i64> = list_new(); set cs2: list<i64> = list_new(); set cs2_ai: list<i64> = list_new(); set cv2_ty: list<str> = list_new();
                compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, cv2, cp2, cs2, cs2_ai, cv2_ty, var_names, var_types);
                check len(cp2) > 0 { pos = cp2[0]; } check len(cs2) > 0 { s = cs2[0]; } check len(cs2_ai) > 0 { an = cs2_ai[0]; }
                check len(cv2) > 0 {
                    set lhs3: str = cur_cond;
                    set rhs3: str = cv2[0];
                    set rhsty3: str = "ptr"; check len(cv2_ty) > 0 { rhsty3 = cv2_ty[0]; }
                    check cur_ty != "i1" { fixed ztl: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", ztl), " = icmp ne i64 "), str_concat(coerce_i64(lhs3, ir, ctr), ", 0"))); lhs3 = ztl; }
                    check rhsty3 != "i1" { fixed ztr: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", ztr), " = icmp ne i64 "), str_concat(coerce_i64(rhs3, ir, ctr), ", 0"))); rhs3 = ztr; }
                    fixed cmb3: str = make_tmp(ctr);
                    check is_and_op == 1 { emit(ir, str_concat(str_concat(str_concat("  ", cmb3), " = and i1 "), str_concat(lhs3, str_concat(", ", rhs3)))); } fallback { emit(ir, str_concat(str_concat(str_concat("  ", cmb3), " = or i1 "), str_concat(lhs3, str_concat(", ", rhs3)))); }
                    cur_cond = cmb3;
                    cur_ty = "i1";
                }
            }

            fixed lnum: i64    = lctr[0];
            lctr[0]            = lnum + 1;
            fixed tlbl: str    = str_concat("then", int_to_str(lnum));
            fixed elbl: str    = str_concat("else", int_to_str(lnum));
            fixed mlbl: str    = str_concat("merge", int_to_str(lnum));

            fixed cval: str = cur_cond;
            pos = check_no_stranded_op(tokens, pos, ir);
            set ci1: str = cval;
            fixed cv_ty_s: str = cur_ty;
            check cv_ty_s != "i1" {
                fixed tmp_ci: str = make_tmp(ctr);
                check cv_ty_s == "i64" { emit(ir, str_concat(str_concat(str_concat("  ", tmp_ci), " = icmp ne i64 "), str_concat(cval, ", 0"))); }
                check cv_ty_s != "i64" { fixed cv_i64: str = coerce_i64(cval, ir, ctr); emit(ir, str_concat(str_concat(str_concat("  ", tmp_ci), " = icmp ne i64 "), str_concat(cv_i64, ", 0"))); }
                ci1 = tmp_ci;
            }
            emit(ir, str_concat(str_concat(str_concat(str_concat("  br i1 ", ci1), ", label %"), tlbl), str_concat(", label %", elbl)));
            emit(ir, str_concat(tlbl, ":"));

            check tok_peek(tokens, pos) == PUNCT_LBRACE {
                pos += 1;
                fixed te: i64 = skip_to_close_brace(tokens, pos);
                {
                    fixed cs_ret: i64 = compile_stmts(tokens, strings, allnames, pos, te - 1, s, an, ir, ctr, gvals, gnames, lctr, fn_ret_type, var_names, var_types, global_names, err_pos, err_msg);
                    s = cs_ret % 100000;
                    an = cs_ret / 100000;
                }
                pos = te;
            }
            fixed then_term: i64 = block_terminated(ir);
            emit(ir, str_concat("  br label %", mlbl));
            emit(ir, str_concat(elbl, ":"));

            check tok_peek(tokens, pos) == KW_FALLBACK {
                pos += 1;
                check tok_peek(tokens, pos) == PUNCT_LBRACE {
                    pos += 1;
                    fixed ee: i64 = skip_to_close_brace(tokens, pos);
                    {
                        fixed cs_ret: i64 = compile_stmts(tokens, strings, allnames, pos, ee - 1, s, an, ir, ctr, gvals, gnames, lctr, fn_ret_type, var_names, var_types, global_names, err_pos, err_msg);
                        s = cs_ret % 100000;
                        an = cs_ret / 100000;
                    }
                    pos = ee;
                }
            }
            fixed else_term: i64 = block_terminated(ir);
            emit(ir, str_concat("  br label %", mlbl));
            emit(ir, str_concat(mlbl, ":"));
            // If both branches end in a terminator, the merge block is unreachable.
            // Terminate it so the IR is valid even when nothing follows — e.g. a
            // function ending in `check c { return a } fallback { return b }`.
            check then_term == 1 && else_term == 1 { emit(ir, "  unreachable"); }
            continue;
        }

        // return EXPR;
        // Continue statement
        check t == KW_CONTINUE {
            pos += 1; check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; } fallback { push(err_pos, pos - 1); push(err_msg, "expected a semicolon after this statement"); }
            check len(lctr) > 1 && lctr[1] >= 0 {
                emit(ir, str_concat("  br label %loop", int_to_str(lctr[1])));
                fixed dead_c: str = make_label(lctr, "dead");
                emit(ir, str_concat(dead_c, ":"));
            }
            continue;
        }
        check t == KW_BREAK {
            pos += 1; check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; } fallback { push(err_pos, pos - 1); push(err_msg, "expected a semicolon after this statement"); }
            check len(lctr) > 2 && lctr[2] >= 0 {
                emit(ir, str_concat("  br label %exit", int_to_str(lctr[2])));
                fixed dead_b: str = make_label(lctr, "dead");
                emit(ir, str_concat(dead_b, ":"));
            }
            continue;
        }

        check t == KW_RETURN {
            fixed ret_pos: i64 = pos;
            pos += 1;
            check tok_peek(tokens, pos) == PUNCT_SEMI { emit(ir, "  ret ptr null"); pos += 1; continue; }
            set rv: list<str> = list_new();
            set rp: list<i64> = list_new();
            set rs: list<i64> = list_new();
            set rs_ai: list<i64> = list_new();
            set rv_ty: list<str> = list_new();
            compile_value(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, rv, rp, rs, rs_ai, rv_ty, var_names, var_types);
            check len(rp) > 0 { pos = rp[0]; }
            check len(rs) > 0 { s   = rs[0]; }
            check len(rs_ai) > 0 { an = rs_ai[0]; }
            // Combine && / || operands so multi-operand returns evaluate correctly
            set ret_cur: str = "null"; check len(rv) > 0 { ret_cur = rv[0]; }
            set ret_cur_ty: str = "ptr"; check len(rv_ty) > 0 { ret_cur_ty = rv_ty[0]; }
            whilst tok_peek(tokens, pos) == OP_AMPAMP || tok_peek(tokens, pos) == OP_PIPEPIPE {
                set r_is_and: i64 = 0; check tok_peek(tokens, pos) == OP_AMPAMP { r_is_and = 1; }
                pos += 1;
                set rv3: list<str> = list_new(); set rp3: list<i64> = list_new(); set rs3: list<i64> = list_new(); set rs3_ai: list<i64> = list_new(); set rs3_ty: list<str> = list_new();
                compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, rv3, rp3, rs3, rs3_ai, rs3_ty, var_names, var_types);
                check len(rp3) > 0 { pos = rp3[0]; } check len(rs3) > 0 { s = rs3[0]; } check len(rs3_ai) > 0 { an = rs3_ai[0]; }
                set rhs3v: str = "null"; check len(rv3) > 0 { rhs3v = rv3[0]; }
                set rhs3ty: str = "ptr"; check len(rs3_ty) > 0 { rhs3ty = rs3_ty[0]; }
                set rl_i1: str = ret_cur; check ret_cur_ty != "i1" { fixed zt3: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", zt3), " = icmp ne i64 "), str_concat(coerce_i64(ret_cur, ir, ctr), ", 0"))); rl_i1 = zt3; }
                set rr_i1: str = rhs3v; check rhs3ty != "i1" { fixed zt4: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", zt4), " = icmp ne i64 "), str_concat(coerce_i64(rhs3v, ir, ctr), ", 0"))); rr_i1 = zt4; }
                fixed rcmb: str = make_tmp(ctr);
                check r_is_and == 1 { emit(ir, str_concat(str_concat(str_concat("  ", rcmb), " = and i1 "), str_concat(rl_i1, str_concat(", ", rr_i1)))); }
                check r_is_and == 0 { emit(ir, str_concat(str_concat(str_concat("  ", rcmb), " = or i1 "), str_concat(rl_i1, str_concat(", ", rr_i1)))); }
                ret_cur = rcmb; ret_cur_ty = "i1";
            }
            set rv: list<str> = list_new(); push(rv, ret_cur);
            set rv_ty: list<str> = list_new(); push(rv_ty, ret_cur_ty);
            pos = check_no_stranded_op(tokens, pos, ir);
            check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; } fallback { push(err_pos, pos - 1); push(err_msg, "expected a semicolon after this statement"); }
            check fn_ret_type == "void" || len(fn_ret_type) == 0 { push(err_pos, ret_pos); push(err_msg, "this function returns void and cannot return a value - use a bare `return;` to exit early"); continue; } check fn_ret_type != "void" && len(fn_ret_type) > 0 { check len(rv) > 0 { set rv_type_s: str = "ptr"; check len(rv_ty) > 0 { rv_type_s = rv_ty[0]; }
            // v1.1.3: return-type compatibility. A definite kind mismatch between
            // the returned value and the declared return type is a clean error -
            // previously `df f() -> str { return 5; }` compiled and crashed (or
            // printed a pointer) at run time. "ptr" (an integer variable's
            // uniform load) is indefinite and stays unchecked, mirroring the
            // declaration-side type check.
            check line_eq(rv_type_s, "ptr") == 0 {
                set _rvk: str = ty_kind(rv_type_s);
                check line_eq(rv_type_s, "i1") == 1 { _rvk = "num"; }
                fixed _rdk: str = ty_kind(fn_ret_type);
                check line_eq(_rvk, _rdk) == 0 && line_eq(_rvk, "other") == 0 && line_eq(_rdk, "other") == 0 {
                    push(err_pos, ret_pos);
                    push(err_msg, fmt("can't return a value of type {rv_type_s} from a function declared to return {fn_ret_type}"));
                    continue;
                }
            }
            check rv_type_s == "i1" { fixed zext_t: str = make_tmp(ctr); fixed itp_t: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", zext_t), " = zext i1 "), str_concat(rv[0], " to i64"))); emit(ir, str_concat(str_concat(str_concat("  ", itp_t), " = inttoptr i64 "), str_concat(zext_t, " to ptr"))); emit(ir, str_concat("  ret ptr ", itp_t)); } check rv_type_s == "i64" || rv_type_s == "u64" || rv_type_s == "bool" || (int_width(rv_type_s) > 0 && rv_type_s != "i128" && rv_type_s != "u128") { fixed rcv: str = canonicalize_int(rv[0], fn_ret_type, ir, ctr); fixed itp_t: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", itp_t), " = inttoptr i64 "), str_concat(rcv, " to ptr"))); emit(ir, str_concat("  ret ptr ", itp_t)); } check rv_type_s == "f64" { fixed rfb: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", rfb), " = bitcast double "), str_concat(rv[0], " to i64"))); fixed rfp: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", rfp), " = inttoptr i64 "), str_concat(rfb, " to ptr"))); emit(ir, str_concat("  ret ptr ", rfp)); } check rv_type_s != "i1" && rv_type_s != "i64" && rv_type_s != "u64" && rv_type_s != "bool" && rv_type_s != "f64" && (int_width(rv_type_s) == 0 || rv_type_s == "i128" || rv_type_s == "u128") { emit(ir, str_concat("  ret ptr ", rv[0])); } } }
            continue;
        }

        // Function call statement (IDENT(...))
        check t == TOK_IDENT {
            fixed nm: str = allnames[an]; fixed snm_pos: i64 = pos; an += 1; pos += 1;
            check tok_peek(tokens, pos) == PUNCT_LPAREN {
                pos += 1;
                // First-argument identifier name, for list element-type validation
                // on push/insert (mirrors the compile_expr call path).
                set s_first_arg_name: str = "";
                check tok_peek(tokens, pos) == TOK_IDENT {
                    s_first_arg_name = allnames[an];
                }
                set args: list<str> = list_new();
                set args_ty: list<str> = list_new();
                set args_lit: list<str> = list_new();
                whilst tok_peek(tokens, pos) != PUNCT_RPAREN && tok_peek(tokens, pos) != TOK_EOF {
                    set rv: list<str> = list_new();
                    set rp: list<i64> = list_new();
                    set rs: list<i64> = list_new();
                    set rs_ai: list<i64> = list_new();
                    set rs_ty2: list<str> = list_new();
                    set this_lit2: str = "";
                    check tok_peek(tokens, pos) == TOK_INT {
                        fixed nxt_lit2: i64 = tok_peek(tokens, pos + 1);
                        check nxt_lit2 == PUNCT_COMMA || nxt_lit2 == PUNCT_RPAREN { this_lit2 = strings[s]; }
                    }
                    check tok_peek(tokens, pos) == OP_MINUS && tok_peek(tokens, pos + 1) == TOK_INT {
                        fixed nxt_neg2: i64 = tok_peek(tokens, pos + 2);
                        check nxt_neg2 == PUNCT_COMMA || nxt_neg2 == PUNCT_RPAREN { this_lit2 = str_concat("-", strings[s]); }
                    }
                    compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, rv, rp, rs, rs_ai, rs_ty2, var_names, var_types);
                    check len(rv) > 0 { push(args, rv[0]); }
                    check len(rs_ty2) > 0 { push(args_ty, rs_ty2[0]); } fallback { push(args_ty, "ptr"); }
                    push(args_lit, this_lit2);
                    check len(rp) > 0 { pos = rp[0]; }
                    check len(rs) > 0 { s   = rs[0]; }
                    check len(rs_ai) > 0 { an = rs_ai[0]; }
                    check tok_peek(tokens, pos) == PUNCT_COMMA { pos += 1; }
                }
                check tok_peek(tokens, pos) == PUNCT_RPAREN { pos += 1; }
                check tok_peek(tokens, pos) == PUNCT_SEMI   { pos += 1; } fallback { push(err_pos, pos - 1); push(err_msg, "expected a semicolon after this statement"); }

                check nm == "exit" {
                    set code_i: str = "0";
                    check len(args) > 0 {
                        set et: str = "ptr"; check len(args_ty) > 0 { et = args_ty[0]; }
                        check et == "i64" { code_i = args[0]; } fallback { code_i = coerce_i64(args[0], ir, ctr); }
                    }
                    fixed code32: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", code32), " = trunc i64 "), str_concat(code_i, " to i32")));
                    emit(ir, str_concat(str_concat("  call void @exit(i32 ", code32), ")"));
                    emit(ir, "  unreachable");
                    continue;
                }
                check nm == "fs_mkdir" && len(args) >= 1 {
                    emit(ir, str_concat(str_concat("  call void @torvik_fs_mkdir(ptr ", args[0]), ")"));
                    continue;
                }
                check nm == "fs_remove" && len(args) >= 1 {
                    emit(ir, str_concat(str_concat("  call void @torvik_fs_remove(ptr ", args[0]), ")"));
                    continue;
                }
                check nm == "writefile" && len(args) >= 2 {
                    emit(ir, str_concat(str_concat(str_concat("  call void @torvik_writefile(ptr ", args[0]), ", ptr "), str_concat(args[1], ")")));
                    continue;
                }
                check nm == "appendline" && len(args) >= 2 {
                    emit(ir, str_concat(str_concat(str_concat("  call void @torvik_appendline(ptr ", args[0]), ", ptr "), str_concat(args[1], ")")));
                    continue;
                }
                check nm == "write_ir" && len(args) >= 3 {
                    set wir_ap: str = args[2];
                    check len(args_ty) < 3 || args_ty[2] != "i64" { wir_ap = coerce_i64(args[2], ir, ctr); }
                    emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  call void @torvik_write_ir(ptr ", args[0]), ", ptr "), args[1]), ", i64 "), str_concat(wir_ap, ")")));
                    continue;
                }
                check nm == "push" && len(args) >= 2 {
                    fixed spelem: str = list_elem_type(lookup_var_type(s_first_arg_name, var_names, var_types));
                    set pval: str = args[1];
                    set pval_ty: str = "ptr"; check len(args_ty) >= 2 { pval_ty = args_ty[1]; }
                    set spe128: i64 = 0; check line_eq(spelem, "i128") == 1 || line_eq(spelem, "u128") == 1 { spe128 = 1; }
                    set spv128: i64 = 0; check pval_ty == "i128" || pval_ty == "u128" { spv128 = 1; }
                    set split: str = ""; check len(args_lit) >= 2 { split = args_lit[1]; }
                    check spe128 == 1 && spv128 == 0 && len(split) > 0 {
                        set splok: i64 = 0;
                        check line_eq(spelem, "i128") == 1 && i128_lit_in_range(split) == 1 { splok = 1; }
                        check line_eq(spelem, "u128") == 1 && u128_in_range(split) == 1 { splok = 1; }
                        check splok == 0 { emit_uerr(ir, pos, str_concat(str_concat("literal ", split), str_concat(" is out of range for ", spelem))); }
                        fixed splbox: str = i128_box_lit(split, ir, ctr);
                        pval = splbox; pval_ty = spelem; spv128 = 1;
                    }
                    check spe128 == 1 && spv128 == 0 { emit_uerr(ir, pos, "only a 128-bit value can be pushed into a list<i128>/list<u128>. Bind a literal to an i128/u128 variable first, then push that."); }
                    check spe128 == 0 && spv128 == 1 && (int_width(spelem) > 0) { emit_uerr(ir, pos, "a 128-bit value cannot be pushed into a non-128-bit integer list. Use list<i128>/list<u128>."); }
                    check pval_ty == "i1" { fixed pzt: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", pzt), " = zext i1 "), str_concat(pval, " to i64"))); pval = pzt; } fallback { check line_eq(spelem, "f64") == 1 || pval_ty == "f64" { fixed spfb: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", spfb), " = bitcast double "), str_concat(pval, " to i64"))); pval = spfb; } fallback { check pval_ty != "i64" { pval = coerce_i64(pval, ir, ctr); } } }
                    emit(ir, str_concat(str_concat(str_concat("  call void @torvik_push(ptr ", args[0]), ", i64 "), str_concat(pval, ")")));
                    continue;
                }
                check nm == "list_remove" && len(args) >= 2 {
                    // remove(list, idx): drop element at idx. Runtime releases the
                    // element first when the list is managed (list<str>), so the
                    // refcount is correct; out-of-bounds panics (no silent no-op).
                    set ridx: str = args[1];
                    set ridx_ty: str = "ptr"; check len(args_ty) >= 2 { ridx_ty = args_ty[1]; }
                    check ridx_ty == "i1" { fixed rzt: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", rzt), " = zext i1 "), str_concat(ridx, " to i64"))); ridx = rzt; } fallback { check ridx_ty != "i64" { ridx = coerce_i64(ridx, ir, ctr); } }
                    emit(ir, str_concat(str_concat(str_concat("  call void @torvik_remove(ptr ", args[0]), ", i64 "), str_concat(ridx, ")")));
                    continue;
                }
                check nm == "list_insert" && len(args) >= 3 {
                    // insert(list, idx, item): runtime retains item when managed,
                    // mirroring push; out-of-bounds panics.
                    fixed sielem: str = list_elem_type(lookup_var_type(s_first_arg_name, var_names, var_types));
                    set iidx: str = args[1]; set iidx_ty: str = "ptr"; check len(args_ty) >= 2 { iidx_ty = args_ty[1]; }
                    check iidx_ty == "i1" { fixed izt: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", izt), " = zext i1 "), str_concat(iidx, " to i64"))); iidx = izt; } fallback { check iidx_ty != "i64" { iidx = coerce_i64(iidx, ir, ctr); } }
                    set ival: str = args[2]; set ival_ty: str = "ptr"; check len(args_ty) >= 3 { ival_ty = args_ty[2]; }
                    set sie128: i64 = 0; check line_eq(sielem, "i128") == 1 || line_eq(sielem, "u128") == 1 { sie128 = 1; }
                    set siv128: i64 = 0; check ival_ty == "i128" || ival_ty == "u128" { siv128 = 1; }
                    set silit: str = ""; check len(args_lit) >= 3 { silit = args_lit[2]; }
                    check sie128 == 1 && siv128 == 0 && len(silit) > 0 {
                        set silok: i64 = 0;
                        check line_eq(sielem, "i128") == 1 && i128_lit_in_range(silit) == 1 { silok = 1; }
                        check line_eq(sielem, "u128") == 1 && u128_in_range(silit) == 1 { silok = 1; }
                        check silok == 0 { emit_uerr(ir, pos, str_concat(str_concat("literal ", silit), str_concat(" is out of range for ", sielem))); }
                        fixed silbox: str = i128_box_lit(silit, ir, ctr);
                        ival = silbox; ival_ty = sielem; siv128 = 1;
                    }
                    check sie128 == 1 && siv128 == 0 { emit_uerr(ir, pos, "only a 128-bit value can be inserted into a list<i128>/list<u128>. Bind a literal to an i128/u128 variable first, then insert that."); }
                    check sie128 == 0 && siv128 == 1 && (int_width(sielem) > 0) { emit_uerr(ir, pos, "a 128-bit value cannot be inserted into a non-128-bit integer list. Use list<i128>/list<u128>."); }
                    check ival_ty == "i1" { fixed ivzt: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", ivzt), " = zext i1 "), str_concat(ival, " to i64"))); ival = ivzt; } fallback { check line_eq(sielem, "f64") == 1 || ival_ty == "f64" { fixed sifb: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", sifb), " = bitcast double "), str_concat(ival, " to i64"))); ival = sifb; } fallback { check ival_ty != "i64" { ival = coerce_i64(ival, ir, ctr); } } }
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  call void @torvik_insert(ptr ", args[0]), ", i64 "), str_concat(iidx, ", i64 ")), str_concat(ival, ")")));
                    continue;
                }
                check nm == "sys_run" && len(args) >= 1 {
                    fixed srtmp: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", srtmp), " = call i64 @torvik_sys_run(ptr "), str_concat(args[0], ")")));
                    continue;
                }
                check nm == "sleep" && len(args) >= 1 {
                    set sl: str = args[0]; set slt: str = "ptr"; check len(args_ty) >= 1 { slt = args_ty[0]; }
                    check slt != "i64" { sl = coerce_i64(sl, ir, ctr); }
                    emit(ir, str_concat(str_concat("  call void @torvik_sleep(i64 ", sl), ")"));
                    continue;
                }
                check nm == "clear_screen" {
                    emit(ir, "  call void @torvik_clear_screen()");
                    continue;
                }
                check nm == "wait" && len(args) >= 1 {
                    set wsec: str = args[0]; set wsect: str = "ptr"; check len(args_ty) >= 1 { wsect = args_ty[0]; }
                    fixed wsecd: str = as_double(wsec, wsect, ir, ctr);
                    emit(ir, str_concat(str_concat("  call void @torvik_wait(double ", wsecd), ")"));
                    continue;
                }
                check nm == "assert" && len(args) >= 2 {
                    // assert(cond, msg): panics with msg when cond is false. C side
                    // takes `int`, so narrow the i1/i64 condition to i32.
                    set acond: str = args[0]; set acond_ty: str = "ptr"; check len(args_ty) >= 1 { acond_ty = args_ty[0]; }
                    fixed acond32: str = make_tmp(ctr);
                    check acond_ty == "i1" { emit(ir, str_concat(str_concat(str_concat("  ", acond32), " = zext i1 "), str_concat(acond, " to i32"))); } fallback {
                        set ac_i: str = acond; check acond_ty != "i64" { ac_i = coerce_i64(acond, ir, ctr); }
                        emit(ir, str_concat(str_concat(str_concat("  ", acond32), " = trunc i64 "), str_concat(ac_i, " to i32")));
                    }
                    emit(ir, str_concat(str_concat(str_concat("  call void @torvik_assert(i32 ", acond32), ", ptr "), str_concat(args[1], ")")));
                    continue;
                }
                check nm == "bag_add" && len(args) >= 2 {
                    emit(ir, str_concat(str_concat(str_concat("  call void @torvik_bag_add(ptr ", args[0]), ", ptr "), str_concat(args[1], ")")));
                    continue;
                }
                check nm == "bag_remove" && len(args) >= 2 {
                    emit(ir, str_concat(str_concat(str_concat("  call void @torvik_bag_remove(ptr ", args[0]), ", ptr "), str_concat(args[1], ")")));
                    continue;
                }
                check nm == "table_set" && len(args) >= 3 {
                    // value passed as i64 (like push): str values are ptrtoint'd,
                    // the runtime stores the bits as void* and retains if managed.
                    set tval: str = args[2]; set tval_ty: str = "ptr"; check len(args_ty) >= 3 { tval_ty = args_ty[2]; }
                    check tval_ty == "i1" { fixed tzt: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", tzt), " = zext i1 "), str_concat(tval, " to i64"))); tval = tzt; } fallback { check tval_ty != "i64" { tval = coerce_i64(tval, ir, ctr); } }
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  call void @torvik_table_set(ptr ", args[0]), ", ptr "), str_concat(args[1], ", i64 ")), str_concat(tval, ")")));
                    continue;
                }
                check nm == "table_del" && len(args) >= 2 {
                    emit(ir, str_concat(str_concat(str_concat("  call void @torvik_table_del(ptr ", args[0]), ", ptr "), str_concat(args[1], ")")));
                    continue;
                }
                // Other call statement (user function or runtime) — emit the call, discard result
                fixed scallee_ptypes: list<str> = split_words(lookup_var_type(str_concat("@p@", nm), var_names, var_types));
                set sgen_args: str = "";
                set sgi: i64 = 0;
                whilst sgi < len(args) {
                    check len(sgen_args) > 0 { sgen_args = str_concat(sgen_args, ", "); }
                    set sarg_ty: str = "ptr";
                    check sgi < len(args_ty) { sarg_ty = args_ty[sgi]; }
                    check sgi < len(scallee_ptypes) {
                        fixed sppt: str = scallee_ptypes[sgi];
                        set sp_is_128: i64 = 0; check line_eq(sppt, "i128") == 1 || line_eq(sppt, "u128") == 1 { sp_is_128 = 1; }
                        set sa_is_128: i64 = 0; check sarg_ty == "i128" || sarg_ty == "u128" { sa_is_128 = 1; }
                        check sp_is_128 == 1 && sa_is_128 == 0 && (sarg_ty == "i64" || sarg_ty == "i1" || sarg_ty == "bool" || sarg_ty == "f64") {
                            emit_uerr(ir, pos, "a non-128-bit value cannot be passed to a 128-bit parameter. Bind the value to an i128/u128 variable first, then pass that.");
                        }
                        check sp_is_128 == 0 && sa_is_128 == 1 && int_width(sppt) > 0 {
                            emit_uerr(ir, pos, "a 128-bit value cannot be passed to a non-128-bit integer parameter. Use a matching 128-bit parameter type, or convert explicitly.");
                        }
                    }
                    check sarg_ty == "i1" || sarg_ty == "i64" || sarg_ty == "bool" {
                        sgen_args = str_concat(sgen_args, str_concat("i64 ", args[sgi]));
                    }
                    check sarg_ty == "f64" {
                        // Box the double into the uniform ptr slot, like the
                        // expression-call path does, so void calls accept floats too.
                        fixed sfb: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", sfb), " = bitcast double "), str_concat(args[sgi], " to i64")));
                        fixed sfp: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", sfp), " = inttoptr i64 "), str_concat(sfb, " to ptr")));
                        sgen_args = str_concat(sgen_args, str_concat("ptr ", sfp));
                    }
                    check sarg_ty != "i1" && sarg_ty != "i64" && sarg_ty != "f64" {
                        sgen_args = str_concat(sgen_args, str_concat("ptr ", args[sgi]));
                    }
                    sgi += 1;
                }
                fixed scall_tmp: str = make_tmp(ctr);
                fixed scp_arity: list<str> = split_words(lookup_var_type(str_concat("@p@", nm), var_names, var_types));
                check starts(lookup_var_type(nm, var_names, var_types), "fnret:") {
                    check len(args) != len(scp_arity) {
                        push(err_pos, snm_pos);
                        push(err_msg, fmt("function '{}' expects {} argument(s) but got {}", nm, len(scp_arity), len(args)));
                        continue;
                    }
                } fallback {
                    // v1.2.1: a bare statement call of a value-returning builtin
                    // is a real situation with a real explanation - not an
                    // "undefined function". Truly undefined names keep the marker.
                    check is_expr_builtin(nm) == 1 {
                        emit_uerr(ir, snm_pos, fmt("'{}' is a builtin that returns a value - a bare statement discards the result. Use it: `set v = {}(...)`, or inside an expression.", nm, nm));
                    } fallback {
                        emit(ir, str_concat(str_concat(str_concat("  ; tv.undeffn:", nm), ":"), int_to_str(snm_pos)));
                    }
                }
                emit(ir, str_concat(str_concat(str_concat(str_concat("  ", scall_tmp), " = call ptr @"), nm), str_concat("(", str_concat(sgen_args, ")"))));
                continue;
            }
            // Indexed assignment: NAME[ IDX ] = EXPR  (list<i64> element store)
            check tok_peek(tokens, pos) == PUNCT_LBRACKET {
                // The target list must exist in this function (else the load below
                // references an undefined slot — a TVC-5002).
                check slot_defined(ir, nm) == 1 { } fallback {
                    emit(ir, str_concat(str_concat(str_concat("  ; tv.undefvar:", nm), ":"), int_to_str(snm_pos)));
                }
                pos += 1;
                set ixv: list<str> = list_new(); set ixp: list<i64> = list_new(); set ixs: list<i64> = list_new(); set ixs_ai: list<i64> = list_new(); set ixv_ty: list<str> = list_new();
                compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, ixv, ixp, ixs, ixs_ai, ixv_ty, var_names, var_types);
                check len(ixp) > 0 { pos = ixp[0]; } check len(ixs) > 0 { s = ixs[0]; } check len(ixs_ai) > 0 { an = ixs_ai[0]; }
                check tok_peek(tokens, pos) == PUNCT_RBRACKET { pos += 1; }
                check tok_peek(tokens, pos) == OP_EQ { pos += 1; }
                set wv: list<str> = list_new(); set wp: list<i64> = list_new(); set ws: list<i64> = list_new(); set ws_ai: list<i64> = list_new(); set wv_ty: list<str> = list_new();
                // compile_value: the stored element may be a ternary (v1.1.0).
                compile_value(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, wv, wp, ws, ws_ai, wv_ty, var_names, var_types);
                check len(wp) > 0 { pos = wp[0]; } check len(ws) > 0 { s = ws[0]; } check len(ws_ai) > 0 { an = ws_ai[0]; }
                pos = check_no_stranded_op(tokens, pos, ir);
                check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; } fallback { push(err_pos, pos - 1); push(err_msg, "expected a semicolon after this statement"); }
                set ixval: str = "0"; check len(ixv) > 0 { ixval = ixv[0]; }
                set ixval_ty: str = "ptr"; check len(ixv_ty) > 0 { ixval_ty = ixv_ty[0]; }
                set ixi: str = ixval; check ixval_ty != "i64" { ixi = coerce_i64(ixval, ir, ctr); }
                set wval: str = "0"; check len(wv) > 0 { wval = wv[0]; }
                set wval_ty: str = "ptr"; check len(wv_ty) > 0 { wval_ty = wv_ty[0]; }
                set wi: str = wval;
                check wval_ty == "i1" { fixed wzx: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", wzx), " = zext i1 "), str_concat(wval, " to i64"))); wi = wzx; } fallback { check wval_ty != "i64" { wi = coerce_i64(wval, ir, ctr); } }
                fixed lst: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat(str_concat("  ", lst), " = load ptr, ptr %"), nm), "_slot, align 8"));
                emit(ir, str_concat(str_concat(str_concat("  call void @torvik_list_set(ptr ", lst), str_concat(", i64 ", ixi)), str_concat(", i64 ", str_concat(wi, ")"))));
                continue;
            }
            // Assignment: NAME = EXPR, NAME += EXPR, NAME -= EXPR
            fixed asg_op: i64 = tok_peek(tokens, pos);
            check asg_op == OP_EQ || asg_op == OP_PLUSEQ || asg_op == OP_MINUSEQ || asg_op == OP_STAREQ || asg_op == OP_SLASHEQ || asg_op == OP_PERCENTEQ {
                // Assigning to a name with no slot in this function — undefined (Torvik
                // does not auto-declare; use 'set name: type = value;' to declare).
                check slot_defined(ir, nm) == 1 { } fallback {
                    emit(ir, str_concat(str_concat(str_concat("  ; tv.undefvar:", nm), ":"), int_to_str(snm_pos)));
                }
                // v1.1.3: a `fixed` binding cannot be reassigned (plain or compound).
                check lookup_fixed_marker(nm, var_names, var_types) == 1 {
                    emit_uerr(ir, snm_pos, fmt("'{nm}' is fixed and cannot be reassigned - declare it with 'set' if it needs to change."));
                }
                fixed is_compound_asg: bool = asg_op != OP_EQ;
                pos += 1;
                // Reject an out-of-range literal assigned to a sized var (plain '='
                // only; compound ops are arithmetic and wrap). 'unsafe' opts in.
                check asg_op == OP_EQ && unsafe_decl == 0 && tok_peek(tokens, pos) == TOK_INT && tok_peek(tokens, pos + 1) == PUNCT_SEMI {
                    fixed _aty: str = lookup_var_type(nm, var_names, var_types);
                    set _alo: list<i64> = list_new();
                    set _ahi: list<i64> = list_new();
                    check int_range(_aty, _alo, _ahi) == 1 {
                        fixed _alit: str = strings[s];
                        fixed _av: i64 = toint(_alit);
                        check _av < _alo[0] || _av > _ahi[0] {
                            set _amsg: str = str_concat("literal ", _alit);
                            _amsg = str_concat(_amsg, " is out of range for ");
                            _amsg = str_concat(_amsg, _aty);
                            _amsg = str_concat(_amsg, " (valid ");
                            _amsg = str_concat(_amsg, int_to_str(_alo[0]));
                            _amsg = str_concat(_amsg, " to ");
                            _amsg = str_concat(_amsg, int_to_str(_ahi[0]));
                            _amsg = str_concat(_amsg, ") - prefix the statement with 'unsafe' to wrap intentionally");
                            push(err_pos, pos);
                            push(err_msg, _amsg);
                            pos += 1; s += 1;
                            check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
                            continue;
                        }
                    }
                    check line_eq(_aty, "u64") == 1 {
                        fixed _aulit: str = strings[s];
                        check u64_in_range(_aulit) == 0 {
                            set _aumsg: str = str_concat("literal ", _aulit);
                            _aumsg = str_concat(_aumsg, " is out of range for u64 (valid 0 to 18446744073709551615) - prefix the statement with 'unsafe' to wrap intentionally");
                            push(err_pos, pos);
                            push(err_msg, _aumsg);
                            pos += 1; s += 1;
                            check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
                            continue;
                        }
                    }
                }
                set av: list<str> = list_new(); set ap: list<i64> = list_new(); set asi: list<i64> = list_new(); set asi_ai: list<i64> = list_new(); set av_ty: list<str> = list_new();
                // compile_value: the RHS of an assignment (plain or compound) may be
                // a ternary — a pure pass-through when it is not (v1.1.0).
                compile_value(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, av, ap, asi, asi_ai, av_ty, var_names, var_types);
                check len(ap) > 0 { pos = ap[0]; }
                check len(asi) > 0 { s = asi[0]; }
                check len(asi_ai) > 0 { an = asi_ai[0]; }
                pos = check_no_stranded_op(tokens, pos, ir);
                check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; } fallback { push(err_pos, pos - 1); push(err_msg, "expected a semicolon after this statement"); }
                fixed aslot: str = str_concat(str_concat("%", nm), "_slot");
                set aval: str = "null"; check len(av) > 0 { aval = av[0]; }
                set aval_ty: str = "ptr"; check len(av_ty) > 0 { aval_ty = av_ty[0]; }
                check is_compound_asg {
                    check line_eq(lookup_var_type(nm, var_names, var_types), "f64") == 1 {
                        // Float compound: load+bitcast to double, fop, bitcast back.
                        check asg_op == OP_PERCENTEQ {
                            emit_uerr(ir, pos, "%= is not defined on floats.");
                        }
                        fixed facld: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat(str_concat("  ", facld), " = load ptr, ptr "), aslot), ", align 8"));
                        fixed facbits: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", facbits), " = ptrtoint ptr "), str_concat(facld, " to i64")));
                        fixed facd: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", facd), " = bitcast i64 "), str_concat(facbits, " to double")));
                        fixed farhs: str = as_double(aval, aval_ty, ir, ctr);
                        fixed fares: str = make_tmp(ctr);
                        check asg_op == OP_PLUSEQ  { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", fares), " = fadd double "), facd), str_concat(", ", farhs))); }
                        check asg_op == OP_MINUSEQ { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", fares), " = fsub double "), facd), str_concat(", ", farhs))); }
                        check asg_op == OP_STAREQ  { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", fares), " = fmul double "), facd), str_concat(", ", farhs))); }
                        check asg_op == OP_SLASHEQ { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", fares), " = fdiv double "), facd), str_concat(", ", farhs))); }
                        fixed faresbc: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", faresbc), " = bitcast double "), str_concat(fares, " to i64")));
                        fixed farespt: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", farespt), " = inttoptr i64 "), str_concat(faresbc, " to ptr")));
                        emit(ir, str_concat(str_concat(str_concat(str_concat("  store ptr ", farespt), ", ptr "), aslot), ", align 8"));
                    } fallback {
                    fixed acur: str = make_tmp(ctr);
                    fixed acur_i: str = make_tmp(ctr);
                    set arhs_i: str = aval;
                    check aval_ty == "i1" { fixed azx: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", azx), " = zext i1 "), str_concat(aval, " to i64"))); arhs_i = azx; } fallback { check aval_ty != "i64" { arhs_i = coerce_i64(aval, ir, ctr); } }
                    fixed ares_i: str = make_tmp(ctr);
                    fixed ares_p: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  ", acur), " = load ptr, ptr "), aslot), ", align 8"));
                    emit(ir, str_concat(str_concat(str_concat("  ", acur_i), " = ptrtoint ptr "), str_concat(acur, " to i64")));
                    fixed acomp_uns: bool = line_eq(lookup_var_type(nm, var_names, var_types), "u64") == 1;
                    set adivf: str = "torvik_div"; set amodf: str = "torvik_mod";
                    check acomp_uns { adivf = "torvik_udiv"; amodf = "torvik_umod"; }
                    check asg_op == OP_PLUSEQ    { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", ares_i), " = add i64 "), acur_i), str_concat(", ", arhs_i))); }
                    check asg_op == OP_MINUSEQ   { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", ares_i), " = sub i64 "), acur_i), str_concat(", ", arhs_i))); }
                    check asg_op == OP_STAREQ    { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", ares_i), " = mul i64 "), acur_i), str_concat(", ", arhs_i))); }
                    check asg_op == OP_SLASHEQ   { emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", ares_i), " = call i64 @"), adivf), str_concat("(i64 ", acur_i)), str_concat(", i64 ", str_concat(arhs_i, ")")))); }
                    check asg_op == OP_PERCENTEQ { emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", ares_i), " = call i64 @"), amodf), str_concat("(i64 ", acur_i)), str_concat(", i64 ", str_concat(arhs_i, ")")))); }
                    emit(ir, str_concat(str_concat(str_concat("  ", ares_p), " = inttoptr i64 "), str_concat(ares_i, " to ptr")));
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  store ptr ", ares_p), ", ptr "), aslot), ", align 8"));
                    }
                } fallback {
                    set astore_val: str = aval;
                    check aval_ty == "i64" || aval_ty == "i1" || aval_ty == "u64" || aval_ty == "bool" {
                        set aiv: str = aval;
                        check aval_ty == "i1" { fixed az: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", az), " = zext i1 "), str_concat(aval, " to i64"))); aiv = az; }
                        // Narrow integer types wrap to their width on store (no-op for i64).
                        fixed acv: str = canonicalize_int(aiv, lookup_var_type(nm, var_names, var_types), ir, ctr);
                        fixed apv: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", apv), " = inttoptr i64 "), str_concat(acv, " to ptr")));
                        astore_val = apv;
                    }
                    check aval_ty == "f64" {
                        fixed afbc: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", afbc), " = bitcast double "), str_concat(aval, " to i64")));
                        fixed afpt: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", afpt), " = inttoptr i64 "), str_concat(afbc, " to ptr")));
                        astore_val = afpt;
                    }
                    // ARC slot reassignment — retain new before releasing old
                    // (self-assign safe). Gated on the type map; an unannotated
                    // var returns "" and gets a plain store, matching its
                    // declaration site (which also emitted no rcinit/refcount).
                    fixed asg_dty: str = lookup_var_type(nm, var_names, var_types);
                    set asg_kind: str = "";
                    check starts(asg_dty, "list") { asg_kind = "list"; }
                    check asg_dty == "str" { asg_kind = "str"; }
                    check starts(asg_dty, "bag") { asg_kind = "bag"; }  // v1.1.3: starts(), see decl site
                    check starts(asg_dty, "table") { asg_kind = "table"; }
                    check asg_dty == "i128" || asg_dty == "u128" { asg_kind = "i128"; }
                    check len(asg_kind) > 0 {
                        emit(ir, str_concat(str_concat("  call ptr @torvik_", asg_kind), str_concat("_retain(ptr ", str_concat(astore_val, ")"))));
                        fixed rc_old2: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", rc_old2), " = load ptr, ptr "), str_concat(aslot, ", align 8")));
                        emit(ir, str_concat(str_concat("  call void @torvik_", asg_kind), str_concat("_release(ptr ", str_concat(rc_old2, ")"))));
                    }
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  store ptr ", astore_val), ", ptr "), aslot), ", align 8"));
                    // B3: a fresh list assigned into a list<str> slot needs marking
                    // (e.g. xs = list_new() reusing an annotated slot). Idempotent.
                    check asg_dty == "list<str>" {
                        emit(ir, str_concat("  call void @torvik_list_mark_managed(ptr ", str_concat(astore_val, ")")));
                    }
                    check asg_dty == "list<i128>" || asg_dty == "list<u128>" {
                        emit(ir, str_concat("  call void @torvik_list_mark_managed_i128(ptr ", str_concat(astore_val, ")")));
                    }
                    check asg_dty == "result<str>" {
                        emit(ir, str_concat("  call void @torvik_result_mark_managed(ptr ", str_concat(astore_val, ")")));
                    }
                }
                continue;
            }
            // ── Unrecognized-statement diagnostic ─────────────────────────
            // Every valid statement form has a handler that `continue`s before
            // here. Reaching this fallback with tokens before the ';' means the
            // statement was not recognized (typo'd keyword, unsupported form).
            // Previously such statements were silently skipped to the ';' and
            // emitted no IR — a silent no-op. Now it is a compile error.
            // (Stranded-operator tails are caught earlier by check_no_stranded_op
            // at the statement/condition chokepoints, before reaching here.)
            set scan: i64 = pos;
            set leftover: i64 = 0;
            whilst scan < ntok && tok_peek(tokens, scan) != PUNCT_SEMI {
                leftover += 1;
                scan += 1;
            }
            check leftover > 0 {
                push(err_pos, pos);
                push(err_msg, "unrecognized or malformed statement");
                pos = scan;   // recover: skip to the ';' so we can collect further errors
            }
            // Empty statement (a bare ';'): consume and move on.
            check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
            continue;
        }

        // whilst COND { BODY } — while loop
        check t == KW_UNTIL {
            pos += 1; // skip whilst
            fixed loop_num: i64 = lctr[0];
            fixed loop_lbl: str = make_label(lctr, "loop");
            fixed body_lbl: str = make_label(lctr, "body");
            fixed exit_num: i64 = lctr[0];
            fixed exit_lbl: str = make_label(lctr, "exit");
            fixed saved_cont: i64 = lctr[1];
            fixed saved_brk: i64 = lctr[2];
            emit(ir, str_concat("  br label %", loop_lbl));
            emit(ir, str_concat(loop_lbl, ":"));
            // Compile condition
            set cv: list<str> = list_new();
            set cp: list<i64> = list_new();
            set cs: list<i64> = list_new();
            set cs_ai: list<i64> = list_new();
            set cv_ty: list<str> = list_new();
            compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, cv, cp, cs, cs_ai, cv_ty, var_names, var_types);
            check len(cp) > 0 { pos = cp[0]; }
            check len(cs) > 0 { s   = cs[0]; }
            check len(cs_ai) > 0 { an = cs_ai[0]; }
            // Accumulators for the running condition value/type
            set cur_cond: str = "null"; check len(cv) > 0 { cur_cond = cv[0]; }
            set cur_ty: str = "ptr"; check len(cv_ty) > 0 { cur_ty = cv_ty[0]; }
            // Handle && and || compound conditions in whilst
            whilst tok_peek(tokens, pos) == OP_AMPAMP || tok_peek(tokens, pos) == OP_PIPEPIPE {
                set is_and_op2: i64 = 0; check tok_peek(tokens, pos) == OP_AMPAMP { is_and_op2 = 1; }
                pos += 1;
                set cv2u: list<str> = list_new(); set cp2u: list<i64> = list_new(); set cs2u: list<i64> = list_new(); set cs2u_ai: list<i64> = list_new(); set cv2u_ty: list<str> = list_new();
                compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, cv2u, cp2u, cs2u, cs2u_ai, cv2u_ty, var_names, var_types);
                check len(cp2u) > 0 { pos = cp2u[0]; } check len(cs2u) > 0 { s = cs2u[0]; } check len(cs2u_ai) > 0 { an = cs2u_ai[0]; }
                check len(cv2u) > 0 {
                    set lhs2: str = cur_cond;
                    set rhs2: str = cv2u[0];
                    set rhsty2: str = "ptr"; check len(cv2u_ty) > 0 { rhsty2 = cv2u_ty[0]; }
                    check cur_ty != "i1" { fixed ztl: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", ztl), " = icmp ne i64 "), str_concat(coerce_i64(lhs2, ir, ctr), ", 0"))); lhs2 = ztl; }
                    check rhsty2 != "i1" { fixed ztr: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", ztr), " = icmp ne i64 "), str_concat(coerce_i64(rhs2, ir, ctr), ", 0"))); rhs2 = ztr; }
                    fixed cmb2: str = make_tmp(ctr);
                    check is_and_op2 == 1 { emit(ir, str_concat(str_concat(str_concat("  ", cmb2), " = and i1 "), str_concat(lhs2, str_concat(", ", rhs2)))); } fallback { emit(ir, str_concat(str_concat(str_concat("  ", cmb2), " = or i1 "), str_concat(lhs2, str_concat(", ", rhs2)))); }
                    cur_cond = cmb2;
                    cur_ty = "i1";
                }
            }
            fixed cval: str = cur_cond;
            pos = check_no_stranded_op(tokens, pos, ir);
            // Convert condition to i1
            set ci1: str = cval;
            fixed ucv_ty_s: str = cur_ty;
            check ucv_ty_s != "i1" {
                fixed tmp_ci: str = make_tmp(ctr);
                check ucv_ty_s == "i64" { emit(ir, str_concat(str_concat(str_concat("  ", tmp_ci), " = icmp ne i64 "), str_concat(cval, ", 0"))); }
                check ucv_ty_s != "i64" { fixed cv_i64: str = coerce_i64(cval, ir, ctr); emit(ir, str_concat(str_concat(str_concat("  ", tmp_ci), " = icmp ne i64 "), str_concat(cv_i64, ", 0"))); }
                ci1 = tmp_ci;
            }








            emit(ir, str_concat(str_concat(str_concat(str_concat("  br i1 ", ci1), ", label %"), body_lbl), str_concat(", label %", exit_lbl)));
            emit(ir, str_concat(body_lbl, ":"));
            lctr[1] = loop_num;
            lctr[2] = exit_num;
            // Compile body
            check tok_peek(tokens, pos) == PUNCT_LBRACE {
                pos += 1;
                fixed be: i64 = skip_to_close_brace(tokens, pos);
                {
                    fixed cs_ret: i64 = compile_stmts(tokens, strings, allnames, pos, be - 1, s, an, ir, ctr, gvals, gnames, lctr, fn_ret_type, var_names, var_types, global_names, err_pos, err_msg);
                    s = cs_ret % 100000;
                    an = cs_ret / 100000;
                }
                pos = be;
            }
            lctr[1] = saved_cont;
            lctr[2] = saved_brk;
            emit(ir, str_concat("  br label %", loop_lbl));
            emit(ir, str_concat(exit_lbl, ":"));
            continue;
        }

        // halt(MSG);  — fatal error: print MSG and exit(1)
        check t == KW_HALT {
            pos += 1;
            check tok_peek(tokens, pos) == PUNCT_LPAREN { pos += 1; } fallback {
                push(err_pos, pos); push(err_msg, "halt expects a message in parentheses, like halt(\"reason\")");
                continue;
            }
            set hv: list<str> = list_new(); set hp: list<i64> = list_new(); set hs: list<i64> = list_new(); set hai: list<i64> = list_new(); set hty: list<str> = list_new();
            compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, hv, hp, hs, hai, hty, var_names, var_types);
            check len(hp) > 0 { pos = hp[0]; } check len(hs) > 0 { s = hs[0]; } check len(hai) > 0 { an = hai[0]; }
            set hmsg: str = "null"; check len(hv) > 0 { hmsg = hv[0]; }
            set hmty: str = "ptr"; check len(hty) > 0 { hmty = hty[0]; }
            check line_eq(hmty, "str") == 0 && line_eq(hmty, "ptr") == 0 {
                push(err_pos, pos); push(err_msg, "halt's message must be a string");
                continue;
            }
            check tok_peek(tokens, pos) == PUNCT_RPAREN { pos += 1; } fallback {
                push(err_pos, pos); push(err_msg, "expected ')' to close halt(...)");
                continue;
            }
            check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; } fallback {
                push(err_pos, pos); push(err_msg, "expected ';' after halt(...)");
                continue;
            }
            emit(ir, str_concat("  call i32 @puts(ptr ", str_concat(hmsg, ")")));
            emit(ir, "  call void @exit(i32 1)");
            emit(ir, "  unreachable");
            fixed dead_h: str = make_label(lctr, "dead");
            emit(ir, str_concat(dead_h, ":"));
            continue;
        }

        // vow(COND, MSG);  — assert: if COND is false, print MSG and exit(1)
        check t == KW_VOW {
            pos += 1;
            check tok_peek(tokens, pos) == PUNCT_LPAREN { pos += 1; } fallback {
                push(err_pos, pos); push(err_msg, "vow expects (condition, message), like vow(x > 0, \"x must be positive\")");
                continue;
            }
            set vc: list<str> = list_new(); set vcp: list<i64> = list_new(); set vcs: list<i64> = list_new(); set vcai: list<i64> = list_new(); set vcty: list<str> = list_new();
            compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, vc, vcp, vcs, vcai, vcty, var_names, var_types);
            check len(vcp) > 0 { pos = vcp[0]; } check len(vcs) > 0 { s = vcs[0]; } check len(vcai) > 0 { an = vcai[0]; }
            set vcond: str = "null"; check len(vc) > 0 { vcond = vc[0]; }
            set vcondty: str = "ptr"; check len(vcty) > 0 { vcondty = vcty[0]; }
            set vci1: str = vcond;
            check line_eq(vcondty, "i1") == 0 {
                fixed vzt: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", vzt), " = icmp ne i64 "), str_concat(coerce_i64(vcond, ir, ctr), ", 0")));
                vci1 = vzt;
            }
            check tok_peek(tokens, pos) == PUNCT_COMMA { pos += 1; } fallback {
                push(err_pos, pos); push(err_msg, "vow expects a message after the condition: vow(cond, \"message\")");
                continue;
            }
            set vm: list<str> = list_new(); set vmp: list<i64> = list_new(); set vms: list<i64> = list_new(); set vmai: list<i64> = list_new(); set vmty: list<str> = list_new();
            compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, vm, vmp, vms, vmai, vmty, var_names, var_types);
            check len(vmp) > 0 { pos = vmp[0]; } check len(vms) > 0 { s = vms[0]; } check len(vmai) > 0 { an = vmai[0]; }
            set vmsg: str = "null"; check len(vm) > 0 { vmsg = vm[0]; }
            set vmsgty: str = "ptr"; check len(vmty) > 0 { vmsgty = vmty[0]; }
            check line_eq(vmsgty, "str") == 0 && line_eq(vmsgty, "ptr") == 0 {
                push(err_pos, pos); push(err_msg, "vow's message must be a string");
                continue;
            }
            check tok_peek(tokens, pos) == PUNCT_RPAREN { pos += 1; } fallback {
                push(err_pos, pos); push(err_msg, "expected ')' to close vow(...)");
                continue;
            }
            check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; } fallback {
                push(err_pos, pos); push(err_msg, "expected ';' after vow(...)");
                continue;
            }
            fixed vok: str = make_label(lctr, "vowok");
            fixed vfail: str = make_label(lctr, "vowfail");
            emit(ir, str_concat(str_concat(str_concat(str_concat("  br i1 ", vci1), ", label %"), vok), str_concat(", label %", vfail)));
            emit(ir, str_concat(vfail, ":"));
            emit(ir, str_concat("  call i32 @puts(ptr ", str_concat(vmsg, ")")));
            emit(ir, "  call void @exit(i32 1)");
            emit(ir, "  unreachable");
            emit(ir, str_concat(vok, ":"));
            continue;
        }

        // guard COND fallback { BODY }  — run BODY when COND is false (early-exit)
        check t == KW_GUARD {
            pos += 1;
            set gc: list<str> = list_new(); set gcp: list<i64> = list_new(); set gcs: list<i64> = list_new(); set gcai: list<i64> = list_new(); set gcty: list<str> = list_new();
            compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, gc, gcp, gcs, gcai, gcty, var_names, var_types);
            check len(gcp) > 0 { pos = gcp[0]; } check len(gcs) > 0 { s = gcs[0]; } check len(gcai) > 0 { an = gcai[0]; }
            set gcond: str = "null"; check len(gc) > 0 { gcond = gc[0]; }
            set gcondty: str = "ptr"; check len(gcty) > 0 { gcondty = gcty[0]; }
            pos = check_no_stranded_op(tokens, pos, ir);
            set gci1: str = gcond;
            check line_eq(gcondty, "i1") == 0 {
                fixed gzt: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", gzt), " = icmp ne i64 "), str_concat(coerce_i64(gcond, ir, ctr), ", 0")));
                gci1 = gzt;
            }
            check tok_peek(tokens, pos) == KW_FALLBACK { pos += 1; } fallback {
                push(err_pos, pos); push(err_msg, "guard expects `fallback { ... }` after its condition, like guard x > 0 fallback { return; }");
                continue;
            }
            check tok_peek(tokens, pos) == PUNCT_LBRACE { pos += 1; } fallback {
                push(err_pos, pos); push(err_msg, "expected '{' to open guard's fallback block");
                continue;
            }
            fixed gcont: str = make_label(lctr, "gcont");
            fixed gfail: str = make_label(lctr, "gfail");
            // COND true -> skip the body; COND false -> run the fallback body
            emit(ir, str_concat(str_concat(str_concat(str_concat("  br i1 ", gci1), ", label %"), gcont), str_concat(", label %", gfail)));
            emit(ir, str_concat(gfail, ":"));
            fixed ge: i64 = skip_to_close_brace(tokens, pos);
            {
                fixed gcs_ret: i64 = compile_stmts(tokens, strings, allnames, pos, ge - 1, s, an, ir, ctr, gvals, gnames, lctr, fn_ret_type, var_names, var_types, global_names, err_pos, err_msg);
                s = gcs_ret % 100000;
                an = gcs_ret / 100000;
            }
            pos = ge;
            check block_terminated(ir) == 0 { emit(ir, str_concat("  br label %", gcont)); }
            emit(ir, str_concat(gcont, ":"));
            continue;
        }

        // each VAR in START..END { BODY }   — exclusive-range for loop
        check t == KW_EACH {
            pos += 1;
            check tok_peek(tokens, pos) == TOK_IDENT { } fallback {
                push(err_pos, pos); push(err_msg, "each expects a loop variable name, like each i in 0..n { ... }");
                continue;
            }
            fixed evar: str = allnames[an];
            an += 1;
            pos += 1;
            // The loop variable is implicitly i64 — reusing a non-i64 name from
            // this function would corrupt that variable's slot. Reject cleanly,
            // caret on the variable name.
            check redecl_conflict(evar, "i64", var_names, var_types) == 1 {
                set _emsg: str = str_concat("loop variable '", evar);
                _emsg = str_concat(_emsg, "' is already declared with type ");
                _emsg = str_concat(_emsg, lookup_var_type(evar, var_names, var_types));
                _emsg = str_concat(_emsg, " in this function - an each loop variable is i64; use a different name");
                push(err_pos, pos - 1); push(err_msg, _emsg);
                // Recover past the whole statement (range + body), keeping the
                // string/name streams aligned, so no phantom errors follow.
                whilst pos < end && pos < ntok && tok_peek(tokens, pos) != PUNCT_LBRACE {
                    fixed _etk: i64 = tok_peek(tokens, pos);
                    check _etk == TOK_INT || _etk == TOK_FLOAT { s += 1; }
                    check _etk == TOK_STRING { s += 1; an += 1; }
                    check _etk == TOK_IDENT { an += 1; }
                    pos += 1;
                }
                check tok_peek(tokens, pos) == PUNCT_LBRACE {
                    pos += 1;
                    fixed _ebe: i64 = skip_to_close_brace(tokens, pos);
                    whilst pos < _ebe {
                        fixed _btk: i64 = tok_peek(tokens, pos);
                        check _btk == TOK_INT || _btk == TOK_FLOAT { s += 1; }
                        check _btk == TOK_STRING { s += 1; an += 1; }
                        check _btk == TOK_IDENT { an += 1; }
                        pos += 1;
                    }
                }
                continue;
            }
            check tok_peek(tokens, pos) == KW_IN { pos += 1; } fallback {
                push(err_pos, pos); push(err_msg, "each expects `in` after the loop variable, like each i in 0..n { ... }");
                continue;
            }
            // v1.1.0: direct collection iteration — `each x in xs { ... }` where
            // xs is a bare list variable (not followed by `..`/`..+`). Binds the
            // loop variable to each element in turn, typed as the list's element
            // type, walking an internal 0..len counter. Detected by: a bare list
            // IDENT immediately followed by `{` (a range always has `..` between
            // the start expression and the body). A non-list bare variable here
            // is a clean error pointing at the collection.
            check tok_peek(tokens, pos) == TOK_IDENT && tok_peek(tokens, pos + 1) == PUNCT_LBRACE {
                fixed coll_name: str = allnames[an];
                fixed coll_ty: str = lookup_var_type(coll_name, var_names, var_types);
                check starts(coll_ty, "list") {
                    an += 1; pos += 1;   // consume the collection name
                    fixed celem: str = list_elem_type(coll_ty);
                    // The loop variable takes the element type; reusing a name
                    // already bound to a DIFFERENT type in this function would
                    // corrupt that slot (e.g. an i64 loop var reused for str
                    // elements). Reject cleanly, same rule as declarations.
                    check redecl_conflict(evar, celem, var_names, var_types) == 1 {
                        emit_uerr(ir, pos - 2, fmt("loop variable '{}' is already declared with type {} in this function - an each loop over this list binds it as {}; use a different name.", evar, lookup_var_type(evar, var_names, var_types), celem));
                    }
                    set cel_is_str: i64 = 0; check line_eq(celem, "str") == 1 { cel_is_str = 1; }
                    // load the collection ptr once
                    fixed ccol: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  ", ccol), " = load ptr, ptr %"), coll_name), "_slot, align 8"));
                    // internal counter slot (unique per loop via the label counter)
                    fixed cidx_slot: str = str_concat(str_concat("%_each_idx", int_to_str(lctr[0])), "_slot");
                    emit(ir, str_concat(str_concat("  ", cidx_slot), " = alloca i64, align 8"));
                    emit(ir, str_concat(str_concat("  store i64 0, ptr ", cidx_slot), ", align 8"));
                    // register the loop variable with the ELEMENT type + its slot
                    push(var_names, evar); push(var_types, celem);
                    fixed cvslot: str = str_concat(str_concat("%", evar), "_slot");
                    fixed cvalloca: str = str_concat(str_concat("  ", cvslot), " = alloca ptr, align 8");
                    check slot_exists(ir, cvalloca) == 0 { emit(ir, cvalloca); }
                    // For str elements the slot is ARC-managed: null-init it (tagged
                    // tv.rcinit so the init hoists to entry and the scope pass frees
                    // the slot once at end of scope). This makes the per-iteration
                    // release-of-previous safe on the first pass (release(null) is a
                    // no-op) and balances the retain-on-bind below.
                    check cel_is_str == 1 {
                        emit(ir, str_concat(str_concat("  store ptr null, ptr ", cvslot), ", align 8 ; tv.rcinit:str"));
                    }
                    fixed cchk: str = make_label(lctr, "loop");
                    fixed cbody: str = make_label(lctr, "body");
                    fixed clatch_num: i64 = lctr[0];
                    fixed clatch: str = make_label(lctr, "loop");
                    fixed cexit_num: i64 = lctr[0];
                    fixed cexit: str = make_label(lctr, "exit");
                    fixed csc: i64 = lctr[1];
                    fixed csb: i64 = lctr[2];
                    // condition: idx < len(coll)
                    emit(ir, str_concat("  br label %", cchk));
                    emit(ir, str_concat(cchk, ":"));
                    fixed cidxl: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat("  ", cidxl), str_concat(" = load i64, ptr ", str_concat(cidx_slot, ", align 8"))));
                    fixed clen: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", clen), " = call i64 @torvik_len(ptr "), str_concat(ccol, ")")));
                    fixed ccond: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", ccond), " = icmp slt i64 "), str_concat(cidxl, str_concat(", ", clen))));
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  br i1 ", ccond), ", label %"), cbody), str_concat(", label %", cexit)));
                    emit(ir, str_concat(cbody, ":"));
                    // element = coll[idx]; bind into the loop-var slot
                    fixed cget: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cget), " = call ptr @torvik_list_get(ptr "), ccol), str_concat(", i64 ", str_concat(cidxl, ")"))));
                    // For str elements, retain on bind (the slot owns a reference,
                    // released at end-of-iteration below) so ARC stays balanced.
                    check cel_is_str == 1 {
                        emit(ir, str_concat("  call ptr @torvik_str_retain(ptr ", str_concat(cget, ")")));
                        // release any prior slot value (from the previous iteration)
                        fixed cprev: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", cprev), " = load ptr, ptr "), str_concat(cvslot, ", align 8")));
                        emit(ir, str_concat("  call void @torvik_str_release(ptr ", str_concat(cprev, ")")));
                    }
                    emit(ir, str_concat(str_concat("  store ptr ", cget), str_concat(", ptr ", str_concat(cvslot, ", align 8"))));
                    lctr[1] = clatch_num;
                    lctr[2] = cexit_num;
                    check tok_peek(tokens, pos) == PUNCT_LBRACE {
                        pos += 1;
                        fixed cbe: i64 = skip_to_close_brace(tokens, pos);
                        {
                            fixed ccs: i64 = compile_stmts(tokens, strings, allnames, pos, cbe - 1, s, an, ir, ctr, gvals, gnames, lctr, fn_ret_type, var_names, var_types, global_names, err_pos, err_msg);
                            s = ccs % 100000;
                            an = ccs / 100000;
                        }
                        pos = cbe;
                    } fallback {
                        lctr[1] = csc; lctr[2] = csb;
                        push(err_pos, pos); push(err_msg, "expected '{' to open each's loop body");
                        continue;
                    }
                    lctr[1] = csc;
                    lctr[2] = csb;
                    check block_terminated(ir) == 0 { emit(ir, str_concat("  br label %", clatch)); }
                    emit(ir, str_concat(clatch, ":"));
                    // idx += 1
                    fixed cidx2: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat("  ", cidx2), str_concat(" = load i64, ptr ", str_concat(cidx_slot, ", align 8"))));
                    fixed cinc: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", cinc), " = add i64 "), str_concat(cidx2, ", 1")));
                    emit(ir, str_concat(str_concat("  store i64 ", cinc), str_concat(", ptr ", str_concat(cidx_slot, ", align 8"))));
                    emit(ir, str_concat("  br label %", cchk));
                    emit(ir, str_concat(cexit, ":"));
                    // NOTE: no manual release of the final held element here — the
                    // loop variable is a str-typed slot in the type map, so the
                    // function's ARC scope-release pass frees it exactly once at
                    // end of scope. (An explicit release here double-freed it.)
                    continue;
                } fallback {
                    emit_uerr(ir, pos, fmt("`each {} in {}` needs a range or a list - `{}` is type {}. Use `each i in 0..len(...)` for a range, or iterate a list variable directly.", evar, coll_name, coll_name, coll_ty));
                    // recover past the body
                    an += 1; pos += 1;
                    check tok_peek(tokens, pos) == PUNCT_LBRACE {
                        pos += 1;
                        fixed cbe2: i64 = skip_to_close_brace(tokens, pos);
                        whilst pos < cbe2 {
                            fixed btk2: i64 = tok_peek(tokens, pos);
                            check btk2 == TOK_INT || btk2 == TOK_FLOAT { s += 1; }
                            check btk2 == TOK_STRING { s += 1; an += 1; }
                            check btk2 == TOK_IDENT { an += 1; }
                            pos += 1;
                        }
                    }
                    continue;
                }
            }
            set ev0: list<str> = list_new(); set ep0: list<i64> = list_new(); set es0: list<i64> = list_new(); set ea0: list<i64> = list_new(); set et0: list<str> = list_new();
            compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, ev0, ep0, es0, ea0, et0, var_names, var_types);
            check len(ep0) > 0 { pos = ep0[0]; } check len(es0) > 0 { s = es0[0]; } check len(ea0) > 0 { an = ea0[0]; }
            set estart: str = "null"; check len(ev0) > 0 { estart = ev0[0]; }
            set e_incl: i64 = 0;
            check tok_peek(tokens, pos) == OP_DOTDOTPLUS { e_incl = 1; }
            check tok_peek(tokens, pos) == OP_DOTDOT || tok_peek(tokens, pos) == OP_DOTDOTPLUS { pos += 1; } fallback {
                push(err_pos, pos); push(err_msg, "each iterates a range: each i in START..END (exclusive) or START..+END (inclusive). To walk a list, use each i in 0..len(xs) and index xs[i].");
                continue;
            }
            set ev1: list<str> = list_new(); set ep1: list<i64> = list_new(); set es1: list<i64> = list_new(); set ea1: list<i64> = list_new(); set et1: list<str> = list_new();
            compile_expr(tokens, strings, allnames, pos, s, an, ir, ctr, gvals, gnames, ev1, ep1, es1, ea1, et1, var_names, var_types);
            check len(ep1) > 0 { pos = ep1[0]; } check len(es1) > 0 { s = es1[0]; } check len(ea1) > 0 { an = ea1[0]; }
            set eend: str = "null"; check len(ev1) > 0 { eend = ev1[0]; }
            pos = check_no_stranded_op(tokens, pos, ir);
            fixed estart_i: str = coerce_i64(estart, ir, ctr);
            fixed eend_i: str = coerce_i64(eend, ir, ctr);
            // register loop var (i64) + its slot
            push(var_names, evar); push(var_types, "i64");
            fixed eslot: str = str_concat(str_concat("%", evar), "_slot");
            fixed ealloca: str = str_concat(str_concat("  ", eslot), " = alloca ptr, align 8");
            check slot_exists(ir, ealloca) == 0 { emit(ir, ealloca); }
            // VAR = START
            fixed estp: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", estp), " = inttoptr i64 "), str_concat(estart_i, " to ptr")));
            emit(ir, str_concat(str_concat("  store ptr ", estp), str_concat(", ptr ", str_concat(eslot, ", align 8"))));
            fixed echk: str = make_label(lctr, "loop");
            fixed ebody: str = make_label(lctr, "body");
            fixed elatch_num: i64 = lctr[0];
            fixed elatch: str = make_label(lctr, "loop");
            fixed eexit_num: i64 = lctr[0];
            fixed eexit: str = make_label(lctr, "exit");
            fixed esc: i64 = lctr[1];
            fixed esb: i64 = lctr[2];
            emit(ir, str_concat("  br label %", echk));
            emit(ir, str_concat(echk, ":"));
            fixed eld: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", eld), " = load ptr, ptr "), str_concat(eslot, ", align 8")));
            fixed eldi: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", eldi), " = ptrtoint ptr "), str_concat(eld, " to i64")));
            fixed econd: str = make_tmp(ctr);
            // ..  (exclusive) -> slt;  ..+ (inclusive) -> sle
            set e_cmpop: str = "slt";
            check e_incl == 1 { e_cmpop = "sle"; }
            emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat(str_concat("  ", econd), " = icmp "), e_cmpop), " i64 "), eldi), str_concat(", ", eend_i)));
            emit(ir, str_concat(str_concat(str_concat(str_concat("  br i1 ", econd), ", label %"), ebody), str_concat(", label %", eexit)));
            emit(ir, str_concat(ebody, ":"));
            lctr[1] = elatch_num;
            lctr[2] = eexit_num;
            check tok_peek(tokens, pos) == PUNCT_LBRACE {
                pos += 1;
                fixed ebe: i64 = skip_to_close_brace(tokens, pos);
                {
                    fixed ecs: i64 = compile_stmts(tokens, strings, allnames, pos, ebe - 1, s, an, ir, ctr, gvals, gnames, lctr, fn_ret_type, var_names, var_types, global_names, err_pos, err_msg);
                    s = ecs % 100000;
                    an = ecs / 100000;
                }
                pos = ebe;
            } fallback {
                lctr[1] = esc; lctr[2] = esb;
                push(err_pos, pos); push(err_msg, "expected '{' to open each's loop body");
                continue;
            }
            lctr[1] = esc;
            lctr[2] = esb;
            check block_terminated(ir) == 0 { emit(ir, str_concat("  br label %", elatch)); }
            emit(ir, str_concat(elatch, ":"));
            fixed eld2: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", eld2), " = load ptr, ptr "), str_concat(eslot, ", align 8")));
            fixed eld2i: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", eld2i), " = ptrtoint ptr "), str_concat(eld2, " to i64")));
            fixed einc: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", einc), " = add i64 "), str_concat(eld2i, ", 1")));
            fixed eincp: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", eincp), " = inttoptr i64 "), str_concat(einc, " to ptr")));
            emit(ir, str_concat(str_concat("  store ptr ", eincp), str_concat(", ptr ", str_concat(eslot, ", align 8"))));
            emit(ir, str_concat("  br label %", echk));
            emit(ir, str_concat(eexit, ":"));
            continue;
        }

        // Bare block statement: { BODY }
        check t == PUNCT_LBRACE {
            pos += 1;
            fixed blk_end: i64 = skip_to_close_brace(tokens, pos);
            {
                fixed blk_ret: i64 = compile_stmts(tokens, strings, allnames, pos, blk_end - 1, s, an, ir, ctr, gvals, gnames, lctr, fn_ret_type, var_names, var_types, global_names, err_pos, err_msg);
                s = blk_ret % 100000;
                an = blk_ret / 100000;
            }
            pos = blk_end;
            continue;
        }

        // No statement branch matched this leading token. This used to be a silent
        // `pos += 1`, which (a) accepted bogus statements like `"is";` or `42;` with
        // no error and (b) skipped literal tokens WITHOUT advancing the string-literal
        // index `s`, desyncing every later string/number literal and producing WRONG
        // OUTPUT (e.g. a later echo printing an earlier string). Now: report an
        // unrecognized statement and recover to the next ';', advancing `s`/`an`
        // across the skipped tokens so the literal/name indices stay in sync.
        check t == PUNCT_SEMI { pos += 1; continue; }   // bare ';' — empty statement, allowed
        push(err_pos, pos);
        push(err_msg, "unrecognized or malformed statement");
        whilst pos < end && pos < ntok && tok_peek(tokens, pos) != PUNCT_SEMI {
            fixed _ftk: i64 = tok_peek(tokens, pos);
            check _ftk == TOK_INT || _ftk == TOK_FLOAT { s += 1; }
                        check _ftk == TOK_STRING { s += 1; an += 1; }
            check _ftk == TOK_IDENT { an += 1; }
            pos += 1;
        }
        check tok_peek(tokens, pos) == PUNCT_SEMI { pos += 1; }
        continue;
    }
    set _enc: i64 = an * 100000;
    return s + _enc;
}

// ─── Main entry point ─────────────────────────────────────────────────────────

// Escape a string for LLVM constant emission (byte-for-byte)
// Check if haystack contains needle (substring search)
df str_contains(haystack: str, needle: str) -> bool {
    fixed hn: i64 = len(haystack);
    fixed nn: i64 = len(needle);
    check nn == 0 { return true; }
    check nn > hn { return false; }
    set i: i64 = 0;
    whilst i <= hn - nn {
        set j: i64 = 0;
        set matched: i64 = 1;
        whilst j < nn {
            check byte_at(haystack, i + j) != byte_at(needle, j) { matched = 0; j = nn; } fallback { j += 1; }
        }
        check matched == 1 { return true; }
        i += 1;
    }
    return false;
}

// Hoist all alloca instructions to the function entry block (LLVM dominance rule).
// ARC Stage A: also hoists ; tv.rcinit null-init stores to run right after the
// allocas — once per function entry, never inside a loop body.
df hoist_allocas(fn_ir: list<str>) -> list<str> {
    set head: list<str> = list_new();
    set allocas: list<str> = list_new();
    set inits: list<str> = list_new();
    set rest: list<str> = list_new();
    fixed n: i64 = len(fn_ir);
    set i: i64 = 0;
    fixed amark: str = "= alloca ";
    fixed imark: str = "; tv.rcinit";
    whilst i < n {
        fixed line: str = fn_ir[i];
        check i < 2 { push(head, line); } fallback {
            check str_contains(line, amark) { push(allocas, line); } fallback {
                check str_contains(line, imark) { push(inits, line); } fallback { push(rest, line); }
            }
        }
        i += 1;
    }
    set out: list<str> = list_new();
    set k: i64 = 0;
    whilst k < len(head) { push(out, head[k]); k += 1; }
    set k2: i64 = 0;
    whilst k2 < len(allocas) { push(out, allocas[k2]); k2 += 1; }
    set ki: i64 = 0;
    whilst ki < len(inits) { push(out, inits[ki]); ki += 1; }
    set k3: i64 = 0;
    whilst k3 < len(rest) { push(out, rest[k3]); k3 += 1; }
    return out;
}

// Memory Stage C: scope-exit release. Before EVERY `ret`, release each
// refcounted slot in the function — locals (collected from ; tv.rcinit:KIND
// tags, which hoisting placed in the entry block, so every slot is null-or-
// valid at any ret) and params (balancing their entry retains). The RETURNED
// value is retained FIRST (ARC +1-on-return): releasing the slot it came from
// must not free it mid-return; the caller's store then takes its own claim.
// The in-flight +1 on call results is dropped by Stage E temp management.
// Collection dedups slot names so a shadowed/recollected slot can never be
// double-released.
df inject_scope_releases(fn_ir: list<str>, ctr: list<i64>, rty: str, pnames: list<str>, ptypes: list<str>) -> list<str> {
    set rc_slots: list<str> = list_new();
    set rc_kinds: list<str> = list_new();
    fixed n: i64 = len(fn_ir);
    set i: i64 = 0;
    whilst i < n {
        fixed line: str = fn_ir[i];
        check ends(line, "; tv.rcinit:str") {
            fixed sl: i64 = len(line);
            fixed snm: str = substr(line, 22, sl - 25);
            check slot_exists(rc_slots, snm) == 0 { push(rc_slots, snm); push(rc_kinds, "str"); }
        }
        check ends(line, "; tv.rcinit:list") {
            fixed sl2: i64 = len(line);
            fixed snm2: str = substr(line, 22, sl2 - 26);
            check slot_exists(rc_slots, snm2) == 0 { push(rc_slots, snm2); push(rc_kinds, "list"); }
        }
        check ends(line, "; tv.rcinit:bag") {
            fixed sl3: i64 = len(line);
            fixed snm3: str = substr(line, 22, sl3 - 25);
            check slot_exists(rc_slots, snm3) == 0 { push(rc_slots, snm3); push(rc_kinds, "bag"); }
        }
        check ends(line, "; tv.rcinit:table") {
            fixed sl4: i64 = len(line);
            fixed snm4: str = substr(line, 22, sl4 - 27);
            check slot_exists(rc_slots, snm4) == 0 { push(rc_slots, snm4); push(rc_kinds, "table"); }
        }
        check ends(line, "; tv.rcinit:result") {
            fixed sl5: i64 = len(line);
            fixed snm5: str = substr(line, 22, sl5 - 28);
            check slot_exists(rc_slots, snm5) == 0 { push(rc_slots, snm5); push(rc_kinds, "result"); }
        }
        check ends(line, "; tv.rcinit:i128") {
            fixed sl6: i64 = len(line);
            fixed snm6: str = substr(line, 22, sl6 - 26);
            check slot_exists(rc_slots, snm6) == 0 { push(rc_slots, snm6); push(rc_kinds, "i128"); }
        }
        i += 1;
    }
    set pi: i64 = 0;
    whilst pi < len(pnames) {
        check pi < len(ptypes) {
            fixed pt: str = ptypes[pi];
            set pk: str = "";
            check starts(pt, "list") { pk = "list"; }
            check pt == "str" { pk = "str"; }
            check starts(pt, "bag") { pk = "bag"; }  // v1.1.3: starts(), see decl site
            check starts(pt, "table") { pk = "table"; }
            check starts(pt, "result") { pk = "result"; }
            check pt == "i128" || pt == "u128" { pk = "i128"; }
            check len(pk) > 0 {
                fixed pslot: str = str_concat(str_concat("%", pnames[pi]), "_slot");
                check slot_exists(rc_slots, pslot) == 0 { push(rc_slots, pslot); push(rc_kinds, pk); }
            }
        }
        pi += 1;
    }
    set rkind: str = "";
    check starts(rty, "list") { rkind = "list"; }
    check rty == "str" { rkind = "str"; }
    check starts(rty, "result") { rkind = "result"; }
    check rty == "i128" || rty == "u128" { rkind = "i128"; }
    set out: list<str> = list_new();
    set j: i64 = 0;
    whilst j < n {
        fixed l2: str = fn_ir[j];
        check starts(l2, "  ret ptr ") {
            fixed rop: str = substr(l2, 10, len(l2));
            // A returned result<str> must OWN its string value before this
            // function's local str slots release at scope exit — otherwise the
            // value dangles in the caller. mark_managed retains the ok-value
            // (no-op on an err result); idempotent if the caller re-marks.
            check rty == "result<str>" && rop != "null" {
                emit(out, str_concat("  call void @torvik_result_mark_managed(ptr ", str_concat(rop, ")")));
            }
            check len(rkind) > 0 && rop != "null" {
                emit(out, str_concat(str_concat("  call ptr @torvik_", rkind), str_concat("_retain(ptr ", str_concat(rop, ")"))));
            }
            set k: i64 = 0;
            whilst k < len(rc_slots) {
                fixed rtmp: str = make_tmp(ctr);
                emit(out, str_concat(str_concat(str_concat("  ", rtmp), " = load ptr, ptr "), str_concat(rc_slots[k], ", align 8")));
                emit(out, str_concat(str_concat("  call void @torvik_", rc_kinds[k]), str_concat("_release(ptr ", str_concat(rtmp, ")"))));
                k += 1;
            }
        }
        push(out, l2);
        j += 1;
    }
    return out;
}

// "  %tN = ..." -> "%tN" ("" if the line isn't an assignment of that shape).
// NOTE: `check starts(...) == 0` is NOT a supported form — starts takes the
// builtin truthiness fast path and the `== 0` tokens are silently skipped
// (same class as the str_const_size `+ 16` bug). Bind to a flag, then compare.
df line_lhs(line: str) -> str {
    set isreg: i64 = 0;
    check starts(line, "  %") { isreg = 1; }
    check isreg == 0 { return ""; }
    fixed n: i64 = len(line);
    set i: i64 = 2;
    whilst i < n {
        fixed c: str = substr(line, i, i + 1);
        check c == " " { return substr(line, 2, i); }
        i += 1;
    }
    return "";
}

// Memory Stage E: classify a line as a refcounted-temp producer.
// Returns "" (not a producer) or CLASS:KIND where CLASS is
//   a = floating result (+0, runtime allocator) -> retain+release at flush:
//       frees ONLY if no slot/list claimed it. Loads (list_get, args_get) are
//       deliberately NOT here — they don't allocate, releasing them would
//       dangle the real holder's value.
//   b = owned result (+1 in-flight from a Torvik fn's ARC return) -> single
//       release at flush drops the producer's claim, holders keep theirs.
df temp_producer_code(line: str, upats: list<str>, ucodes: list<str>) -> str {
    // A ref-kind ternary merge: the phi arrives with the taken branch's carried
    // +1 claim (class b — owned in-flight), released once at the statement flush.
    check str_contains(line, "; tv.ternphi:str") { return "b:str"; }
    check str_contains(line, "; tv.ternphi:list") { return "b:list"; }
    check str_contains(line, "; tv.ternphi:bag") { return "b:bag"; }
    check str_contains(line, "; tv.ternphi:table") { return "b:table"; }
    check str_contains(line, "; tv.ternphi:result") { return "b:result"; }
    check str_contains(line, "; tv.ternphi:i128") { return "b:i128"; }
    check str_contains(line, " = call ptr @torvik_str_concat(") { return "a:str"; }
    check str_contains(line, "; tv.strpop") { return "b:str"; }
    check str_contains(line, " = call ptr @torvik_char_str(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_byte_str(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_int_to_str(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_uint_to_str(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_i128_box(") { return "a:i128"; }
    check str_contains(line, " = call ptr @torvik_i128_to_str(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_u128_to_str(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_substr(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_trim(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_triml(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_trimr(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_upper(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_lower(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_readfile(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_sys_home_dir(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_sys_cwd(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_sys_arch(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_sys_hostname(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_sys_os_name(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_sys_os_version(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_sys_username(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_tostr(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_replace(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_time_str(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_date_str(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_readln(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_read(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_readenv(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_split_list(") { return "a:list"; }
    check str_contains(line, " = call ptr @torvik_bag_new(") { return "a:bag"; }
    check str_contains(line, " = call ptr @torvik_table_new(") { return "a:table"; }
    check str_contains(line, " = call ptr @torvik_result_ok(") { return "a:result"; }
    check str_contains(line, " = call ptr @torvik_result_err(") { return "a:result"; }
    check str_contains(line, " = call ptr @torvik_try_readfile(") { return "a:result"; }
    check str_contains(line, " = call ptr @torvik_try_toint(") { return "a:result"; }
    check str_contains(line, " = call ptr @torvik_try_tofloat(") { return "a:result"; }
    check str_contains(line, " = call ptr @torvik_float_to_str(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_bool_to_str(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_list_to_str(") { return "a:str"; }
    check str_contains(line, "@torvik_fmt_apply(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_datetime_str(") { return "a:str"; }
    check str_contains(line, " = call ptr @torvik_list_new(") { return "a:list"; }
    set u: i64 = 0;
    whilst u < len(upats) {
        check str_contains(line, upats[u]) { return ucodes[u]; }
        u += 1;
    }
    return "";
}

// Memory Stage E: per-statement cleanup of producer temps. Collect refcounted
// producer results between ; tv.stmt markers; at each marker, emit the cleanup
// for the previous statement's temps, then strip the marker. At a terminator
// (ret/br) the pending temps are released BEFORE the terminator — they were
// produced earlier in the same block, so the release dominates (SSA-safe) and
// nothing executes after. The returned value is excepted at a ret (the caller
// adopts it). Non-instruction lines (labels, define, }) only ever follow a
// terminator that already flushed, so pending is empty there.
df inject_temp_cleanup(fn_ir: list<str>, ctr: list<i64>, upats: list<str>, ucodes: list<str>) -> list<str> {
    set out: list<str> = list_new();
    set pend_vals: list<str> = list_new();
    set pend_codes: list<str> = list_new();
    fixed n: i64 = len(fn_ir);
    set i: i64 = 0;
    whilst i < n {
        fixed line: str = fn_ir[i];
        check line == "  ; tv.stmt" {
            set k: i64 = 0;
            whilst k < len(pend_vals) {
                fixed pc: str = pend_codes[k];
                fixed pv: str = pend_vals[k];
                // Every refcounted temp is owned at rc>=1 for its whole life:
                // class a (floating runtime result) is retained at production
                // below; class b (a Torvik fn's +1-on-return) arrives owned. So
                // the per-statement cleanup is a single release that drops the
                // temp's own claim — freeing it iff no slot/list/etc. took one.
                check len(pc) > 2 {
                    fixed pkd: str = substr(pc, 2, len(pc));
                    emit(out, str_concat(str_concat("  call void @torvik_", pkd), str_concat("_release(ptr ", str_concat(pv, ")"))));
                }
                k += 1;
            }
            pend_vals = list_new();
            pend_codes = list_new();
            i += 1;
            continue;
        }
        check starts(line, "  ret ") {
            // Stage E at a ret: release this block's pending producer temps,
            // INCLUDING the returned value. inject_scope_releases already emitted
            // its +1 return-retain just above (transferring a claim to the
            // caller), so releasing the temp's own production/return claim here
            // leaves exactly the caller's +1. A non-temp return value (a slot
            // load) is never in pending, so it is untouched.
            set kr: i64 = 0;
            whilst kr < len(pend_vals) {
                fixed pcr: str = pend_codes[kr];
                fixed pvr: str = pend_vals[kr];
                check len(pcr) > 2 {
                    fixed rkd: str = substr(pcr, 2, len(pcr));
                    emit(out, str_concat(str_concat("  call void @torvik_", rkd), str_concat("_release(ptr ", str_concat(pvr, ")"))));
                }
                kr += 1;
            }
            push(out, line);
            pend_vals = list_new();
            pend_codes = list_new();
            i += 1;
            continue;
        }
        check starts(line, "  br ") {
            // Stage E before a branch: single release of pending producer temps.
            // They are consumed within their own statement and never referenced
            // across the edge in this codegen, so releasing here frees a temp no
            // slot claimed and leaves an owned one alive (slot keeps its claim).
            set kb: i64 = 0;
            whilst kb < len(pend_vals) {
                fixed pcb: str = pend_codes[kb];
                fixed pvb: str = pend_vals[kb];
                check len(pcb) > 2 {
                    fixed bkd: str = substr(pcb, 2, len(pcb));
                    emit(out, str_concat(str_concat("  call void @torvik_", bkd), str_concat("_release(ptr ", str_concat(pvb, ")"))));
                }
                kb += 1;
            }
            push(out, line);
            pend_vals = list_new();
            pend_codes = list_new();
            i += 1;
            continue;
        }
        set isinstr: i64 = 0;
        check starts(line, "  ") { isinstr = 1; }
        check isinstr == 0 {
            push(out, line);
            pend_vals = list_new();
            pend_codes = list_new();
            i += 1;
            continue;
        }
        fixed code: str = temp_producer_code(line, upats, ucodes);
        push(out, line);
        check len(code) > 0 {
            fixed lhs: str = line_lhs(line);
            check len(lhs) > 0 {
                push(pend_vals, lhs); push(pend_codes, code);
                // retain-at-production: take ownership of a class-a floating temp
                // (rc 0 from the runtime allocator) immediately, so any claim a
                // callee takes and drops cannot free it before this statement's
                // single flush release does. class b is already +1-owned.
                check starts(code, "a") {
                    fixed rkd0: str = substr(code, 2, len(code));
                    emit(out, str_concat(str_concat("  call ptr @torvik_", rkd0), str_concat("_retain(ptr ", str_concat(lhs, ")"))));
                }
            }
        }
        i += 1;
    }
    return out;
}

df llvm_escape(sv: str) -> str {
    set out: str = "";
    fixed bs: str = "\\";
    fixed n: i64 = len(sv);
    set i: i64 = 0;
    whilst i < n {
        fixed cc: i64 = byte_at(sv, i);
        check cc == 34 { out = str_concat(out, str_concat(bs, "22")); } fallback {
        check cc == 92 { out = str_concat(out, str_concat(bs, "5C")); } fallback {
        check cc == 10 { out = str_concat(out, str_concat(bs, "0A")); } fallback {
        check cc == 9  { out = str_concat(out, str_concat(bs, "09")); } fallback {
        check cc == 13 { out = str_concat(out, str_concat(bs, "0D")); } fallback {
            out = str_concat(out, substr(sv, i, i + 1));
        } } } } }
        i += 1;
    }
    return out;
}

df codegen_tokens(tokens: list<i64>, source: str, ir_out_path: str, srcfile: str) -> void {
    fixed strings: list<str>  = extract_strings(source, tokens);
    fixed allnames: list<str> = extract_all_names(source);
    // Per-token source offsets for line+caret diagnostics. extract_offsets
    // mirrors lex_source's scan exactly, so the tables must be the same length;
    // a mismatch means the two scans drifted — a compiler bug, caught here.
    fixed offsets: list<i64> = extract_offsets(source);
    check len(offsets) != len(tokens) {
        internal_error("TVC-1001", "lex", srcfile, "token/offset table length mismatch (lexer scan drift)");
    }
    // Statement/expression compile errors are accumulated here (token position +
    // message) and rendered with line+caret at the end, before torvc_main hands
    // the IR to clang. Lets multiple located errors surface at once.
    set err_pos: list<i64> = list_new();
    set err_msg: list<str> = list_new();
    // v1.2.0: warnings collected across all functions, rendered after a
    // successful (error-free) compile unless --no-warn set warn_suppress.
    set warn_pos: list<i64> = list_new();
    set warn_cat: list<str> = list_new();
    set warn_msg: list<str> = list_new();
    // v1.2.0: file-level `!@` warning directives - scanned from the raw source.
    fixed warn_dsup: list<i64> = list_new(); push(warn_dsup, 0);
    fixed warn_allow: list<str> = list_new();
    fixed derr_off: list<i64> = list_new();
    fixed derr_msg: list<str> = list_new();
    scan_warn_directives(source, warn_dsup, warn_allow, derr_off, derr_msg);
    // v1.2.0: collect aett declarations before any function compiles.
    collect_aetts(tokens, allnames, err_pos, err_msg);
    check len(derr_off) > 0 {
        set de: i64 = 0;
        whilst de < len(derr_off) {
            render_source_error(source, srcfile, derr_off[de], derr_msg[de]);
            echo!("");
            de += 1;
        }
        echo!(fmt("{} error(s) found.", len(derr_off)));
        exit(1);
    }
    check warn_dsup[0] == 1 { warn_suppress = 1; }

    // Parse
    set fn_names:       list<str> = list_new();
    set fn_param_names: list<str> = list_new();
    set fn_param_types: list<str> = list_new();
    set fn_ret_types:   list<str> = list_new();
    set fn_body_start:  list<i64> = list_new();
    set fn_body_end:    list<i64> = list_new();
    set fn_body_an:     list<i64> = list_new();
    set fn_body_s:      list<i64> = list_new();
    set global_names:   list<str> = list_new();
    set global_values:  list<str> = list_new();
    set global_types:   list<str> = list_new();
    set global_init_pos: list<i64> = list_new();
    set global_init_s:   list<i64> = list_new();
    set global_init_an:  list<i64> = list_new();

    parse_program(tokens, allnames, strings, fn_names, fn_param_names, fn_param_types, fn_ret_types, fn_body_start, fn_body_end, fn_body_an, fn_body_s, global_names, global_values, global_types, global_init_pos, global_init_s, global_init_an, err_pos, err_msg);

    // ── Semantic check: duplicate function definitions ──
    // Two functions with the same name would emit two LLVM @defs and surface as
    // an opaque clang redefinition error (internal TVC-5002). Catch it here as a
    // clean, located user error. Caret lands on the second definition.
    set dup_i: i64 = 0;
    whilst dup_i < len(fn_names) {
        set dup_j: i64 = dup_i + 1;
        whilst dup_j < len(fn_names) {
            check line_eq(fn_names[dup_i], fn_names[dup_j]) == 1 {
                push(err_pos, fn_body_start[dup_j]);
                push(err_msg, str_concat(str_concat("duplicate definition of function '", fn_names[dup_j]), "' - a function with this name is already defined earlier in the file"));
            }
            dup_j += 1;
        }
        dup_i += 1;
    }

    // ── Semantic check: unknown return types ──
    // A return type that isn't a known Torvik type (e.g. `-> random`) would be
    // treated as non-void and emit broken IR (internal TVC-5002). Caret lands at
    // the function body opener.
    set rti: i64 = 0;
    whilst rti < len(fn_ret_types) {
        fixed rt: str = fn_ret_types[rti];
        set rt_ok: i64 = 0;
        check is_value_type(rt) == 1 { rt_ok = 1; }
        check is_aett_name(rt) == 1 { rt_ok = 1; }   // v1.2.0: aett return types
        check line_eq(rt, "void") == 1 { rt_ok = 1; }
        set rt_caret: i64 = fn_body_start[rti] - 1;
        check rt_caret < 0 { rt_caret = 0; }
        check rt_ok == 0 {
            push(err_pos, rt_caret);
            push(err_msg, str_concat(str_concat("unknown return type '", rt), "' - expected i64, f64, str, bool, void, or a list/bag/table/result type"));
        }
        // Parameter types must each be a valid (non-void) value type. An unknown
        // annotation (e.g. `df f(x: zorp)`) would otherwise reach codegen and emit
        // broken IR or crash. Caret lands at the function body opener (best
        // available position for the header).
        fixed ptypes_v: list<str> = split_words(fn_param_types[rti]);
        set pvi: i64 = 0;
        whilst pvi < len(ptypes_v) {
            fixed pvt: str = ptypes_v[pvi];
            check is_value_type(pvt) == 0 && is_aett_name(pvt) == 0 {
                push(err_pos, rt_caret);
                push(err_msg, str_concat(str_concat("unknown parameter type '", pvt), "' - expected i64, f64, str, bool, or a list/bag/table/result type"));
            }
            pvi += 1;
        }
        rti += 1;
    }

    // ── Render structural / parse-level errors and abort BEFORE codegen ──
    // Malformed headers (missing name/'('/')'/'->'/return type/'{'/'}', or a missing
    // 'df') and duplicate definitions would otherwise emit broken IR that clang
    // rejects as an internal TVC-5002. Surface them as clean located errors here.
    check len(err_pos) > 0 {
        set pe: i64 = 0;
        whilst pe < len(err_pos) {
            render_source_error(source, srcfile, offsets[err_pos[pe]], err_msg[pe]);
            echo!("");
            pe += 1;
        }
        echo!(fmt("{} error(s) found.", len(err_pos)));
        exit(1);
    }

    // ── Entry point: every program needs a 'main' function ──
    // The emitted C entry wrapper calls @torvik_user_main, so a file with no main
    // (including an empty file or one that is only comments) would otherwise fail
    // as an internal TVC-5002 (undefined @torvik_user_main). Report it cleanly.
    set has_main: i64 = 0;
    set mi: i64 = 0;
    whilst mi < len(fn_names) {
        check line_eq(fn_names[mi], "main") == 1 { has_main = 1; }
        mi += 1;
    }
    check has_main == 0 {
        echo!("error: no 'main' function found");
        echo!("  every Torvik program needs an entry point: df main() -> void { ... }");
        echo!("");
        echo!("1 error(s) found.");
        exit(1);
    }

    // String table
    set gvals:  list<str> = list_new();
    set gnames: list<str> = list_new();
    // Type-tracking map (stage 1: record-only). Parallel lists: var_names[i] -> var_types[i].
    set var_names: list<str> = list_new();
    set var_types: list<str> = list_new();
    // Pre-register each function's return type under its name as "fnret:<ty>" so a
    // call expression can recover a float result (returned as bit-packed ptr) back
    // to f64. Registered before any body compiles; locals/params pushed later shadow
    // via last-match, so a same-named local still wins. Non-float returns are inert.
    set fri: i64 = 0;
    whilst fri < len(fn_names) {
        push(var_names, fn_names[fri]);
        push(var_types, str_concat("fnret:", fn_ret_types[fri]));
        // Also register the param type list under a synthetic key ("@p@" can't
        // appear in a real identifier) so call sites can validate argument types
        // (e.g. reject a non-128-bit literal/i64 passed to an i128 parameter,
        // which would otherwise be dereferenced as a bogus box pointer).
        push(var_names, str_concat("@p@", fn_names[fri]));
        push(var_types, fn_param_types[fri]);
        fri += 1;
    }

    // Counters
    set ctr:  list<i64> = list_new();
    set lctr: list<i64> = list_new();
    push(ctr, 0);
    push(ctr, 0);  // ctr[1] = chain-suppression flag (stage 2 operand eval)
    push(lctr, 0);
    push(lctr, -1);
    push(lctr, -1);

    set ir: list<str> = list_new();

    // Header
    emit(ir, "; Torvik Stage 5 codegen");
    emit(ir, "target triple = \"x86_64-solus-linux\"");
    emit(ir, "");
    emit(ir, "declare i32 @puts(ptr)");
    emit(ir, "declare void @torvik_print(ptr)");
    emit(ir, "declare void @exit(i32) noreturn");
    emit(ir, "declare i32 @strcmp(ptr, ptr)");
    emit(ir, "declare i64 @strlen(ptr)");
    emit(ir, "declare i64 @torvik_len(ptr)");
    emit(ir, "declare ptr @malloc(i64)");
    emit(ir, "declare ptr @strcpy(ptr, ptr)");
    emit(ir, "declare ptr @strcat(ptr, ptr)");
    emit(ir, "declare i32 @snprintf(ptr, i64, ptr, ...)");
    emit(ir, "declare ptr @torvik_readfile(ptr)");
    emit(ir, "declare ptr @torvik_str_dup(ptr)");
    emit(ir, "declare ptr @torvik_str_concat(ptr, ptr)");
    emit(ir, "declare ptr @torvik_substr(ptr, i64, i64)");
    emit(ir, "declare ptr @torvik_trim(ptr)");
    emit(ir, "declare ptr @torvik_triml(ptr)");
    emit(ir, "declare ptr @torvik_trimr(ptr)");
    emit(ir, "declare ptr @torvik_upper(ptr)");
    emit(ir, "declare ptr @torvik_lower(ptr)");
    emit(ir, "declare i64 @torvik_toint(ptr)");
    emit(ir, "declare ptr @torvik_int_to_str(i64)");
    emit(ir, "declare ptr @torvik_uint_to_str(i64)");
    emit(ir, "declare ptr @torvik_i128_box(ptr)");
    emit(ir, "declare void @torvik_i128_load(ptr, ptr)");
    emit(ir, "declare ptr @torvik_i128_retain(ptr)");
    emit(ir, "declare void @torvik_i128_release(ptr)");
    emit(ir, "declare ptr @torvik_i128_to_str(ptr)");
    emit(ir, "declare ptr @torvik_u128_to_str(ptr)");
    emit(ir, "declare void @torvik_i128_div(ptr, ptr, ptr)");
    emit(ir, "declare void @torvik_i128_mod(ptr, ptr, ptr)");
    emit(ir, "declare void @torvik_u128_div(ptr, ptr, ptr)");
    emit(ir, "declare void @torvik_u128_mod(ptr, ptr, ptr)");
    emit(ir, "declare ptr @torvik_bool_to_str(i64)");
    emit(ir, "declare ptr @torvik_list_to_str(ptr)");
    emit(ir, "declare i64 @torvik_sys_run(ptr)");
    emit(ir, "declare ptr @torvik_fmt_apply(ptr, i64, ...)");
    emit(ir, "declare ptr @torvik_datetime_str()");
    emit(ir, "declare i64 @torvik_fs_exists(ptr)");
    emit(ir, "declare i64 @torvik_fs_mtime(ptr)");
    emit(ir, "declare void @torvik_fs_mkdir(ptr)");
    emit(ir, "declare void @torvik_fs_remove(ptr)");
    emit(ir, "declare ptr @torvik_sys_home_dir()");
    emit(ir, "declare ptr @torvik_sys_cwd()");
    emit(ir, "declare void @torvik_writefile(ptr, ptr)");
    emit(ir, "declare void @torvik_appendline(ptr, ptr)");
    emit(ir, "declare ptr @torvik_sys_arch()");
    emit(ir, "declare ptr @torvik_sys_hostname()");
    emit(ir, "declare ptr @torvik_sys_os_name()");
    emit(ir, "declare ptr @torvik_sys_os_version()");
    emit(ir, "declare ptr @torvik_sys_username()");
    emit(ir, "declare i64 @torvik_sys_cpu_count()");
    emit(ir, "declare i64 @torvik_sys_mem_total()");
    emit(ir, "declare i64 @torvik_sys_mem_free()");
    emit(ir, "declare i64 @torvik_sys_pid()");
    emit(ir, "declare void @torvik_write_ir(ptr, ptr, i64)");
    // lex_source and codegen_tokens are defined in this compilation — no forward declare needed
    emit(ir, "declare ptr @torvik_list_new()");
    emit(ir, "declare ptr @torvik_pop(ptr)");
    emit(ir, "declare void @torvik_push(ptr, i64)");
    emit(ir, "declare void @torvik_remove(ptr, i64)");
    emit(ir, "declare void @torvik_insert(ptr, i64, i64)");
    emit(ir, "declare i64 @torvik_abs(i64)");
    emit(ir, "declare i64 @torvik_max(i64, i64)");
    emit(ir, "declare i64 @torvik_min(i64, i64)");
    emit(ir, "declare i64 @torvik_randint(i64, i64)");
    emit(ir, "declare i64 @torvik_time_now()");
    emit(ir, "declare i64 @torvik_time_ms()");
    emit(ir, "declare i64 @torvik_readint(ptr)");
    emit(ir, "declare i8 @torvik_readkey()");
    emit(ir, "declare i32 @torvik_contains(ptr, ptr)");
    emit(ir, "declare i32 @torvik_readbool(ptr)");
    emit(ir, "declare void @torvik_sleep(i64)");
    emit(ir, "declare void @torvik_clear_screen()");
    emit(ir, "declare void @torvik_assert(i32, ptr)");
    emit(ir, "declare ptr @torvik_tostr(i64)");
    emit(ir, "declare ptr @torvik_replace(ptr, ptr, ptr)");
    emit(ir, "declare ptr @torvik_time_str()");
    emit(ir, "declare ptr @torvik_date_str()");
    emit(ir, "declare ptr @torvik_readln()");
    emit(ir, "declare ptr @torvik_read(ptr)");
    emit(ir, "declare ptr @torvik_readenv(ptr)");
    emit(ir, "declare ptr @torvik_split_list(ptr, ptr)");
    emit(ir, "declare ptr @torvik_float_to_str(double)");
    emit(ir, "declare double @torvik_to_float(ptr)");
    emit(ir, "declare double @torvik_rand()");
    emit(ir, "declare double @torvik_readfloat(ptr)");
    emit(ir, "declare void @torvik_wait(double)");
    emit(ir, "declare ptr @torvik_bag_new()");
    emit(ir, "declare void @torvik_bag_add(ptr, ptr)");
    emit(ir, "declare i32 @torvik_bag_has(ptr, ptr)");
    emit(ir, "declare i64 @torvik_bag_len(ptr)");
    emit(ir, "declare void @torvik_bag_remove(ptr, ptr)");
    emit(ir, "declare ptr @torvik_bag_retain(ptr)");
    emit(ir, "declare void @torvik_bag_release(ptr)");
    emit(ir, "declare ptr @torvik_table_new()");
    emit(ir, "declare void @torvik_table_mark_managed(ptr)");
    emit(ir, "declare void @torvik_table_set(ptr, ptr, i64)");
    emit(ir, "declare ptr @torvik_table_get(ptr, ptr)");
    emit(ir, "declare i32 @torvik_table_has(ptr, ptr)");
    emit(ir, "declare void @torvik_table_del(ptr, ptr)");
    emit(ir, "declare i64 @torvik_table_len(ptr)");
    emit(ir, "declare ptr @torvik_table_retain(ptr)");
    emit(ir, "declare void @torvik_table_release(ptr)");
    emit(ir, "declare ptr @torvik_list_get(ptr, i64)");
    emit(ir, "declare void @torvik_list_set(ptr, i64, i64)");
    emit(ir, "declare i64 @torvik_list_len(ptr)");
    emit(ir, "declare i64 @torvik_list_contains(ptr, i64)");
    emit(ir, "declare i64 @torvik_list_contains_str(ptr, ptr)");
    emit(ir, "declare ptr @torvik_list_retain(ptr)");
    emit(ir, "declare void @torvik_list_release(ptr)");
    emit(ir, "declare ptr @torvik_args_copy(i64, ptr)");
    emit(ir, "declare ptr @torvik_str_retain(ptr)");
    emit(ir, "declare void @torvik_str_release(ptr)");
    emit(ir, "declare i64 @torvik_div(i64, i64)");
    emit(ir, "declare i64 @torvik_mod(i64, i64)");
    emit(ir, "declare i64 @torvik_udiv(i64, i64)");
    emit(ir, "declare i64 @torvik_umod(i64, i64)");
    emit(ir, "declare ptr @torvik_result_ok(ptr)");
    emit(ir, "declare ptr @torvik_result_err(i64, ptr)");
    emit(ir, "declare void @torvik_result_mark_managed(ptr)");
    emit(ir, "declare i64 @torvik_result_is_ok(ptr)");
    emit(ir, "declare i64 @torvik_result_is_err(ptr)");
    emit(ir, "declare ptr @torvik_result_unwrap(ptr)");
    emit(ir, "declare ptr @torvik_result_unwrap_or(ptr, ptr)");
    emit(ir, "declare i64 @torvik_result_err_code(ptr)");
    emit(ir, "declare ptr @torvik_result_err_msg(ptr)");
    emit(ir, "declare ptr @torvik_result_retain(ptr)");
    emit(ir, "declare void @torvik_result_release(ptr)");
    emit(ir, "declare ptr @torvik_try_readfile(ptr)");
    emit(ir, "declare ptr @torvik_try_toint(ptr)");
    emit(ir, "declare ptr @torvik_try_tofloat(ptr)");
    emit(ir, "declare void @torvik_list_mark_managed(ptr)");
    emit(ir, "declare void @torvik_list_mark_managed_i128(ptr)");
    emit(ir, "declare i64 @torvik_char_at(ptr, i64)");
    emit(ir, "declare ptr @torvik_char_str(ptr, i64)");
    emit(ir, "declare ptr @torvik_byte_str(i64)");
    emit(ir, "declare i64 @torvik_find(ptr, ptr)");
    emit(ir, "declare i32 @torvik_ends(ptr, ptr)");
    emit(ir, "declare i32 @torvik_starts(ptr, ptr)");
    emit(ir, "@torvik_argc = internal global i64 0, align 8");
    emit(ir, "@torvik_argv = internal global ptr null, align 8");
    emit(ir, "");

    // Global variables — each becomes a shared @NAME holding a boxed ptr value.
    // i64 globals box the integer (inttoptr); str globals point at the string body.
    set gi: i64 = 0;
    whilst gi < len(global_names) {
        fixed gn: str  = global_names[gi];
        fixed gv: str  = global_values[gi];
        fixed gt: str  = global_types[gi];
        // Expression-initialized globals (init_pos >= 0) start as null and are
        // filled in at startup, before main runs. Literal globals (init_pos < 0)
        // become LLVM constants here.
        check global_init_pos[gi] >= 0 {
            emit(ir, str_concat(str_concat("@", gn), " = internal global ptr null, align 8"));
        }
        check global_init_pos[gi] < 0 {
            check gt == "i64" {
                emit(ir, str_concat(str_concat(str_concat("@", gn), " = internal global ptr inttoptr (i64 "), str_concat(gv, " to ptr), align 8")));
            }
            check gt != "i64" {
                fixed gl: i64  = str_const_size(len(gv));
                fixed sn: str  = intern_str(gv, gvals, gnames);
                emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat(str_concat("@", gn), " = internal global ptr getelementptr inbounds (["), int_to_str(gl)), " x i8], ptr "), sn), ", i32 0, i32 16), align 8"));
            }
        }
        gi += 1;
    }
    emit(ir, "");

    // Compile functions
    // Memory Stage E: precompute producer patterns for Torvik fns with
    // refcounted returns (their results carry the ARC +1 in-flight claim).
    // Built ONCE here, scanned per line in inject_temp_cleanup.
    set upats: list<str> = list_new();
    set ucodes: list<str> = list_new();
    set upi: i64 = 0;
    whilst upi < len(fn_names) {
        fixed ufn: str = fn_names[upi];
        set uirn: str = ufn;
        check ufn == "main" { uirn = "torvik_user_main"; }
        set urty: str = "";
        check upi < len(fn_ret_types) { urty = fn_ret_types[upi]; }
        set ucode: str = "";
        check starts(urty, "list") { ucode = "b:list"; }
        check urty == "str" { ucode = "b:str"; }
        check starts(urty, "result") { ucode = "b:result"; }
        check urty == "i128" || urty == "u128" { ucode = "b:i128"; }
        check len(ucode) > 0 {
            push(upats, str_concat(str_concat(" = call ptr @", uirn), "("));
            push(ucodes, ucode);
        }
        upi += 1;
    }
    set fi: i64 = 0;
    // v1.1.3: names of top-level `fixed` globals, for reassignment enforcement.
    fixed fglist: list<str> = list_new();
    collect_fixed_globals(tokens, allnames, fglist);
    // Tracks undefined-function names already reported (program-wide dedup).
    set undef_seen: list<str> = list_new();
    set undefvar_seen: list<str> = list_new();
    // Write IR header to file before compiling functions (O(n), single open)
    write_ir(ir, ir_out_path, 0);
    set ir: list<str> = list_new(); // Reset ir so tail section doesn't re-emit header content
whilst fi < len(fn_names) {
        fixed fname: str  = fn_names[fi];
            fixed bstart: i64 = fn_body_start[fi];
        fixed bend: i64   = fn_body_end[fi];
        set irname: str = fname;
        check fname == "main" { irname = "torvik_user_main"; }

        // Use per-function IR list to avoid O(N^2) join_ir across all functions
        fixed fn_ir: list<str> = list_new();

        // Build parameter list for signature and create param slots
        fixed pnames_str: str = fn_param_names[fi];
        fixed pnames: list<str> = split_words(pnames_str);
        set sig_params: str = "";
        set pi: i64 = 0;
        whilst pi < len(pnames) {
            check len(sig_params) > 0 { sig_params = str_concat(sig_params, ", "); }
            sig_params = str_concat(sig_params, str_concat("ptr %", pnames[pi]));
            pi += 1;
        }
        fixed fn_llret: str = "ptr";
        emit(fn_ir, str_concat(str_concat(str_concat(str_concat("define ", fn_llret), str_concat(" @", irname)), str_concat("(", str_concat(sig_params, ") {"))), ""));
        emit(fn_ir, "entry:");
        // ARC Stage A: parse param types BEFORE the slot-store loop so list-typed
        // params can be retained at entry — the param slot counts as a slot under
        // slot-counting, and protects a borrowed caller list if the callee
        // reassigns the param (release-old then undoes this retain, not the
        // caller's ownership). Balanced by scope-exit release in Stage C.
        fixed ptypes: list<str> = split_words(fn_param_types[fi]);
        set pi2: i64 = 0;
        whilst pi2 < len(pnames) {
            fixed pn: str = pnames[pi2];
            emit(fn_ir, str_concat(str_concat(str_concat("  %", pn), "_slot = alloca ptr, align 8"), ""));
            emit(fn_ir, str_concat(str_concat(str_concat(str_concat("  store ptr %", pn), ", ptr %"), pn), "_slot, align 8"));
            check pi2 < len(ptypes) {
                fixed pty: str = ptypes[pi2];
                set pkind: str = "";
                check starts(pty, "list") { pkind = "list"; }
                check pty == "str" { pkind = "str"; }
                check starts(pty, "bag") { pkind = "bag"; }  // v1.1.3: starts(), see decl site
                check starts(pty, "table") { pkind = "table"; }
                check starts(pty, "result") { pkind = "result"; }
                check pty == "i128" || pty == "u128" { pkind = "i128"; }
                check len(pkind) > 0 {
                    emit(fn_ir, str_concat(str_concat(str_concat("  call ptr @torvik_", pkind), "_retain(ptr %"), str_concat(pn, ")")));
                }
                // Narrow integer params are normalized to their width on entry, so
                // the body sees a canonical value no matter what the caller passed.
                check int_width(pty) > 0 && int_width(pty) < 64 {
                    fixed pld: str = make_tmp(ctr);
                    emit(fn_ir, str_concat(str_concat(str_concat("  ", pld), " = ptrtoint ptr %"), str_concat(pn, " to i64")));
                    fixed pcv: str = canonicalize_int(pld, pty, fn_ir, ctr);
                    fixed pcp: str = make_tmp(ctr);
                    emit(fn_ir, str_concat(str_concat(str_concat("  ", pcp), " = inttoptr i64 "), str_concat(pcv, " to ptr")));
                    emit(fn_ir, str_concat(str_concat(str_concat("  store ptr ", pcp), ", ptr %"), str_concat(pn, "_slot, align 8")));
                }
            }
            pi2 += 1;
        }
        // Function boundary sentinel: per-function scans (the redeclaration
        // check) stop here instead of bleeding into the previous function's
        // locals. "@fn@" can never match a real identifier.
        push(var_names, "@fn@"); push(var_types, "@fn@");
        // Stage 5: record parameter types in the map so len(param)/string-eq on
        // params resolve at compile time. Types are space-aligned with names.
        set ppi: i64 = 0;
        whilst ppi < len(pnames) {
            check ppi < len(ptypes) { push(var_names, pnames[ppi]); push(var_types, ptypes[ppi]); }
            ppi += 1;
        }
        // Globals are visible in every function. Register them in the type map so
        // reads resolve to the right type AND assignments to heap globals (str/...)
        // go through the ARC reassignment path (retain new / release old).
        set gvi: i64 = 0;
        whilst gvi < len(global_names) {
            check gvi < len(global_types) { push(var_names, global_names[gvi]); push(var_types, global_types[gvi]); }
            // v1.1.3: a top-level `fixed` global gets the same mutability marker
            // as a fixed local, so reassignment from any function is the same
            // clean compile error.
            check fixed_global_seen(fglist, global_names[gvi]) == 1 {
                push(var_names, str_concat("@fixed@", global_names[gvi]));
                push(var_types, "1");
            }
            gvi += 1;
        }
        // Per-function global slots alias the shared @NAME storage, so reads AND
        // writes from any function operate on the same global. For i64 the global
        // boxes the integer; for str/heap it holds the value pointer. Heap reassignment
        // is kept refcount-correct by the ARC reassignment path (retain new/release old).
        set gi3: i64 = 0;
        whilst gi3 < len(global_names) {
            fixed gn3: str = global_names[gi3];
            emit(fn_ir, str_concat(str_concat(str_concat(str_concat("  %", gn3), "_slot = getelementptr i8, ptr @"), gn3), ", i64 0"));
            gi3 += 1;
        }
        // Expression-initialized globals are filled in here, at the very start of
        // main (the program entry), before any user statement runs. Each initializer
        // is a full expression (list_new(), table_new(), str_concat(...), etc.),
        // compiled in declaration order so later globals may reference earlier ones.
        check fname == "main" {
            set egi: i64 = 0;
            whilst egi < len(global_names) {
                check global_init_pos[egi] >= 0 {
                    fixed egn: str = global_names[egi];
                    fixed egt: str = global_types[egi];
                    // Use-before-init guard: a global initializer that reads a global
                    // declared later (and itself expression-initialized, so still null
                    // here) would crash at run time. Flag it as a located error instead.
                    set scan_p: i64 = global_init_pos[egi];
                    set scan_an: i64 = global_init_an[egi];
                    whilst scan_p < len(tokens) && tok_peek(tokens, scan_p) != PUNCT_SEMI {
                        fixed st: i64 = tok_peek(tokens, scan_p);
                        check st == TOK_IDENT {
                            fixed idn: str = allnames[scan_an];
                            set lj: i64 = egi + 1;
                            whilst lj < len(global_names) {
                                check line_eq(global_names[lj], idn) == 1 {
                                    check global_init_pos[lj] >= 0 {
                                        push(err_pos, global_init_pos[egi]);
                                        push(err_msg, str_concat(str_concat("global initializer references '", idn), "' before it is initialized - move its declaration above this one"));
                                    }
                                }
                                lj += 1;
                            }
                        }
                        check st == TOK_IDENT || st == TOK_STRING { scan_an += 1; }
                        scan_p += 1;
                    }
                    // v1.1.3: 128-bit globals take a single-literal initializer,
                    // boxed exactly like a local i128/u128 declaration. (The
                    // generic expression path below compiles the bare literal as
                    // an i64 constant, which LLVM rejects past the u64 range.)
                    set g128done: i64 = 0;
                    check line_eq(egt, "i128") == 1 || line_eq(egt, "u128") == 1 {
                        fixed g0t: i64 = tok_peek(tokens, global_init_pos[egi]);
                        fixed g1t: i64 = tok_peek(tokens, global_init_pos[egi] + 1);
                        fixed g2t: i64 = tok_peek(tokens, global_init_pos[egi] + 2);
                        set glit: str = "";
                        check g0t == TOK_INT && g1t == PUNCT_SEMI {
                            glit = strings[global_init_s[egi]];
                        }
                        check g0t == OP_MINUS && g1t == TOK_INT && g2t == PUNCT_SEMI {
                            glit = str_concat("-", strings[global_init_s[egi]]);
                        }
                        check len(glit) > 0 {
                            set gneg: i64 = 0;
                            check starts(glit, "-") { gneg = 1; }
                            set glok: i64 = 0;
                            check line_eq(egt, "i128") == 1 && i128_lit_in_range(glit) == 1 { glok = 1; }
                            check line_eq(egt, "u128") == 1 && gneg == 0 && u128_in_range(glit) == 1 { glok = 1; }
                            check glok == 0 {
                                push(err_pos, global_init_pos[egi]);
                                push(err_msg, str_concat(str_concat("literal ", glit), str_concat(" is out of range for ", egt)));
                            }
                            fixed gbox: str = i128_box_lit(glit, fn_ir, ctr);
                            emit(fn_ir, str_concat("  call ptr @torvik_i128_retain(ptr ", str_concat(gbox, ")")));
                            emit(fn_ir, str_concat(str_concat(str_concat("  store ptr ", gbox), ", ptr %"), str_concat(egn, "_slot, align 8")));
                            g128done = 1;
                        }
                        check g128done == 0 {
                            push(err_pos, global_init_pos[egi]);
                            push(err_msg, str_concat(str_concat("a ", egt), " global takes a single literal initializer - compute expressions in a function, or bind the literal here and combine values at runtime"));
                            g128done = 1;
                        }
                    }
                    check g128done == 0 {
                    set iev: list<str> = list_new(); set iep: list<i64> = list_new(); set ies: list<i64> = list_new(); set iea: list<i64> = list_new(); set iety: list<str> = list_new();
                    compile_expr(tokens, strings, allnames, global_init_pos[egi], global_init_s[egi], global_init_an[egi], fn_ir, ctr, gvals, gnames, iev, iep, ies, iea, iety, var_names, var_types);
                    set ival: str = "0"; check len(iev) > 0 { ival = iev[0]; }
                    set ivty: str = "ptr"; check len(iety) > 0 { ivty = iety[0]; }
                    // Box scalars into the uniform ptr slot; pointers store directly.
                    set sptr: str = ival;
                    check ivty == "i64" || ivty == "u64" || ivty == "bool" || (int_width(ivty) > 0 && ivty != "i128" && ivty != "u128") {
                        // Narrow integer globals wrap to their width (no-op for i64).
                        // v1.1.3: "u64"/"bool"/narrow-int TAGS box through the same
                        // path - previously only the exact "i64" tag matched, so a
                        // bool or u64-tagged initializer was stored raw (clang
                        // rejected the IR: i64 where ptr expected).
                        fixed icv: str = canonicalize_int(ival, egt, fn_ir, ctr);
                        fixed bx: str = make_tmp(ctr);
                        emit(fn_ir, str_concat(str_concat(str_concat("  ", bx), " = inttoptr i64 "), str_concat(icv, " to ptr")));
                        sptr = bx;
                    }
                    check ivty == "i1" {
                        fixed zx: str = make_tmp(ctr);
                        emit(fn_ir, str_concat(str_concat(str_concat("  ", zx), " = zext i1 "), str_concat(ival, " to i64")));
                        fixed bxz: str = make_tmp(ctr);
                        emit(fn_ir, str_concat(str_concat(str_concat("  ", bxz), " = inttoptr i64 "), str_concat(zx, " to ptr")));
                        sptr = bxz;
                    }
                    check ivty == "f64" {
                        fixed fb: str = make_tmp(ctr);
                        emit(fn_ir, str_concat(str_concat(str_concat("  ", fb), " = bitcast double "), str_concat(ival, " to i64")));
                        fixed bxf: str = make_tmp(ctr);
                        emit(fn_ir, str_concat(str_concat(str_concat("  ", bxf), " = inttoptr i64 "), str_concat(fb, " to ptr")));
                        sptr = bxf;
                    }
                    // Heap-typed globals retain the value so @NAME owns it past the
                    // statement temp-cleanup, and mark managed element types.
                    set ekind: str = "";
                    check starts(egt, "list") { ekind = "list"; }
                    check egt == "str" { ekind = "str"; }
                    check starts(egt, "bag") { ekind = "bag"; }  // v1.1.3: starts(), see decl site
                    check starts(egt, "table") { ekind = "table"; }
                    check starts(egt, "result") { ekind = "result"; }
                    check egt == "i128" || egt == "u128" { ekind = "i128"; }  // v1.1.3: claim the box past temp cleanup
                    check len(ekind) > 0 {
                        emit(fn_ir, str_concat(str_concat("  call ptr @torvik_", ekind), str_concat("_retain(ptr ", str_concat(sptr, ")"))));
                    }
                    check egt == "list<str>" {
                        emit(fn_ir, str_concat("  call void @torvik_list_mark_managed(ptr ", str_concat(sptr, ")")));
                    }
                    check egt == "list<i128>" || egt == "list<u128>" {
                        emit(fn_ir, str_concat("  call void @torvik_list_mark_managed_i128(ptr ", str_concat(sptr, ")")));
                    }
                    check egt == "result<str>" {
                        emit(fn_ir, str_concat("  call void @torvik_result_mark_managed(ptr ", str_concat(sptr, ")")));
                    }
                    emit(fn_ir, str_concat(str_concat(str_concat("  store ptr ", sptr), ", ptr %"), str_concat(egn, "_slot, align 8")));
                    }
                }
                egi += 1;
            }
        }
            fixed body_ani: i64 = fn_body_an[fi];
        fixed body_si: i64 = fn_body_s[fi];
            set fret_ty: str = "void"; check fi < len(fn_ret_types) { fret_ty = fn_ret_types[fi]; }
        fixed _cs_ret: i64 = compile_stmts(tokens, strings, allnames, bstart, bend, body_si, body_ani, fn_ir, ctr, gvals, gnames, lctr, fret_ty, var_names, var_types, global_names, err_pos, err_msg);
            // Surface calls to functions that don't exist as clean located errors
            // (otherwise clang rejects the call to an undefined @name — a TVC-5002).
            collect_undef_fns(fn_ir, undef_seen, err_pos, err_msg);
            collect_undef_vars(fn_ir, fn_names, undefvar_seen, err_pos, err_msg);
            collect_user_errors(fn_ir, err_pos, err_msg);
            // v1.2.0: warnings - append unused-local warnings, then collect all
            // tv.warn markers this function produced.
            warn_unused_locals(fn_ir);
            collect_warnings(fn_ir, warn_pos, warn_cat, warn_msg);
            // Non-void functions must return on every path. If the body can reach its
            // end without a terminator (ret/br/unreachable), the LLVM block is
            // unterminated — previously an internal TVC-5002 at the closing '}'. Report
            // it cleanly. Any non-void function that compiles already terminates, so
            // this never flags valid code.
            check fret_ty != "void" && len(fret_ty) > 0 {
                set li: i64 = len(fn_ir) - 1;
                set last_real: str = "";
                set found_lr: i64 = 0;
                whilst li >= 0 && found_lr == 0 {
                    fixed lrl: str = fn_ir[li];
                    check len(lrl) > 0 {
                        check starts(lrl, "  ;") { } fallback { last_real = lrl; found_lr = 1; }
                    }
                    li -= 1;
                }
                set terminated: i64 = 0;
                check starts(last_real, "  ret ") { terminated = 1; }
                check starts(last_real, "  br ") { terminated = 1; }
                check starts(last_real, "  unreachable") { terminated = 1; }
                check terminated == 0 {
                    push(err_pos, bstart);
                    push(err_msg, str_concat(str_concat("function declared to return '", fret_ty), "' must return a value - its body can reach the end without returning"));
                }
            }
            check fret_ty == "void" || len(fret_ty) == 0 { emit(fn_ir, "  ret ptr null"); }
        emit(fn_ir, "}");
        emit(fn_ir, "");
        // Hoist allocas to entry block (LLVM dominance), then inject Stage C
        // scope-exit releases (after hoisting so rcinit tags sit in entry and
        // dominate every ret), then append in chunks
        fixed fn_ir_hh: list<str> = hoist_allocas(fn_ir);
        fixed fn_ir_hs: list<str> = inject_scope_releases(fn_ir_hh, ctr, fret_ty, pnames, ptypes);
        fixed fn_ir_h: list<str> = inject_temp_cleanup(fn_ir_hs, ctr, upats, ucodes);
        // Append this function's IR in one O(n) pass (was a chunked cat-append loop
        // that forked a shell per 50 lines — thousands of fork/execs on big inputs).
        write_ir(fn_ir_h, ir_out_path, 1);
        fi += 1;
    }

    // String globals
    set si2: i64 = 0;
    whilst si2 < len(gvals) {
        fixed sv: str  = gvals[si2];
        fixed sn: str  = gnames[si2];
        fixed sl: i64  = str_const_size(len(sv));
        fixed sv_esc: str = llvm_escape(sv);
        // Layout: [8B magic "HRTSVROT"][8B refcount "LATROMMI"][bytes \00 pad...]
        emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat(str_concat(sn, " = private constant ["), int_to_str(sl)), " x i8] c\"HRTSVROTLATROMMI"), sv_esc), str_concat("\\00", str_const_pad(len(sv)))), "\", align 16"));
        si2 += 1;
    }
    emit(ir, "");

    // C main wrapper
    emit(ir, "define i32 @main(i32 %argc, ptr %argv) {");
    emit(ir, "entry:");
    emit(ir, "  %a = sext i32 %argc to i64");
    emit(ir, "  store i64 %a, ptr @torvik_argc, align 8");
    // B2: copy OS argv into HEADERED strings at the boundary so the
    // everything-headered contract holds for args_get() results.
    emit(ir, "  %ac = call ptr @torvik_args_copy(i64 %a, ptr %argv)");
    emit(ir, "  store ptr %ac, ptr @torvik_argv, align 8");
    emit(ir, "  call ptr @torvik_user_main()");
    emit(ir, "  ret i32 0");
    emit(ir, "}");

    // Append the tail IR (string globals + C main) in one O(n) pass.
    write_ir(ir, ir_out_path, 1);

    // ── Render accumulated compile errors (line+caret) and abort before clang ──
    // The IR on disk is irrelevant once we exit(1) here — torvc_main only invokes
    // clang after codegen_tokens returns, so partial IR is never compiled.
    // v1.2.0: render warnings FIRST (never fatal) - when errors follow, the
    // warning often explains them (e.g. "unreachable code" right before a
    // "must return a value" error caused by dead statements after a return).
    set warn_shown: i64 = 0;
    check warn_suppress == 0 && len(warn_pos) > 0 {
        set cw: i64 = 0;
        whilst cw < len(warn_pos) {
            check warn_cat_allowed(warn_cat[cw], warn_allow) == 0 {
                render_source_warning(source, srcfile, offsets[warn_pos[cw]], warn_msg[cw]);
                echo!("");
                warn_shown += 1;
            }
            cw += 1;
        }
    }
    check len(err_pos) > 0 {
        set ce: i64 = 0;
        whilst ce < len(err_pos) {
            render_source_error(source, srcfile, offsets[err_pos[ce]], err_msg[ce]);
            echo!("");
            ce += 1;
        }
        echo!(fmt("{} error(s) found.", len(err_pos)));
        exit(1);
    }
    check warn_suppress == 0 && warn_shown > 0 {
        echo!(fmt("{} warning(s).", warn_shown));
    }
}

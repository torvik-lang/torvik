            check nm == "max" && len(args) >= 2 { fixed m0: str = args[0]; fixed m0t: str = "ptr"; check len(args_ty) >= 1 { m0t = args_ty[0]; } fixed m0i: str = m0; check m0t != "i64" { m0i = coerce_i64(m0, ir, ctr); } fixed m1: str = args[1]; fixed m1t: str = "ptr"; check len(args_ty) >= 2 { m1t = args_ty[1]; } fixed m1i: str = m1; check m1t != "i64" { m1i = coerce_i64(m1, ir, ctr); } emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_max(i64 "), str_concat(m0i, ", i64 ")), str_concat(m1i, ")"))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "min" && len(args) >= 2 { fixed n0: str = args[0]; fixed n0t: str = "ptr"; check len(args_ty) >= 1 { n0t = args_ty[0]; } fixed n0i: str = n0; check n0t != "i64" { n0i = coerce_i64(n0, ir, ctr); } fixed n1: str = args[1]; fixed n1t: str = "ptr"; check len(args_ty) >= 2 { n1t = args_ty[1]; } fixed n1i: str = n1; check n1t != "i64" { n1i = coerce_i64(n1, ir, ctr); } emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_min(i64 "), str_concat(n0i, ", i64 ")), str_concat(n1i, ")"))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "randint" && len(args) >= 2 { fixed r0: str = args[0]; fixed r0t: str = "ptr"; check len(args_ty) >= 1 { r0t = args_ty[0]; } fixed r0i: str = r0; check r0t != "i64" { r0i = coerce_i64(r0, ir, ctr); } fixed r1: str = args[1]; fixed r1t: str = "ptr"; check len(args_ty) >= 2 { r1t = args_ty[1]; } fixed r1i: str = r1; check r1t != "i64" { r1i = coerce_i64(r1, ir, ctr); } emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_randint(i64 "), str_concat(r0i, ", i64 ")), str_concat(r1i, ")"))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "time_now" { emit(ir, str_concat(str_concat("  ", tmp), " = call i64 @torvik_time_now()")); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "time_ms" { emit(ir, str_concat(str_concat("  ", tmp), " = call i64 @torvik_time_ms()")); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "readint" && len(args) >= 1 { emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_readint(ptr "), str_concat(args[0], ")"))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "readkey" { fixed rk8: str = make_tmp(ctr); emit(ir, str_concat(str_concat("  ", rk8), " = call i8 @torvik_readkey()")); emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = sext i8 "), str_concat(rk8, " to i64"))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
            check nm == "contains" && len(args) >= 2 { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call i32 @torvik_contains(ptr "), args[0]), str_concat(", ptr ", str_concat(args[1], ")")))); fixed ctb: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", ctb), " = icmp ne i32 "), str_concat(tmp, ", 0"))); push(out_val, ctb); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return; }
            check nm == "readbool" && len(args) >= 1 { emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i32 @torvik_readbool(ptr "), str_concat(args[0], ")"))); fixed rbb: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", rbb), " = icmp ne i32 "), str_concat(tmp, ", 0"))); push(out_val, rbb); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return; }
            check nm == "trim" && len(args) >= 1 {
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_trim(ptr "), str_concat(args[0], ")")));
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "str"); return;
            }
            check nm == "triml" && len(args) >= 1 {
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_triml(ptr "), str_concat(args[0], ")")));
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "str"); return;
            }
            check nm == "trimr" && len(args) >= 1 {
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_trimr(ptr "), str_concat(args[0], ")")));
                push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "str"); return;
            }
            // Generic call fallback — emit actual call with all args as ptr
            fixed callee_ptypes: list<str> = split_words(lookup_var_type(str_concat("@p@", nm), var_names, var_types));
            set generic_args: str = "";
            set gi2: i64 = 0;
            whilst gi2 < len(args) {
                check len(generic_args) > 0 { generic_args = str_concat(generic_args, ", "); }
                fixed garg_ty: str = "ptr";
                check gi2 < len(args_ty) { garg_ty = args_ty[gi2]; }
                // A 128-bit value is a heap-box ptr that the callee dereferences via
                // torvik_i128_load. Passing a non-128-bit scalar (an int literal, i64,
                // bool, or float) would reinterpret its bits as a box address and
                // segfault. Require 128-bit args to be 128-bit-typed (bind a literal
                // to an i128 variable first). Conversely, a 128-bit value passed where
                // a non-128-bit int is expected would have its box ADDRESS read as the
                // value — also a clean error.
                check gi2 < len(callee_ptypes) {
                    fixed ppt: str = callee_ptypes[gi2];
                    fixed param_is_128: i64 = 0; check line_eq(ppt, "i128") == 1 || line_eq(ppt, "u128") == 1 { param_is_128 = 1; }
                    fixed arg_is_128: i64 = 0; check garg_ty == "i128" || garg_ty == "u128" { arg_is_128 = 1; }

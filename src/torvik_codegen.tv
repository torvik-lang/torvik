apply torvik_lexer;
apply torvik_parser;

df split_words(s: str) -> list<str> {
    set result: list<str> = list_new();
    fixed slen: i64 = len(s);
    set i: i64 = 0;
    set word_start: i64 = 0;
    set in_word: i64 = 0;
    whilst i < slen {
        fixed c: i64 = byte_at(s, i);
        check c == 32 {
            check in_word == 1 {
                push(result, substr(s, word_start, i));
                in_word = 0;
            }
        }
        check c != 32 { check in_word == 0 { word_start = i; in_word = 1; } }
        i += 1;
    }
    check in_word == 1 { push(result, substr(s, word_start, slen)); }
    return result;
}

// torvik_codegen.tv — Full Torvik Codegen written in Torvik
// Stage 5: Parses and compiles real .tv programs


// ─── Helpers ──────────────────────────────────────────────────────────────────

df make_tmp(counter: list<i64>) -> str {
    fixed n: i64 = counter[0];
    counter[0] = n + 1;
    return str_concat("%t", int_to_str(n));
}

df make_label(counter: list<i64>, prefix: str) -> str {
    fixed n: i64 = counter[0];
    counter[0] = n + 1;
    return str_concat(prefix, int_to_str(n));
}

df emit(ir: list<str>, line: str) -> void {
    push(ir, line);
}

// Convert any value to i64
// Uses ptrtoint for ptr values, or add i64 0 for already-i64 values
// In our system, all stored vars are ptr (via inttoptr), so ptrtoint is standard
// Does the temp `val` already hold an i64? Inspect its defining instruction
// in the current function IR. Compensates for partial type tracking so we
// never emit an invalid 'ptrtoint ptr %tN to i64' on a value already i64.
df defines_i64(val: str, ir: list<str>) -> i64 {
    fixed marker: str = str_concat(str_concat("  ", val), " = ");
    set i: i64 = 0;
    whilst i < len(ir) {
        fixed line: str = ir[i];
        check str_contains(line, marker) {
            check str_contains(line, "= add i64 ")  { return 1; }
            check str_contains(line, "= sub i64 ")  { return 1; }
            check str_contains(line, "= mul i64 ")  { return 1; }
            check str_contains(line, "= sdiv i64 ") { return 1; }
            check str_contains(line, "= srem i64 ") { return 1; }
            check str_contains(line, "= ptrtoint ") { return 1; }
            check str_contains(line, "= zext ")     { return 1; }
            check str_contains(line, "= sext ")     { return 1; }
            check str_contains(line, "= call i64 ") { return 1; }
            check str_contains(line, "= phi i64 ")  { return 1; }
            return 0;
        }
        i += 1;
    }
    return 0;
}

df coerce_i64(val: str, ir: list<str>, ctr: list<i64>) -> str {
    // Already an i64 literal
    check val == "0" || val == "1" { return val; }
    // Check if val is a multi-digit integer literal (no % prefix)
    check len(val) > 0 {
        fixed fc: i64 = byte_at(val, 0);
        check fc >= 48 && fc <= 57 { return val; }  // digit → already i64
    }
    // Already an i64-producing temp → don't re-coerce
    check defines_i64(val, ir) == 1 { return val; }
    fixed tmp: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = ptrtoint ptr "), str_concat(val, " to i64")));
    return tmp;
}

// ─── Sized integer types (i8/i16/i32/u8/u16/u32, plus full-width i64) ──────────
// Width-typed values are stored as a canonical i64: the narrow value sign- or
// zero-extended. add/sub/mul are modular, so canonicalizing the RESULT equals
// canonicalizing each step; and for the <=32-bit widths the canonical rep stays
// inside i63 range, so comparison/division/printing reuse the i64 machinery as-is.
df int_width(ty: str) -> i64 {
    check line_eq(ty, "i8")  == 1 { return 8; }
    check line_eq(ty, "u8")  == 1 { return 8; }
    check line_eq(ty, "i16") == 1 { return 16; }
    check line_eq(ty, "u16") == 1 { return 16; }
    check line_eq(ty, "i32") == 1 { return 32; }
    check line_eq(ty, "u32") == 1 { return 32; }
    check line_eq(ty, "i64") == 1 { return 64; }
    check line_eq(ty, "u64") == 1 { return 64; }
    check line_eq(ty, "i128") == 1 { return 128; }
    check line_eq(ty, "u128") == 1 { return 128; }
    return 0;
}
df int_signed(ty: str) -> i64 {
    check line_eq(ty, "i8")  == 1 { return 1; }
    check line_eq(ty, "i16") == 1 { return 1; }
    check line_eq(ty, "i32") == 1 { return 1; }
    check line_eq(ty, "i64") == 1 { return 1; }
    check line_eq(ty, "i128") == 1 { return 1; }
    return 0;
}
// Re-canonicalize an i64 value to the storage form for type `ty`. A no-op for
// non-sized types and for i64 (already full-width). Narrow widths trunc to iN
// then re-extend (sext for signed, zext for unsigned) — this is the wraparound.
df canonicalize_int(val: str, ty: str, ir: list<str>, ctr: list<i64>) -> str {
    fixed w: i64 = int_width(ty);
    check w == 0 || w >= 64 { return val; }
    fixed iN: str = str_concat("i", int_to_str(w));
    fixed tr: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", tr), " = trunc i64 "), val), " to "), iN));
    fixed ex: str = make_tmp(ctr);
    check int_signed(ty) == 1 {
        emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", ex), " = sext "), iN), str_concat(" ", tr)), " to i64"));
    }
    check int_signed(ty) == 0 {
        emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", ex), " = zext "), iN), str_concat(" ", tr)), " to i64"));
    }
    return ex;
}
// All sized integer types (i8..u64, i128, u128) are now supported. This guard is
// retained as an extension point but currently reserves nothing.
// Range of a sized integer type as [lo, hi] for literal bounds checking. Returns
// 1 and fills lo/hi for a recognized narrow type; returns 0 otherwise. (i64/u64
// span or exceed the i64 range, so they are not bounds-checked here.)
df int_range(ty: str, out_lo: list<i64>, out_hi: list<i64>) -> i64 {
    check line_eq(ty, "i8")  == 1 { push(out_lo, 0 - 128); push(out_hi, 127); return 1; }
    check line_eq(ty, "u8")  == 1 { push(out_lo, 0); push(out_hi, 255); return 1; }
    check line_eq(ty, "i16") == 1 { push(out_lo, 0 - 32768); push(out_hi, 32767); return 1; }
    check line_eq(ty, "u16") == 1 { push(out_lo, 0); push(out_hi, 65535); return 1; }
    check line_eq(ty, "i32") == 1 { push(out_lo, 0 - 2147483648); push(out_hi, 2147483647); return 1; }
    check line_eq(ty, "u32") == 1 { push(out_lo, 0); push(out_hi, 4294967295); return 1; }
    return 0;
}

// u64's max (2^64-1) overflows i64, so its literal bound is checked by comparing
// digit strings rather than toint. Returns 1 if the (non-negative) decimal digit
// string `lit` is <= 18446744073709551615, else 0. Leading zeros are ignored.
df u64_in_range(lit: str) -> i64 {
    return digits_le(lit, "18446744073709551615");
}

// 1 if the decimal digit string `lit` (non-negative, leading zeros ignored) is
// <= `mx`. Used for bounds that overflow i64 (u64, i128, u128).
df digits_le(lit: str, mx: str) -> i64 {
    set i: i64 = 0;
    whilst i < len(lit) - 1 && byte_at(lit, i) == 48 { i += 1; }
    fixed d: str = substr(lit, i, len(lit));
    check len(d) > len(mx) { return 0; }
    check len(d) < len(mx) { return 1; }
    set j: i64 = 0;
    whilst j < len(d) {
        fixed cd: i64 = byte_at(d, j);
        fixed cm: i64 = byte_at(mx, j);
        check cd < cm { return 1; }
        check cd > cm { return 0; }
        j += 1;
    }
    return 1;
}

// i128 literal max (positive; negatives are expressions): 2^127 - 1.
df i128_in_range(lit: str) -> i64 {
    return digits_le(lit, "170141183460469231731687303715884105727");
}
// u128 literal max: 2^128 - 1. A negative literal is never valid for u128.
df u128_in_range(lit: str) -> i64 {
    check starts(lit, "-") { return 0; }
    return digits_le(lit, "340282366920938463463374607431768211455");
}
// Magnitude bound for a NEGATIVE i128 literal: -2^127 is the most-negative value,
// so the digit magnitude may be as large as 2^127 (one past the positive max).
df i128_neg_in_range(lit: str) -> i64 {
    return digits_le(lit, "170141183460469231731687303715884105728");
}
// Range check for a possibly-signed i128 literal string ("-NN" or "NN").
df i128_lit_in_range(lit: str) -> i64 {
    check starts(lit, "-") { return i128_neg_in_range(substr(lit, 1, len(lit))); }
    return i128_in_range(lit);
}

// ─── 128-bit by-pointer call helpers ────────────────────────────────────────
// __int128 travels by pointer across the runtime boundary (see the convention
// note in the runtime). These wrap the alloca/store/call/load boilerplate so the
// call sites stay readable. Allocas are hoisted to the entry block by
// hoist_allocas, so emitting them here (even inside a loop) is safe.

// Box an i128 SSA value -> returns the box pointer.
df i128_box_ir(v128: str, ir: list<str>, ctr: list<i64>) -> str {
    fixed slot: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat("  ", slot), " = alloca i128, align 16"));
    emit(ir, str_concat(str_concat(str_concat("  store i128 ", v128), ", ptr "), str_concat(slot, ", align 16")));
    fixed bx: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat("  ", bx), " = call ptr @torvik_i128_box(ptr "), str_concat(slot, ")")));
    return bx;
}

// Box an i128 literal (text) -> returns the box pointer.
df i128_box_lit(lit: str, ir: list<str>, ctr: list<i64>) -> str {
    fixed slot: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat("  ", slot), " = alloca i128, align 16"));
    emit(ir, str_concat(str_concat(str_concat("  store i128 ", lit), ", ptr "), str_concat(slot, ", align 16")));
    fixed bx: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat("  ", bx), " = call ptr @torvik_i128_box(ptr "), str_concat(slot, ")")));
    return bx;
}

// Load an i128 native value from a box pointer -> returns the i128 SSA value.
df i128_load_ir(boxptr: str, ir: list<str>, ctr: list<i64>) -> str {
    fixed slot: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat("  ", slot), " = alloca i128, align 16"));
    emit(ir, str_concat(str_concat(str_concat("  call void @torvik_i128_load(ptr ", boxptr), ", ptr "), str_concat(slot, ")")));
    fixed lv: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat("  ", lv), " = load i128, ptr "), str_concat(slot, ", align 16")));
    return lv;
}

// Emit a by-pointer i128 div/mod/etc. binop: fn(a128, b128) -> i128 SSA.
df i128_binop_ptr(fn: str, a128: str, b128: str, ir: list<str>, ctr: list<i64>) -> str {
    fixed aslot: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat("  ", aslot), " = alloca i128, align 16"));
    emit(ir, str_concat(str_concat(str_concat("  store i128 ", a128), ", ptr "), str_concat(aslot, ", align 16")));
    fixed bslot: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat("  ", bslot), " = alloca i128, align 16"));
    emit(ir, str_concat(str_concat(str_concat("  store i128 ", b128), ", ptr "), str_concat(bslot, ", align 16")));
    fixed oslot: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat("  ", oslot), " = alloca i128, align 16"));
    fixed callstr: str = str_concat(str_concat(str_concat("  call void @", fn), "(ptr "), str_concat(aslot, str_concat(", ptr ", str_concat(bslot, str_concat(", ptr ", str_concat(oslot, ")"))))));
    emit(ir, callstr);
    fixed ov: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat("  ", ov), " = load i128, ptr "), str_concat(oslot, ", align 16")));
    return ov;
}

// Convert any value to a printable string ptr for echo / interpolation.
//   val    — the SSA value
//   ev_ty  — the type compile_expr produced ("i64"/"f64"/"i1"/"ptr"/"str"/"list..")
//   eff_ty — the *effective* type used for the formatting decision. For a bare
//            variable this is the declared type, which disambiguates a boxed
//            scalar (printed numerically) from a string (both surface as "ptr").
// Returns a string ptr; non-stringifiable types fall through and print as-is.
df echo_stringify(val: str, ev_ty: str, eff_ty: str, ir: list<str>, ctr: list<i64>) -> str {
    // v1.2.0: aett-typed values are i64 ordinals - print them numerically.
    // (One entry-point check covers echo AND interpolation, since every
    // stringify path funnels through here.)
    check is_aett_name(eff_ty) == 1 {
        return echo_stringify(val, ev_ty, "i64", ir, ctr);
    }
    check eff_ty == "i128" || eff_ty == "u128" {
        fixed lv: str = i128_load_ir(val, ir, ctr);
        fixed vslot: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat("  ", vslot), " = alloca i128, align 16"));
        emit(ir, str_concat(str_concat(str_concat("  store i128 ", lv), ", ptr "), str_concat(vslot, ", align 16")));
        set fn128: str = "torvik_i128_to_str";
        check eff_ty == "u128" { fn128 = "torvik_u128_to_str"; }
        fixed t128: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat(str_concat("  ", t128), " = call ptr @"), fn128), str_concat("(ptr ", str_concat(vslot, ")"))));
        return t128;
    }
    check int_width(eff_ty) > 0 {
        set iv: str = val;
        check ev_ty != "i64" { iv = coerce_i64(val, ir, ctr); }
        fixed t1: str = make_tmp(ctr);
        set fn: str = "torvik_int_to_str";
        check eff_ty == "u64" { fn = "torvik_uint_to_str"; }
        emit(ir, str_concat(str_concat(str_concat(str_concat("  ", t1), " = call ptr @"), fn), str_concat("(i64 ", str_concat(iv, ")"))));
        return t1;
    }
    check eff_ty == "f64" {
        set fv: str = val;
        check ev_ty != "f64" {
            fixed pbits: str = coerce_i64(val, ir, ctr);
            fixed db: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", db), " = bitcast i64 "), str_concat(pbits, " to double")));
            fv = db;
        }
        fixed t2: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", t2), " = call ptr @torvik_float_to_str(double "), str_concat(fv, ")")));
        return t2;
    }
    check eff_ty == "bool" || eff_ty == "i1" {
        set bi: str = val;
        check ev_ty == "i1" { fixed z: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", z), " = zext i1 "), str_concat(val, " to i64"))); bi = z; }
        check ev_ty != "i1" { bi = coerce_i64(val, ir, ctr); }
        fixed t3: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", t3), " = call ptr @torvik_bool_to_str(i64 "), str_concat(bi, ")")));
        return t3;
    }
    check starts(eff_ty, "list") {
        fixed t4: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", t4), " = call ptr @torvik_list_to_str(ptr "), str_concat(val, ")")));
        return t4;
    }
    return val;
}

df join_ir(ir: list<str>) -> str {
    set result: str = "";
    set i: i64 = 0;
    fixed n: i64 = len(ir);
    whilst i < n {
        result = str_concat(result, str_concat(ir[i], "\n"));
        i += 1;
    }
    return result;
}

// ─── String interning ─────────────────────────────────────────────────────────

df intern_str(s: str, gvals: list<str>, gnames: list<str>) -> str {
    set i: i64 = 0;
    whilst i < len(gvals) {
        check line_eq(gvals[i], s) == 1 { return gnames[i]; }
        i += 1;
    }
    fixed n: str = str_concat("@.s", int_to_str(len(gvals)));
    push(gvals, s);
    push(gnames, n);
    return n;
}

// Memory Stage B2: interned string constants carry the same 16-byte refcount
// header as heap strings — [magic "HRTSVROT"][refcount "LATROMMI" = immortal]
// — embedded directly in the constant's bytes. Content is padded to >= 8 bytes
// so torvik_len's 8-byte dispatch read is in-bounds (mirrors torvik_str_alloc).
// All consumers address the BYTES at offset 16; retain/release see IMMORTAL
// and no-op, so literals live in rodata forever: never written, never freed.
// The three sites below (emit_str_ref GEP, global ptr GEPs, constant emission)
// MUST agree on this layout — these helpers are the single source of truth.
df str_const_content(vlen: i64) -> i64 {
    set c: i64 = vlen + 1;
    check c < 8 { c = 8; }
    return c;
}

df str_const_size(vlen: i64) -> i64 {
    // NOTE: a call is not yet a valid chain operand (roadmap: chaining stage 2),
    // so `return str_const_content(vlen) + 16;` silently DROPS the `+ 16` —
    // the old compiler compiled it without complaint and the +16 tokens were
    // skipped. Bind the call result first; var + int is fully supported.
    fixed c: i64 = str_const_content(vlen);
    return c + 16;
}

df str_const_pad(vlen: i64) -> str {
    set p: str = "";
    set k: i64 = vlen + 1;
    whilst k < 8 { p = str_concat(p, "\\00"); k += 1; }
    return p;
}

df emit_str_ref(gname: str, s: str, ir: list<str>, ctr: list<i64>) -> str {
    fixed slen: i64 = str_const_size(len(s));
    fixed tmp: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat(str_concat("  ", tmp), " = getelementptr ["), int_to_str(slen)), " x i8], ptr "), gname), ", i32 0, i32 16"));
    return tmp;
}

// Char-by-char line equality — independent of str== type inference, so it
// works correctly under the self-hosted codegen's partial type tracking.
df line_eq(a: str, b: str) -> i64 {
    fixed la: i64 = len(a);
    check la != len(b) { return 0; }
    set i: i64 = 0;
    whilst i < la {
        check byte_at(a, i) != byte_at(b, i) { return 0; }
        i += 1;
    }
    return 1;
}

// Returns 1 if the IR's last real instruction is a terminator (ret/br/unreachable),
// skipping trailing blank lines and "  ;" comment markers. Used to decide whether a
// basic block needs a synthesized terminator.
df block_terminated(ir: list<str>) -> i64 {
    set i: i64 = len(ir) - 1;
    set last: str = "";
    set found: i64 = 0;
    whilst i >= 0 && found == 0 {
        fixed l: str = ir[i];
        check len(l) > 0 {
            check starts(l, "  ;") { } fallback { last = l; found = 1; }
        }
        i -= 1;
    }
    set term: i64 = 0;
    check starts(last, "  ret ") { term = 1; }
    check starts(last, "  br ") { term = 1; }
    check starts(last, "  unreachable") { term = 1; }
    return term;
}


// Scan a function's IR for "  ; tv.undeffn:NAME:POS" markers (emitted at call sites
// to functions that don't exist) and turn each new NAME into a located error.
// undef_seen dedups across the whole program so a function called many times yields
// one error. POS is a token index; the caller renders it via offsets[POS].
// ── Generic located-error channel (v1.1.0) ──────────────────────────────────
// Any expression- or statement-level codegen site can report a LOCATED user
// error by emitting a "  ; tv.uerr:POS:MESSAGE" marker into the IR and simply
// continuing. Markers are collected after codegen (collect_user_errors below)
// and rendered as standard located errors — line, caret, message — together
// with every other error in the file. Because located errors abort BEFORE the
// IR is handed to clang, any nonsense the continuing codegen emits after the
// marker is never compiled; the only requirement on a reporting site is that
// it keeps torvc itself from crashing. This replaces the old echo!+exit(1)
// pattern, which could report only ONE error and could not point at a line.
df emit_uerr(ir: list<str>, tok_pos: i64, msg: str) -> void {
    emit(ir, str_concat(str_concat(str_concat("  ; tv.uerr:", int_to_str(tok_pos)), ":"), msg));
}

// ── v1.2.0: warnings channel ─────────────────────────────────────────────────
// Warnings ride the same marker mechanism as user errors (`; tv.warn:POS:MSG`
// comment lines collected after each function) but never fail the build. The
// torvc --no-warn flag sets warn_suppress before codegen runs.
set warn_suppress: i64 = 0;

df emit_warn(ir: list<str>, tok_pos: i64, cat: str, msg: str) -> void {
    emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ; tv.warn:", int_to_str(tok_pos)), ":"), cat), ":"), msg));
}

df collect_warnings(fn_ir: list<str>, w_pos: list<i64>, w_cat: list<str>, w_msg: list<str>) -> void {
    set i: i64 = 0;
    whilst i < len(fn_ir) {
        fixed line: str = fn_ir[i];
        check starts(line, "  ; tv.warn:") {
            fixed rest: str = substr(line, 12, len(line));
            set ci: i64 = 0;
            set found_c: i64 = 0;
            whilst ci < len(rest) && found_c == 0 {
                check byte_at(rest, ci) == 58 { found_c = 1; } fallback { ci += 1; }
            }
            push(w_pos, toint(substr(rest, 0, ci)));
            fixed r2: str = substr(rest, ci + 1, len(rest));
            set c2: i64 = 0;
            set found_c2: i64 = 0;
            whilst c2 < len(r2) && found_c2 == 0 {
                check byte_at(r2, c2) == 58 { found_c2 = 1; } fallback { c2 += 1; }
            }
            push(w_cat, substr(r2, 0, c2));
            push(w_msg, substr(r2, c2 + 1, len(r2)));
        }
        i += 1;
    }
}

// v1.2.0: `!@` warning directives. Scans the raw source (the lexer consumes
// directives like comments, so the token stream never sees them) skipping
// string literals, // comments, and nestable #- -# blocks, so a directive
// inside a string can never trigger. Recognized:
//   !@NO_WARN;              suppress every warning for this compilation
//   !@ALLOW[category];      suppress one category (unused_variable,
//                           unreachable_code, deprecated)
// A malformed or unknown directive is a LOCATED COMPILE ERROR - a typo'd
// directive silently doing nothing would be exactly the silent-no-op class
// Torvik hunts. Returns via out-lists: derr_off/derr_msg for errors; sets
// suppress[0]=1 for NO_WARN; appends allowed-off categories to allow_cats.
df scan_warn_directives(source: str, suppress: list<i64>, allow_cats: list<str>, derr_off: list<i64>, derr_msg: list<str>) -> void {
    fixed n: i64 = len(source);
    set i: i64 = 0;
    whilst i < n {
        fixed c: i64 = byte_at(source, i);
        // string literal: consume with escape handling
        check c == 34 {
            i += 1;
            whilst i < n && byte_at(source, i) != 34 {
                check byte_at(source, i) == 92 { i += 1; }
                i += 1;
            }
            i += 1;
            continue;
        }
        // line comment
        check c == 47 && i + 1 < n && byte_at(source, i + 1) == 47 {
            whilst i < n && byte_at(source, i) != 10 { i += 1; }
            continue;
        }
        // block comment (nestable)
        check c == 35 && i + 1 < n && byte_at(source, i + 1) == 45 {
            i += 2;
            set bd: i64 = 1;
            whilst i < n && bd > 0 {
                check byte_at(source, i) == 35 && i + 1 < n && byte_at(source, i + 1) == 45 { bd += 1; i += 2; continue; }
                check byte_at(source, i) == 45 && i + 1 < n && byte_at(source, i + 1) == 35 { bd -= 1; i += 2; continue; }
                i += 1;
            }
            continue;
        }
        check c == 33 && i + 1 < n && byte_at(source, i + 1) == 64 {
            fixed dstart: i64 = i;
            i += 2;
            // collect the directive text up to `;` (same line only)
            set dend: i64 = i;
            whilst dend < n && byte_at(source, dend) != 59 && byte_at(source, dend) != 10 { dend += 1; }
            check dend >= n || byte_at(source, dend) == 10 {
                push(derr_off, dstart);
                push(derr_msg, "unterminated warning directive - a `!@...` directive must end with `;` on the same line");
                i = dend;
                continue;
            }
            fixed body: str = substr(source, i, dend);
            i = dend + 1;
            check line_eq(body, "NO_WARN") == 1 {
                check len(suppress) > 0 { suppress[0] = 1; }
                continue;
            }
            check starts(body, "ALLOW[") && ends(body, "]") {
                fixed cat: str = substr(body, 6, len(body) - 1);
                set cat_ok: i64 = 0;
                check line_eq(cat, "unused_variable") == 1 { cat_ok = 1; }
                check line_eq(cat, "unreachable_code") == 1 { cat_ok = 1; }
                check line_eq(cat, "deprecated") == 1 { cat_ok = 1; }
                check cat_ok == 1 { push(allow_cats, cat); }
                check cat_ok == 0 {
                    push(derr_off, dstart);
                    push(derr_msg, fmt("unknown warning category '{cat}' in !@ALLOW[...] - known categories: unused_variable, unreachable_code, deprecated"));
                }
                continue;
            }
            push(derr_off, dstart);
            push(derr_msg, fmt("unknown warning directive '!@{body};' - known directives: !@NO_WARN; and !@ALLOW[category];"));
            continue;
        }
        i += 1;
    }
}

df warn_cat_allowed(cat: str, allow_cats: list<str>) -> i64 {
    set i: i64 = 0;
    whilst i < len(allow_cats) {
        check line_eq(allow_cats[i], cat) == 1 { return 1; }
        i += 1;
    }
    return 0;
}

// Deprecation channel: builtins scheduled for removal get an entry here and
// every call site receives a warning naming the replacement. Empty today -
// the mechanism ships in v1.2.0 so future deprecations are a one-line change.
df deprecated_msg(nm: str) -> str {
    return "";
}

// Unused locals: declarations drop a `; tv.declpos:NAME:POS` marker; after the
// function body is compiled, any declared local whose slot is never LOADED
// (`= load ptr, ptr %NAME_slot,`) gets a warning at its declaration. Loop
// variables load their slot in the loop machinery and parameters emit no
// marker, so neither ever warns.
df warn_unused_locals(fn_ir: list<str>) -> void {
    set di: i64 = 0;
    whilst di < len(fn_ir) {
        fixed line: str = fn_ir[di];
        check starts(line, "  ; tv.declpos:") {
            fixed rest: str = substr(line, 15, len(line));
            set ci: i64 = 0;
            set found_c: i64 = 0;
            whilst ci < len(rest) && found_c == 0 {
                check byte_at(rest, ci) == 58 { found_c = 1; } fallback { ci += 1; }
            }
            fixed dname: str = substr(rest, 0, ci);
            fixed dpos: i64 = toint(substr(rest, ci + 1, len(rest)));
            // Underscore-prefixed names are deliberate: `fixed _r: i64 = f(x);`
            // says "I'm calling f for its effect and discarding the result".
            // They are exempt from the unused warning.
            check byte_at(dname, 0) == 95 { di += 1; continue; }
            fixed needle: str = str_concat(str_concat("= load ptr, ptr %", dname), "_slot,");
            // A slot LOAD is only a real use if its result temp feeds anything
            // beyond the ARC machinery. Heap-typed slots (str/list/table/...)
            // are loaded by release-of-old-contents at every store and by the
            // scope-exit release pass, so a raw load count would never flag
            // them. Follow each load's temp: a line using it that is not a
            // retain/release call means the variable is genuinely read.
            set used: i64 = 0;
            set li: i64 = 0;
            whilst li < len(fn_ir) && used == 0 {
                fixed lline: str = fn_ir[li];
                check str_contains(lline, needle) {
                    // temp name = text before " = load" (skip the 2-space indent)
                    set te: i64 = 2;
                    whilst te < len(lline) && byte_at(lline, te) != 32 { te += 1; }
                    fixed ltmp: str = substr(lline, 2, te);
                    set ui: i64 = 0;
                    whilst ui < len(fn_ir) && used == 0 {
                        check ui != li {
                            fixed uline: str = fn_ir[ui];
                            set hits: i64 = 0;
                            check str_contains(uline, str_concat(ltmp, " "))  { hits = 1; }
                            check str_contains(uline, str_concat(ltmp, ",")) { hits = 1; }
                            check str_contains(uline, str_concat(ltmp, ")")) { hits = 1; }
                            // line-final temps: `ret ptr %tN` has no trailing
                            // character, so the three delimiter matchers miss it.
                            check ends(uline, ltmp) { hits = 1; }
                            check hits == 1 {
                                set arc_only: i64 = 0;
                                check str_contains(uline, "_release(") { arc_only = 1; }
                                check str_contains(uline, "_retain(")  { arc_only = 1; }
                                check arc_only == 0 { used = 1; }
                            }
                        }
                        ui += 1;
                    }
                }
                li += 1;
            }
            check used == 0 {
                emit_warn(fn_ir, dpos, "unused_variable", fmt("unused variable '{dname}' - it is never read. Remove it, or use it."));
            }
        }
        di += 1;
    }
}

// POS is the digits before the FIRST colon; everything after it is the message
// verbatim (so messages may themselves contain colons).
df collect_user_errors(fn_ir: list<str>, e_pos: list<i64>, e_msg: list<str>) -> void {
    set i: i64 = 0;
    whilst i < len(fn_ir) {
        fixed line: str = fn_ir[i];
        check starts(line, "  ; tv.uerr:") {
            fixed rest: str = substr(line, 12, len(line));
            set ci: i64 = 0;
            set found_c: i64 = 0;
            whilst ci < len(rest) && found_c == 0 {
                check byte_at(rest, ci) == 58 { found_c = 1; } fallback { ci += 1; }
            }
            push(e_pos, toint(substr(rest, 0, ci)));
            push(e_msg, substr(rest, ci + 1, len(rest)));
        }
        i += 1;
    }
}

df collect_undef_fns(fn_ir: list<str>, undef_seen: list<str>, e_pos: list<i64>, e_msg: list<str>) -> void {
    set i: i64 = 0;
    whilst i < len(fn_ir) {
        fixed line: str = fn_ir[i];
        check starts(line, "  ; tv.undeffn:") {
            fixed rest: str = substr(line, 15, len(line));
            set ci: i64 = 0;
            set found_c: i64 = 0;
            whilst ci < len(rest) && found_c == 0 {
                check byte_at(rest, ci) == 58 { found_c = 1; } fallback { ci += 1; }
            }
            fixed uname: str = substr(rest, 0, ci);
            fixed upos: i64 = toint(substr(rest, ci + 1, len(rest)));
            set seen: i64 = 0;
            set sj: i64 = 0;
            whilst sj < len(undef_seen) {
                check line_eq(undef_seen[sj], uname) == 1 { seen = 1; }
                sj += 1;
            }
            check seen == 0 {
                push(undef_seen, uname);
                push(e_pos, upos);
                push(e_msg, str_concat(str_concat("call to undefined function '", uname), "' - no function with this name is defined"));
            }
        }
        i += 1;
    }
}

// Scan a function's IR for "  ; tv.undefvar:NAME:POS" markers (reads of variables
// with no slot in this function) and turn each new NAME into a located error.
df collect_undef_vars(fn_ir: list<str>, fn_names: list<str>, undef_seen: list<str>, e_pos: list<i64>, e_msg: list<str>) -> void {
    set i: i64 = 0;
    whilst i < len(fn_ir) {
        fixed line: str = fn_ir[i];
        check starts(line, "  ; tv.unclosedinterp:") {
            fixed ipos: i64 = toint(substr(line, 22, len(line)));
            push(e_pos, ipos);
            push(e_msg, "unclosed interpolation in a string - every '{{' needs a matching '}}' (use '{{{{' to print a literal brace)");
        }
        check starts(line, "  ; tv.undefvar:") {
            fixed rest: str = substr(line, 16, len(line));
            set ci: i64 = 0;
            set found_c: i64 = 0;
            whilst ci < len(rest) && found_c == 0 {
                check byte_at(rest, ci) == 58 { found_c = 1; } fallback { ci += 1; }
            }
            fixed uname: str = substr(rest, 0, ci);
            fixed upos: i64 = toint(substr(rest, ci + 1, len(rest)));
            set seen: i64 = 0;
            set sj: i64 = 0;
            whilst sj < len(undef_seen) {
                check line_eq(undef_seen[sj], uname) == 1 { seen = 1; }
                sj += 1;
            }
            check seen == 0 {
                push(undef_seen, uname);
                push(e_pos, upos);
                // If the name is actually a function, the user likely forgot the call
                // parentheses — give a more useful message than "undefined variable".
                set is_fn: i64 = 0;
                set fj: i64 = 0;
                whilst fj < len(fn_names) {
                    check line_eq(fn_names[fj], uname) == 1 { is_fn = 1; }
                    fj += 1;
                }
                // A name with non-identifier characters only arises from an
                // interpolation like "{x + 1}" (the lexer never produces such an
                // identifier), so report it as an unsupported interpolated expression.
                set uname_bad: i64 = 0;
                set ubi: i64 = 0;
                whilst ubi < len(uname) {
                    fixed ubc: i64 = byte_at(uname, ubi);
                    check (ubc >= 65 && ubc <= 90) || (ubc >= 97 && ubc <= 122) || (ubc >= 48 && ubc <= 57) || ubc == 95 { } fallback { uname_bad = 1; }
                    ubi += 1;
                }
                check uname_bad == 1 {
                    push(e_msg, str_concat(str_concat("can't interpolate '", uname), "' - string interpolation takes a plain variable name, not an expression. Compute it into a variable first, then interpolate that."));
                }
                check uname_bad == 0 && is_fn == 1 {
                    push(e_msg, str_concat(str_concat("'", uname), "' is a function, not a variable - call it with parentheses, e.g. 'name(...)'"));
                }
                check uname_bad == 0 && is_fn == 0 {
                    push(e_msg, str_concat(str_concat("undefined variable '", uname), "' - no variable with this name is in scope"));
                }
            }
        }
        i += 1;
    }
}


df slot_exists(ir: list<str>, slot_line: str) -> i64 {
    set i: i64 = 0;
    whilst i < len(ir) {
        check line_eq(ir[i], slot_line) == 1 { return 1; }
        i += 1;
    }
    return 0;
}

// True if a slot "  %<nm>_slot = ..." is defined anywhere in this function's IR so
// far — i.e. nm is an accessible param, global, or already-declared local. Used to
// detect reads of variables that don't exist in the current function's scope.
df slot_defined(ir: list<str>, nm: str) -> i64 {
    fixed pfx: str = str_concat(str_concat("  %", nm), "_slot = ");
    set i: i64 = 0;
    whilst i < len(ir) {
        check starts(ir[i], pfx) { return 1; }
        i += 1;
    }
    return 0;
}

// ─── Expression compiler ──────────────────────────────────────────────────────

// ── Expression chaining, increment 1: exactly `var OP {int|var}` ───────────
// Minimal wedge in front of the old single-op path. Emits ; CHAIN comments
// (inert to LLVM) so miscompiles are observable via grep. No lists, no tiers.
df chain_tier6(op: i64) -> i64 {
    check op == OP_STAR || op == OP_SLASH || op == OP_PERCENT { return 6; }
    check op == OP_PLUS || op == OP_MINUS { return 5; }
    check op == OP_SHL || op == OP_SHR { return 4; }
    check op == OP_AMP { return 3; }
    check op == OP_CARET { return 2; }
    check op == OP_PIPE { return 1; }
    return 0;
}

df chain_emit_binop1(op: i64, lhs: str, rhs: str, ir: list<str>, ctr: list<i64>, uns: i64) -> str {
    fixed res: str = make_tmp(ctr);
    fixed pre: str = str_concat(str_concat("  ", res), " = ");
    fixed tail: str = str_concat(lhs, str_concat(", ", rhs));
    fixed divf: str = "torvik_div"; fixed modf: str = "torvik_mod"; fixed shrop: str = "ashr i64 ";
    set df2: str = divf; set mf2: str = modf; set sh2: str = shrop;
    check uns == 1 { df2 = "torvik_udiv"; mf2 = "torvik_umod"; sh2 = "lshr i64 "; }
    check op == OP_PLUS    { emit(ir, str_concat(pre, str_concat("add i64 ", tail))); }
    check op == OP_MINUS   { emit(ir, str_concat(pre, str_concat("sub i64 ", tail))); }
    check op == OP_STAR    { emit(ir, str_concat(pre, str_concat("mul i64 ", tail))); }
    check op == OP_SLASH   { emit(ir, str_concat(pre, str_concat(str_concat(str_concat("call i64 @", df2), str_concat("(i64 ", lhs)), str_concat(", i64 ", str_concat(rhs, ")"))))); }
    check op == OP_PERCENT { emit(ir, str_concat(pre, str_concat(str_concat(str_concat("call i64 @", mf2), str_concat("(i64 ", lhs)), str_concat(", i64 ", str_concat(rhs, ")"))))); }
    check op == OP_SHL     { emit(ir, str_concat(pre, str_concat("shl i64 ", tail))); }
    check op == OP_SHR     { emit(ir, str_concat(pre, str_concat(sh2, tail))); }
    check op == OP_AMP     { emit(ir, str_concat(pre, str_concat("and i64 ", tail))); }
    check op == OP_CARET   { emit(ir, str_concat(pre, str_concat("xor i64 ", tail))); }
    check op == OP_PIPE    { emit(ir, str_concat(pre, str_concat("or i64 ", tail))); }
    return res;
}

df lookup_var_type(name: str, var_names: list<str>, var_types: list<str>) -> str {
    // Return the LAST match, not the first. Entries accumulate in declaration
    // order across functions; the current function's params/locals are pushed
    // most recently, so the last match for a name is its innermost (correct)
    // binding. This scopes lookups per-function without truncating the map.
    //
    // Scanning backward and stopping at the first hit finds that innermost binding
    // directly: the current function's locals sit at the tail, so a typical lookup
    // touches only a handful of entries instead of the whole program-wide list
    // (which turned per-reference lookups into an O(N^2) hot path on large inputs).
    set i: i64 = len(var_names) - 1;
    whilst i >= 0 {
        check line_eq(var_names[i], name) == 1 { return var_types[i]; }
        i -= 1;
    }
    return "";
}

// v1.1.3: is `nm` a `fixed` binding in the CURRENT function? Declarations
// record an `@fixed@NAME` marker; the backward scan stops at the "@fn@"
// sentinel pushed at each function's start, so another function's fixed
// local with the same name never false-positives against this function's
// param or `set` local.
df lookup_fixed_marker(nm: str, var_names: list<str>, var_types: list<str>) -> i64 {
    fixed key: str = str_concat("@fixed@", nm);
    set i: i64 = len(var_names) - 1;
    whilst i >= 0 {
        check line_eq(var_names[i], "@fn@") == 1 { return 0; }
        check line_eq(var_names[i], key) == 1 {
            check line_eq(var_types[i], "1") == 1 { return 1; }
            return 0;
        }
        i -= 1;
    }
    return 0;
}

// v1.1.3: collect the names of top-level `fixed` GLOBALS by scanning the token
// stream at brace depth 0. The parser's global lists don't record the declaring
// keyword, so this one O(N) pass recovers mutability without changing the parse
// signature. The allnames cursor advances on TOK_IDENT and TOK_STRING, exactly
// as the statement scanners do.
df collect_fixed_globals(tokens: list<i64>, allnames: list<str>, out: list<str>) -> void {
    fixed ntok: i64 = len(tokens);
    set pos: i64 = 0;
    set an: i64 = 0;
    set depth: i64 = 0;
    whilst pos < ntok {
        fixed tk: i64 = tok_peek(tokens, pos);
        check tk == PUNCT_LBRACE { depth += 1; }
        check tk == PUNCT_RBRACE { depth -= 1; }
        check depth == 0 && tk == KW_FIXED && tok_peek(tokens, pos + 1) == TOK_IDENT {
            check an < len(allnames) { push(out, allnames[an]); }
        }
        check tk == TOK_IDENT || tk == TOK_STRING { an += 1; }
        pos += 1;
    }
}

// ── v1.2.0: aett - a family of named values ─────────────────────────────────
// `aett Status { Pending, Active, Closed }` declares named i64 constants
// (0-based ordinals) with a nominal type name. Variants are accessed as
// Status::Pending. Declarations are collected here from the raw tokens (the
// parser skips the blocks); the maps live in globals so the deep expression
// paths need no signature changes.
set g_aett_names: list<str> = list_new();    // "Status"
set g_aett_vlists: list<str> = list_new();   // "Pending Active Closed" (space-joined, parallel)
set g_aett_keys: list<str> = list_new();     // "Status::Pending"
set g_aett_ords: list<i64> = list_new();     // 0 (parallel to keys)

df collect_aetts(tokens: list<i64>, allnames: list<str>, err_pos: list<i64>, err_msg: list<str>) -> void {
    fixed ntok: i64 = len(tokens);
    set pos: i64 = 0;
    set an: i64 = 0;
    set depth: i64 = 0;
    whilst pos < ntok {
        fixed tk: i64 = tok_peek(tokens, pos);
        check tk == PUNCT_LBRACE { depth += 1; }
        check tk == PUNCT_RBRACE { depth -= 1; }
        check depth == 0 && tk == KW_AETT {
            check tok_peek(tokens, pos + 1) != TOK_IDENT || tok_peek(tokens, pos + 2) != PUNCT_LBRACE {
                push(err_pos, pos);
                push(err_msg, "malformed aett - expected `aett Name { Variant, Variant, ... }`");
                pos += 1;
                continue;
            }
            fixed aname: str = allnames[an];
            check is_aett_name(aname) == 1 {
                push(err_pos, pos + 1);
                push(err_msg, fmt("aett '{aname}' is declared twice - each aett needs a unique name."));
            }
            an += 1;         // the name
            pos += 3;        // aett NAME {
            set vlist: str = "";
            set ord: i64 = 0;
            set adone: i64 = 0;
            whilst pos < ntok && adone == 0 {
                fixed vt: i64 = tok_peek(tokens, pos);
                check vt == PUNCT_RBRACE { adone = 1; pos += 1; }
                check adone == 0 && vt == TOK_IDENT {
                    fixed vname: str = allnames[an];
                    fixed vkey: str = str_concat(str_concat(aname, "::"), vname);
                    check aett_ord_for(vkey) >= 0 {
                        push(err_pos, pos);
                        push(err_msg, fmt("variant '{vname}' appears twice in aett '{aname}'."));
                    }
                    push(g_aett_keys, vkey);
                    push(g_aett_ords, ord);
                    check ord == 0 { vlist = vname; } fallback { vlist = str_concat(str_concat(vlist, " "), vname); }
                    ord += 1;
                    an += 1; pos += 1;
                    check tok_peek(tokens, pos) == PUNCT_COMMA { pos += 1; }
                    continue;
                }
                check adone == 0 && vt != TOK_IDENT {
                    push(err_pos, pos);
                    push(err_msg, fmt("unexpected token in aett '{aname}' - variants are comma-separated names, e.g. `aett {aname} {{ A, B }}`."));
                    adone = 1;
                }
            }
            check ord == 0 && adone == 1 {
                push(err_pos, pos - 1);
                push(err_msg, fmt("aett '{aname}' has no variants - declare at least one, e.g. `aett {aname} {{ A }}`."));
            }
            push(g_aett_names, aname);
            push(g_aett_vlists, vlist);
            continue;
        }
        check tk == TOK_IDENT || tk == TOK_STRING { an += 1; }
        pos += 1;
    }
}

df is_aett_name(nm: str) -> i64 {
    set i: i64 = 0;
    whilst i < len(g_aett_names) {
        check line_eq(g_aett_names[i], nm) == 1 { return 1; }
        i += 1;
    }
    return 0;
}

// Ordinal for "Name::Variant", or -1.
df aett_ord_for(key: str) -> i64 {
    set i: i64 = 0;
    whilst i < len(g_aett_keys) {
        check line_eq(g_aett_keys[i], key) == 1 { return g_aett_ords[i]; }
        i += 1;
    }
    return -1;
}

// Space-joined variant names of an aett, or "".
df aett_variants_of(nm: str) -> str {
    set i: i64 = 0;
    whilst i < len(g_aett_names) {
        check line_eq(g_aett_names[i], nm) == 1 { return g_aett_vlists[i]; }
        i += 1;
    }
    return "";
}

// v1.2.1: the value-returning builtins that exist only in EXPRESSION position.
// A bare statement call of one of these previously produced the misleading
// "call to undefined function" (and emitted a bogus direct call) - the
// statement path recognizes them and explains the real situation instead.
// KEEP IN LOCKSTEP with the expression registrations in compile_value.
df is_expr_builtin(nm: str) -> i64 {
    check nm == "trim" || nm == "triml" || nm == "trimr" || nm == "upper" || nm == "lower" { return 1; }
    check nm == "replace" || nm == "substr" || nm == "char_at" || nm == "byte_at" || nm == "split" { return 1; }
    check nm == "find" || nm == "contains" || nm == "starts" || nm == "ends" || nm == "str_concat" { return 1; }
    check nm == "fmt" || nm == "tostr" || nm == "int_to_str" || nm == "float_to_str" { return 1; }
    check nm == "toint" || nm == "tofloat" || nm == "typeof" || nm == "len" { return 1; }
    check nm == "abs" || nm == "min" || nm == "max" || nm == "randint" || nm == "rand" { return 1; }
    check nm == "readln" || nm == "readint" || nm == "readfloat" || nm == "readbool" || nm == "read" { return 1; }
    check nm == "readkey" || nm == "readkey_str" || nm == "readenv" || nm == "readfile" { return 1; }
    check nm == "try_readfile" || nm == "try_toint" || nm == "try_tofloat" { return 1; }
    check nm == "ok" || nm == "err" || nm == "is_ok" || nm == "is_err" { return 1; }
    check nm == "unwrap" || nm == "unwrap_or" || nm == "err_msg" || nm == "err_code" { return 1; }
    check nm == "table_get" || nm == "table_has" || nm == "bag_has" || nm == "table_new" || nm == "bag_new" || nm == "list_new" { return 1; }
    check nm == "time_ms" || nm == "datetime_str" || nm == "fs_exists" || nm == "fs_mtime" { return 1; }
    check nm == "sys_os_name" || nm == "sys_os_version" || nm == "sys_arch" || nm == "sys_hostname" || nm == "sys_username" { return 1; }
    check nm == "sys_cpu_count" || nm == "sys_mem_total" || nm == "sys_mem_free" || nm == "sys_pid" || nm == "args" || nm == "args_get" { return 1; }
    return 0;
}

// Membership test over the collected fixed-global names.
df fixed_global_seen(names: list<str>, nm: str) -> i64 {
    set i: i64 = 0;
    whilst i < len(names) {
        check line_eq(names[i], nm) == 1 { return 1; }
        i += 1;
    }
    return 0;
}

// Does declaring `nm` with type `newty` conflict with an existing declaration
// of the SAME name and a DIFFERENT type in the CURRENT function? Both would
// share one %nm_slot, so mixing types corrupts storage (an i64 stored where a
// str is later released is a crash at a distance). Same-type redeclaration (the
// loop-body `set` idiom) is legal. The backward scan stops at the "@fn@"
// sentinel pushed at each function's start, so other functions' locals with
// the same name never false-positive.
df redecl_conflict(nm: str, newty: str, var_names: list<str>, var_types: list<str>) -> i64 {
    set i: i64 = len(var_names) - 1;
    whilst i >= 0 {
        check line_eq(var_names[i], "@fn@") == 1 { return 0; }
        check line_eq(var_names[i], nm) == 1 {
            check line_eq(var_types[i], newty) == 1 { return 0; }
            return 1;
        }
        i -= 1;
    }
    return 0;
}

// Coarse type "kind" for assignment-compatibility checks: "num" (any integer
// width, f64, or bool), "str", "list", or "other" (bag/table/result, or the
// ambiguous uniform "ptr" — never flagged, to avoid false positives).
df ty_kind(t: str) -> str {
    check line_eq(t, "i64") == 1 { return "num"; }
    check line_eq(t, "u64") == 1 { return "num"; }
    check line_eq(t, "i128") == 1 { return "num"; }
    check line_eq(t, "u128") == 1 { return "num"; }
    check line_eq(t, "f64") == 1 { return "float"; }
    check line_eq(t, "bool") == 1 { return "num"; }
    check line_eq(t, "i1") == 1 { return "num"; }
    check line_eq(t, "i8") == 1 { return "num"; }
    check line_eq(t, "u8") == 1 { return "num"; }
    check line_eq(t, "i16") == 1 { return "num"; }
    check line_eq(t, "u16") == 1 { return "num"; }
    check line_eq(t, "i32") == 1 { return "num"; }
    check line_eq(t, "u32") == 1 { return "num"; }
    check line_eq(t, "str") == 1 { return "str"; }
    check starts(t, "list") { return "list"; }
    return "other";
}

// True if `t` names a valid Torvik value type (any type usable for a variable,
// parameter, or non-void return). `void` is intentionally excluded — it is only
// valid as a return type, handled separately at the return-type validator.
df is_value_type(t: str) -> i64 {
    check line_eq(t, "i64") == 1 { return 1; }
    check line_eq(t, "f64") == 1 { return 1; }
    check line_eq(t, "str") == 1 { return 1; }
    check line_eq(t, "bool") == 1 { return 1; }
    check line_eq(t, "i8") == 1 { return 1; }
    check line_eq(t, "u8") == 1 { return 1; }
    check line_eq(t, "i16") == 1 { return 1; }
    check line_eq(t, "u16") == 1 { return 1; }
    check line_eq(t, "i32") == 1 { return 1; }
    check line_eq(t, "u32") == 1 { return 1; }
    check line_eq(t, "u64") == 1 { return 1; }
    check line_eq(t, "i128") == 1 { return 1; }
    check line_eq(t, "u128") == 1 { return 1; }
    check line_eq(t, "bag") == 1 { return 1; }
    check starts(t, "list<") { return 1; }
    check starts(t, "bag<") { return 1; }
    check starts(t, "table<") { return 1; }
    check starts(t, "result<") { return 1; }
    return 0;
}

// Extract the element type from a "list<ELEM>" type string (e.g. "list<i128>"
// -> "i128", "list<str>" -> "str"). Returns "" if `ty` is not a list type.
// Used by the index-read and push paths to manage 128-bit element boxes and to
// reject ill-typed elements. Handles nested generics by taking everything
// between the first '<' and the final '>'.
// Only str list_pop results are owned +1 strings needing ARC; the tag makes the
// producer registry match str pops (release/transfer) while a scalar pop stays
// a plain integer cell (no ARC). Returns " ; tv.strpop" for str, "" otherwise.
df check_str_pop_tag(elem: str) -> str {
    check line_eq(elem, "str") == 1 { return " ; tv.strpop"; }
    return "";
}

df list_elem_type(ty: str) -> str {
    set out: str = "";
    check starts(ty, "list<") {
        fixed n: i64 = len(ty);
        check n > 6 { out = substr(ty, 5, n - 1); }
    }
    return out;
}

// Infer the element type of an unannotated `set xs = list_new();` by scanning
// forward from the declaration for the FIRST `push(xs, VALUE)` in the same
// function and reading VALUE's type. Handles the common literal/variable cases
// directly (a string literal → "str"; an int/float/bool literal → that type; a
// bare typed variable → its type). Returns "" when nothing usable is found, in
// which case the caller keeps requiring an explicit annotation. `vpos` is the
// token index of the variable name in the declaration; `stop` bounds the scan
// to the enclosing function's token range.
df infer_list_elem(vname: str, tokens: list<i64>, strings: list<str>, allnames: list<str>, start_pos: i64, start_si: i64, start_ani: i64, stop: i64, var_names: list<str>, var_types: list<str>) -> str {
    set p: i64 = start_pos;
    set s: i64 = start_si;
    set a: i64 = start_ani;
    fixed ntok: i64 = len(tokens);
    whilst p < stop && p < ntok {
        fixed t: i64 = tok_peek(tokens, p);
        // Track the string- and name-stream indices in lockstep with the tokens
        // so that when we reach a push we can read the pushed value's literal.
        check t == TOK_IDENT {
            // push ( NAME , VALUE )
            check line_eq(allnames[a], "push") == 1 && tok_peek(tokens, p + 1) == PUNCT_LPAREN && tok_peek(tokens, p + 2) == TOK_IDENT {
                check line_eq(allnames[a + 1], vname) == 1 && tok_peek(tokens, p + 3) == PUNCT_COMMA {
                    // The value token is at p+4; its stream indices are tracked by
                    // walking from `a`/`s` up to that point.
                    fixed vtk: i64 = tok_peek(tokens, p + 4);
                    // count string/name tokens consumed by "push" "NAME" before value
                    // push=name(a), NAME=name(a+1); no strings before the value.
                    check vtk == TOK_STRING { return "str"; }
                    check vtk == TOK_INT { return "i64"; }
                    check vtk == TOK_FLOAT { return "f64"; }
                    check vtk == KW_TRUE || vtk == KW_FALSE { return "bool"; }
                    check vtk == TOK_IDENT {
                        fixed argnm: str = allnames[a + 2];
                        check line_eq(argnm, "true") == 1 || line_eq(argnm, "false") == 1 { return "bool"; }
                        fixed at: str = lookup_var_type(argnm, var_names, var_types);
                        check len(at) > 0 {
                            check starts(at, "fnret:") {
                                fixed frt: str = substr(at, 6, len(at));
                                check len(frt) > 0 { return frt; }
                            } fallback {
                                check starts(at, "@p@") { } fallback { return at; }
                            }
                        }
                    }
                }
            }
            a += 1;
        }
        check t == TOK_STRING { s += 1; a += 1; }
        p += 1;
    }
    return "";
}


// Extract the value type V from a "table<K,V>" annotation (first comma splits
// K from V; the outer '>' is dropped). Returns "" when ty isn't a typed table.
df table_val_type(ty: str) -> str {
    set out: str = "";
    check starts(ty, "table<") {
        fixed n: i64 = len(ty);
        set ci: i64 = 0;
        set i: i64 = 6;
        whilst i < n && ci == 0 {
            check byte_at(ty, i) == 44 { ci = i; }
            i += 1;
        }
        check ci > 0 && n > ci + 1 { out = substr(ty, ci + 1, n - 1); }
    }
    return out;
}

// ── fold_chain6 ──────────────────────────────────────────────────────────────
// Six-tier precedence-climbing arithmetic/bitwise chain, factored out of the
// identifier path so call/index results can feed the same machinery (expression
// chaining stage 2). Starts from a caller-supplied i64 accumulator `chcur_in`
// at position p_in and folds `OP operand` pairs while the next token is a chain
// operator and the operand is foldable. Returns the result i64, plus updated
// p/s/an, via out-params. Stage 1 keeps the original int/plain-var operand
// reader byte-for-byte; stage 2 widens it to call/index operands below.
df fold_chain6(tokens: list<i64>, strings: list<str>, allnames: list<str>, chcur_in: str, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, var_names: list<str>, var_types: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, uns: i64, out_uns: list<i64>) -> void {
    // v1.1.0: signedness is no longer lead-operand-only. It starts from the
    // lead (uns) and UPGRADES to unsigned the moment any u64 operand is read,
    // so `2 / x` and `total - spent / x` with a u64 x use udiv/umod/lshr and
    // unsigned comparison predicates from that operand onward. The final
    // signedness is reported through out_uns so callers pick the right
    // predicate for a trailing comparison.
    set uns2: i64 = uns;
    set chcur: str = chcur_in;
    set p: i64 = p_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    set opnd6: str = "0";
    set op6: i64 = 0;
    set has6: i64 = 0;
    set opnd5: str = "0";
    set op5: i64 = 0;
    set has5: i64 = 0;
    set opnd4: str = "0";
    set op4: i64 = 0;
    set has4: i64 = 0;
    set opnd3: str = "0";
    set op3: i64 = 0;
    set has3: i64 = 0;
    set opnd2: str = "0";
    set op2: i64 = 0;
    set has2: i64 = 0;
    set opnd1: str = "0";
    set op1: i64 = 0;
    set has1: i64 = 0;
    set more: i64 = 1;
    whilst more == 1 {
        fixed nop: i64 = tok_peek(tokens, p);
        fixed tier: i64 = chain_tier6(nop);
        check tier == 0 { more = 0; } fallback {
            // v1.1.0 operator edges: a unary minus may prefix any chain operand
            // (`a - -b`, `a + -5`, `a * -f(x)`). Classify the operand one token
            // further along and negate the computed value afterward.
            set noff: i64 = 0;
            check tok_peek(tokens, p + 1) == OP_MINUS { noff = 1; }
            fixed nxp: i64 = tok_peek(tokens, p + 1 + noff);
            fixed nx2: i64 = tok_peek(tokens, p + 2 + noff);
            set ni: i64 = 0; check nxp == TOK_INT { ni = 1; }
            set nxv: i64 = 0; check nxp == TOK_IDENT && nx2 != PUNCT_LPAREN && nx2 != PUNCT_LBRACKET { nxv = 1; }
            set nxcall: i64 = 0; check nxp == TOK_IDENT && nx2 == PUNCT_LPAREN { nxcall = 1; }
            set nxidx: i64 = 0; check nxp == TOK_IDENT && nx2 == PUNCT_LBRACKET { nxidx = 1; }
            set nxpar: i64 = 0; check nxp == PUNCT_LPAREN { nxpar = 1; }
            check ni == 0 && nxv == 0 && nxcall == 0 && nxidx == 0 && nxpar == 0 { more = 0; } fallback {
                set operand_i: str = "0";
                set simple: i64 = 1;
                check ni == 1 {
                    fixed iv2: str = strings[s];
                    fixed it2: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", it2), " = add i64 0, "), iv2));
                    operand_i = it2; s += 1;
                }
                check nxv == 1 {
                    fixed vn2: str = allnames[an];
                    check line_eq(lookup_var_type(vn2, var_names, var_types), "f64") == 1 {
                        emit_uerr(ir, p + 1 + noff, "float operand in an integer expression. Lead the expression with the float (e.g. `x * 2`), or convert with tofloat(...).");
                    }
                    fixed vn2ty: str = lookup_var_type(vn2, var_names, var_types);
                    check line_eq(vn2ty, "i128") == 1 || line_eq(vn2ty, "u128") == 1 {
                        emit_uerr(ir, p + 1 + noff, "a 128-bit value as a non-leading operand in an i64 expression is not yet supported. Lead the expression with the 128-bit operand (the whole expression is then 128-bit), or convert explicitly.");
                    }
                    check line_eq(vn2ty, "u64") == 1 { uns2 = 1; }
                    fixed vt2: str = make_tmp(ctr);
                    fixed vp2: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  ", vt2), " = load ptr, ptr %"), vn2), "_slot, align 8"));
                    emit(ir, str_concat(str_concat(str_concat("  ", vp2), " = ptrtoint ptr "), str_concat(vt2, " to i64")));
                    operand_i = vp2; an += 1;
                }
                check nxcall == 1 || nxidx == 1 || nxpar == 1 {
                    // Stage 2: a call / index / parenthesized expression as a chain
                    // operand. Evaluate the single primary via compile_expr at p+1.
                    // Set the suppression flag so that primary resolves to itself
                    // and does NOT fold the chain we are in the middle of (which
                    // would break precedence, e.g. `a * f(x) + 1`).
                    check len(ctr) > 1 { ctr[1] = 1; }
                    set ev: list<str> = list_new(); set ep: list<i64> = list_new(); set es: list<i64> = list_new(); set ea: list<i64> = list_new(); set ety: list<str> = list_new();
                    compile_expr(tokens, strings, allnames, p + 1 + noff, s, an, ir, ctr, gvals, gnames, ev, ep, es, ea, ety, var_names, var_types);
                    set evv: str = "0"; check len(ev) > 0 { evv = ev[0]; }
                    set evty: str = "ptr"; check len(ety) > 0 { evty = ety[0]; }
                    // It DOES fold a trailing comparison after a call/index. If that
                    // happened (operand came back i1), the user wrote something like
                    // `a + f(x) > b`, whose precedence is ambiguous to this folder.
                    // Refuse loudly rather than silently bind it as `a + (f(x) > b)`.
                    check evty == "i1" {
                        emit_uerr(ir, p + 1 + noff, "comparison/boolean inside an arithmetic chain operand. Parenthesize the comparison, e.g. `(a + f(x)) > b`, or bind the call to a local first.");
                    }
                    check line_eq(evty, "u64") == 1 { uns2 = 1; }
                    set evi: str = evv; check evty != "i64" { evi = coerce_i64(evv, ir, ctr); }
                    operand_i = evi;
                    check len(es) > 0 { s = es[0]; }
                    check len(ea) > 0 { an = ea[0]; }
                    check len(ep) > 0 { p = ep[0]; }
                    simple = 0;
                }
                check noff == 1 {
                    fixed negt: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", negt), " = sub i64 0, "), operand_i));
                    operand_i = negt;
                }
                check has6 == 1 { chcur = chain_emit_binop1(op6, opnd6, chcur, ir, ctr, uns2); has6 = 0; }
                check tier <= 5 && has5 == 1 { chcur = chain_emit_binop1(op5, opnd5, chcur, ir, ctr, uns2); has5 = 0; }
                check tier <= 4 && has4 == 1 { chcur = chain_emit_binop1(op4, opnd4, chcur, ir, ctr, uns2); has4 = 0; }
                check tier <= 3 && has3 == 1 { chcur = chain_emit_binop1(op3, opnd3, chcur, ir, ctr, uns2); has3 = 0; }
                check tier <= 2 && has2 == 1 { chcur = chain_emit_binop1(op2, opnd2, chcur, ir, ctr, uns2); has2 = 0; }
                check tier <= 1 && has1 == 1 { chcur = chain_emit_binop1(op1, opnd1, chcur, ir, ctr, uns2); has1 = 0; }
                check tier == 6 { opnd6 = chcur; op6 = nop; has6 = 1; }
                check tier == 5 { opnd5 = chcur; op5 = nop; has5 = 1; }
                check tier == 4 { opnd4 = chcur; op4 = nop; has4 = 1; }
                check tier == 3 { opnd3 = chcur; op3 = nop; has3 = 1; }
                check tier == 2 { opnd2 = chcur; op2 = nop; has2 = 1; }
                check tier == 1 { opnd1 = chcur; op1 = nop; has1 = 1; }
                chcur = operand_i;
                check simple == 1 { p += 2 + noff; }
            }
        }
    }
    check has6 == 1 { chcur = chain_emit_binop1(op6, opnd6, chcur, ir, ctr, uns2); has6 = 0; }
    check has5 == 1 { chcur = chain_emit_binop1(op5, opnd5, chcur, ir, ctr, uns2); has5 = 0; }
    check has4 == 1 { chcur = chain_emit_binop1(op4, opnd4, chcur, ir, ctr, uns2); has4 = 0; }
    check has3 == 1 { chcur = chain_emit_binop1(op3, opnd3, chcur, ir, ctr, uns2); has3 = 0; }
    check has2 == 1 { chcur = chain_emit_binop1(op2, opnd2, chcur, ir, ctr, uns2); has2 = 0; }
    check has1 == 1 { chcur = chain_emit_binop1(op1, opnd1, chcur, ir, ctr, uns2); has1 = 0; }
    push(out_val, chcur); push(out_pos, p); push(out_si, s); push(out_ani, an);
    push(out_uns, uns2);
}

// ── i128/u128 arithmetic chain ─────────────────────────────────────────────────
// A 128-bit value is a heap-box ptr (uniform-ptr model), so it can NEVER ride the
// i64 chain: coerce_i64 would ptrtoint the box address. These three helpers are a
// parallel path that loads operands to native LLVM `i128` SSA values, emits native
// i128 ops, and (for arithmetic) re-boxes the result. Signedness is lead-operand
// driven (uns), exactly like u64. Mixed i128/i64 operands are a CLEAN error, never
// a silent coercion.

df chain_emit_binop1_i128(op: i64, lhs: str, rhs: str, ir: list<str>, ctr: list<i64>, uns: i64) -> str {
    fixed res: str = make_tmp(ctr);
    fixed pre: str = str_concat(str_concat("  ", res), " = ");
    fixed tail: str = str_concat(lhs, str_concat(", ", rhs));
    fixed divf: str = "torvik_i128_div"; fixed modf: str = "torvik_i128_mod"; fixed shrop: str = "ashr i128 ";
    set df2: str = divf; set mf2: str = modf; set sh2: str = shrop;
    check uns == 1 { df2 = "torvik_u128_div"; mf2 = "torvik_u128_mod"; sh2 = "lshr i128 "; }
    check op == OP_PLUS    { emit(ir, str_concat(pre, str_concat("add i128 ", tail))); }
    check op == OP_MINUS   { emit(ir, str_concat(pre, str_concat("sub i128 ", tail))); }
    check op == OP_STAR    { emit(ir, str_concat(pre, str_concat("mul i128 ", tail))); }
    check op == OP_SLASH   { fixed dv: str = i128_binop_ptr(df2, lhs, rhs, ir, ctr); emit(ir, str_concat(pre, str_concat("add i128 0, ", dv))); }
    check op == OP_PERCENT { fixed mv: str = i128_binop_ptr(mf2, lhs, rhs, ir, ctr); emit(ir, str_concat(pre, str_concat("add i128 0, ", mv))); }
    check op == OP_SHL     { emit(ir, str_concat(pre, str_concat("shl i128 ", tail))); }
    check op == OP_SHR     { emit(ir, str_concat(pre, str_concat(sh2, tail))); }
    check op == OP_AMP     { emit(ir, str_concat(pre, str_concat("and i128 ", tail))); }
    check op == OP_CARET   { emit(ir, str_concat(pre, str_concat("xor i128 ", tail))); }
    check op == OP_PIPE    { emit(ir, str_concat(pre, str_concat("or i128 ", tail))); }
    return res;
}

// Read ONE i128 operand at position p (the operand token itself). int literal ->
// `add i128 0, <lit>` (LLVM takes arbitrary-precision i128 immediates); 128-bit var
// -> load box ptr then torvik_i128_load. Any other operand (i64 var, call, index,
// paren, float) is a clean mixed-operand error. Pushes updated p/s/an; returns the
// i128 SSA.
df read_i128_operand(tokens: list<i64>, strings: list<str>, allnames: list<str>, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, var_names: list<str>, var_types: list<str>, out_p: list<i64>, out_s: list<i64>, out_an: list<i64>) -> str {
    set p: i64 = p_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    fixed t1: i64 = tok_peek(tokens, p);
    fixed t2: i64 = tok_peek(tokens, p + 1);
    check t1 == TOK_INT {
        fixed iv: str = strings[s];
        fixed it: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", it), " = add i128 0, "), iv));
        s += 1; p += 1;
        push(out_p, p); push(out_s, s); push(out_an, an);
        return it;
    }
    check t1 == TOK_IDENT && t2 != PUNCT_LPAREN && t2 != PUNCT_LBRACKET {
        fixed vn: str = allnames[an];
        fixed vty: str = lookup_var_type(vn, var_names, var_types);
        check line_eq(vty, "i128") == 1 || line_eq(vty, "u128") == 1 {
            fixed vt: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat(str_concat("  ", vt), " = load ptr, ptr %"), vn), "_slot, align 8"));
            fixed vp: str = i128_load_ir(vt, ir, ctr);
            an += 1; p += 1;
            push(out_p, p); push(out_s, s); push(out_an, an);
            return vp;
        }
        emit_uerr(ir, p, "mixed 128-bit and non-128-bit operands in one expression are not yet supported. Use 128-bit variables (or integer literals) throughout, or convert explicitly.");
    }
    // A list<i128>/list<u128> element operand: NAME[idx]. Fetch the element box
    // (torvik_list_get) and load the native i128, so `xs[i] + xs[j]`, `xs[i] > v`
    // etc. fold like any other 128-bit operand. Only valid when the list's element
    // type is 128-bit; other element types fall through to the mixed-operand error.
    check t1 == TOK_IDENT && t2 == PUNCT_LBRACKET {
        fixed lvn: str = allnames[an];
        fixed lvty: str = lookup_var_type(lvn, var_names, var_types);
        fixed lelem: str = list_elem_type(lvty);
        check line_eq(lelem, "i128") == 1 || line_eq(lelem, "u128") == 1 {
            fixed lvp: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat(str_concat("  ", lvp), " = load ptr, ptr %"), lvn), "_slot, align 8"));
            an += 1; p += 1;                 // consume NAME
            p += 1;                          // consume '['
            // The index is a literal or a simple i64 variable (the common forms
            // `xs[0]`, `xs[i]`). Handling these two directly avoids threading the
            // global-string tables through the operand reader.
            fixed itk: i64 = tok_peek(tokens, p);
            set ixi: str = "0";
            check itk == TOK_INT {
                ixi = strings[s]; s += 1; p += 1;
            } fallback {
                check itk == TOK_IDENT {
                    fixed ixvn: str = allnames[an];
                    fixed ixld: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  ", ixld), " = load i64, ptr %"), ixvn), "_slot, align 8"));
                    ixi = ixld; an += 1; p += 1;
                } fallback {
                    emit_uerr(ir, p, "a 128-bit list element index must be an integer literal or a variable here; bind a complex index to a variable first.");
                }
            }
            p += 1;                          // consume ']'
            fixed gbox: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat(str_concat("  ", gbox), " = call ptr @torvik_list_get(ptr "), lvp), str_concat(", i64 ", str_concat(ixi, ")"))));
            fixed gload: str = i128_load_ir(gbox, ir, ctr);
            push(out_p, p); push(out_s, s); push(out_an, an);
            return gload;
        }
        emit_uerr(ir, p, "mixed 128-bit and non-128-bit operands in one expression are not yet supported. Use 128-bit variables (or integer literals) throughout, or convert explicitly.");
    }
    emit_uerr(ir, p, "unsupported operand in a 128-bit expression. v1.0 supports 128-bit variables and integer literals; calls, indexes, and parenthesized sub-expressions are not yet foldable in a 128-bit chain.");
    push(out_p, p); push(out_s, s); push(out_an, an);
    return "0";
}

// Six-tier precedence-climbing chain for i128/u128. Structurally identical to
// fold_chain6 (same has6..has1 / tier folding), but the accumulator and operands
// are native i128 and ops go through chain_emit_binop1_i128. Operand reading is
// delegated to read_i128_operand (literals + 128-bit vars only).
df fold_chain6_i128(tokens: list<i64>, strings: list<str>, allnames: list<str>, chcur_in: str, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, var_names: list<str>, var_types: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, uns: i64) -> void {
    set chcur: str = chcur_in;
    set p: i64 = p_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    set opnd6: str = "0"; set op6: i64 = 0; set has6: i64 = 0;
    set opnd5: str = "0"; set op5: i64 = 0; set has5: i64 = 0;
    set opnd4: str = "0"; set op4: i64 = 0; set has4: i64 = 0;
    set opnd3: str = "0"; set op3: i64 = 0; set has3: i64 = 0;
    set opnd2: str = "0"; set op2: i64 = 0; set has2: i64 = 0;
    set opnd1: str = "0"; set op1: i64 = 0; set has1: i64 = 0;
    set more: i64 = 1;
    whilst more == 1 {
        fixed nop: i64 = tok_peek(tokens, p);
        fixed tier: i64 = chain_tier6(nop);
        check tier == 0 { more = 0; } fallback {
            // Operand is at p+1. Read it via read_i128_operand (which errors cleanly
            // on calls/index/paren/i64). The reader advances from p+1.
            set rop: list<i64> = list_new(); set ros: list<i64> = list_new(); set roa: list<i64> = list_new();
            fixed operand_i: str = read_i128_operand(tokens, strings, allnames, p + 1, s, an, ir, ctr, var_names, var_types, rop, ros, roa);
            check len(rop) > 0 { p = rop[0]; }
            check len(ros) > 0 { s = ros[0]; }
            check len(roa) > 0 { an = roa[0]; }
            check has6 == 1 { chcur = chain_emit_binop1_i128(op6, opnd6, chcur, ir, ctr, uns); has6 = 0; }
            check tier <= 5 && has5 == 1 { chcur = chain_emit_binop1_i128(op5, opnd5, chcur, ir, ctr, uns); has5 = 0; }
            check tier <= 4 && has4 == 1 { chcur = chain_emit_binop1_i128(op4, opnd4, chcur, ir, ctr, uns); has4 = 0; }
            check tier <= 3 && has3 == 1 { chcur = chain_emit_binop1_i128(op3, opnd3, chcur, ir, ctr, uns); has3 = 0; }
            check tier <= 2 && has2 == 1 { chcur = chain_emit_binop1_i128(op2, opnd2, chcur, ir, ctr, uns); has2 = 0; }
            check tier <= 1 && has1 == 1 { chcur = chain_emit_binop1_i128(op1, opnd1, chcur, ir, ctr, uns); has1 = 0; }
            check tier == 6 { opnd6 = chcur; op6 = nop; has6 = 1; }
            check tier == 5 { opnd5 = chcur; op5 = nop; has5 = 1; }
            check tier == 4 { opnd4 = chcur; op4 = nop; has4 = 1; }
            check tier == 3 { opnd3 = chcur; op3 = nop; has3 = 1; }
            check tier == 2 { opnd2 = chcur; op2 = nop; has2 = 1; }
            check tier == 1 { opnd1 = chcur; op1 = nop; has1 = 1; }
            chcur = operand_i;
        }
    }
    check has6 == 1 { chcur = chain_emit_binop1_i128(op6, opnd6, chcur, ir, ctr, uns); has6 = 0; }
    check has5 == 1 { chcur = chain_emit_binop1_i128(op5, opnd5, chcur, ir, ctr, uns); has5 = 0; }
    check has4 == 1 { chcur = chain_emit_binop1_i128(op4, opnd4, chcur, ir, ctr, uns); has4 = 0; }
    check has3 == 1 { chcur = chain_emit_binop1_i128(op3, opnd3, chcur, ir, ctr, uns); has3 = 0; }
    check has2 == 1 { chcur = chain_emit_binop1_i128(op2, opnd2, chcur, ir, ctr, uns); has2 = 0; }
    check has1 == 1 { chcur = chain_emit_binop1_i128(op1, opnd1, chcur, ir, ctr, uns); has1 = 0; }
    push(out_val, chcur); push(out_pos, p); push(out_si, s); push(out_ani, an);
}


// ── chain_tail ───────────────────────────────────────────────────────────────
// Given a primary already lowered to an i64 value (`init_i64`) sitting at p_in,
// fold any following arithmetic/bitwise chain (via fold_chain6) and then an
// optional trailing comparison, pushing the final value+type. This lets an
// integer literal, a call result, or an index result *begin* a chain — the
// counterpart to fold_chain6's widened operand reader, which lets them appear
// as later operands. Mutually recursive with compile_expr (forward ref is fine).
df chain_tail(tokens: list<i64>, strings: list<str>, allnames: list<str>, init_i64: str, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, var_names: list<str>, var_types: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>, uns: i64) -> void {
    set uns3: i64 = uns;
    set cur: str = init_i64;
    set p: i64 = p_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    check chain_tier6(tok_peek(tokens, p)) > 0 {
        set fcv: list<str> = list_new(); set fcp: list<i64> = list_new(); set fcs: list<i64> = list_new(); set fca: list<i64> = list_new();
        set fcu: list<i64> = list_new();
        fold_chain6(tokens, strings, allnames, cur, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, fcv, fcp, fcs, fca, uns, fcu);
        check len(fcu) > 0 { check fcu[0] == 1 { uns3 = 1; } }
        check len(fcv) > 0 { cur = fcv[0]; }
        check len(fcp) > 0 { p = fcp[0]; }
        check len(fcs) > 0 { s = fcs[0]; }
        check len(fca) > 0 { an = fca[0]; }
    }
    fixed cop: i64 = tok_peek(tokens, p);
    check cop == OP_EQEQ || cop == OP_BANGEQ || cop == OP_LT || cop == OP_GT || cop == OP_LTEQ || cop == OP_GTEQ {
        p += 1;
        // v1.1.0: a bare u64 VARIABLE on the right selects unsigned ordering
        // (u64 calls/indexes already carry their type via rhsty below).
        check tok_peek(tokens, p) == TOK_IDENT && tok_peek(tokens, p + 1) != PUNCT_LPAREN && tok_peek(tokens, p + 1) != PUNCT_LBRACKET {
            check line_eq(lookup_var_type(allnames[an], var_names, var_types), "u64") == 1 { uns3 = 1; }
        }
        set rv: list<str> = list_new(); set rp: list<i64> = list_new(); set rs: list<i64> = list_new(); set ra: list<i64> = list_new(); set rty: list<str> = list_new();
        compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rv, rp, rs, ra, rty, var_names, var_types);
        check len(rp) > 0 { p = rp[0]; } check len(rs) > 0 { s = rs[0]; } check len(ra) > 0 { an = ra[0]; }
        set rhs: str = "0"; check len(rv) > 0 { rhs = rv[0]; }
        set rhsty: str = "ptr"; check len(rty) > 0 { rhsty = rty[0]; }
        set rhsi: str = rhs; check rhsty != "i64" { rhsi = coerce_i64(rhs, ir, ctr); }
        // v1.1.0: unsigned ordering when EITHER side is u64.
        check line_eq(rhsty, "u64") == 1 { uns3 = 1; }
        fixed cmp: str = make_tmp(ctr);
        set ctpred: str = "";
        check cop == OP_EQEQ  { ctpred = "eq "; }
        check cop == OP_BANGEQ { ctpred = "ne "; }
        check cop == OP_LT    { ctpred = "slt"; check uns3 == 1 { ctpred = "ult"; } }
        check cop == OP_GT    { ctpred = "sgt"; check uns3 == 1 { ctpred = "ugt"; } }
        check cop == OP_LTEQ  { ctpred = "sle"; check uns3 == 1 { ctpred = "ule"; } }
        check cop == OP_GTEQ  { ctpred = "sge"; check uns3 == 1 { ctpred = "uge"; } }
        emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", cmp), " = icmp "), ctpred), str_concat(" i64 ", cur)), str_concat(", ", rhsi)));
        push(out_val, cmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;
    }
    set ct_ty: str = "i64";
    check uns3 == 1 { ct_ty = "u64"; }
    push(out_val, cur); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, ct_ty);
}


// ── float arithmetic chain (isolated f64 path) ───────────────────────────────
// Mirrors fold_chain6/chain_tail but for f64: two precedence tiers (* / then
// + -) since modulo/bitwise/shift are undefined on floats. Entered only when a
// leading primary is float-typed; int operands inside the chain are promoted to
// double via sitofp, so e.g. `2.0 * count` works. The i64 chain is untouched.
df float_tier(op: i64) -> i64 {
    check op == OP_STAR || op == OP_SLASH { return 2; }
    check op == OP_PLUS || op == OP_MINUS { return 1; }
    return 0;
}

df float_emit_binop(op: i64, lhs: str, rhs: str, ir: list<str>, ctr: list<i64>) -> str {
    fixed res: str = make_tmp(ctr);
    fixed pre: str = str_concat(str_concat("  ", res), " = ");
    fixed tail: str = str_concat(lhs, str_concat(", ", rhs));
    check op == OP_PLUS  { emit(ir, str_concat(pre, str_concat("fadd double ", tail))); }
    check op == OP_MINUS { emit(ir, str_concat(pre, str_concat("fsub double ", tail))); }
    check op == OP_STAR  { emit(ir, str_concat(pre, str_concat("fmul double ", tail))); }
    check op == OP_SLASH { emit(ir, str_concat(pre, str_concat("fdiv double ", tail))); }
    return res;
}

// Coerce a (value,type) pair to an f64 SSA value. f64 passes through; i64 (and
// anything else, via ptrtoint) is promoted with sitofp.
df as_double(val: str, ty: str, ir: list<str>, ctr: list<i64>) -> str {
    check ty == "f64" { return val; }
    set iv: str = val;
    check ty != "i64" { iv = coerce_i64(val, ir, ctr); }
    fixed d: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat("  ", d), " = sitofp i64 "), str_concat(iv, " to double")));
    return d;
}

df fold_float_chain(tokens: list<i64>, strings: list<str>, allnames: list<str>, fcur_in: str, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, var_names: list<str>, var_types: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>) -> void {
    set fcur: str = fcur_in;
    set p: i64 = p_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    set opnd2: str = "0"; set op2: i64 = 0; set has2: i64 = 0;
    set opnd1: str = "0"; set op1: i64 = 0; set has1: i64 = 0;
    set more: i64 = 1;
    whilst more == 1 {
        fixed nop: i64 = tok_peek(tokens, p);
        fixed tier: i64 = float_tier(nop);
        check tier == 0 { more = 0; } fallback {
            // v1.1.0 operator edges: unary minus before a float-chain operand
            // (`x - -y`, `x * -1.5`). Same treatment as the i64 folder.
            set noff: i64 = 0;
            check tok_peek(tokens, p + 1) == OP_MINUS { noff = 1; }
            fixed nxp: i64 = tok_peek(tokens, p + 1 + noff);
            fixed nx2: i64 = tok_peek(tokens, p + 2 + noff);
            set ni: i64 = 0; check nxp == TOK_INT { ni = 1; }
            set nf: i64 = 0; check nxp == TOK_FLOAT { nf = 1; }
            set nxv: i64 = 0; check nxp == TOK_IDENT && nx2 != PUNCT_LPAREN && nx2 != PUNCT_LBRACKET { nxv = 1; }
            set nxcall: i64 = 0; check nxp == TOK_IDENT && nx2 == PUNCT_LPAREN { nxcall = 1; }
            set nxidx: i64 = 0; check nxp == TOK_IDENT && nx2 == PUNCT_LBRACKET { nxidx = 1; }
            set nxpar: i64 = 0; check nxp == PUNCT_LPAREN { nxpar = 1; }
            check ni == 0 && nf == 0 && nxv == 0 && nxcall == 0 && nxidx == 0 && nxpar == 0 { more = 0; } fallback {
                set operand_f: str = "0.0";
                set simple: i64 = 1;
                check nf == 1 {
                    fixed fv2: str = strings[s];
                    fixed ft2: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", ft2), " = fadd double 0.0, "), fv2));
                    operand_f = ft2; s += 1;
                }
                check ni == 1 {
                    fixed iv2: str = strings[s];
                    fixed itmp: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", itmp), " = add i64 0, "), iv2));
                    operand_f = as_double(itmp, "i64", ir, ctr); s += 1;
                }
                check nxv == 1 {
                    fixed vn2: str = allnames[an];
                    fixed vty2: str = lookup_var_type(vn2, var_names, var_types);
                    fixed vld: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  ", vld), " = load ptr, ptr %"), vn2), "_slot, align 8"));
                    fixed vbits: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", vbits), " = ptrtoint ptr "), str_concat(vld, " to i64")));
                    check line_eq(vty2, "f64") == 1 {
                        fixed vd: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat("  ", vd), " = bitcast i64 "), str_concat(vbits, " to double")));
                        operand_f = vd;
                    } fallback {
                        operand_f = as_double(vbits, "i64", ir, ctr);
                    }
                    an += 1;
                }
                check nxcall == 1 || nxidx == 1 || nxpar == 1 {
                    check len(ctr) > 1 { ctr[1] = 1; }
                    set ev: list<str> = list_new(); set ep: list<i64> = list_new(); set es: list<i64> = list_new(); set ea: list<i64> = list_new(); set ety: list<str> = list_new();
                    compile_expr(tokens, strings, allnames, p + 1 + noff, s, an, ir, ctr, gvals, gnames, ev, ep, es, ea, ety, var_names, var_types);
                    set evv: str = "0"; check len(ev) > 0 { evv = ev[0]; }
                    set evty: str = "ptr"; check len(ety) > 0 { evty = ety[0]; }
                    operand_f = as_double(evv, evty, ir, ctr);
                    check len(es) > 0 { s = es[0]; }
                    check len(ea) > 0 { an = ea[0]; }
                    check len(ep) > 0 { p = ep[0]; }
                    simple = 0;
                }
                check noff == 1 {
                    fixed fnegt: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat("  ", fnegt), " = fsub double 0.0, "), operand_f));
                    operand_f = fnegt;
                }
                check has2 == 1 { fcur = float_emit_binop(op2, opnd2, fcur, ir, ctr); has2 = 0; }
                check tier <= 1 && has1 == 1 { fcur = float_emit_binop(op1, opnd1, fcur, ir, ctr); has1 = 0; }
                check tier == 2 { opnd2 = fcur; op2 = nop; has2 = 1; }
                check tier == 1 { opnd1 = fcur; op1 = nop; has1 = 1; }
                fcur = operand_f;
                check simple == 1 { p += 2 + noff; }
            }
        }
    }
    check has2 == 1 { fcur = float_emit_binop(op2, opnd2, fcur, ir, ctr); has2 = 0; }
    check has1 == 1 { fcur = float_emit_binop(op1, opnd1, fcur, ir, ctr); has1 = 0; }
    push(out_val, fcur); push(out_pos, p); push(out_si, s); push(out_ani, an);
}

df chain_tail_f(tokens: list<i64>, strings: list<str>, allnames: list<str>, init_f64: str, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, var_names: list<str>, var_types: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>) -> void {
    set cur: str = init_f64;
    set p: i64 = p_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    check float_tier(tok_peek(tokens, p)) > 0 {
        set fcv: list<str> = list_new(); set fcp: list<i64> = list_new(); set fcs: list<i64> = list_new(); set fca: list<i64> = list_new();
        fold_float_chain(tokens, strings, allnames, cur, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, fcv, fcp, fcs, fca);
        check len(fcv) > 0 { cur = fcv[0]; }
        check len(fcp) > 0 { p = fcp[0]; }
        check len(fcs) > 0 { s = fcs[0]; }
        check len(fca) > 0 { an = fca[0]; }
    }
    fixed cop: i64 = tok_peek(tokens, p);
    check cop == OP_PERCENT || cop == OP_SHL || cop == OP_SHR || cop == OP_AMP || cop == OP_CARET || cop == OP_PIPE {
        emit_uerr(ir, p, "modulo/bitwise/shift operators are not defined on floats.");
    }
    check cop == OP_EQEQ || cop == OP_BANGEQ || cop == OP_LT || cop == OP_GT || cop == OP_LTEQ || cop == OP_GTEQ {
        p += 1;
        set rv: list<str> = list_new(); set rp: list<i64> = list_new(); set rs: list<i64> = list_new(); set ra: list<i64> = list_new(); set rty: list<str> = list_new();
        compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rv, rp, rs, ra, rty, var_names, var_types);
        check len(rp) > 0 { p = rp[0]; } check len(rs) > 0 { s = rs[0]; } check len(ra) > 0 { an = ra[0]; }
        set rhs: str = "0"; check len(rv) > 0 { rhs = rv[0]; }
        set rhsty: str = "ptr"; check len(rty) > 0 { rhsty = rty[0]; }
        fixed rhsf: str = as_double(rhs, rhsty, ir, ctr);
        fixed cmp: str = make_tmp(ctr);
        check cop == OP_EQEQ   { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp), " = fcmp oeq double "), cur), str_concat(", ", rhsf))); }
        check cop == OP_BANGEQ { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp), " = fcmp one double "), cur), str_concat(", ", rhsf))); }
        check cop == OP_LT     { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp), " = fcmp olt double "), cur), str_concat(", ", rhsf))); }
        check cop == OP_GT     { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp), " = fcmp ogt double "), cur), str_concat(", ", rhsf))); }
        check cop == OP_LTEQ   { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp), " = fcmp ole double "), cur), str_concat(", ", rhsf))); }
        check cop == OP_GTEQ   { emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cmp), " = fcmp oge double "), cur), str_concat(", ", rhsf))); }
        push(out_val, cmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;
    }
    push(out_val, cur); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "f64");
}


// True when a string literal contains real interpolation/escaping work: a brace
// escape ({{ or }}) or a '{' that opens an identifier. A lone '{' or the empty
// '{}' (used by fmt) are left untouched, so existing constants stay byte-identical.
df needs_interp(sv: str) -> i64 {
    fixed n: i64 = len(sv);
    set i: i64 = 0;
    whilst i < n {
        fixed c: i64 = byte_at(sv, i);
        check c == 123 {
            check i + 1 < n {
                fixed d: i64 = byte_at(sv, i + 1);
                check d == 123 { return 1; }
                check (d >= 65 && d <= 90) || (d >= 97 && d <= 122) || d == 95 { return 1; }
                // v1.1.3: an expression span may also open with a digit, a
                // unary minus, or a parenthesis ({2 + 3}, {-x}, {(a + b)}).
                // Previously these were treated as literal text - a SILENT
                // no-interpolation for a documented "full expression" form.
                check (d >= 48 && d <= 57) || d == 45 || d == 40 { return 1; }
            }
        }
        check c == 125 {
            check i + 1 < n && byte_at(sv, i + 1) == 125 { return 1; }
        }
        i += 1;
    }
    return 0;
}

// Build an interpolated string literal at runtime: literal chunks are interned
// constants, "{name}" spans load the variable and stringify it (any type), and
// {{ / }} collapse to single braces. An unknown variable emits a tv.undefvar
// marker so collect_undef_vars turns it into a clean located compile error.
df emit_interp(sv: str, p: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, var_names: list<str>, var_types: list<str>) -> str {
    fixed e0: str = intern_str("", gvals, gnames);
    set result: str = emit_str_ref(e0, "", ir, ctr);
    set lit: str = "";
    set i: i64 = 0;
    fixed n: i64 = len(sv);
    whilst i < n {
        fixed ch: i64 = byte_at(sv, i);
        check ch == 123 {
            check i + 1 < n && byte_at(sv, i + 1) == 123 { lit = str_concat(lit, "{"); i += 2; continue; }
            set d: i64 = 0;
            check i + 1 < n { d = byte_at(sv, i + 1); }
            set is_id: i64 = 0;
            check (d >= 65 && d <= 90) || (d >= 97 && d <= 122) || d == 95 { is_id = 1; }
            // v1.1.3: digit / unary-minus / parenthesis also open an expression
            // span, matching needs_interp (they can never be bare identifiers,
            // so they always take the expression path below).
            check (d >= 48 && d <= 57) || d == 45 || d == 40 { is_id = 1; }
            check is_id == 0 { lit = str_concat(lit, "{"); i += 1; continue; }
            // scan up to the matching '}', tracking nested () [] so a '}' inside
            // (e.g. a call arg) doesn't close the span early. Collect the raw text.
            set j: i64 = i + 1;
            set span: str = "";
            set depth: i64 = 0;
            set closed: i64 = 0;
            whilst j < n && closed == 0 {
                fixed cj: i64 = byte_at(sv, j);
                check cj == 40 || cj == 91 { depth += 1; }
                check cj == 41 || cj == 93 { depth -= 1; }
                check cj == 125 && depth <= 0 { closed = 1; j += 1; } fallback { span = str_concat(span, substr(sv, j, j + 1)); j += 1; }
            }
            // An unclosed '{' (reached end of string with no '}') is a malformed
            // interpolation — flag it as a located error rather than silently
            // interpolating whatever was collected.
            check closed == 0 {
                emit(ir, str_concat("  ; tv.unclosedinterp:", int_to_str(p)));
                i = n; continue;
            }
            // Is the span a bare identifier (fast path) or an expression?
            set is_bare: i64 = 1;
            set bi: i64 = 0;
            fixed slen: i64 = len(span);
            whilst bi < slen {
                fixed bc: i64 = byte_at(span, bi);
                set okc: i64 = 0;
                check (bc >= 65 && bc <= 90) || (bc >= 97 && bc <= 122) || bc == 95 { okc = 1; }
                check bc >= 48 && bc <= 57 && bi > 0 { okc = 1; }
                check okc == 0 { is_bare = 0; }
                bi += 1;
            }
            // flush pending literal text before the interpolated value
            check len(lit) > 0 {
                fixed gl: str = intern_str(lit, gvals, gnames);
                fixed lr: str = emit_str_ref(gl, lit, ir, ctr);
                fixed tc: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tc), " = call ptr @torvik_str_concat(ptr "), str_concat(result, ", ptr ")), str_concat(lr, ")")));
                result = tc; lit = "";
            }
            check is_bare == 1 {
                fixed vname: str = span;
                check slot_defined(ir, vname) == 0 {
                    emit(ir, str_concat(str_concat(str_concat("  ; tv.undefvar:", vname), ":"), int_to_str(p)));
                }
                check slot_defined(ir, vname) == 1 {
                    fixed ld: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  ", ld), " = load ptr, ptr %"), vname), "_slot, align 8"));
                    fixed dty: str = lookup_var_type(vname, var_names, var_types);
                    fixed sval: str = echo_stringify(ld, "ptr", dty, ir, ctr);
                    fixed tc2: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tc2), " = call ptr @torvik_str_concat(ptr "), str_concat(result, ", ptr ")), str_concat(sval, ")")));
                    result = tc2;
                }
            } fallback {
                // Expression interpolation (v1.1.0): lex the span into its own
                // token/string/name streams and compile it with compile_value. Bare
                // variables inside resolve to the SAME %NAME_slot as the enclosing
                // function (slots are name-keyed), so `{a + b}`, `{f(x)}`, `{xs[0]}`
                // all work. The result is stringified and appended.
                fixed etoks: list<i64> = lex_source(span);
                fixed estrs: list<str> = extract_strings(span, etoks);
                fixed enames: list<str> = extract_all_names(span);
                set spv: list<str> = list_new(); set spp: list<i64> = list_new(); set sps: list<i64> = list_new(); set spa: list<i64> = list_new(); set spty: list<str> = list_new();
                compile_value(etoks, estrs, enames, 0, 0, 0, ir, ctr, gvals, gnames, spv, spp, sps, spa, spty, var_names, var_types);
                set spval: str = "null"; check len(spv) > 0 { spval = spv[0]; }
                set spt: str = "ptr"; check len(spty) > 0 { spt = spty[0]; }
                fixed sps2: str = echo_stringify(spval, spt, spt, ir, ctr);
                fixed tc4: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tc4), " = call ptr @torvik_str_concat(ptr "), str_concat(result, ", ptr ")), str_concat(sps2, ")")));
                result = tc4;
            }
            i = j; continue;
        }
        check ch == 125 {
            check i + 1 < n && byte_at(sv, i + 1) == 125 { lit = str_concat(lit, "}"); i += 2; continue; }
            lit = str_concat(lit, "}"); i += 1; continue;
        }
        lit = str_concat(lit, substr(sv, i, i + 1)); i += 1;
    }
    check len(lit) > 0 {
        fixed gl2: str = intern_str(lit, gvals, gnames);
        fixed lr2: str = emit_str_ref(gl2, lit, ir, ctr);
        fixed tc3: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tc3), " = call ptr @torvik_str_concat(ptr "), str_concat(result, ", ptr ")), str_concat(lr2, ")")));
        result = tc3;
    }
    return result;
}

// Fold a '+' concatenation chain. `cur` is the already-compiled left operand (a
// string value); `pp_in` points at the first '+'. Each following operand is
// compiled with the chain suppressed so it consumes exactly one primary, then
// stringified (any type) and appended. Walks the chain by loop, keeping cursors
// in sync. Shared by the string-literal lead and the string-variable lead.
df emit_concat_chain(cur: str, pp_in: i64, s_in: i64, an_in: i64, tokens: list<i64>, strings: list<str>, allnames: list<str>, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, var_names: list<str>, var_types: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>) -> void {
    set acc: str = cur;
    set pp: i64 = pp_in;
    set s: i64 = s_in;
    set an: i64 = an_in;
    whilst tok_peek(tokens, pp) == OP_PLUS {
        set rhs_eff: str = "";
        check tok_peek(tokens, pp + 1) == TOK_IDENT {
            fixed nx: i64 = tok_peek(tokens, pp + 2);
            check nx == OP_PLUS || nx == PUNCT_RPAREN || nx == PUNCT_SEMI || nx == PUNCT_COMMA {
                rhs_eff = lookup_var_type(allnames[an], var_names, var_types);
            }
        }
        check len(ctr) > 1 { ctr[1] = 1; }
        set rv: list<str> = list_new();
        set rp: list<i64> = list_new();
        set rs: list<i64> = list_new();
        set ra: list<i64> = list_new();
        set rt: list<str> = list_new();
        compile_expr(tokens, strings, allnames, pp + 1, s, an, ir, ctr, gvals, gnames, rv, rp, rs, ra, rt, var_names, var_types);
        check len(rp) > 0 { pp = rp[0]; }
        check len(rs) > 0 { s = rs[0]; }
        check len(ra) > 0 { an = ra[0]; }
        set ev_eff: str = rt[0];
        check len(rhs_eff) > 0 { ev_eff = rhs_eff; }
        fixed osval: str = echo_stringify(rv[0], rt[0], ev_eff, ir, ctr);
        fixed cc: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat(str_concat("  ", cc), " = call ptr @torvik_str_concat(ptr "), str_concat(acc, ", ptr ")), str_concat(osval, ")")));
        acc = cc;
    }
    push(out_val, acc); push(out_pos, pp); push(out_si, s); push(out_ani, an); push(out_ty, "str");
}


df is_cmp_op(t: i64) -> i64 {
    check t == OP_EQEQ || t == OP_BANGEQ || t == OP_LT || t == OP_GT || t == OP_LTEQ || t == OP_GTEQ { return 1; }
    return 0;
}

// ── compile_cmp_tail (expression chaining, stage 2) ──────────────────────────
// Folds `LHS <cmp> RHS` for an already-compiled left operand of ANY shape:
// variable load, string literal, builtin/user call result, index read, or
// parenthesized value. The caller consumed the operator; p_in is the first RHS
// token. Strings compare by CONTENT via strcmp — == / != and lexicographic
// < <= > >= (byte order). A comparison is a string comparison when either side
// is known to be a string: the LHS class says "str", the RHS type says str,
// the RHS value is an interned literal, or the RHS's first token is a string
// literal. Mixing a definite numeric operand with a string is a clean compile
// error (previously: a silent pointer comparison, or a strcmp crash).
//
// lhs_ty is the SSA CLASS of lhs_val — "str" (a string ptr), "i64" (a real i64
// SSA value), or "ptr" (anything coerce_i64 can lower). lhs_num_hint = 1 means
// the operand is SEMANTICALLY numeric (e.g. an i64 variable loaded as ptr),
// which arms the mixed-type guard without changing the lowering. lhs_u64 picks
// unsigned ordering predicates. f64 and i128/u128 leads never come here —
// their dedicated paths fold their own comparisons.
df compile_cmp_tail(tokens: list<i64>, strings: list<str>, allnames: list<str>, lhs_val: str, lhs_ty: str, lhs_num_hint: i64, lhs_u64: i64, cmp_op: i64, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>, var_names: list<str>, var_types: list<str>) -> void {
    set p: i64 = p_in; set s: i64 = s_in; set an: i64 = an_in;
    fixed rhs_tok0: i64 = tok_peek(tokens, p);
    set rv: list<str> = list_new(); set rp: list<i64> = list_new(); set rs: list<i64> = list_new(); set ra: list<i64> = list_new(); set rty: list<str> = list_new();
    compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rv, rp, rs, ra, rty, var_names, var_types);
    check len(rp) > 0 { p = rp[0]; } check len(rs) > 0 { s = rs[0]; } check len(ra) > 0 { an = ra[0]; }
    set rhs: str = "0"; check len(rv) > 0 { rhs = rv[0]; }
    set rhs_ty: str = "ptr"; check len(rty) > 0 { rhs_ty = rty[0]; }

    set lhs_str: i64 = 0; check starts(lhs_ty, "str") { lhs_str = 1; }
    set rhs_str: i64 = 0;
    check line_eq(rhs_ty, "str") == 1 { rhs_str = 1; }
    check starts(rhs, "@.s") { rhs_str = 1; }
    check rhs_tok0 == TOK_STRING { rhs_str = 1; }

    check lhs_str == 1 || rhs_str == 1 {
        check lhs_str == 0 && lhs_num_hint == 1 {
            emit_uerr(ir, p_in, "can't compare a numeric value with a string - both sides of a string comparison must be strings. To compare against a number's text form, convert with tostr(...).");
        }
        check rhs_str == 0 {
            check line_eq(ty_kind(rhs_ty), "num") == 1 || line_eq(rhs_ty, "i1") == 1 {
                emit_uerr(ir, p_in, "can't compare a string with a numeric value - both sides of a string comparison must be strings. To compare against a number's text form, convert with tostr(...).");
            }
        }
        fixed scv: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat(str_concat("  ", scv), " = call i32 @strcmp(ptr "), lhs_val), str_concat(", ptr ", str_concat(rhs, ")"))));
        fixed scr: str = make_tmp(ctr);
        set scp: str = "eq ";
        check cmp_op == OP_BANGEQ { scp = "ne "; }
        check cmp_op == OP_LT     { scp = "slt"; }
        check cmp_op == OP_GT     { scp = "sgt"; }
        check cmp_op == OP_LTEQ   { scp = "sle"; }
        check cmp_op == OP_GTEQ   { scp = "sge"; }
        emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", scr), " = icmp "), scp), str_concat(" i32 ", scv)), ", 0"));
        push(out_val, scr); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1");
        return;
    }

    set lv: str = lhs_val;
    check line_eq(lhs_ty, "i64") == 1 { } fallback {
        // "ptr"/"str" are definitely ptr-shaped SSA — lower with a direct
        // ptrtoint (no IR scan). Narrow/uncertain classes go through
        // coerce_i64, whose defines_i64 scan handles already-i64 SSA values.
        check line_eq(lhs_ty, "ptr") == 1 || starts(lhs_ty, "str") {
            fixed lpt: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", lpt), " = ptrtoint ptr "), str_concat(lhs_val, " to i64")));
            lv = lpt;
        } fallback {
            lv = coerce_i64(lhs_val, ir, ctr);
        }
    }
    set rvi: str = rhs;
    check line_eq(rhs_ty, "i64") == 1 { } fallback {
        check line_eq(rhs_ty, "i1") == 1 {
            fixed rzx: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", rzx), " = zext i1 "), str_concat(rhs, " to i64")));
            rvi = rzx;
        } fallback {
            check line_eq(rhs_ty, "ptr") == 1 || line_eq(rhs_ty, "str") == 1 || starts(rhs_ty, "list") {
                fixed rpt: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", rpt), " = ptrtoint ptr "), str_concat(rhs, " to i64")));
                rvi = rpt;
            } fallback {
                rvi = coerce_i64(rhs, ir, ctr);
            }
        }
    }
    fixed ncr: str = make_tmp(ctr);
    // v1.1.0: unsigned ordering when EITHER side is u64 (not just the lead).
    set cuns: i64 = lhs_u64;
    check line_eq(rhs_ty, "u64") == 1 { cuns = 1; }
    check rhs_tok0 == TOK_IDENT && tok_peek(tokens, p_in + 1) != PUNCT_LPAREN && tok_peek(tokens, p_in + 1) != PUNCT_LBRACKET {
        check line_eq(lookup_var_type(allnames[an_in], var_names, var_types), "u64") == 1 { cuns = 1; }
    }
    set ncp: str = "eq ";
    check cmp_op == OP_BANGEQ { ncp = "ne "; }
    check cmp_op == OP_LT     { ncp = "slt"; check cuns == 1 { ncp = "ult"; } }
    check cmp_op == OP_GT     { ncp = "sgt"; check cuns == 1 { ncp = "ugt"; } }
    check cmp_op == OP_LTEQ   { ncp = "sle"; check cuns == 1 { ncp = "ule"; } }
    check cmp_op == OP_GTEQ   { ncp = "sge"; check cuns == 1 { ncp = "uge"; } }
    emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", ncr), " = icmp "), ncp), str_concat(" i64 ", lv)), str_concat(", ", rvi)));
    push(out_val, ncr); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1");
}

// finish_str_result: shared exit for every primary whose value is a string —
// folds a trailing comparison via compile_cmp_tail, unless this primary is a
// suppressed chain operand (the comparison then belongs to the enclosing
// chain's level, not to this operand).
df finish_str_result(tokens: list<i64>, strings: list<str>, allnames: list<str>, val: str, p: i64, s: i64, an: i64, suppress_chain: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>, var_names: list<str>, var_types: list<str>) -> void {
    fixed fnop: i64 = tok_peek(tokens, p);
    check suppress_chain == 0 && is_cmp_op(fnop) == 1 {
        compile_cmp_tail(tokens, strings, allnames, val, "str", 0, 0, fnop, p + 1, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
        return;
    }
    check suppress_chain == 0 && fnop == OP_BOUND {
        compile_bound_tail(tokens, strings, allnames, val, 1, 0, p + 1, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
        return;
    }
    check suppress_chain == 0 && fnop == OP_WEAVE {
        compile_weave_tail(tokens, strings, allnames, val, "str", p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
        return;
    }
    push(out_val, val); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "str");
}

// ── compile_bound_tail (operator edges, v1.1.0) ──────────────────────────────
// Folds `LHS <| COLLECTION` for an already-compiled left operand of any shape
// (variable, literal, call result, index read). Dispatch is by the collection's
// ELEMENT type when it is a bare, annotated list variable: list<str> searches by
// CONTENT (strcmp); every other element type compares by i64 value. When the
// element type is unknown (the collection is a call result), the item's own
// string-ness decides. A definite item/element type mismatch is a clean error.
df compile_bound_tail(tokens: list<i64>, strings: list<str>, allnames: list<str>, lhs_val: str, lhs_is_str: i64, lhs_num_hint: i64, p_in: i64, s_in: i64, an_in: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>, var_names: list<str>, var_types: list<str>) -> void {
    set p: i64 = p_in; set s: i64 = s_in; set an: i64 = an_in;
    // A bare list variable on the right: validate + learn the element type.
    set relem: str = "";
    check tok_peek(tokens, p) == TOK_IDENT && tok_peek(tokens, p + 1) != PUNCT_LPAREN && tok_peek(tokens, p + 1) != PUNCT_LBRACKET {
        fixed bcn: str = allnames[an];
        fixed bct: str = lookup_var_type(bcn, var_names, var_types);
        check len(bct) > 0 {
            check starts(bct, "list") { relem = list_elem_type(bct); } fallback {
                check starts(bct, "fnret:") { } fallback {
                    emit_uerr(ir, p, str_concat(str_concat("the right side of `<|` (membership) must be a list, but `", bcn), "` is not a list. Put a list<T> on the right of `<|` - for a bag, use bag_has instead"));
                }
            }
        }
    }
    set rvb: list<str> = list_new(); set rpb: list<i64> = list_new(); set rsb: list<i64> = list_new(); set rsb_ai: list<i64> = list_new(); set rsb_ty: list<str> = list_new();
    compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rvb, rpb, rsb, rsb_ai, rsb_ty, var_names, var_types);
    check len(rpb) > 0 { p = rpb[0]; }
    check len(rsb) > 0 { s = rsb[0]; }
    check len(rsb_ai) > 0 { an = rsb_ai[0]; }
    set bcoll: str = "null"; check len(rvb) > 0 { bcoll = rvb[0]; }
    set use_str: i64 = 0;
    check line_eq(relem, "str") == 1 { use_str = 1; }
    check len(relem) == 0 { check lhs_is_str == 1 { use_str = 1; } }
    check use_str == 1 && lhs_num_hint == 1 {
        emit_uerr(ir, p_in, "`<|` item/list type mismatch - the item is numeric but the list holds strings.");
    }
    check lhs_is_str == 1 && len(relem) > 0 {
        check line_eq(relem, "str") == 0 {
            emit_uerr(ir, p_in, fmt("`<|` item/list type mismatch - the item is a string but the list holds {} elements.", relem));
        }
    }
    fixed bres: str = make_tmp(ctr);
    check use_str == 1 {
        emit(ir, fmt("  {} = call i64 @torvik_list_contains_str(ptr {}, ptr {})", bres, bcoll, lhs_val));
    } fallback {
        fixed bitem_i: str = coerce_i64(lhs_val, ir, ctr);
        emit(ir, fmt("  {} = call i64 @torvik_list_contains(ptr {}, i64 {})", bres, bcoll, bitem_i));
    }
    fixed bcmp: str = make_tmp(ctr);
    emit(ir, str_concat(str_concat(str_concat("  ", bcmp), " = icmp ne i64 "), str_concat(bres, ", 0")));
    push(out_val, bcmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1");
}

// ── compile_weave_tail (operator edges, v1.1.0) ──────────────────────────────
// Folds `LHS ~> f ~> g` for an already-compiled left operand of any shape:
// g(f(LHS)). p_in points AT the first `~>`. Tracks the result type through the
// weave (the str builtins and fnret:str user functions yield "str") so a
// trailing comparison folds with content semantics: `s ~> trim == "x"`.
// v1.1.3: kind check for the value entering a weave stage. An unknown incoming
// type ("ptr"/"") skips the check; a definite str-vs-numeric mismatch is a
// clean compile error instead of a run-time crash or garbage (`5 ~> shout`
// where shout takes str previously segfaulted).
df weave_stage_type_check(win_ty: str, want_ty: str, wbf: str, ir: list<str>, wbf_pos: i64) -> void {
    check line_eq(win_ty, "ptr") == 1 || len(win_ty) == 0 { return; }
    set ik: str = ty_kind(win_ty);
    check line_eq(win_ty, "i1") == 1 || line_eq(win_ty, "bool") == 1 { ik = "num"; }
    set wk: str = ty_kind(want_ty);
    check line_eq(want_ty, "i1") == 1 || line_eq(want_ty, "bool") == 1 { wk = "num"; }
    check line_eq(ik, "other") == 1 || line_eq(wk, "other") == 1 { return; }
    check line_eq(ik, wk) == 0 {
        emit_uerr(ir, wbf_pos, fmt("weave stage '{}' takes {} here, but the woven value is {} - keep the woven value's type matched to the stage's first parameter.", wbf, want_ty, win_ty));
    }
}

df compile_weave_tail(tokens: list<i64>, strings: list<str>, allnames: list<str>, lhs_val: str, lead_ty: str, p_in: i64, s_in: i64, an_in: i64, suppress_chain: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>, var_names: list<str>, var_types: list<str>) -> void {
    set p: i64 = p_in; set s: i64 = s_in; set an: i64 = an_in;
    set wbv: str = lhs_val;
    set wb_ty: str = "ptr";
    // The type of the value ENTERING the current stage: the caller-supplied
    // lead type for stage one, then each stage's return type for the next.
    set win_ty: str = lead_ty;
    set wbg: i64 = 1;
    whilst wbg == 1 {
        check tok_peek(tokens, p) != OP_WEAVE { wbg = 0; } fallback {
            p += 1;
            check tok_peek(tokens, p) == TOK_IDENT {
                fixed wbf_pos: i64 = p;
                fixed wbf: str = allnames[an]; an += 1; p += 1;
                // v1.1.0: argument-insertion form — `x ~> f(a, b)` means f(x, a, b).
                check tok_peek(tokens, p) == PUNCT_LPAREN {
                    p += 1;
                    set wargs: list<str> = list_new();
                    set wargs_ty: list<str> = list_new();
                    whilst tok_peek(tokens, p) != PUNCT_RPAREN && tok_peek(tokens, p) != TOK_EOF && tok_peek(tokens, p) != PUNCT_SEMI && tok_peek(tokens, p) != PUNCT_RBRACE {
                        set wrv: list<str> = list_new(); set wrp: list<i64> = list_new(); set wrs: list<i64> = list_new(); set wra: list<i64> = list_new(); set wrty: list<str> = list_new();
                        compile_value(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, wrv, wrp, wrs, wra, wrty, var_names, var_types);
                        check len(wrv) > 0 { push(wargs, wrv[0]); }
                        check len(wrty) > 0 { push(wargs_ty, wrty[0]); } fallback { push(wargs_ty, "ptr"); }
                        check len(wrp) > 0 { p = wrp[0]; }
                        check len(wrs) > 0 { s = wrs[0]; }
                        check len(wra) > 0 { an = wra[0]; }
                        check tok_peek(tokens, p) == PUNCT_COMMA { p += 1; }
                    }
                    check tok_peek(tokens, p) == PUNCT_RPAREN { p += 1; } fallback {
                        emit_uerr(ir, wbf_pos, fmt("expected ')' to close the weave arguments of '{}' (a '(' is unclosed).", wbf));
                    }
                    check wbf == "trim" || wbf == "triml" || wbf == "trimr" || wbf == "upper" || wbf == "lower" {
                        emit_uerr(ir, wbf_pos, fmt("'{}' takes no weave arguments - write `x ~> {}` without parentheses.", wbf, wbf));
                    }
                    set whandled: i64 = 0;
                    check wbf == "replace" {
                        check len(wargs) >= 2 { } fallback {
                            emit_uerr(ir, wbf_pos, "`~> replace(...)` needs two arguments: `x ~> replace(from, to)`.");
                        }
                        fixed wrr: str = make_tmp(ctr);
                        // Bind-first: pre-fix compilers garble list elements passed
                        // straight to fmt (the fmt/index bug fixed in this version).
                        fixed wra0: str = wargs[0];
                        fixed wra1: str = wargs[1];
                        weave_stage_type_check(win_ty, "str", wbf, ir, wbf_pos);  // v1.1.3
                        emit(ir, fmt("  {} = call ptr @torvik_replace(ptr {}, ptr {}, ptr {})", wrr, wbv, wra0, wra1));
                        wbv = wrr; wb_ty = "str"; win_ty = "str"; whandled = 1;
                    }
                    check whandled == 0 && wbf == "substr" {
                        check len(wargs) >= 2 { } fallback {
                            emit_uerr(ir, wbf_pos, "`~> substr(...)` needs two arguments: `x ~> substr(start, end)`.");
                        }
                        set wsa: str = wargs[0];
                        check line_eq(wargs_ty[0], "i64") == 1 { } fallback { wsa = coerce_i64(wargs[0], ir, ctr); }
                        set wsb: str = wargs[1];
                        check line_eq(wargs_ty[1], "i64") == 1 { } fallback { wsb = coerce_i64(wargs[1], ir, ctr); }
                        fixed wsr: str = make_tmp(ctr);
                        weave_stage_type_check(win_ty, "str", wbf, ir, wbf_pos);  // v1.1.3
                        emit(ir, fmt("  {} = call ptr @torvik_substr(ptr {}, i64 {}, i64 {})", wsr, wbv, wsa, wsb));
                        wbv = wsr; wb_ty = "str"; whandled = 1;
                    }
                    check whandled == 0 {
                        // A user-defined function: insert the woven value as the first
                        // argument, then pass the given arguments with the standard
                        // per-type call convention. Arity checks count the insertion.
                        fixed _wfa: str = lookup_var_type(wbf, var_names, var_types);
                        check starts(_wfa, "fnret:") { } fallback {
                            emit_uerr(ir, wbf_pos, fmt("'{}' is not a user-defined function - weave arguments work with user functions plus replace(from, to) and substr(start, end). For other builtins, wrap the call in a small helper function.", wbf));
                        }
                        fixed wf_ptypes: list<str> = split_words(lookup_var_type(str_concat("@p@", wbf), var_names, var_types));
                        // Bind-first shape: the PREVIOUS generation's compiler must
                        // compile this file, and pre-fix binaries mis-fold
                        // `len(a) + 1 != len(b)` (the greedy len-arith bug fixed in
                        // this very version). Keep the conservative form here.
                        fixed wf_have: i64 = len(wargs) + 1;
                        check wf_have != len(wf_ptypes) {
                            emit_uerr(ir, wbf_pos, fmt("function '{}' expects {} argument(s), and a weave inserts the woven value as the first - so `x ~> {}(...)` needs {} more.", wbf, len(wf_ptypes), wbf, len(wf_ptypes) - 1));
                        }
                        // v1.1.3: the woven value's kind must match the stage's
                        // first parameter when both are definite.
                        check len(wf_ptypes) > 0 {
                            weave_stage_type_check(win_ty, wf_ptypes[0], wbf, ir, wbf_pos);
                        }
                        set wcall: str = str_concat("ptr ", wbv);
                        set wgi: i64 = 0;
                        whilst wgi < len(wargs) {
                            wcall = str_concat(wcall, ", ");
                            fixed wga_ty: str = wargs_ty[wgi];
                            check wga_ty == "i1" || wga_ty == "i64" || wga_ty == "bool" {
                                wcall = str_concat(wcall, str_concat("i64 ", wargs[wgi]));
                            }
                            check wga_ty == "f64" {
                                fixed wgb: str = make_tmp(ctr);
                                emit(ir, str_concat(str_concat(str_concat("  ", wgb), " = bitcast double "), str_concat(wargs[wgi], " to i64")));
                                fixed wgp: str = make_tmp(ctr);
                                emit(ir, str_concat(str_concat(str_concat("  ", wgp), " = inttoptr i64 "), str_concat(wgb, " to ptr")));
                                wcall = str_concat(wcall, str_concat("ptr ", wgp));
                            }
                            check wga_ty != "i1" && wga_ty != "i64" && wga_ty != "f64" {
                                wcall = str_concat(wcall, str_concat("ptr ", wargs[wgi]));
                            }
                            wgi += 1;
                        }
                        fixed wur: str = make_tmp(ctr);
                        emit(ir, str_concat(str_concat(str_concat(str_concat("  ", wur), " = call ptr @"), wbf), str_concat("(", str_concat(wcall, ")"))));
                        wbv = wur;
                        // v1.1.3: carry the stage's FULL return type (not just
                        // str-or-ptr) so the tail below can type the result -
                        // previously an integer-returning weave inside echo!()
                        // was stringified as a str pointer and crashed.
                        wb_ty = "ptr";
                        check starts(_wfa, "fnret:") { wb_ty = substr(_wfa, 6, len(_wfa)); }
                        win_ty = wb_ty;
                    }
                } fallback {
                    set wbsym: str = wbf;
                    check wbf == "trim"  { wbsym = "torvik_trim"; }
                    check wbf == "triml" { wbsym = "torvik_triml"; }
                    check wbf == "trimr" { wbsym = "torvik_trimr"; }
                    check wbf == "upper" { wbsym = "torvik_upper"; }
                    check wbf == "lower" { wbsym = "torvik_lower"; }
                    check wbsym == wbf {
                        // Not a weave builtin — must be a user-defined function.
                        fixed _wft: str = lookup_var_type(wbf, var_names, var_types);
                        fixed _wisfn: bool = starts(_wft, "fnret:");
                        check _wisfn { } fallback {
                            emit(ir, str_concat(str_concat(str_concat("  ; tv.undeffn:", wbf), ":"), int_to_str(wbf_pos)));
                        }
                        // v1.1.3: arity is checked on the BARE stage form too -
                        // `5 ~> addn` where addn takes two arguments previously
                        // compiled and called addn with one, leaving the second
                        // parameter as garbage (a silent wrong answer).
                        check _wisfn {
                            fixed _wbp: list<str> = split_words(lookup_var_type(str_concat("@p@", wbf), var_names, var_types));
                            check len(_wbp) != 1 {
                                emit_uerr(ir, wbf_pos, fmt("function '{wbf}' expects more than the woven value - a bare weave stage passes exactly one argument. Write the missing ones explicitly: `x ~> {wbf}(...)`."));
                            }
                            // v1.1.3: the woven value's kind must match the
                            // stage's (single) parameter when both are definite.
                            check len(_wbp) > 0 {
                                weave_stage_type_check(win_ty, _wbp[0], wbf, ir, wbf_pos);
                            }
                        }
                        // v1.1.3: carry the stage's FULL return type (see the
                        // argument form above) so the tail can type the result.
                        wb_ty = "ptr";
                        check starts(_wft, "fnret:") { wb_ty = substr(_wft, 6, len(_wft)); }
                    } fallback {
                        // Builtin bare stages (trim/upper/lower/...) all take str.
                        weave_stage_type_check(win_ty, "str", wbf, ir, wbf_pos);
                        wb_ty = "str";
                    }
                    fixed wbr: str = make_tmp(ctr);
                    emit(ir, str_concat(str_concat(str_concat(str_concat("  ", wbr), " = call ptr @"), wbsym), str_concat("(ptr ", str_concat(wbv, ")"))));
                    wbv = wbr;
                    win_ty = wb_ty;
                }
            } fallback { wbg = 0; }
        }
    }
    // v1.1.3: materialize the final stage's TYPED value. User-function calls
    // return a uniform ptr; recover the declared return type so echo, chains,
    // declarations, and comparisons all see a first-class typed result.
    // (Previously only str was recovered; an integer-returning weave inside
    // echo!() was printed as a string pointer - a crash.)
    set wres: str = wbv;
    set wres_ty: str = wb_ty;
    set w_u64: i64 = 0;
    check line_eq(wb_ty, "u64") == 1 { w_u64 = 1; }
    check int_width(wb_ty) > 0 && line_eq(wb_ty, "i128") == 0 && line_eq(wb_ty, "u128") == 0 {
        wres = coerce_i64(wbv, ir, ctr);
    }
    check line_eq(wb_ty, "f64") == 1 {
        fixed wfb: str = coerce_i64(wbv, ir, ctr);
        fixed wfd: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", wfd), " = bitcast i64 "), str_concat(wfb, " to double")));
        wres = wfd;
    }
    check line_eq(wb_ty, "bool") == 1 {
        fixed wbi: str = coerce_i64(wbv, ir, ctr);
        fixed wbb: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", wbb), " = icmp ne i64 "), str_concat(wbi, ", 0")));
        wres = wbb; wres_ty = "i1";
    }
    fixed wnop: i64 = tok_peek(tokens, p);
    check suppress_chain == 0 && is_cmp_op(wnop) == 1 {
        set wcl: str = "ptr"; check line_eq(wb_ty, "str") == 1 { wcl = "str"; }
        set wch: i64 = 0;
        check int_width(wb_ty) > 0 || line_eq(wb_ty, "f64") == 1 { wch = 1; wcl = "i64"; }
        check line_eq(wb_ty, "f64") == 1 {
            // compare in the float domain: recover both sides via cmp on i64
            // bits is wrong; keep the simple path - bind-first for float weave
            // comparisons stays documented. Fall back to the ptr class.
            wch = 0; wcl = "ptr";
        }
        check wch == 1 {
            compile_cmp_tail(tokens, strings, allnames, wres, "i64", 1, w_u64, wnop, p + 1, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
            return;
        }
        compile_cmp_tail(tokens, strings, allnames, wbv, wcl, 0, 0, wnop, p + 1, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
        return;
    }
    push(out_val, wres); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, wres_ty);
}

df compile_expr(tokens: list<i64>, strings: list<str>, allnames: list<str>, pos: i64, si: i64, ani: i64, ir: list<str>, ctr: list<i64>, gvals: list<str>, gnames: list<str>, out_val: list<str>, out_pos: list<i64>, out_si: list<i64>, out_ani: list<i64>, out_ty: list<str>, var_names: list<str>, var_types: list<str>) -> void {
    fixed t: i64 = tok_peek(tokens, pos);
    set p: i64 = pos;
    set s: i64 = si;
    set an: i64 = ani;
    // Chain-suppression (stage 2): fold_chain6 sets ctr[1]=1 before evaluating a
    // call/index/paren *operand*, so that primary resolves to itself WITHOUT
    // folding the surrounding chain (otherwise `a * f(x) + 1` would over-consume
    // `f(x) + 1` and break precedence). We capture it and clear immediately, so
    // it applies only to THIS leading primary — nested arguments chain normally.
    set suppress_chain: i64 = 0;
    check len(ctr) > 1 { suppress_chain = ctr[1]; ctr[1] = 0; }

    // ── Unary prefix (leading position only): !x logical-not, -x negate ──
    // Fires only when ! or - is the FIRST token of this expression. Binary
    // subtraction never reaches here (it follows a value, handled by the chain).
    check t == OP_BANG {
        set uv: list<str> = list_new(); set up2: list<i64> = list_new(); set us: list<i64> = list_new(); set us_ai: list<i64> = list_new(); set uty: list<str> = list_new();
        compile_expr(tokens, strings, allnames, p + 1, s, an, ir, ctr, gvals, gnames, uv, up2, us, us_ai, uty, var_names, var_types);
        check len(up2) > 0 { p = up2[0]; }
        check len(us) > 0 { s = us[0]; }
        check len(us_ai) > 0 { an = us_ai[0]; }
        set uval: str = "0"; check len(uv) > 0 { uval = uv[0]; }
        set uvty: str = "ptr"; check len(uty) > 0 { uvty = uty[0]; }
        set uvi: str = uval;
        check uvty == "i1" {
            fixed uzx: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", uzx), " = zext i1 "), str_concat(uval, " to i64")));
            uvi = uzx;
        } fallback {
            check uvty != "i64" { uvi = coerce_i64(uval, ir, ctr); }
        }
        fixed ures: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", ures), " = icmp eq i64 "), str_concat(uvi, ", 0")));
        push(out_val, ures); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;
    }
    check t == OP_MINUS {
        // v1.1.3: a LEADING unary minus consumes exactly ONE primary (unary
        // minus binds tighter than every binary operator), negates it
        // TYPE-AWARE, then lets the ordinary chain fold whatever follows with
        // the negated value as the lead. Previously this handler compiled the
        // ENTIRE following expression and negated the result (`-5 + 2` gave
        // -7, not -3 - a silent wrong answer), and it coerced every operand
        // to i64 (an f64 operand hit ptrtoint-on-double = invalid IR; an
        // i128/u128 box or str had its POINTER negated = garbage/segfault).
        fixed neg_pos: i64 = p;
        // Plain-VARIABLE operand: negate the single variable directly, then let
        // the ordinary chain fold the tail with the negated value as the lead.
        // The generic one-primary recursion below can't serve this shape: a
        // bare-variable lead folds its own following chain regardless of the
        // suppression flag (that leniency is what `"a" + n * 2` relies on), so
        // recursing on `-m + 2` would wrongly compute -(m + 2).
        check tok_peek(tokens, p + 1) == TOK_IDENT && tok_peek(tokens, p + 2) != PUNCT_LPAREN && tok_peek(tokens, p + 2) != PUNCT_LBRACKET {
            fixed nvn: str = allnames[an];
            check slot_defined(ir, nvn) == 0 {
                emit(ir, str_concat(str_concat(str_concat("  ; tv.undefvar:", nvn), ":"), int_to_str(p + 1)));
            }
            an += 1;
            p += 2;                          // consume '-' and the identifier
            fixed after_nv: i64 = tok_peek(tokens, p);
            fixed nvld: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat(str_concat("  ", nvld), " = load ptr, ptr %"), nvn), "_slot, align 8"));
            fixed nvdt: str = lookup_var_type(nvn, var_names, var_types);
            check line_eq(nvdt, "f64") == 1 {
                fixed nfb: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", nfb), " = ptrtoint ptr "), str_concat(nvld, " to i64")));
                fixed nfd: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", nfd), " = bitcast i64 "), str_concat(nfb, " to double")));
                fixed nfr: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", nfr), " = fsub double 0.0, "), nfd));
                check suppress_chain == 0 {
                    chain_tail_f(tokens, strings, allnames, nfr, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
                    return;
                }
                push(out_val, nfr); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "f64"); return;
            }
            check line_eq(nvdt, "i128") == 1 {
                fixed nvv: str = i128_load_ir(nvld, ir, ctr);
                fixed nvr: str = make_tmp(ctr);
                emit(ir, str_concat(str_concat(str_concat("  ", nvr), " = sub i128 0, "), nvv));
                fixed nvb: str = i128_box_ir(nvr, ir, ctr);
                push(out_val, nvb); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i128"); return;
            }
            check line_eq(nvdt, "u128") == 1 {
                emit_uerr(ir, neg_pos, "can't negate a u128 value - an unsigned type has no negative values. Use i128 if the value can be negative.");
                push(out_val, "0"); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
            }
            check starts(nvdt, "str") || starts(nvdt, "list") || line_eq(nvdt, "table") == 1 || line_eq(nvdt, "bag") == 1 {
                emit_uerr(ir, neg_pos, fmt("can't negate a value of type {nvdt} - unary '-' applies to numeric values only."));
                push(out_val, "0"); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
            }
            fixed nvvi: str = coerce_i64(nvld, ir, ctr);
            fixed nvres: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", nvres), " = sub i64 0, "), nvvi));
            check suppress_chain == 0 && (chain_tier6(after_nv) > 0 || is_cmp_op(after_nv) == 1) {
                set nvuns: i64 = 0;
                check line_eq(nvdt, "u64") == 1 { nvuns = 1; }
                chain_tail(tokens, strings, allnames, nvres, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, nvuns);
                return;
            }
            push(out_val, nvres); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
        }
        check len(ctr) > 1 { ctr[1] = 1; }
        set nv: list<str> = list_new(); set np2: list<i64> = list_new(); set ns: list<i64> = list_new(); set ns_ai: list<i64> = list_new(); set nty: list<str> = list_new();
        compile_expr(tokens, strings, allnames, p + 1, s, an, ir, ctr, gvals, gnames, nv, np2, ns, ns_ai, nty, var_names, var_types);
        check len(np2) > 0 { p = np2[0]; }
        check len(ns) > 0 { s = ns[0]; }
        check len(ns_ai) > 0 { an = ns_ai[0]; }
        set nval: str = "0"; check len(nv) > 0 { nval = nv[0]; }
        set nvty: str = "ptr"; check len(nty) > 0 { nvty = nty[0]; }
        fixed after_neg: i64 = tok_peek(tokens, p);
        // Float operand: fsub double, then the f64 chain folds the tail.
        check line_eq(nvty, "f64") == 1 {
            fixed nfres: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", nfres), " = fsub double 0.0, "), nval));
            check suppress_chain == 0 {
                chain_tail_f(tokens, strings, allnames, nfres, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
                return;
            }
            push(out_val, nfres); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "f64"); return;
        }
        // 128-bit operand: unbox, negate in native i128, re-box. Negating a
        // u128 is a clean error (an unsigned value has no negative).
        check line_eq(nvty, "i128") == 1 {
            fixed n128v: str = i128_load_ir(nval, ir, ctr);
            fixed n128r: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", n128r), " = sub i128 0, "), n128v));
            fixed n128b: str = i128_box_ir(n128r, ir, ctr);
            push(out_val, n128b); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i128"); return;
        }
        check line_eq(nvty, "u128") == 1 {
            emit_uerr(ir, neg_pos, "can't negate a u128 value - an unsigned type has no negative values. Use i128 if the value can be negative.");
            push(out_val, "0"); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
        }
        // Non-numeric operands: a clean error instead of negating a pointer.
        check line_eq(nvty, "str") == 1 || starts(nvty, "list") || line_eq(nvty, "table") == 1 || line_eq(nvty, "bag") == 1 {
            emit_uerr(ir, neg_pos, fmt("can't negate a value of type {nvty} - unary '-' applies to numeric values only."));
            push(out_val, "0"); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
        }
        check line_eq(nvty, "i1") == 1 {
            emit_uerr(ir, neg_pos, "can't negate a bool with '-' - use '!' to negate a boolean.");
            push(out_val, "0"); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;
        }
        // Integer operand (i64 SSA, or the uniform ptr an integer variable
        // decays to): negate in i64, then the integer chain folds the tail.
        set nvi: str = nval;
        check line_eq(nvty, "i64") == 1 { } fallback { nvi = coerce_i64(nval, ir, ctr); }
        fixed nres: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", nres), " = sub i64 0, "), nvi));
        check suppress_chain == 0 && (chain_tier6(after_neg) > 0 || is_cmp_op(after_neg) == 1) {
            chain_tail(tokens, strings, allnames, nres, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0);
            return;
        }
        push(out_val, nres); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
    }
    // v1.1.3: leading unary `~` (bitwise NOT). Documented in the operator
    // table since v1.0 but previously unhandled - `echo!(~0)` was a parse
    // error. Integer domain only; consumes exactly ONE primary (a plain
    // variable directly, anything else via the suppressed recursion), then
    // the ordinary chain folds the tail with the NOT-ed value as the lead.
    check t == OP_TILDE {
        fixed not_pos: i64 = p;
        check tok_peek(tokens, p + 1) == TOK_IDENT && tok_peek(tokens, p + 2) != PUNCT_LPAREN && tok_peek(tokens, p + 2) != PUNCT_LBRACKET {
            fixed tvn: str = allnames[an];
            check slot_defined(ir, tvn) == 0 {
                emit(ir, str_concat(str_concat(str_concat("  ; tv.undefvar:", tvn), ":"), int_to_str(p + 1)));
            }
            an += 1;
            p += 2;
            fixed after_tv: i64 = tok_peek(tokens, p);
            fixed tvdt: str = lookup_var_type(tvn, var_names, var_types);
            check line_eq(tvdt, "f64") == 1 || line_eq(tvdt, "i128") == 1 || line_eq(tvdt, "u128") == 1 || starts(tvdt, "str") || starts(tvdt, "list") || line_eq(tvdt, "table") == 1 || line_eq(tvdt, "bag") == 1 || line_eq(tvdt, "bool") == 1 {
                emit_uerr(ir, not_pos, fmt("bitwise '~' applies to integer values only - can't apply it to a value of type {tvdt}."));
                push(out_val, "0"); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
            }
            fixed tvld: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat(str_concat("  ", tvld), " = load ptr, ptr %"), tvn), "_slot, align 8"));
            fixed tvi: str = coerce_i64(tvld, ir, ctr);
            fixed tvres: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", tvres), " = xor i64 "), str_concat(tvi, ", -1")));
            check suppress_chain == 0 && (chain_tier6(after_tv) > 0 || is_cmp_op(after_tv) == 1) {
                chain_tail(tokens, strings, allnames, tvres, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0);
                return;
            }
            push(out_val, tvres); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
        }
        check len(ctr) > 1 { ctr[1] = 1; }
        set tv2: list<str> = list_new(); set tp2: list<i64> = list_new(); set ts2: list<i64> = list_new(); set ta2: list<i64> = list_new(); set tty2: list<str> = list_new();
        compile_expr(tokens, strings, allnames, p + 1, s, an, ir, ctr, gvals, gnames, tv2, tp2, ts2, ta2, tty2, var_names, var_types);
        check len(tp2) > 0 { p = tp2[0]; }
        check len(ts2) > 0 { s = ts2[0]; }
        check len(ta2) > 0 { an = ta2[0]; }
        set tval: str = "0"; check len(tv2) > 0 { tval = tv2[0]; }
        set tvty: str = "ptr"; check len(tty2) > 0 { tvty = tty2[0]; }
        fixed after_t2: i64 = tok_peek(tokens, p);
        check line_eq(tvty, "f64") == 1 || line_eq(tvty, "i128") == 1 || line_eq(tvty, "u128") == 1 || line_eq(tvty, "str") == 1 || starts(tvty, "list") || line_eq(tvty, "i1") == 1 || line_eq(tvty, "bool") == 1 {
            emit_uerr(ir, not_pos, fmt("bitwise '~' applies to integer values only - can't apply it to a value of type {tvty}."));
            push(out_val, "0"); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
        }
        set t2i: str = tval;
        check line_eq(tvty, "i64") == 1 { } fallback { t2i = coerce_i64(tval, ir, ctr); }
        fixed t2res: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", t2res), " = xor i64 "), str_concat(t2i, ", -1")));
        check suppress_chain == 0 && (chain_tier6(after_t2) > 0 || is_cmp_op(after_t2) == 1) {
            chain_tail(tokens, strings, allnames, t2res, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0);
            return;
        }
        push(out_val, t2res); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return;
    }

    // String literal — advance an to keep allnames in sync (strings are in allnames too)
    check t == TOK_STRING {
        fixed sv: str = strings[s];
        s += 1;
        an += 1;  // allnames has an entry for this string literal
        set val: str = "";
        set vty: str = "str";
        check needs_interp(sv) == 1 {
            val = emit_interp(sv, p, ir, ctr, gvals, gnames, var_names, var_types); vty = "str";
        } fallback {
            fixed gn: str = intern_str(sv, gvals, gnames);
            val = emit_str_ref(gn, sv, ir, ctr);
        }
        // '+' concatenation: a string/char/interpolated literal on the left folds
        // each following operand and appends it, stringifying any value type. Each
        // operand is compiled with the chain suppressed (ctr[1]=1) so it consumes
        // exactly one primary — the loop, not recursion, walks the '+' chain. This
        // keeps cursors in sync even for `"a " + n + " b"` (a var mid-chain).
        check suppress_chain == 0 && tok_peek(tokens, p + 1) == OP_PLUS {
            emit_concat_chain(val, p + 1, s, an, tokens, strings, allnames, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
            return;
        }
        // Stage 2: a string literal may lead a comparison (`"a" == x`,
        // `"abc" < name`) — content compare via the shared tail.
        check suppress_chain == 0 && is_cmp_op(tok_peek(tokens, p + 1)) == 1 {
            compile_cmp_tail(tokens, strings, allnames, val, "str", 0, 0, tok_peek(tokens, p + 1), p + 2, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
            return;
        }
        // v1.1.0 operator edges: a string literal may lead membership
        // (`"x" <| names`, by content) or a weave (`"hey" ~> shout`).
        check suppress_chain == 0 && tok_peek(tokens, p + 1) == OP_BOUND {
            compile_bound_tail(tokens, strings, allnames, val, 1, 0, p + 2, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
            return;
        }
        check suppress_chain == 0 && tok_peek(tokens, p + 1) == OP_WEAVE {
            compile_weave_tail(tokens, strings, allnames, val, "str", p + 1, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
            return;
        }
        push(out_val, val); push(out_pos, p + 1); push(out_si, s); push(out_ani, an); push(out_ty, vty); return;
    }

    // Integer literal — read actual value from strings[]
    check t == TOK_INT {
        fixed int_val: str = strings[s];
        fixed tmp: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = add i64 0, "), int_val));
        // Stage 2: an integer literal may begin an arithmetic chain (`2 + 3 * 4`)
        // or a comparison (`2 > 1`). Route through chain_tail when one follows.
        fixed after_int: i64 = tok_peek(tokens, p + 1);
        check suppress_chain == 0 && (chain_tier6(after_int) > 0 || after_int == OP_EQEQ || after_int == OP_BANGEQ || after_int == OP_LT || after_int == OP_GT || after_int == OP_LTEQ || after_int == OP_GTEQ) {
            chain_tail(tokens, strings, allnames, tmp, p + 1, s + 1, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0);
            return;
        }
        // v1.1.0 operator edges: an integer literal may lead membership
        // (`20 <| ids`) or a weave (`5 ~> f`, the value passed uniformly).
        check suppress_chain == 0 && after_int == OP_BOUND {
            compile_bound_tail(tokens, strings, allnames, tmp, 0, 1, p + 2, s + 1, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
            return;
        }
        check suppress_chain == 0 && after_int == OP_WEAVE {
            fixed ilw: str = make_tmp(ctr);
            emit(ir, str_concat(str_concat(str_concat("  ", ilw), " = inttoptr i64 "), str_concat(tmp, " to ptr")));
            compile_weave_tail(tokens, strings, allnames, ilw, "i64", p + 1, s + 1, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
            return;
        }
        push(out_val, tmp); push(out_pos, p + 1); push(out_si, s + 1); push(out_ani, an); push(out_ty, "i64"); return;
    }

    // Float literal: materialize into an f64 SSA temp, then fold any float chain
    // or comparison via the isolated f64 path.
    check t == TOK_FLOAT {
        fixed flt_val: str = strings[s];
        fixed ftmp: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat(str_concat("  ", ftmp), " = fadd double 0.0, "), flt_val));
        check suppress_chain == 0 {
            chain_tail_f(tokens, strings, allnames, ftmp, p + 1, s + 1, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
            return;
        }
        push(out_val, ftmp); push(out_pos, p + 1); push(out_si, s + 1); push(out_ani, an); push(out_ty, "f64"); return;
    }
    check t == KW_TRUE {
        fixed tmp_t: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat("  ", tmp_t), " = add i64 0, 1"));
        // v1.1.3: tagged "bool" (the SSA value stays i64 0/1) so `echo!(true)`
        // prints `true`, matching bool variables - previously the "i64" tag
        // made a bare literal print as `1`.
        push(out_val, tmp_t); push(out_pos, p + 1); push(out_si, s); push(out_ani, an); push(out_ty, "bool"); return;
    }
    check t == KW_FALSE {
        fixed tmp_f: str = make_tmp(ctr);
        emit(ir, str_concat(str_concat("  ", tmp_f), " = add i64 0, 0"));
        push(out_val, tmp_f); push(out_pos, p + 1); push(out_si, s); push(out_ani, an); push(out_ty, "bool"); return;
    }

    // Parenthesized expression: ( EXPR ) with && / || support inside
    check t == PUNCT_LPAREN {
        p += 1; // skip "("
        set iv: list<str> = list_new();
        set ip: list<i64> = list_new();
        set is2: list<i64> = list_new();
        set iai: list<i64> = list_new();
        set ity: list<str> = list_new();
        compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, iv, ip, is2, iai, ity, var_names, var_types);
        check len(ip) > 0 { p = ip[0]; }
        check len(is2) > 0 { s = is2[0]; }
        check len(iai) > 0 { an = iai[0]; }
        set cur: str = "null"; check len(iv) > 0 { cur = iv[0]; }
        set cur_ty: str = "ptr"; check len(ity) > 0 { cur_ty = ity[0]; }
        // Combine && / || operands inside the parentheses
        whilst tok_peek(tokens, p) == OP_AMPAMP || tok_peek(tokens, p) == OP_PIPEPIPE {
            set p_is_and: i64 = 0; check tok_peek(tokens, p) == OP_AMPAMP { p_is_and = 1; }
            p += 1;
            set rv2: list<str> = list_new(); set rp2: list<i64> = list_new(); set rs2: list<i64> = list_new(); set rs2_ai: list<i64> = list_new(); set rs2_ty: list<str> = list_new();
            compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rv2, rp2, rs2, rs2_ai, rs2_ty, var_names, var_types);
            check len(rp2) > 0 { p = rp2[0]; } check len(rs2) > 0 { s = rs2[0]; } check len(rs2_ai) > 0 { an = rs2_ai[0]; }
            set rhs2v: str = "null"; check len(rv2) > 0 { rhs2v = rv2[0]; }
            set rhs2ty: str = "ptr"; check len(rs2_ty) > 0 { rhs2ty = rs2_ty[0]; }
            set lhs_i1: str = cur; check cur_ty != "i1" { fixed zt: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", zt), " = icmp ne i64 "), str_concat(coerce_i64(cur, ir, ctr), ", 0"))); lhs_i1 = zt; }
            set rhs_i1: str = rhs2v; check rhs2ty != "i1" { fixed zt2: str = make_tmp(ctr); emit(ir, str_concat(str_concat(str_concat("  ", zt2), " = icmp ne i64 "), str_concat(coerce_i64(rhs2v, ir, ctr), ", 0"))); rhs_i1 = zt2; }
            fixed cmb: str = make_tmp(ctr);
            check p_is_and == 1 { emit(ir, str_concat(str_concat(str_concat("  ", cmb), " = and i1 "), str_concat(lhs_i1, str_concat(", ", rhs_i1)))); }
            check p_is_and == 0 { emit(ir, str_concat(str_concat(str_concat("  ", cmb), " = or i1 "), str_concat(lhs_i1, str_concat(", ", rhs_i1)))); }
            cur = cmb; cur_ty = "i1";
        }
        // A ternary may complete a parenthesized expression: (cond ?> a !> b).
        // Routed through the shared tail, so `(...)` accepts the ternary
        // everywhere parentheses are accepted (conditions included).
        check tok_peek(tokens, p) == OP_TERNTHEN {
            set qv: list<str> = list_new(); set qp: list<i64> = list_new(); set qs: list<i64> = list_new(); set qa: list<i64> = list_new(); set qty: list<str> = list_new();
            compile_tern_tail(tokens, strings, allnames, cur, cur_ty, p, s, an, ir, ctr, gvals, gnames, qv, qp, qs, qa, qty, var_names, var_types);
            check len(qp) > 0 { p = qp[0]; } check len(qs) > 0 { s = qs[0]; } check len(qa) > 0 { an = qa[0]; }
            check len(qv) > 0 { cur = qv[0]; }
            check len(qty) > 0 { cur_ty = qty[0]; }
        }
        check tok_peek(tokens, p) == PUNCT_RPAREN { p += 1; } fallback {
            emit_uerr(ir, p, "expected ')' to close a parenthesized expression (a '(' is unclosed).");
        }
        // Stage 2: `(expr)` may begin an arithmetic chain (`(a + b) * c`) or be
        // compared (`(a + b) > c`). Only for non-boolean results; an i1 from an
        // inner &&/|| isn't an arithmetic operand. chain_tail handles both.
        fixed paren_next: i64 = tok_peek(tokens, p);
        check suppress_chain == 0 && cur_ty == "f64" && (float_tier(paren_next) > 0 || paren_next == OP_EQEQ || paren_next == OP_BANGEQ || paren_next == OP_LT || paren_next == OP_GT || paren_next == OP_LTEQ || paren_next == OP_GTEQ) {
            chain_tail_f(tokens, strings, allnames, cur, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty);
            return;
        }
        // Stage 2: a parenthesized STRING value compares by content, not by the
        // numeric chain below (which would compare pointers).
        check suppress_chain == 0 && cur_ty == "str" && is_cmp_op(paren_next) == 1 {
            compile_cmp_tail(tokens, strings, allnames, cur, "str", 0, 0, paren_next, p + 1, s, an, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types);
            return;
        }
        check suppress_chain == 0 && cur_ty != "i1" && cur_ty != "f64" && cur_ty != "str" && (chain_tier6(paren_next) > 0 || paren_next == OP_EQEQ || paren_next == OP_BANGEQ || paren_next == OP_LT || paren_next == OP_GT || paren_next == OP_LTEQ || paren_next == OP_GTEQ) {
            fixed pci: str = coerce_i64(cur, ir, ctr);
            chain_tail(tokens, strings, allnames, pci, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0);
            return;
        }
        push(out_val, cur); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, cur_ty); return;
    }

    // Identifier or call
    check t == TOK_IDENT {
        fixed nm: str = allnames[an];
        fixed nm_pos: i64 = p;
        an += 1; p += 1;

        // v1.2.0: aett variant access - `Status::Pending` is a named i64
        // constant (its 0-based ordinal), usable anywhere an integer is.
        check tok_peek(tokens, p) == PUNCT_COLONCOLON && tok_peek(tokens, p + 1) == TOK_IDENT {
            fixed avn: str = allnames[an];
            an += 1; p += 2;
            fixed akey: str = str_concat(str_concat(nm, "::"), avn);
            fixed aord: i64 = aett_ord_for(akey);
            check aord < 0 {
                check is_aett_name(nm) == 1 {
                    emit_uerr(ir, nm_pos, fmt("aett '{}' has no variant '{}' - its variants are: {}.", nm, avn, aett_variants_of(nm)));
                } fallback {
                    emit_uerr(ir, nm_pos, fmt("'{}' is not an aett - `X::Y` reads variant Y of aett X. Declare it first: `aett {} {{ ... }}`.", nm, nm));
                }
            }
            set aval: i64 = aord;
            check aval < 0 { aval = 0; }
            fixed atmp: str = make_tmp(ctr);
            emit(ir, fmt("  {} = add i64 0, {}", atmp, aval));
            check suppress_chain == 0 {
                chain_tail(tokens, strings, allnames, atmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0);
                return;
            }
            push(out_val, atmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64");
            return;
        }

        check tok_peek(tokens, p) == PUNCT_LPAREN {
            p += 1;
            // v1.2.0: deprecation channel - builtins listed in deprecated_msg()
            // warn at every call site (the table is empty today).
            fixed _depm: str = deprecated_msg(nm);
            check len(_depm) > 0 { emit_warn(ir, nm_pos, "deprecated", _depm); }
            // Stage 4: capture a lone bare-identifier argument's name (for len dispatch).
            set lone_arg_name: str = "";
            check tok_peek(tokens, p) == TOK_IDENT && tok_peek(tokens, p + 1) == PUNCT_RPAREN {
                lone_arg_name = allnames[an];
            }
            // First-argument identifier name (any follower), used to recover a list's
            // element type for push/insert managed-element validation.
            set first_arg_name: str = "";
            check tok_peek(tokens, p) == TOK_IDENT {
                first_arg_name = allnames[an];
            }
            // First-argument string-literal text (for fmt placeholder counting). The
            // literal at the current string-table index is this arg's text when the
            // first token is a string literal.
            set first_arg_lit: str = "";
            set first_arg_is_lit: i64 = 0;
            check tok_peek(tokens, p) == TOK_STRING {
                first_arg_lit = strings[s];
                first_arg_is_lit = 1;
            }
            set args: list<str> = list_new();
            set args_ty: list<str> = list_new();
            set args_lit: list<str> = list_new();
            whilst tok_peek(tokens, p) != PUNCT_RPAREN && tok_peek(tokens, p) != TOK_EOF && tok_peek(tokens, p) != PUNCT_SEMI && tok_peek(tokens, p) != PUNCT_RBRACE {
                set rv: list<str> = list_new();
                set rp: list<i64> = list_new();
                set rs: list<i64> = list_new();
                set rs_ai: list<i64> = list_new();
                set rs_ty: list<str> = list_new();
                // Record this argument's integer-literal text (if it's a bare int
                // literal immediately followed by ',' or ')') before compiling it,
                // so 128-bit list push/insert can box a literal argument directly.
                set this_lit: str = "";
                check tok_peek(tokens, p) == TOK_INT {
                    fixed nxt_lit: i64 = tok_peek(tokens, p + 1);
                    check nxt_lit == PUNCT_COMMA || nxt_lit == PUNCT_RPAREN { this_lit = strings[s]; }
                }
                // Also capture a negative integer literal `- NN` (unary minus then
                // int), so a 128-bit list can take a negative literal directly.
                check tok_peek(tokens, p) == OP_MINUS && tok_peek(tokens, p + 1) == TOK_INT {
                    fixed nxt_neg: i64 = tok_peek(tokens, p + 2);
                    check nxt_neg == PUNCT_COMMA || nxt_neg == PUNCT_RPAREN { this_lit = str_concat("-", strings[s]); }
                }
                compile_value(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rv, rp, rs, rs_ai, rs_ty, var_names, var_types);
                check len(rv) > 0 { push(args, rv[0]); }
                check len(rs_ty) > 0 { push(args_ty, rs_ty[0]); } fallback { push(args_ty, "ptr"); }
                push(args_lit, this_lit);
                check len(rp) > 0 { p = rp[0]; }
                check len(rs) > 0 { s = rs[0]; }
                check len(rs_ai) > 0 { an = rs_ai[0]; }
                check tok_peek(tokens, p) == PUNCT_COMMA { p += 1; }
            }
            check tok_peek(tokens, p) == PUNCT_RPAREN { p += 1; } fallback {
                emit_uerr(ir, nm_pos, fmt("expected ')' to close the arguments of '{}' (a '(' is unclosed).", nm));
            }

            fixed tmp: str = make_tmp(ctr);

            check nm == "str_concat" && len(args) >= 2 {
                emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_str_concat(ptr "), args[0]), ", ptr "), str_concat(args[1], ")")));
                finish_str_result(tokens, strings, allnames, tmp, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types); return;
            }
            check nm == "int_to_str" && len(args) >= 1 {
                set its_arg_ty: str = "ptr";
                check len(args_ty) > 0 { its_arg_ty = args_ty[0]; }
                set its_val: str = args[0];
                check its_arg_ty != "i64" { its_val = coerce_i64(args[0], ir, ctr); }
                emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call ptr @torvik_int_to_str(i64 "), str_concat(its_val, ")")));
                finish_str_result(tokens, strings, allnames, tmp, p, s, an, suppress_chain, ir, ctr, gvals, gnames, out_val, out_pos, out_si, out_ani, out_ty, var_names, var_types); return;
            }
            check nm == "len" && len(args) >= 1 {
                // Type-aware dispatch: if the argument is a variable of known type,
                // emit strlen (str) or torvik_list_len (list) directly; else fall
                // back to torvik_len's runtime magic-header dispatch.
                set len_arg_ty: str = "";
                check len(lone_arg_name) > 0 { len_arg_ty = lookup_var_type(lone_arg_name, var_names, var_types); }
                check starts(len_arg_ty, "str") {
                    emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i64 @strlen(ptr "), str_concat(args[0], ")")));
                } fallback {
                    check starts(len_arg_ty, "list") {
                        emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_list_len(ptr "), str_concat(args[0], ")")));
                    } fallback {
                        emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_len(ptr "), str_concat(args[0], ")")));
                    }
                }
                fixed len_nop: i64 = tok_peek(tokens, p);

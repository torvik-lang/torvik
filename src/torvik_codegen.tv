                p += 1;
                set rvk: list<str> = list_new(); set rpk: list<i64> = list_new(); set rsk: list<i64> = list_new(); set rsk_ai: list<i64> = list_new(); set rsk_ty: list<str> = list_new();
                compile_expr(tokens, strings, allnames, p, s, an, ir, ctr, gvals, gnames, rvk, rpk, rsk, rsk_ai, rsk_ty, var_names, var_types);
                check len(rpk) > 0 { p = rpk[0]; } check len(rsk) > 0 { s = rsk[0]; } check len(rsk_ai) > 0 { an = rsk_ai[0]; }
                fixed rhsk: str = "0"; check len(rvk) > 0 { rhsk = rvk[0]; }
                fixed rhsk_ty: str = "ptr"; check len(rsk_ty) > 0 { rhsk_ty = rsk_ty[0]; }
                fixed lk_i: str = coerce_i64(tmp, ir, ctr);
                fixed rk_i: str = rhsk; check rhsk_ty != "i64" { rk_i = coerce_i64(rhsk, ir, ctr); }
                fixed ckmp: str = make_tmp(ctr);
                set ckpred: str = "";
                check call_next_op == OP_EQEQ  { ckpred = "eq "; }
                check call_next_op == OP_BANGEQ { ckpred = "ne "; }
                check call_next_op == OP_LT    { ckpred = "slt"; check call_is_u64 { ckpred = "ult"; } }
                check call_next_op == OP_GT    { ckpred = "sgt"; check call_is_u64 { ckpred = "ugt"; } }
                check call_next_op == OP_LTEQ  { ckpred = "sle"; check call_is_u64 { ckpred = "ule"; } }
                check call_next_op == OP_GTEQ  { ckpred = "sge"; check call_is_u64 { ckpred = "uge"; } }
                emit(ir, str_concat(str_concat(str_concat(str_concat(str_concat("  ", ckmp), " = icmp "), ckpred), str_concat(" i64 ", lk_i)), str_concat(", ", rk_i)));
                push(out_val, ckmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i1"); return;

            check nm == "bag_len" && len(args) >= 1 { emit(ir, str_concat(str_concat(str_concat("  ", tmp), " = call i64 @torvik_bag_len(ptr "), str_concat(args[0], ")"))); check suppress_chain == 0 { chain_tail(tokens, strings, allnames, tmp, p, s, an, ir, ctr, gvals, gnames, var_names, var_types, out_val, out_pos, out_si, out_ani, out_ty, 0); return; } push(out_val, tmp); push(out_pos, p); push(out_si, s); push(out_ani, an); push(out_ty, "i64"); return; }
